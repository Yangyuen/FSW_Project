                </table>
                <label class="form-label small">น้ำหนักอื่นๆ (กก.) <span class="text-danger">●</span></label>
                <input type="number" id="editWeightValue" class="form-control text-end"
                    placeholder="0.000" step="0.001" min="0" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i> ยกเลิก
                </button>
                <button type="button" class="btn btn-primary" id="btnSaveEditWeight">
                    <i class="ri ri-save-line me-1"></i> บันทึก
                </button>
            </div>
        </div>
    </div>
</div>
<!-- /Modal 4 -->

@section PageScripts {
<script>
    $(document).ready(function() {
        // ── Select2 ──
        $('.select2').select2({ width: '100%' });

        // ── Flatpickr ──
        function initFlatpickr(el) {
            if (el && !el._flatpickr) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
            }
        }
        document.querySelectorAll('.flatpickr-date').forEach(function(el) { initFlatpickr(el); });

        $('#modalSearchRMBS1').on('shown.bs.modal', function() {
            $(this).find('.flatpickr-date').each(function() { initFlatpickr(this); });
        });
        $('#modalAddRMBS2').on('shown.bs.modal', function() {
            $(this).find('.flatpickr-date').each(function() { initFlatpickr(this); });
            initFlatpickr(document.getElementById('searchRmbs2Date'));
        });

        // ── Unique row ID counter ──
        var _rowCounter = 10;
        function nextRowId() { return 'r' + (++_rowCounter); }

        // ── Reindex RMBS1 main row numbers ──
        function reindexRows() {
            var n = 0;
            $('#productionTbody .rmbs1-main-row').each(function() {
                n++;
                $(this).find('td:nth-child(2)').text(n);
            });
        }

        // ── Reindex RMBS2 rows inside a sub-table ──
        function reindexRmbs2(tableId) {
            $('#' + tableId + ' tbody tr').each(function(i) {
                $(this).find('td:first').text(i + 1);
            });
        }

        // ── Calculate total RMBS1 weight ──
        function recalcTotal() {
            var total = 0;
            $('#productionTbody .rmbs1-main-row').each(function() {
                total += parseFloat($(this).data('weight')) || 0;
            });
            $('#totalWeightSum').text(total.toLocaleString('th-TH', { minimumFractionDigits: 3 }));
        }
        recalcTotal();

        // ── Toggle sub-row (expand/collapse) ──
        $(document).on('click', '.btn-toggle-sub', function() {
            var target = $(this).data('target');
            var $sub = $('#' + target);
            var $icon = $(this).find('i');
            if ($sub.hasClass('d-none')) {
                $sub.removeClass('d-none');
                $icon.removeClass('ri-arrow-right-s-line').addClass('ri-arrow-down-s-line');
            } else {
                $sub.addClass('d-none');
                $icon.removeClass('ri-arrow-down-s-line').addClass('ri-arrow-right-s-line');
            }
        });

        // ── Click RMBS1 result row to select ──
        $(document).on('click', '.rmbs1-result-row', function() {
            $('.rmbs1-result-row').removeClass('table-active');
            $(this).addClass('table-active');
            $(this).find('input[type=radio]').prop('checked', true);
        });

        // ── เลือกรายการ RMBS1 → Modal 2 ──
        var _selectedData = {};
        $('#btnSelectRmbs1').on('click', function() {
            var $sel = $('input[name=rmbs1Select]:checked').closest('tr');
            if ($sel.length === 0) { alert('กรุณาเลือกรายการก่อน'); return; }
            _selectedData = {
                rmbs:    $sel.data('rmbs'),
                cc:      $sel.data('cc'),
                ccdate:  $sel.data('ccdate'),
                ship:    $sel.data('ship'),
                species: $sel.data('species'),
                qty:     $sel.data('qty')
            };
            $('#confirm_rmbs').text(_selectedData.rmbs);
            $('#confirm_cc').text(_selectedData.cc);
            $('#confirm_ccdate').text(_selectedData.ccdate);
            $('#confirm_ship').text(_selectedData.ship);
            $('#confirm_species').text(_selectedData.species);
            $('#confirm_qty').text(_selectedData.qty);
            $('#confirm_other_weight').val('');
            bootstrap.Modal.getInstance(document.getElementById('modalSearchRMBS1')).hide();
            new bootstrap.Modal(document.getElementById('modalConfirmRMBS1')).show();
        });

        // ── ย้อนกลับ ──
        $('#btnBackToSearch').on('click', function() {
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmRMBS1')).hide();
            new bootstrap.Modal(document.getElementById('modalSearchRMBS1')).show();
        });

        // ── บันทึก RMBS1 → เพิ่มแถวใน main table ──
        $('#btnConfirmAddRow').on('click', function() {
            var weight = parseFloat($('#confirm_other_weight').val()) || 0;
            if (weight <= 0) { alert('กรุณากรอกน้ำหนักให้ถูกต้อง'); return; }
            var rowId = nextRowId();
            var subId = 'sub-' + rowId;
            var weightFmt = weight.toLocaleString('th-TH', { minimumFractionDigits: 3 });
            var rmbs = _selectedData.rmbs;

            var $mainRow = $(`<tr class="rmbs1-main-row"
                    data-row-id="${rowId}"
                    data-rmbs="${rmbs}"
                    data-cc="${_selectedData.cc}"
                    data-ccdate="${_selectedData.ccdate}"
                    data-ship="${_selectedData.ship}"
                    data-species="${_selectedData.species}"
                    data-weight="${weight}">
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-link p-0 btn-toggle-sub"
                        data-target="${subId}" title="แสดง/ซ่อนผลิตภัณฑ์">
                        <i class="ri ri-arrow-right-s-line fs-5 text-primary"></i>
                    </button>
                </td>
                <td class="text-center text-muted small"></td>
                <td class="text-primary fw-semibold">${rmbs}</td>
                <td>${_selectedData.cc}</td>
                <td>${_selectedData.ccdate}</td>
                <td>${_selectedData.ship}</td>
                <td>${_selectedData.species}</td>
                <td class="text-end" id="weight-${rowId}">${weightFmt}</td>
                <td class="text-center">
                    <div class="d-flex gap-1 justify-content-center">
                        <button type="button"
                            class="btn btn-sm btn-icon btn-outline-warning btn-edit-weight"
                            data-row-id="${rowId}" title="แก้ไขน้ำหนัก">
                            <i class="ri ri-pencil-line text-warning"></i>
                        </button>
                        <button type="button"
                            class="btn btn-sm btn-icon btn-outline-danger btn-remove-row"
                            data-target="${subId}" title="ลบรายการ">
                            <i class="ri ri-delete-bin-line text-danger"></i>
                        </button>
                    </div>
                </td>
            </tr>`);

            var $subRow = $(`<tr class="rmbs1-sub-row d-none" id="${subId}">
                <td colspan="9" class="p-0 border-0">
                    <div class="border-start border-4 border-primary ms-4 ps-3 pe-3 pb-3 pt-2" style="background-color:var(--bs-table-header-bg-color);">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                    <i class="ri ri-box-3-line fs-5"></i>
                                </span>
                                <span class="fw-semibold text-primary">ข้อมูลผลิตภัณฑ์ที่ส่งออก (RMBS2) — RMBS1: ${rmbs}</span>
                            </div>
                            <button type="button" class="btn btn-outline-primary btn-sm btn-add-rmbs2"
                                data-parent-id="${rowId}" data-parent-rmbs="${rmbs}">
                                <i class="ri ri-add-line me-1"></i> เพิ่มผลิตภัณฑ์
                            </button>
                        </div>
                        <table class="table table-bordered table-sm table-hover mb-0 bg-white rmbs2-table small" id="rmbs2-${rowId}">
                            <thead class="text-center">
                                <tr>
                                    <th style="width:2rem;">#</th>
                                    <th>วันที่นำสัตว์น้ำมาแปรรูป</th>
                                    <th>รหัสสายการผลิต</th>
                                    <th>รหัสผลิตภัณฑ์</th>
                                    <th>ชื่อผลิตภัณฑ์</th>
                                    <th class="text-end">จำนวนกิโลผลิต</th>
                                    <th class="text-end">จำนวนที่ส่งออก</th>
                                    <th class="text-end">ปริมาณที่ส่งออกตามปริมาณภัณฑ์</th>
                                    <th class="text-end">N.W.</th>
                                    <th style="width:3rem;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="text-center text-muted">
                                    <td colspan="10" class="py-2 small fst-italic">ยังไม่มีรายการ — กด "เพิ่มผลิตภัณฑ์"</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </td>
            </tr>`);

            $('#productionTbody').append($mainRow).append($subRow);
            reindexRows();
            recalcTotal();
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmRMBS1')).hide();
            $('input[name=rmbs1Select]').prop('checked', false);
            $('.rmbs1-result-row').removeClass('table-active');
        });

        // ── แก้ไขน้ำหนัก RMBS1 ──
        $(document).on('click', '.btn-edit-weight', function() {
            var rowId = $(this).data('row-id');
            var $row = $(this).closest('tr');
            $('#editWeightRowId').val(rowId);
            $('#ew_rmbs').text($row.data('rmbs'));
            $('#ew_cc').text($row.data('cc'));
            $('#ew_ccdate').text($row.data('ccdate'));
            $('#ew_ship').text($row.data('ship'));
            $('#ew_species').text($row.data('species'));
            $('#editWeightValue').val($row.data('weight'));
            new bootstrap.Modal(document.getElementById('modalEditWeight')).show();
            setTimeout(function() { $('#editWeightValue').select(); }, 300);
        });

        $('#btnSaveEditWeight').on('click', function() {
            var rowId = $('#editWeightRowId').val();
            var newWeight = parseFloat($('#editWeightValue').val()) || 0;
            if (newWeight <= 0) { alert('กรุณากรอกน้ำหนักให้ถูกต้อง'); return; }
            var $row = $('[data-row-id="' + rowId + '"]');
            var weightFmt = newWeight.toLocaleString('th-TH', { minimumFractionDigits: 3 });
            $row.data('weight', newWeight);
            $('#weight-' + rowId).text(weightFmt);
            recalcTotal();
            bootstrap.Modal.getInstance(document.getElementById('modalEditWeight')).hide();
        });

        // ── ลบ RMBS1 row (และ sub-row) ──
        $(document).on('click', '.btn-remove-row', function() {
            var subId = $(this).data('target');
            $('#' + subId).remove();
            $(this).closest('tr').remove();
            reindexRows();
            recalcTotal();
        });

        // ── เพิ่มผลิตภัณฑ์ (RMBS2) — เปิด Modal แล้ว reset กลับ Step 1 ──
        var _rmbs2Target = '';
        var _rmbs2NwUnit = 0;
        $(document).on('click', '.btn-add-rmbs2', function() {
            _rmbs2Target = 'rmbs2-' + $(this).data('parent-id');
            var parentRmbs = $(this).data('parent-rmbs');
            $('#rmbs2ParentLabel').text('RMBS1: ' + parentRmbs);
            // Reset to Step 1
            $('#rmbs2StepSearch').removeClass('d-none');
            $('#rmbs2StepDetail').addClass('d-none');
            $('#rmbs2FooterSearch').removeClass('d-none');
            $('#rmbs2FooterDetail').addClass('d-none');
            $('input[name=rmbs2Select]').prop('checked', false);
            $('.rmbs2-search-row').removeClass('table-active');
            $('#searchRmbs2Code, #searchRmbs2Name, #searchRmbs2Date').val('');
            $('#d2_exported, #d2_nw').val('');
            $('#d2_qty_product').val('');
            new bootstrap.Modal(document.getElementById('modalAddRMBS2')).show();
        });

        // ── คลิก RMBS2 result row ──
        $(document).on('click', '.rmbs2-search-row', function() {
            $('.rmbs2-search-row').removeClass('table-active');
            $(this).addClass('table-active');
            $(this).find('input[type=radio]').prop('checked', true);
        });

        // ── เลือกรายการ RMBS2 → Step 2 ──
        $('#btnSelectRmbs2').on('click', function() {
            var $sel = $('input[name=rmbs2Select]:checked').closest('tr');
            if ($sel.length === 0) { alert('กรุณาเลือกรายการก่อน'); return; }
            _rmbs2NwUnit = parseFloat($sel.data('nw-unit')) || 0;
            $('#d2_date').text($sel.data('date'));
            $('#d2_line').text($sel.data('line'));
            $('#d2_code').text($sel.data('code'));
            $('#d2_name').text($sel.data('name'));
            $('#d2_produced').text($sel.data('produced'));
            $('#d2_yield').text($sel.data('yield'));
            $('#d2_remaining').text($sel.data('remaining'));
            $('#d2_exported, #d2_nw').val('');
            $('#d2_qty_product').val('');
            $('#rmbs2StepSearch').addClass('d-none');
            $('#rmbs2StepDetail').removeClass('d-none');
            $('#rmbs2FooterSearch').addClass('d-none');
            $('#rmbs2FooterDetail').removeClass('d-none');
        });

        // ── ย้อนกลับ Step 1 ──
        $('#btnBackToRmbs2Search').on('click', function() {
            $('#rmbs2StepDetail').addClass('d-none');
            $('#rmbs2StepSearch').removeClass('d-none');
            $('#rmbs2FooterDetail').addClass('d-none');
            $('#rmbs2FooterSearch').removeClass('d-none');
        });

        // ── Auto-calc ปริมาณที่ส่งออกตามบรรจุภัณฑ์ = จำนวนบรรจุ × N.W. ต่อหน่วย ──
        $(document).on('input', '#d2_exported', function() {
            var qty = parseFloat($(this).val()) || 0;
            var qtyProduct = qty * _rmbs2NwUnit;
            $('#d2_qty_product').val(qtyProduct > 0 ? qtyProduct.toLocaleString('th-TH', { minimumFractionDigits: 3 }) : '');
        });

        // ── บันทึก RMBS2 ──
        $('#btnConfirmAddRMBS2').on('click', function() {
            var exported = parseFloat($('#d2_exported').val()) || 0;
            var nw       = parseFloat($('#d2_nw').val()) || 0;
            if (exported <= 0 || nw <= 0) {
                alert('กรุณากรอกจำนวนบรรจุภัณฑ์และน้ำหนักสุทธิให้ถูกต้อง');
                return;
            }
            var fmt = function(v) {
                var n = parseFloat(v) || 0;
                return n.toLocaleString('th-TH', { minimumFractionDigits: 3 });
            };
            var qtyProduct = exported * _rmbs2NwUnit;
            var $tbody = $('#' + _rmbs2Target + ' tbody');
            $tbody.find('tr.text-muted').remove();
            var rowNum = $tbody.find('tr').length + 1;
            var $row = $(`<tr>
                <td class="text-center text-muted small">${rowNum}</td>
                <td>${$('#d2_date').text()}</td>
                <td>${$('#d2_line').text()}</td>
                <td>${$('#d2_code').text()}</td>
                <td>${$('#d2_name').text()}</td>
                <td class="text-end">${$('#d2_produced').text()}</td>
                <td class="text-end">${fmt(exported)}</td>
                <td class="text-end">${fmt(qtyProduct)}</td>
                <td class="text-end">${fmt(nw)}</td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline-danger btn-remove-rmbs2">
                        <i class="ri ri-delete-bin-line"></i>
                    </button>
                </td>
            </tr>`);
            $tbody.append($row);
            bootstrap.Modal.getInstance(document.getElementById('modalAddRMBS2')).hide();
        });

        // ── ลบ RMBS2 row ──
        $(document).on('click', '.btn-remove-rmbs2', function() {
            var $tbody = $(this).closest('tbody');
            var tableId = $(this).closest('table').attr('id');
            $(this).closest('tr').remove();
            reindexRmbs2(tableId);
            if ($tbody.find('tr').length === 0) {
                $tbody.append('<tr class="text-center text-muted"><td colspan="10" class="py-2 small fst-italic">ยังไม่มีรายการ — กด "เพิ่มผลิตภัณฑ์"</td></tr>');
            }
        });
    });
</script>
}