<div class="modal fade" id="modalEditWeight" tabindex="-1" aria-labelledby="modalEditWeightLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalEditWeightLabel">
                    <i class="ri ri-pencil-line me-2"></i>แก้ไขน้ำหนักอื่นๆ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editWeightRowId" />
                <table class="table table-bordered table-sm mb-3">
                    <tbody>
                        <tr>
                            <th class="table-light" style="width:45%">หมายเลข RMBS1</th>
                            <td id="ew_rmbs"></td>
                        </tr>
                        <tr>
                            <th class="table-light">เลขที่ CC</th>
                            <td id="ew_cc"></td>
                        </tr>
                        <tr>
                            <th class="table-light">วันที่ตรวจสอบ CC</th>
                            <td id="ew_ccdate"></td>
                        </tr>
                        <tr>
                            <th class="table-light">ชื่อเรือ / ชะเรือ</th>
                            <td id="ew_ship"></td>
                        </tr>
                        <tr>
                            <th class="table-light">Catch Description</th>
                            <td id="ew_species"></td>
                        </tr>
