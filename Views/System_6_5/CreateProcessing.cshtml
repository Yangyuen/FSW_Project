@{
ViewData["Title"] = "คำขอใบรับรองการแปรรูปสัตว์น้ำ";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/select2/select2.js"></script>
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1">
        <li class="breadcrumb-item">
            <a href="@Url.Action("SelectType", "System_6_5")">เลือกประเภทใบรับรอง</a>
        </li>
        <li class="breadcrumb-item active">ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)</li>
    </ol>
</nav>

<div class="row">
    <div class="col-12 col-xl-11">

        <!-- ===== Tabs ===== -->
        <form method="post" action="#">
        <div class="nav-align-top nav-tabs-shadow mb-4">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-detail" aria-controls="tab-detail" aria-selected="true">
                        <i class="ri ri-file-list-2-line me-1"></i> รายละเอียดคำขอ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-production" aria-controls="tab-production" aria-selected="false">
                        <i class="ri ri-list-check-3 me-1"></i> รายการข้อมูลการผลิต
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-evidence" aria-controls="tab-evidence" aria-selected="false">
                        <i class="ri ri-folder-open-line me-1"></i> หลักฐานประกอบ
                    </button>
                </li>
            </ul>
            <div class="tab-content">

                <!-- ==================== TAB 1: รายละเอียดคำขอ ==================== -->
                <div id="tab-detail" class="tab-pane fade show active">

                    <!-- ===== Accordion: ส่วนหัว ===== -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionHeader">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingHeader">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseHeaderContent" aria-expanded="true"
                                    aria-controls="collapseHeaderContent">
                                    <i class="icon-base ri ri-file-list-line me-2"></i>
                                    รายละเอียดประเภทเอกสารส่วนหัว
                                </button>
                            </h2>
                            <div id="collapseHeaderContent" class="accordion-collapse collapse show"
                                aria-labelledby="headingHeader">
                                <div class="accordion-body p-0">

                                    <!-- รายละเอียด -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-information-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">รายละเอียด</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="requestName"
                                                        value="คำขอใบรับรองการแปรรูปสัตว์น้ำ" readonly />
                                                    <label for="requestName">ชื่อคำขอ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="certName"
                                                        value="ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)" readonly />
                                                    <label for="certName">ใบรับรอง</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="submitChannel"
                                                        value="ออนไลน์" readonly />
                                                    <label for="submitChannel">ยื่นต่อหน่วยงานกรมประมงผ่าน</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ผู้ผ่านพิธีการ / ผู้รับมอบอำนาจ -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-user-star-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ผู้ผ่านพิธีการ / ผู้รับมอบอำนาจ</h6>
                                        </div>
                                        <div class="row g-4">
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <select id="selectBroker" class="select2 form-select" required>
                                                        <option value="">-- เลือก --</option>
                                                        <option value="1" selected>บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด (สาขาสำนักงานใหญ่)</option>
                                                    </select>
                                                    <label for="selectBroker">ผู้ผ่านพิธีการ <span
                                                            class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <select id="selectAuthorized" class="select2 form-select" required>
                                                        <option value="">-- เลือก --</option>
                                                        <option value="1" selected>นาย สมชาย รักษาผล</option>
                                                    </select>
                                                    <label for="selectAuthorized">ผู้รับมอบอำนาจ <span
                                                            class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ข้อมูลผู้ส่งออก -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-building-2-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ข้อมูลผู้ส่งออก</h6>
                                        </div>
                                        <div class="row g-4">
                                            <div class="col-12">
                                                <label class="form-label">ผู้ส่งออก <span
                                                        class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <button type="button" class="btn btn-outline-secondary"
                                                        title="ค้นหาผู้ส่งออก">
                                                        <i class="ri ri-search-line"></i>
                                                    </button>
                                                    <input type="text" id="exporterName" class="form-control"
                                                        placeholder="ชื่อผู้ส่งออก"
                                                        value="บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด (สาขาสำนักงานใหญ่)"
                                                        required />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- แจ้งความประสงค์ -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-file-text-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">แจ้งความประสงค์</h6>
                                        </div>
                                        <div class="row g-4">
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <select id="selectDept" class="select2 form-select" required>
                                                        <option value="">-- เลือก --</option>
                                                        <option value="1" selected>กองตรวจสอบคุณภาพสินค้าประมง</option>
                                                    </select>
                                                    <label for="selectDept">หน่วยงานหรือเอกสาร <span
                                                            class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <select id="selectOfficer" class="select2 form-select" required>
                                                        <option value="">-- เลือก --</option>
                                                        <option value="1" selected>นางสาว วรรณา พิมพ์ทอง</option>
                                                    </select>
                                                    <label for="selectOfficer">ชื่อเจ้าหน้าที่ <span
                                                            class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="timeFrame"
                                                        value="ก่อนนำเข้า/ส่งออก/นำผ่าน" readonly />
                                                    <label for="timeFrame">ช่วงเวลาดำเนินการ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="requestType"
                                                        value="ขอใหม่" readonly />
                                                    <label for="requestType">ลักษณะการขอ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="regulation"
                                                        value="ส่งออก" readonly />
                                                    <label for="regulation">ระเบียบข้อบังคับ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <select id="selectCountry" class="select2 form-select">
                                                        <option value="">-- เลือก --</option>
                                                        <option value="AR" selected>อาร์เจนตินา</option>
                                                        <option value="US">สหรัฐอเมริกา</option>
                                                        <option value="JP">ญี่ปุ่น</option>
                                                        <option value="CN">จีน</option>
                                                        <option value="EU">สหภาพยุโรป</option>
                                                    </select>
                                                    <label for="selectCountry">ชื่อประเทศปลายทาง</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="exportDate"
                                                        class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" value="25/04/2026" />
                                                    <label for="exportDate">วันที่ส่งออก</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ข้อมูล Health Certificate -->
                                    <div class="p-4">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-shield-check-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ข้อมูล Health Certificate</h6>
                                        </div>
                                        <div class="row g-4">
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="hcNumber" class="form-control"
                                                        placeholder="Health Certificate Number" value="HC-TH-2569-00847" />
                                                    <label for="hcNumber">Health Certificate Number</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="hcDate" class="form-control flatpickr-date"
                                                        placeholder="วว/ดด/ปปปป" value="18/04/2026" />
                                                    <label for="hcDate">Date</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /accordion ส่วนหัว -->

                    <!-- ===== Accordion: ส่วนเนื้อหา ===== -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionDetail">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingDetail">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseDetailContent" aria-expanded="true"
                                    aria-controls="collapseDetailContent">
                                    <i class="icon-base ri ri-article-line me-2"></i>
                                    รายละเอียดประเภทเอกสารส่วนเนื้อหา
                                </button>
                            </h2>
                            <div id="collapseDetailContent" class="accordion-collapse collapse show"
                                aria-labelledby="headingDetail">
                                <div class="accordion-body p-0">

                                    <!-- ── 1. Description of Product ── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-success rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-box-3-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">Description of Product</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label small">HS Code (พิกัดศุลกากร) <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="hsCode" placeholder="เช่น 6014.04" value="0306.17" />
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <label class="form-label small">Product Name <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <textarea class="form-control" id="productName" rows="2" placeholder="ชื่อสินค้า">กุ้งขาวแปรรูปแช่แข็ง (Frozen White Shrimp, Processed) / Penaeus vannamei</textarea>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small text-muted"># Total Weight of Product <span class="text-success">●</span></label>
                                                <input type="text" class="form-control bg-light" id="totalWeight"
                                                    placeholder="ระบบจะบันทึกให้อัตโนมัติหลังบันทึกข้อมูล" readonly disabled />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small text-muted"># Total Weight of Product Unit <span class="text-success">●</span></label>
                                                <input type="text" class="form-control bg-light" id="totalWeightUnit"
                                                    placeholder="KGM = กิโลกรัม (ระบบจะบันทึกให้อัตโนมัติ)" readonly disabled />
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ── 2. Establishment Plant ── -->
                                    <div class="p-4">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-warning rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-store-2-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">Establishment Plant</h6>
                                        </div>
                                        <div class="row g-3">
                                            <!-- row 1: Approval No + Name -->
                                            <div class="col-md-4">
                                                <label class="form-label small">Approval Number <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="approvalNumber" value="TH-SMK-2025-0312" />
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <label class="form-label small">Name of the Establishment <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="estName" value="บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด" />
                                                </div>
                                            </div>
                                            <!-- row 2: ID + Branch + Place -->
                                            <div class="col-md-4">
                                                <label class="form-label small">ID of the Establishment <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="estId" value="0105566089321" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Branch of the Establishment <span class="text-success">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="estBranch" value="สำนักงานใหญ่" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Place of the Establishment <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="estPlace" value="สมุทรสาคร" />
                                                </div>
                                            </div>
                                            <!-- row 3: Address -->
                                            <div class="col-12">
                                                <label class="form-label small">Address of the Establishment <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <textarea class="form-control" id="estAddress" rows="2">99/1 หมู่ 5 ถนนพระราม 2 ตำบลท่าทราย อำเภอเมืองสมุทรสาคร จังหวัดสมุทรสาคร 74000</textarea>
                                                </div>
                                            </div>
                                            <!-- row 4: Tel + Fax -->
                                            <div class="col-md-6">
                                                <label class="form-label small">Telephone of the Establishment <span class="text-success">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="estTel" value="034-456-789" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Fax of the Establishment <span class="text-success">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="estFax" value="034-456-790" />
                                                </div>
                                            </div>
                                            <!-- row 5: Resp ID + Resp Person + Signature -->
                                            <div class="col-md-4">
                                                <label class="form-label small">ID of Responsible person <span class="text-success">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="respId" value="3101200456789" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Responsible person <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="respPerson" value="นาย สมชาย รักษาผล" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">Signature <span class="text-success">●</span></label>
                                                <div class="input-group">
                                                    <input type="text" class="form-control" id="signature" value="สมชาย รักษาผล" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /accordion ส่วนเนื้อหา -->
                </div>
                <!-- /TAB 1 -->

                <!-- ==================== TAB 2: รายการข้อมูลการผลิต ==================== -->
                <div id="tab-production" class="tab-pane fade" role="tabpanel">
                    <div class="text-center py-5 text-muted">
                        <i class="ri ri-list-check-3" style="font-size:3.5rem;opacity:.4;"></i>
                        <p class="mt-3 mb-0">รายการข้อมูลการผลิตจะถูกเพิ่มในภายหลัง</p>
                    </div>
                </div>
                <!-- /TAB 2 -->

                <!-- ==================== TAB 3: หลักฐานประกอบ ==================== -->
                <div id="tab-evidence" class="tab-pane fade" role="tabpanel">
                    <div class="text-center py-5 text-muted">
                        <i class="ri ri-folder-open-line" style="font-size:3.5rem;opacity:.4;"></i>
                        <p class="mt-3 mb-0">หลักฐานประกอบจะถูกเพิ่มในภายหลัง</p>
                    </div>
                </div>
                <!-- /TAB 3 -->

            </div><!-- /tab-content -->
        </div><!-- /nav-align-top -->

        <!-- Action Buttons -->
        <div class="d-flex justify-content-end gap-2 mt-3">
            <a href="@Url.Action("SelectType", "System_6_5")" class="btn btn-outline-secondary">
                <i class="ri ri-arrow-left-line me-1"></i> ยกเลิก
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="ri ri-save-line me-1"></i> บันทึก
            </button>
        </div>

        </form>

    </div><!-- /col -->
</div><!-- /row -->

@section PageScripts {
<script>
    $(document).ready(function() {
        // Select2
        $('.select2').select2({
            width: '100%'
        });
        // Flatpickr
        flatpickr('.flatpickr-date', {
            dateFormat: 'd/m/Y',
            allowInput: true
        });
    });
</script>
}