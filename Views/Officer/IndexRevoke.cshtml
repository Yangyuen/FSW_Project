@section VendorScripts {
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var fromInput = document.getElementById('filterDraftDateFrom');
        var toInput = document.getElementById('filterDraftDateTo');

        if (fromInput) {
            flatpickr(fromInput, {
                dateFormat: 'd/m/Y',
                allowInput: true
            });
        }

        if (toInput) {
            flatpickr(toInput, {
                dateFormat: 'd/m/Y',
                allowInput: true
            });
        }

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) {
                return null;
            }

            var parts = value.split('/');
            if (parts.length !== 3) {
                return null;
            }

            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            var hours = endOfDay ? 23 : 0;
            var minutes = endOfDay ? 59 : 0;
            var seconds = endOfDay ? 59 : 0;
            var parsed = new Date(year, month, day, hours, minutes, seconds);

            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function filterRows() {
            var status = (document.getElementById('filterStatus').value || '').trim();
            var fromDate = parseDateInput(document.getElementById('filterDraftDateFrom').value, false);
            var toDate = parseDateInput(document.getElementById('filterDraftDateTo').value, true);
            var excludeRange = document.getElementById('filterDateExclude').checked;
            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowStatus = row.dataset.status || '';
                var rowDraftDate = new Date(row.dataset.draftDate || '');
                var statusMatch = !status || rowStatus === status;
                var dateMatch;
                if (!fromDate && !toDate) {
                    dateMatch = true;
                } else if (excludeRange) {
                    var inRange = (!fromDate || rowDraftDate >= fromDate) && (!toDate || rowDraftDate <= toDate);
                    dateMatch = !inRange;
                } else {
                    dateMatch = (!fromDate || rowDraftDate >= fromDate) && (!toDate || rowDraftDate <= toDate);
                }
                var isVisible = statusMatch && dateMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateFrom').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateTo').addEventListener('change', filterRows);
        document.getElementById('filterDateExclude').addEventListener('change', filterRows);
        document.querySelectorAll('#filterStatus, #filterDraftDateFrom, #filterDraftDateTo').forEach(function (element) {
            element.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    filterRows();
                }
            });
        });
        document.getElementById('btnResetRequests').addEventListener('click', function () {
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterDraftDateFrom').value = '';
            document.getElementById('filterDraftDateTo').value = '';
            document.getElementById('filterDateExclude').checked = false;
            filterRows();
        });
    });
</script>
}

@* ************** Content ************** *@
<h4 class="mb-1">พิจารณายกเลิกใบรับรอง</h4>
<p class="mb-1">พิจารณาคำขอยกเลิกใบรับรองการแปรรูปสัตว์นํ้า (PS) และใบรับรองไม่แปรรูปสัตว์นํ้า (Declaration)</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexRevoke", "Officer")" class="text-primary fw-semibold">พิจารณายกเลิกใบรับรอง</a>
        </li>
    </ol>
</nav>

<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ตัวกรองการค้นหา</h5>
            <p class="text-muted small mb-0">ค้นหารายการคำขอยกเลิกตามสถานะและช่วงวันที่ทำรายการ</p>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติ">อนุมัติ</option>
                    <option value="ไม่อนุมัติ">ไม่อนุมัติ</option>
                    <option value="ยกเลิก">ยกเลิก</option>
                </select>
            </div>
            <div class="col-md-12 col-lg-9">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label for="filterDraftDateFrom" class="form-label">วันที่ทำรายการ</label>
                        <input type="text" id="filterDraftDateFrom" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-md-4">
                        <label for="filterDraftDateTo" class="form-label">ถึงวันที่</label>
                        <input type="text" id="filterDraftDateTo" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="filterDateExclude" />
                            <label class="form-check-label small" for="filterDateExclude">ไม่อยู่ในช่วง</label>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="d-flex gap-2 filter-action-buttons">
                            <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square" title="ค้นหา">
                                <i class="ri ri-search-line"></i>
                            </button>
                            <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square">
                                <i class="ri ri-refresh-line"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการคำขอยกเลิกใบรับรอง</h5>
            <p class="text-muted small mb-0">รายการคำขอยกเลิกใบรับรองการแปรรูปสัตว์นํ้า (PS) และใบรับรองไม่แปรรูปสัตว์นํ้า (Declaration)</p>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:180px;">เลขที่ใบรับรอง</th>
                    <th style="min-width:200px;">ใบรับรอง</th>
                    <th>เรื่อง</th>
                    <th style="min-width:150px;">วันที่ทำรายการ</th>
                    <th style="width:6rem;"></th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    <tr data-certificate="@request.CertificateKey" data-status="@request.StatusText" data-draft-date="@request.TransactionAt.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td>
                            <span class="fw-semibold text-primary d-block mb-1">@request.RequestNumber</span>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.StatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.StatusIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>สถานะ: @request.StatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.RequestedByClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.RequestedByIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>ขอโดย: @request.RequestedByText</span>
                                </div>
                            </div>
                        </td>
                        <td class="small">@request.CertificateName</td>
                        <td class="small">@request.Subject</td>
                        <td class="text-center small text-nowrap">
                            @request.TransactionAt.ToString("dd/MM/yyyy")<br />
                            <span class="text-muted">(@request.TransactionAt.ToString("HH:mm:ss"))</span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                @if (request.StatusText == "รออนุมัติ")
                                {
                                    <a href="@(request.CertificateKey == "processing" ? Url.Action("CreateManageCertificatePS", "PSDeclaration") : Url.Action("CreateManageCertificateNoPS", "PSDeclaration"))" class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                        <i class="ri ri-eye-line"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success" data-bs-toggle="tooltip" title="อนุมัติ">
                                        <i class="ri ri-checkbox-circle-line text-success"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" data-bs-toggle="tooltip" title="ไม่อนุมัติ">
                                        <i class="ri ri-close-circle-line text-danger"></i>
                                    </button>
                                }
                                @if (request.StatusText == "อนุมัติ" || request.StatusText == "ไม่อนุมัติ")
                                {
                                    <a href="@(request.CertificateKey == "processing" ? Url.Action("CreateManageCertificatePS", "PSDeclaration") : Url.Action("CreateManageCertificateNoPS", "PSDeclaration"))" class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                        <i class="ri ri-eye-line"></i>
                                    </a>
                                }
                                @if (request.StatusText == "ยกเลิก")
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="5" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>