@{
    ViewData["Title"] = "ออกเอกสาร RMBS1 สถานะ PS";

    var records = new[]
    {
        new { RowNo=1, RequestNo="RQ-2026-00101", CompanyName="บริษัท สยาม มารีน ฟู้ดส์ จำกัด", FisheryProduct="ปลาทูน่าครีบเหลือง", WeightKg=240000m, YieldPct=72.5m, SubmittedAt=new DateTime(2026,4,20,9,10,0), StatusText="รออนุมัติ", StatusClass="bg-label-warning" },
        new { RowNo=2, RequestNo="RQ-2026-00102", CompanyName="บริษัท โอเชียน ไพร์ม เอ็กซ์พอร์ต จำกัด", FisheryProduct="ปลาโอสา", WeightKg=60000m, YieldPct=68.0m, SubmittedAt=new DateTime(2026,4,21,11,30,0), StatusText="อนุมัติแล้ว", StatusClass="bg-label-success" },
        new { RowNo=3, RequestNo="RQ-2026-00103", CompanyName="บริษัท กัลฟ์ แคทช์ โปรเซสซิ่ง จำกัด", FisheryProduct="ปลาทูน่าตาโต", WeightKg=120000m, YieldPct=70.0m, SubmittedAt=new DateTime(2026,4,22,8,45,0), StatusText="รออนุมัติ", StatusClass="bg-label-warning" },
        new { RowNo=4, RequestNo="RQ-2026-00104", CompanyName="ห้างหุ้นส่วน ภูเก็ต ซีฟู้ด เทรดดิ้ง", FisheryProduct="ปลาอัลบาคอร์", WeightKg=45000m, YieldPct=65.5m, SubmittedAt=new DateTime(2026,4,22,14,20,0), StatusText="ส่งคืน", StatusClass="bg-label-danger" },
        new { RowNo=5, RequestNo="RQ-2026-00105", CompanyName="บริษัท อันดามัน โคลด์สโตเรจ จำกัด", FisheryProduct="ปลาทูน่าครีบเหลือง", WeightKg=180000m, YieldPct=71.0m, SubmittedAt=new DateTime(2026,4,23,9,0,0), StatusText="รออนุมัติ", StatusClass="bg-label-warning" },
    };

    var totalCount = records.Length;
    var pendingCount = records.Count(x => x.StatusText == "รออนุมัติ");
    var approvedCount = records.Count(x => x.StatusText == "อนุมัติแล้ว");
    var totalWeight = records.Sum(x => x.WeightKg);
}

@section PageStyles {
<style>
    .rmbs1-table { font-size: 0.78rem; }
    .rmbs1-table th, .rmbs1-table td { padding: 0.4rem 0.5rem; vertical-align: middle; }
    .rmbs1-table .btn-icon { width: 1.65rem; height: 1.65rem; }
    .filter-sq { width: 48px; height: 48px; padding: 0; display: inline-flex; align-items: center; justify-content: center; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    function filterRows() {
        var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var status = (document.getElementById('filterStatus').value || '').trim();
        var rows = document.querySelectorAll('#rmbs1TableBody tr[data-id]');
        var count = 0;
        rows.forEach(function (row) {
            var text = (row.dataset.searchText || '').toLowerCase();
            var rowStatus = row.dataset.status || '';
            var show = (!keyword || text.includes(keyword)) && (!status || rowStatus === status);
            row.classList.toggle('d-none', !show);
            if (show) count++;
        });
        document.getElementById('rmbs1TableEmpty').classList.toggle('d-none', count !== 0);
    }
    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function () {
        document.getElementById('filterKeyword').value = '';
        document.getElementById('filterStatus').value = '';
        filterRows();
    });
    document.getElementById('filterKeyword').addEventListener('keydown', function (e) { if (e.key === 'Enter') filterRows(); });
    document.getElementById('filterStatus').addEventListener('change', filterRows);
    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) { new bootstrap.Tooltip(el); });
    }
});
</script>
}

<h4 class="mb-1">ออกเอกสาร RMBS1 สถานะ PS</h4>
<p class="mb-1 text-muted">ออกเอกสารควบคุมปริมาณวัตถุดิบที่นำเข้าไปแปรรูปส่งออก เอกสารที่ 1 หรือ RMBS1 สถานะ PS</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item"><a href="#" class="text-primary fw-semibold">เจ้าหน้าที่</a></li>
        <li class="breadcrumb-item active text-secondary">ออกเอกสาร RMBS1 สถานะ PS</li>
    </ol>
</nav>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-primary"><i class="ri ri-file-list-3-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">คำขอทั้งหมด</p><h5 class="mb-0">@totalCount</h5></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-warning"><i class="ri ri-time-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">รออนุมัติ</p><h5 class="mb-0">@pendingCount</h5></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-success"><i class="ri ri-checkbox-circle-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">อนุมัติแล้ว</p><h5 class="mb-0">@approvedCount</h5></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-info"><i class="ri ri-scales-2-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">น้ำหนักรวม (กก.)</p><h5 class="mb-0">@totalWeight.ToString("N0")</h5></div>
            </div>
        </div>
    </div>
</div>

<!-- Filter -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-sm-5">
                <label class="form-label small mb-1">ค้นหา</label>
                <input id="filterKeyword" type="text" class="form-control form-control-sm" placeholder="เลขที่คำขอ / ชื่อบริษัท / สินค้า" />
            </div>
            <div class="col-12 col-sm-3">
                <label class="form-label small mb-1">สถานะ</label>
                <select id="filterStatus" class="form-select form-select-sm">
                    <option value="">ทั้งหมด</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติแล้ว">อนุมัติแล้ว</option>
                    <option value="ส่งคืน">ส่งคืน</option>
                </select>
            </div>
            <div class="col-auto d-flex gap-2">
                <button id="btnSearch" class="btn btn-primary btn-sm filter-sq" data-bs-toggle="tooltip" title="ค้นหา"><i class="ri ri-search-line"></i></button>
                <button id="btnReset" class="btn btn-outline-secondary btn-sm filter-sq" data-bs-toggle="tooltip" title="รีเซ็ต"><i class="ri ri-refresh-line"></i></button>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">รายการคำขอ RMBS1 (PS)</h6>
        <button class="btn btn-primary btn-sm"><i class="ri ri-add-line me-1"></i>สร้างคำขอ</button>
    </div>
    <div class="table-responsive">
        <table class="table table-hover rmbs1-table mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-center" style="width:50px">ลำดับ</th>
                    <th>เลขที่คำขอ</th>
                    <th>บริษัท</th>
                    <th>สินค้า</th>
                    <th class="text-end">น้ำหนัก (กก.)</th>
                    <th class="text-center">%Yield</th>
                    <th>วันที่ยื่น</th>
                    <th class="text-center">สถานะ</th>
                    <th class="text-center" style="width:100px">จัดการ</th>
                </tr>
            </thead>
            <tbody id="rmbs1TableBody">
                @foreach (var r in records)
                {
                    <tr data-id="@r.RequestNo" data-status="@r.StatusText" data-search-text="@r.RequestNo.ToLower() @r.CompanyName.ToLower() @r.FisheryProduct.ToLower()">
                        <td class="text-center text-muted">@r.RowNo</td>
                        <td><span class="fw-semibold text-primary">@r.RequestNo</span></td>
                        <td>@r.CompanyName</td>
                        <td>@r.FisheryProduct</td>
                        <td class="text-end">@r.WeightKg.ToString("N0")</td>
                        <td class="text-center">@r.YieldPct.ToString("F1")%</td>
                        <td>@r.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center"><span class="badge rounded-pill @r.StatusClass">@r.StatusText</span></td>
                        <td class="text-center">
                            <button class="btn btn-icon btn-sm btn-outline-primary" data-bs-toggle="tooltip" title="ดูรายละเอียด"><i class="ri ri-eye-line ri-16px"></i></button>
                            <button class="btn btn-icon btn-sm btn-outline-success" data-bs-toggle="tooltip" title="อนุมัติ"><i class="ri ri-check-line ri-16px"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
            <tbody id="rmbs1TableEmpty" class="d-none">
                <tr><td colspan="9" class="text-center text-muted py-4">ไม่พบข้อมูล</td></tr>
            </tbody>
        </table>
    </div>
</div>
