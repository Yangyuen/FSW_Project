@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        ['filterLogDateFrom', 'filterLogDateTo', 'filterFishingDateFrom', 'filterFishingDateTo'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
            }
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) return null;
            var parts = value.split('/');
            if (parts.length !== 3) return null;
            var d = parseInt(parts[0], 10);
            var m = parseInt(parts[1], 10) - 1;
            var y = parseInt(parts[2], 10);
            var dt = new Date(y, m, d, endOfDay ? 23 : 0, endOfDay ? 59 : 0, endOfDay ? 59 : 0);
            return Number.isNaN(dt.getTime()) ? null : dt;
        }

        function filterRows() {
            var rmbs1No = (document.getElementById('filterRmbs1Number').value || '').trim().toLowerCase();
            var imdNo = (document.getElementById('filterImdNumber').value || '').trim().toLowerCase();
            var ccNo = (document.getElementById('filterCcNumber').value || '').trim().toLowerCase();
            var vessel = (document.getElementById('filterVessel').value || '').trim().toLowerCase();
            var registrationNo = (document.getElementById('filterRegistrationNo').value || '').trim().toLowerCase();
            var certTypeFilter = (document.getElementById('filterCertType').value || '').trim();
            var statusFilter = (document.getElementById('filterStatus').value || '').trim();
            var logFromDate = parseDateInput(document.getElementById('filterLogDateFrom').value, false);
            var logToDate = parseDateInput(document.getElementById('filterLogDateTo').value, true);
            var logExcludeRange = document.getElementById('filterLogDateExclude').checked;
            var fishingFromDate = parseDateInput(document.getElementById('filterFishingDateFrom').value, false);
            var fishingToDate = parseDateInput(document.getElementById('filterFishingDateTo').value, true);

            var rows = document.querySelectorAll('#imdTableBody tr[data-row]');
            var visible = 0;

            rows.forEach(function (row) {
                var txDate = new Date(row.dataset.txDate);
                var fishingStart = new Date(row.dataset.fishingStartDate);
                var fishingEnd = new Date(row.dataset.fishingEndDate);
                var inLogRange = (!logFromDate || txDate >= logFromDate) && (!logToDate || txDate <= logToDate);
                var inFishingRange = (!fishingFromDate || fishingStart >= fishingFromDate) && (!fishingToDate || fishingEnd <= fishingToDate);
                var match =
                    (!rmbs1No || (row.dataset.rmbs1Number || '').toLowerCase().includes(rmbs1No)) &&
                    (!imdNo || (row.dataset.imdNumber || '').toLowerCase().includes(imdNo)) &&
                    (!ccNo || (row.dataset.ccNumber || '').toLowerCase().includes(ccNo)) &&
                    (!vessel || (row.dataset.vessel || '').toLowerCase().includes(vessel)) &&
                    (!registrationNo || (row.dataset.registrationNo || '').toLowerCase().includes(registrationNo)) &&
                    (!certTypeFilter || (row.dataset.certType || '') === certTypeFilter) &&
                    (!statusFilter || (row.dataset.status || '') === statusFilter) &&
                    ((!logFromDate && !logToDate) || (logExcludeRange ? !inLogRange : inLogRange)) &&
                    ((!fishingFromDate && !fishingToDate) || inFishingRange);

                row.classList.toggle('d-none', !match);
                if (match) visible++;
            });

            document.getElementById('imdTableEmpty').classList.toggle('d-none', visible !== 0);
        }

        document.getElementById('btnSearch').addEventListener('click', filterRows);
        document.getElementById('btnReset').addEventListener('click', function () {
            ['filterRmbs1Number', 'filterImdNumber', 'filterCcNumber', 'filterVessel', 'filterRegistrationNo', 'filterLogDateFrom', 'filterLogDateTo', 'filterFishingDateFrom', 'filterFishingDateTo'].forEach(function (id) {
                document.getElementById(id).value = '';
            });
            document.getElementById('filterCertType').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterLogDateExclude').checked = false;
            filterRows();
        });

        document.getElementById('filterCertType').addEventListener('change', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);

        document.getElementById('filterLogDateExclude').addEventListener('change', filterRows);

        ['filterRmbs1Number', 'filterImdNumber', 'filterCcNumber', 'filterVessel', 'filterRegistrationNo', 'filterLogDateFrom', 'filterLogDateTo', 'filterFishingDateFrom', 'filterFishingDateTo'].forEach(function (id) {
            document.getElementById(id).addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });
    });
</script>
}

