@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var fromInput = document.getElementById('filterDraftDateFrom');
        var toInput = document.getElementById('filterDraftDateTo');

        if (fromInput) {
            flatpickr(fromInput, {
                dateFormat: 'd/m/Y',
                allowInput: true
            });
        }

        if (toInput) {
            flatpickr(toInput, {
                dateFormat: 'd/m/Y',
                allowInput: true
            });
        }

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) {
                return null;
            }

            var parts = value.split('/');
            if (parts.length !== 3) {
                return null;
            }

            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            var hours = endOfDay ? 23 : 0;
            var minutes = endOfDay ? 59 : 0;
            var seconds = endOfDay ? 59 : 0;
            var parsed = new Date(year, month, day, hours, minutes, seconds);

            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function filterRows() {
            var certificate = (document.getElementById('filterCertificate').value || '').trim();
            var status = (document.getElementById('filterStatus').value || '').trim();
            var fromDate = parseDateInput(document.getElementById('filterDraftDateFrom').value, false);
            var toDate = parseDateInput(document.getElementById('filterDraftDateTo').value, true);
            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowCertificate = row.dataset.certificate || '';
                var rowStatus = row.dataset.status || '';
                var rowDraftDate = new Date(row.dataset.submittedDate || '');
                var certificateMatch = !certificate || rowCertificate === certificate;
                var statusMatch = !status || rowStatus === status;
                var fromMatch = !fromDate || rowDraftDate >= fromDate;
                var toMatch = !toDate || rowDraftDate <= toDate;
                var isVisible = certificateMatch && statusMatch && fromMatch && toMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
        document.getElementById('filterCertificate').addEventListener('change', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateFrom').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateTo').addEventListener('change', filterRows);
        document.querySelectorAll('#filterCertificate, #filterStatus, #filterDraftDateFrom, #filterDraftDateTo').forEach(function (element) {
            element.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    filterRows();
                }
            });
        });
        document.getElementById('btnResetRequests').addEventListener('click', function () {
            document.getElementById('filterCertificate').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterDraftDateFrom').value = '';
            document.getElementById('filterDraftDateTo').value = '';
            filterRows();
        });
    });
</script>
}

