<h4 class="mb-1">พิจารณาคืนนํ้าหนักสินค้าส่งคืน</h4>
<p class="mb-1">ตรวจสอบและพิจารณาคำขออนุมัติการคืนนํ้าหนักสินค้าส่งคืนจากผู้ประกอบการ</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="#" class="text-primary fw-semibold">เจ้าหน้าที่</a>
        </li>
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexReturnWeight", "Officer")" class="text-primary fw-semibold">พิจารณาคืนนํ้าหนักสินค้าส่งคืน</a>
        </li>
        <li class="breadcrumb-item active text-secondary">10611280616100005</li>
    </ol>
</nav>

<!-- Status Banner -->
@if (returnWeightStatus == "อนุมัติให้คืนน้ำหนัก")
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-checkbox-circle-line fs-5"></i>
        <span><strong>อนุมัติให้คืนน้ำหนัก</strong> — คำขอนี้ได้รับการอนุมัติเรียบร้อยแล้ว</span>
    </div>
}
else if (returnWeightStatus == "อนุมัติให้คืนน้ำหนักแบบมีเงื่อนไข")
{
    <div class="alert alert-primary d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-check-double-line fs-5"></i>
        <span><strong>อนุมัติแบบมีเงื่อนไข</strong> — คำขอนี้ได้รับการอนุมัติแบบมีเงื่อนไข กรุณาดูรายละเอียดในส่วนผลการพิจารณา</span>
    </div>
}
else if (returnWeightStatus == "ไม่อนุมัติให้คืนน้ำหนัก")
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-close-circle-line fs-5"></i>
        <span><strong>ไม่อนุมัติ</strong> — คำขอนี้ถูกปฏิเสธ กรุณาดูเหตุผลในส่วนผลการพิจารณา</span>
    </div>
}
else if (returnWeightStatus == "ยกเลิก")
{
    <div class="alert alert-secondary d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-forbid-line fs-5"></i>
        <span><strong>ยกเลิก</strong> — คำขอนี้ถูกยกเลิกแล้ว</span>
    </div>
}
else
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-time-line fs-5"></i>
        <span><strong>อยู่ระหว่างดำเนินการ</strong> — คำขอนี้รอการพิจารณาจากเจ้าหน้าที่</span>
    </div>
}


