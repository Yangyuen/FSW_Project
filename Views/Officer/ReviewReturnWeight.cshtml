@section PageScripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Flatpickr
            document.querySelectorAll('.flatpickr-date').forEach(function (el) {
                if (el && !el._flatpickr) {
                    flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true, locale: { firstDayOfWeek: 1 } });
                }
            });

            // Tooltips
            if (window.bootstrap && bootstrap.Tooltip) {
                document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                    new bootstrap.Tooltip(el);
                });
            }

            // Toggle condition section
            document.querySelectorAll('input[name="reviewResult"]').forEach(function (radio) {
                radio.addEventListener('change', function () {
                    var conditionSection = document.getElementById('conditionSection');
                    if (conditionSection) {
                        conditionSection.classList.toggle('d-none', this.value !== 'approve_condition');
                        var conditionTextarea = document.getElementById('reviewCondition');
                        if (conditionTextarea) {
                            conditionTextarea.required = this.value === 'approve_condition';
                        }
                    }
                });
            });

            function validateAndConfirm(resultValue, confirmMessage, successMessage) {
                var resultRadio = document.querySelector('input[name="reviewResult"][value="' + resultValue + '"]');
                if (resultRadio) {
                    resultRadio.checked = true;
                    resultRadio.dispatchEvent(new Event('change'));
                }

                var remark = document.getElementById('reviewRemark');
                if (!remark || remark.value.trim() === '') {
                    alert('กรุณาระบุหมายเหตุ/เหตุผลประกอบการพิจารณาก่อนดำเนินการ');
                    document.querySelector('button[data-bs-target="#tab-review"]').click();
                    if (remark) { remark.focus(); }
                    return;
                }

                if (resultValue === 'approve_condition') {
                    var condition = document.getElementById('reviewCondition');
                    if (!condition || condition.value.trim() === '') {
                        alert('กรุณาระบุเงื่อนไขประกอบการอนุมัติแบบมีเงื่อนไข');
                        if (condition) { condition.focus(); }
                        return;
                    }
                }

                if (confirm(confirmMessage)) {
                    alert(successMessage);
                }
            }

            var btnApprove = document.getElementById('btnApproveRequest');
            if (btnApprove) {
                btnApprove.addEventListener('click', function () {
                    validateAndConfirm('approve',
                        'ยืนยันการอนุมัติให้คืนน้ำหนักสินค้าส่งคืนคำขอนี้?',
                        'บันทึกผลการอนุมัติให้คืนน้ำหนักเรียบร้อย');
                });
            }

            var btnApproveCondition = document.getElementById('btnApproveConditionRequest');
            if (btnApproveCondition) {
                btnApproveCondition.addEventListener('click', function () {
                    validateAndConfirm('approve_condition',
                        'ยืนยันการอนุมัติแบบมีเงื่อนไขสำหรับคำขอนี้?',
                        'บันทึกผลการอนุมัติแบบมีเงื่อนไขเรียบร้อย');
                });
            }

            var btnReject = document.getElementById('btnRejectRequest');
            if (btnReject) {
                btnReject.addEventListener('click', function () {
                    validateAndConfirm('reject',
                        'ยืนยันการไม่อนุมัติให้คืนน้ำหนักสำหรับคำขอนี้?',
                        'บันทึกผลการไม่อนุมัติเรียบร้อย');
                });
            }

        });
    </script>
}
