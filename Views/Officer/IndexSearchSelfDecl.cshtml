@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    /* --- Flatpickr --- */
    ['filterDateFrom', 'filterDateTo'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
    });

    /* --- Tooltips --- */
    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            new bootstrap.Tooltip(el);
        });
    }

    /* --- Date parse helper --- */
    function parseDateInput(value, endOfDay) {
        if (!value) return null;
        var parts = value.split('/');
        if (parts.length !== 3) return null;
        var d = parseInt(parts[0], 10), m = parseInt(parts[1], 10) - 1, y = parseInt(parts[2], 10);
        var h = endOfDay ? 23 : 0, min = endOfDay ? 59 : 0, s = endOfDay ? 59 : 0;
        var dt = new Date(y, m, d, h, min, s);
        return isNaN(dt.getTime()) ? null : dt;
    }

    /* --- Filter --- */
    function filterRows() {
        var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var status = (document.getElementById('filterStatus').value || '').trim();
        var certType = (document.getElementById('filterCertType').value || '').trim();
        var fromDate = parseDateInput(document.getElementById('filterDateFrom').value, false);
        var toDate = parseDateInput(document.getElementById('filterDateTo').value, true);

        var rows = document.querySelectorAll('#sdTableBody tr[data-id]');
        var count = 0;
        rows.forEach(function (row) {
            var text = (row.dataset.searchText || '').toLowerCase();
            var rowStatus = row.dataset.status || '';
            var rowCertType = row.dataset.certType || '';
            var rowDate = new Date(row.dataset.issuedDate || '');

            var ok = (!keyword || text.includes(keyword))
                && (!status || rowStatus === status)
                && (!certType || rowCertType === certType)
                && (!fromDate || rowDate >= fromDate)
                && (!toDate || rowDate <= toDate);

            row.classList.toggle('d-none', !ok);
            if (ok) count++;
        });
        document.getElementById('sdTableEmpty').classList.toggle('d-none', count !== 0);
    }

    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function () {
        ['filterKeyword', 'filterStatus', 'filterCertType', 'filterDateFrom', 'filterDateTo'].forEach(function (id) {
            document.getElementById(id).value = '';
        });
        filterRows();
    });
    document.getElementById('filterKeyword').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
    });
    ['filterStatus', 'filterCertType', 'filterDateFrom', 'filterDateTo'].forEach(function (id) {
        document.getElementById(id).addEventListener('change', filterRows);
    });

    /* --- Detail Modal --- */
    var detailModal = new bootstrap.Modal(document.getElementById('modalSelfDeclDetail'));

    document.querySelectorAll('[data-action="show-detail"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var id = this.dataset.docId;
            var card = document.getElementById('detail-' + id);
            if (!card) return;

            // Fill modal header
            document.getElementById('modalDocNo').textContent = card.dataset.docno;
            document.getElementById('modalDocNo2').textContent = card.dataset.docno;
            document.getElementById('modalCompany').textContent = card.dataset.company;
            document.getElementById('modalCertType').textContent = card.dataset.certtype;
            document.getElementById('modalHsCode').textContent = card.dataset.hscode;
            document.getElementById('modalProduct').textContent = card.dataset.product;
            document.getElementById('modalSpecies').textContent = card.dataset.species;
            document.getElementById('modalSourceCountry').textContent = card.dataset.sourcecountry;
            document.getElementById('modalEstCode').textContent = card.dataset.estcode;
            document.getElementById('modalIssuedAt').textContent = card.dataset.issuedat;
            document.getElementById('modalExpiresAt').textContent = card.dataset.expiresat;
            document.getElementById('modalWeightTotal').textContent = parseInt(card.dataset.weighttotal).toLocaleString('th-TH');
            document.getElementById('modalWeightUsed').textContent = parseInt(card.dataset.weightused).toLocaleString('th-TH');
            document.getElementById('modalWeightRemain').textContent = parseInt(card.dataset.weightremain).toLocaleString('th-TH');

            // Fill batches
            var batchContainer = document.getElementById('modalBatches');
            var batchTemplate = document.getElementById('batch-template-' + id);
            batchContainer.innerHTML = batchTemplate ? batchTemplate.innerHTML : '<p class="text-muted small">ไม่มีข้อมูลรุ่นวัตถุดิบ</p>';

            detailModal.show();
        });
    });
});
</script>
}

