        <h5 class="card-title mb-1">ค้นหาหนังสือรับรองตนเอง</h5>
        <p class="text-muted small mb-0">ค้นหาตามเงื่อนไขที่กรมประมงกำหนด</p>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label for="filterKeyword" class="form-label">ค้นหา</label>
                <input type="text" id="filterKeyword" class="form-control" placeholder="เลขที่ / ชื่อบริษัท / HS Code / สินค้า" />
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterCertType" class="form-label">ประเภทใบรับรอง</label>
                <select id="filterCertType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="PS">PS (Processing Statement)</option>
                    <option value="NoPS">NoPS (Non-Processing)</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ใช้งาน">ใช้งาน</option>
                    <option value="หมดแล้ว">หมดแล้ว</option>
                    <option value="หมดอายุ">หมดอายุ</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterDateFrom" class="form-label">วันที่ออก (จาก)</label>
                <input type="text" id="filterDateFrom" class="form-control" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterDateTo" class="form-label">ถึงวันที่</label>
                <input type="text" id="filterDateTo" class="form-control" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-2 col-lg-1">
                <div class="d-flex gap-2">
                    <button id="btnSearch" type="button" class="btn btn-outline-primary filter-sq" title="ค้นหา" data-bs-toggle="tooltip">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button id="btnReset" type="button" class="btn btn-outline-secondary filter-sq" title="รีเซ็ต" data-bs-toggle="tooltip">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* ============================================================ *@
@*  Results table                                                *@
@* ============================================================ *@
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการหนังสือรับรองตนเอง</h5>
            <p class="text-muted small mb-0">แสดงข้อมูลหนังสือรับรองตนเอง รายละเอียดแหล่งที่มา และรุ่นวัตถุดิบที่ใช้ในการผลิต</p>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm">
            <i class="ri ri-download-2-line me-1"></i>Export Excel
        </button>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 sd-table">
            <thead class="text-center">
                <tr>
                    <th style="width:46px">#</th>
                    <th>เลขที่หนังสือรับรองตนเอง</th>
                    <th>ประเภท</th>
                    <th>บริษัท / สถานประกอบการ</th>
                    <th>HS Code</th>
                    <th>สินค้า / ชนิดสัตว์น้ำ</th>
                    <th>แหล่งที่มา</th>
                    <th>น้ำหนัก (กก.)</th>
                    <th>วันที่ออก</th>
                    <th>วันหมดอายุ</th>
                    <th class="text-center">สถานะ</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody id="sdTableBody">
                @foreach (var d in declarations)
                {
                    var pct = d.WeightKg > 0 ? (int)Math.Round(d.UsedWeightKg / d.WeightKg * 100) : 0;
                    var barColor = d.RemainingKg == 0 ? "bg-danger" : pct > 80 ? "bg-warning" : "bg-success";
                    <tr data-id="@d.DocNo"
                        data-status="@d.StatusText"
                        data-cert-type="@d.CertType"
                        data-issued-date="@d.IssuedAt.ToString("yyyy-MM-dd")"
                        data-search-text="@d.DocNo.ToLower() @d.CompanyName.ToLower() @d.HsCode.ToLower() @d.ProductDesc.ToLower() @d.Species.ToLower() @d.EstablishmentCode.ToLower()">
                        <td class="text-center text-muted">@d.RowNo</td>
                        <td>
                            <button type="button" class="btn btn-link p-0 fw-semibold text-primary text-decoration-none" data-action="show-detail" data-doc-id="@d.DocNo">
                                @d.DocNo
                            </button>
                        </td>
                        <td class="text-center">
                            @if (d.CertType == "PS")
                            {
                                <span class="badge bg-label-warning">PS</span>
                            }
                            else
                            {
                                <span class="badge bg-label-info">NoPS</span>
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@d.CompanyName</div>
                            <small class="text-muted">รหัส: @d.EstablishmentCode</small>
                        </td>
                        <td class="text-center">@d.HsCode</td>
                        <td>
                            <div>@d.ProductDesc</div>
                            <small class="text-muted">@d.Species</small>
                        </td>
                        <td>@d.SourceCountry</td>
                        <td>
                            <div class="weight-bar-wrap">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="fw-semibold">@d.WeightKg.ToString("N0")</span>
                                    <span class="text-muted">@(pct)%</span>
                                </div>
                                <div class="weight-bar">
                                    <div class="weight-bar-fill @barColor" style="width:@(pct)%"></div>
                                </div>
                                <div class="d-flex justify-content-between" style="font-size:0.68rem;">
                                    <span class="text-muted">ใช้ @d.UsedWeightKg.ToString("N0")</span>
                                    <span class="@(d.RemainingKg==0?"text-danger":d.RemainingKg<d.WeightKg*0.2m?"text-warning":"text-success") fw-bold">คงเหลือ @d.RemainingKg.ToString("N0")</span>
                                </div>
                            </div>
                        </td>
                        <td>@d.IssuedAt.ToString("dd/MM/yyyy")</td>
                        <td>@d.ExpiresAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <span class="badge rounded-pill @d.StatusClass">@d.StatusText</span>
                        </td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center">
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info" title="ดูรายละเอียด / ตรวจสอบแหล่งที่มา" data-bs-toggle="tooltip" data-bs-placement="top" data-action="show-detail" data-doc-id="@d.DocNo" aria-label="ดูรายละเอียด">
                                    <i class="ri ri-eye-line text-info"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="Export PDF" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="Export PDF">
                                    <i class="ri ri-file-pdf-line text-secondary"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="sdTableEmpty" class="d-none">
                    <td colspan="12" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@* ============================================================ *@
@*  Hidden detail / batch data (read by JS for modal)           *@
@* ============================================================ *@
@foreach (var d in declarations)
{
    var pct2 = d.WeightKg > 0 ? (int)Math.Round(d.UsedWeightKg / d.WeightKg * 100) : 0;
    <div id="detail-@d.DocNo" class="d-none"
         data-docno="@d.DocNo"
         data-company="@d.CompanyName"
         data-certtype="@d.CertType"
         data-hscode="@d.HsCode"
         data-product="@d.ProductDesc"
         data-species="@d.Species"
         data-sourcecountry="@d.SourceCountry"
         data-estcode="@d.EstablishmentCode"
         data-issuedat="@d.IssuedAt.ToString("dd/MM/yyyy")"
         data-expiresat="@d.ExpiresAt.ToString("dd/MM/yyyy")"
         data-weighttotal="@((int)d.WeightKg)"
         data-weightused="@((int)d.UsedWeightKg)"
         data-weightremain="@((int)d.RemainingKg)"></div>

    <div id="batch-template-@d.DocNo" class="d-none">
        @foreach (var b in d.Batches)
        {
            <div class="batch-card mb-3">
                <div class="batch-card-header d-flex align-items-center justify-content-between">
                    <span><i class="ri ri-box-3-line me-1 text-primary"></i>@b.BatchNo</span>
                    <small class="text-muted">วันที่ผลิต: @b.LotDate.ToString("dd/MM/yyyy")</small>
                </div>
                <div class="batch-card-body">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <table class="table table-sm mb-0 source-detail-table">
                                <tbody>
                                    <tr>
                                        <th>วัตถุดิบ</th>
                                        <td>@b.RawMaterial</td>
                                    </tr>
                                    <tr>
                                        <th>น้ำหนักวัตถุดิบ</th>
                                        <td>@b.WeightKg.ToString("N0") กก.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div>
                                <div class="mb-2">
                                    <span class="text-muted small d-block mb-1">เอกสารการนำเข้า / ควบคุมวัตถุดิบ</span>
                                    <div class="d-flex flex-wrap gap-1">
                                        <a href="#" class="link-chip link-chip-rmbs2" title="ระบบ RMBS2 (ใบรับรองนำเข้า)" data-bs-toggle="tooltip">
                                            <i class="ri ri-links-line"></i> RMBS2: @b.Rmbs2No
                                        </a>
                                        <a href="#" class="link-chip link-chip-rmbs1" title="ระบบ RMBS1 (ควบคุมปริมาณวัตถุดิบ)" data-bs-toggle="tooltip">
                                            <i class="ri ri-links-line"></i> RMBS1: @b.Rmbs1No
                                        </a>
                                    </div>
                                </div>
                                <div>
                                    <span class="text-muted small d-block mb-1">เอกสารการผลิต / ผลิตภัณฑ์</span>
                                    <div class="d-flex flex-wrap gap-1">
                                        <a href="#" class="link-chip link-chip-p2" title="เอกสาร P2 (แบบรายงานการผลิต)" data-bs-toggle="tooltip">
                                            <i class="ri ri-links-line"></i> P2: @b.P2No
                                        </a>
                                        <a href="#" class="link-chip link-chip-p1" title="เอกสาร P1 (แบบรายงานผลิตภัณฑ์)" data-bs-toggle="tooltip">
                                            <i class="ri ri-links-line"></i> P1: @b.P1No
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ============================================================ *@
@*  Detail Modal                                                 *@
@* ============================================================ *@
<div class="modal fade" id="modalSelfDeclDetail" tabindex="-1" aria-labelledby="modalSelfDeclDetailLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalSelfDeclDetailLabel">
                    รายละเอียดหนังสือรับรองตนเอง — <span id="modalDocNo" class="text-primary"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                @* --- Certificate info --- *@
                <div class="card mb-4 border-0 bg-light">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3"><i class="ri ri-information-line me-1 text-primary"></i>ข้อมูลหนังสือรับรองตนเอง</h6>
                        <div class="row g-2" style="font-size:0.82rem;">
                            <div class="col-sm-6 col-lg-3">
                                <span class="text-muted d-block">เลขที่เอกสาร</span>
                                <strong id="modalDocNo2"></strong>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <span class="text-muted d-block">ประเภทใบรับรอง</span>
                                <strong id="modalCertType"></strong>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <span class="text-muted d-block">HS Code</span>
                                <strong id="modalHsCode"></strong>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <span class="text-muted d-block">รหัสสถานประกอบการ</span>
                                <strong id="modalEstCode"></strong>
                            </div>
                            <div class="col-sm-12 col-lg-6">
                                <span class="text-muted d-block">บริษัท / สถานประกอบการ</span>
                                <strong id="modalCompany"></strong>
                            </div>
                            <div class="col-sm-6 col-lg-6">
                                <span class="text-muted d-block">ผลิตภัณฑ์สัตว์น้ำ</span>
                                <strong id="modalProduct"></strong>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <span class="text-muted d-block">ชนิดสัตว์น้ำ</span>
                                <strong id="modalSpecies"></strong>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <span class="text-muted d-block">แหล่งที่มา / พื้นที่จับ</span>
                                <strong id="modalSourceCountry"></strong>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <span class="text-muted d-block">วันที่ออก / หมดอายุ</span>
                                <strong><span id="modalIssuedAt"></span> — <span id="modalExpiresAt"></span></strong>
                            </div>
                        </div>
                        <hr class="my-3" />
                        <div class="row g-3" style="font-size:0.82rem;">
                            <div class="col-sm-4">
                                <span class="text-muted d-block">น้ำหนักรวม (กก.)</span>
                                <strong class="fs-5" id="modalWeightTotal"></strong>
                            </div>
                            <div class="col-sm-4">
                                <span class="text-muted d-block">ใช้ไปแล้ว (กก.)</span>
                                <strong class="fs-5 text-warning" id="modalWeightUsed"></strong>
                            </div>
                            <div class="col-sm-4">
                                <span class="text-muted d-block">คงเหลือ (กก.)</span>
                                <strong class="fs-5 text-success" id="modalWeightRemain"></strong>
                            </div>
                        </div>
                    </div>
                </div>

                @* --- Batch / Traceability --- *@
                <h6 class="fw-bold mb-3">
                    <i class="ri ri-git-branch-line me-1 text-primary"></i>
                    รุ่นวัตถุดิบ (Batch/Lot) และเชื่อมโยงระบบตรวจสอบแหล่งที่มา
                </h6>
                <div class="alert alert-info py-2 px-3 mb-3 small d-flex gap-2 align-items-start">
                    <i class="ri ri-information-line mt-1 flex-shrink-0"></i>
                    <div>
                        <strong>RMBS2</strong> = ระบบตรวจสอบแหล่งที่มาของสัตว์น้ำนำเข้า (ใบรับรองนำเข้า) &nbsp;|&nbsp;
                        <strong>RMBS1</strong> = ระบบควบคุมปริมาณวัตถุดิบ &nbsp;|&nbsp;
                        <strong>P2</strong> = แบบรายงานการผลิต &nbsp;|&nbsp;
                        <strong>P1</strong> = แบบรายงานผลิตภัณฑ์
                    </div>
                </div>
                <div id="modalBatches"></div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i>ปิด
                </button>
                <button type="button" class="btn btn-outline-primary btn-sm">
                    <i class="ri ri-file-pdf-line me-1"></i>Export PDF
                </button>
            </div>
        </div>
    </div>
</div>
