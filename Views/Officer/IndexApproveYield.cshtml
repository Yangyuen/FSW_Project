                    <th class="text-center" style="width:120px">จัดการ</th>
                </tr>
            </thead>
            <tbody id="yieldTableBody">
                @foreach (var r in records)
                {
                    <tr data-id="@r.RequestNo" data-status="@r.StatusText" data-reqtype="@r.RequestTypeText" data-rawtype="@r.RawMaterialType" data-bypass="@r.BypassType" data-province="@r.Province" data-search-text="@r.RequestNo.ToLower() @r.CompanyName.ToLower() @r.ProductType.ToLower() @r.BypassType.ToLower() @r.Province.ToLower()">
                        <td class="text-center text-muted">@r.RowNo</td>
                        <td>
                            <a href="@Url.Action("ReviewApproveYield","Officer")" class="fw-semibold text-primary">@r.RequestNo</a>
                        </td>
                        <td>@r.CompanyName</td>
                        <td>
                            <span class="badge @(r.Province == officerProvince ? "bg-label-primary" : "bg-label-secondary")">
                                @if (r.Province == officerProvince) { <text>📍 </text> }
                                @r.Province
                            </span>
                        </td>
                        <td>@r.ProductType</td>
                        <td><span class="badge @r.RequestTypeClass">@r.RequestTypeText</span></td>
                        <td><span class="badge bg-label-secondary">@r.RawMaterialType</span></td>
                        <td class="text-center fw-bold">@r.RequestedYield.ToString("F1")%</td>
                        <td class="text-center text-muted">@r.PreviousYield.ToString("F1")%</td>
                        <td class="text-center">±@r.Tolerance.ToString("F1")%</td>
                        <td class="text-end">@r.WeightKg.ToString("N0")</td>
                        <td>@r.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center small">
                            @if (r.StatusText == "อนุมัติแล้ว")
                            {
                                <span class="text-success fw-semibold">01/05/2569</span><br />
                                <span class="text-muted">– 30/04/2570</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill @r.StatusClass">@r.StatusText</span>
                            @if (r.BypassType != "")
                            {
                                <br /><span class="badge bg-label-info mt-1" style="font-size:0.62rem">⚡ @r.BypassType</span>
                            }
                        </td>
                        <td class="text-center">
                            <a href="@Url.Action("ReviewApproveYield","Officer")" class="btn btn-icon btn-sm btn-outline-primary" title="ดูรายละเอียด"><i class="ri ri-eye-line ri-16px"></i></a>
                            @if (r.StatusText == "รออนุมัติ" || r.StatusText == "ส่งคืนแก้ไข")
                            {
                            <button class="btn btn-icon btn-sm btn-outline-success btn-row-approve" data-reqno="@r.RequestNo" title="อนุมัติ"><i class="ri ri-check-line ri-16px"></i></button>
                            <button class="btn btn-icon btn-sm btn-outline-warning btn-row-suspend" data-reqno="@r.RequestNo" title="ระงับ"><i class="ri ri-pause-circle-line ri-16px"></i></button>
                            <button class="btn btn-icon btn-sm btn-outline-danger btn-row-cancel" data-reqno="@r.RequestNo" title="ยกเลิก"><i class="ri ri-close-circle-line ri-16px"></i></button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tbody id="yieldTableEmpty" class="d-none">
                <tr><td colspan="15" class="text-center text-muted py-4">ไม่พบข้อมูล</td></tr>
            </tbody>
        </table>
    </div>
</div>
