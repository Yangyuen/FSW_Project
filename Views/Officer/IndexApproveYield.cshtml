@section PageStyles {
<style>
    .yield-table { font-size: 0.78rem; }
    .yield-table th, .yield-table td { padding: 0.4rem 0.5rem; vertical-align: middle; }
    .yield-table .btn-icon { width: 1.65rem; height: 1.65rem; }
    .filter-sq { width: 48px; height: 48px; padding: 0; display: inline-flex; align-items: center; justify-content: center; }
    /* ─── Print ─── */
    @@media print {
        body * { visibility: hidden !important; }
        #printYieldArea, #printYieldArea * { visibility: visible !important; }
        #printYieldArea { position: absolute; left: 0; top: 0; width: 100%; padding: 24px; font-size: 11pt; }
        .modal-backdrop { display: none !important; }
    }
    .print-form-header { text-align: center; border-bottom: 2px solid #333; padding-bottom: 8px; margin-bottom: 16px; }
    .print-form-table th, .print-form-table td { border: 1px solid #999; padding: 5px 8px; font-size: 0.82rem; }
    .print-form-table { border-collapse: collapse; width: 100%; }
    .sign-box { border: 1px solid #999; min-height: 70px; border-radius: 4px; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    // ─── Import Template Modal ───
    var importDropzone = document.getElementById('importDropzone');
    var importFileInput = document.getElementById('importFileInput');
    var btnConfirmImport = document.getElementById('btnConfirmImport');

    // Download template mock
    document.getElementById('btnDownloadTemplate').addEventListener('click', function () {
        showImportToast('ดาวน์โหลด Template — TODO: provide actual xlsx file', 'info');
    });

    // Dropzone click / file select
    importDropzone.addEventListener('click', function () { importFileInput.click(); });
    importDropzone.addEventListener('dragover', function (e) {
        e.preventDefault();
        importDropzone.style.background = 'rgba(var(--bs-primary-rgb),.06)';
    });
    importDropzone.addEventListener('dragleave', function () {
        importDropzone.style.background = '';
    });
    importDropzone.addEventListener('drop', function (e) {
        e.preventDefault();
        importDropzone.style.background = '';
        if (e.dataTransfer.files.length) handleImportFile(e.dataTransfer.files[0]);
    });
    importFileInput.addEventListener('change', function () {
        if (this.files.length) handleImportFile(this.files[0]);
    });

    function handleImportFile(file) {
        var allowed = ['.xlsx', '.csv'];
        var ext = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
        var errEl = document.getElementById('importFileError');
        if (!allowed.includes(ext)) {
            errEl.classList.remove('d-none');
            return;
        }
        errEl.classList.add('d-none');
        // Update dropzone UI
        document.getElementById('importDropzoneIcon').className = 'ri ri-file-excel-line fs-3 text-success';
        document.getElementById('importDropzoneText').innerHTML =
            '<span class="text-success fw-semibold">' + file.name + '</span>' +
            ' <span class="text-muted small">(' + (file.size / 1024).toFixed(1) + ' KB)</span>';
        // Show preview
        document.getElementById('importPreviewSection').classList.remove('d-none');
        document.getElementById('importResultSection').classList.add('d-none');
        btnConfirmImport.disabled = false;
    }

    // Confirm import
    btnConfirmImport.addEventListener('click', function () {
        btnConfirmImport.disabled = true;
        btnConfirmImport.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> กำลังนำเข้า...';
        setTimeout(function () {
            document.getElementById('importPreviewSection').classList.add('d-none');
            document.getElementById('importResultSection').classList.remove('d-none');
            document.getElementById('importModalFooter').innerHTML =
                '<button type="button" class="btn btn-primary" data-bs-dismiss="modal">ปิดหน้าต่าง</button>';
            showImportToast('นำเข้าสำเร็จ 3 รายการ — ข้าม 1 รายการ (ผิดพลาด)', 'success');
        }, 800);
    });

    // Reset modal on close
    document.getElementById('modalImportYield').addEventListener('hidden.bs.modal', function () {
        importFileInput.value = '';
        document.getElementById('importDropzoneIcon').className = 'ri ri-cloud-upload-line fs-3 text-muted';
        document.getElementById('importDropzoneText').textContent = 'ลากไฟล์มาวางหรือคลิกเพื่อเลือกไฟล์ (.xlsx, .csv — ไม่เกิน 5 MB)';
        importDropzone.style.background = '';
        document.getElementById('importPreviewSection').classList.add('d-none');
        document.getElementById('importResultSection').classList.add('d-none');
        document.getElementById('importFileError').classList.add('d-none');
        btnConfirmImport.disabled = true;
        btnConfirmImport.innerHTML = '<i class="ri ri-check-double-line me-1"></i> ยืนยันนำเข้า';
        document.getElementById('importModalFooter').innerHTML =
            '<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ปิด</button>' +
            '<button type="button" class="btn btn-primary" id="btnConfirmImport" disabled>' +
            '<i class="ri ri-check-double-line me-1"></i> ยืนยันนำเข้า</button>';
        // Re-attach event
        document.getElementById('btnConfirmImport').addEventListener('click', arguments.callee);
    });

    function showImportToast(msg, type) {
        var bg = type === 'success' ? 'bg-success' : type === 'danger' ? 'bg-danger' : 'bg-info';
        var icon = type === 'success' ? 'ri-checkbox-circle-line' : type === 'danger' ? 'ri-close-circle-line' : 'ri-information-line';
        var el = document.createElement('div');
        el.className = 'position-fixed bottom-0 end-0 p-3'; el.style.zIndex = 9999;
        el.innerHTML = '<div class="toast show align-items-center text-white ' + bg + ' border-0" role="alert">' +
            '<div class="d-flex"><div class="toast-body d-flex align-items-center gap-2">' +
            '<i class="ri ' + icon + ' fs-5"></i> ' + msg + '</div>' +
            '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
            '</div></div>';
        document.body.appendChild(el); setTimeout(function () { el.remove(); }, 4000);
    }

    // ─── Table filter ───
    function filterRows() {
        var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var status = (document.getElementById('filterStatus').value || '').trim();
        var reqType = (document.getElementById('filterRequestType').value || '').trim();
        var rawType = (document.getElementById('filterRawMaterial').value || '').trim();
        var province = (document.getElementById('filterProvince').value || '').trim();
        var rows = document.querySelectorAll('#yieldTableBody tr[data-id]');
        var count = 0;
        rows.forEach(function (row) {
            var text = (row.dataset.searchText || '').toLowerCase();
            var rowStatus = row.dataset.status || '';
            var rowReqType = row.dataset.reqtype || '';
            var rowRawType = row.dataset.rawtype || '';
            var rowProvince = row.dataset.province || '';
            var show = (!keyword || text.includes(keyword)) &&
                       (!status  || rowStatus === status || (status === 'ยกเว้น %Yield' && rowStatus.startsWith('ยกเว้น %Yield'))) &&
                       (!reqType || rowReqType === reqType)  &&
                       (!rawType || rowRawType === rawType) &&
                       (!province || rowProvince === province);
            row.classList.toggle('d-none', !show);
            if (show) count++;
        });
        document.getElementById('yieldTableEmpty').classList.toggle('d-none', count !== 0);
    }
    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function () {
        document.getElementById('filterKeyword').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterRequestType').value = '';
        document.getElementById('filterRawMaterial').value = '';
        document.getElementById('filterProvince').value = 'สมุทรสาคร';
        filterRows();
    });
    document.getElementById('filterKeyword').addEventListener('keydown', function (e) { if (e.key === 'Enter') filterRows(); });
    document.getElementById('filterStatus').addEventListener('change', filterRows);
    document.getElementById('filterRequestType').addEventListener('change', filterRows);
    document.getElementById('filterRawMaterial').addEventListener('change', filterRows);
    document.getElementById('filterProvince').addEventListener('change', function () {
        var lbl = document.getElementById('areaFilterLabel');
        var v = this.value;
        lbl.textContent = v ? '📍 ' + v : '📍 ทั้งหมด';
        lbl.className = v ? 'badge bg-primary ms-2 small' : 'badge bg-secondary ms-2 small';
        filterRows();
    });

    // ── "My Area" toggle (area banner) ──
    document.getElementById('toggleMyArea').addEventListener('change', function () {
        var sel = document.getElementById('filterProvince');
        sel.value = this.checked ? 'สมุทรสาคร' : '';
        sel.dispatchEvent(new Event('change'));
    });
    document.getElementById('filterProvince').addEventListener('change', function () {
        // sync myArea toggle (avoid double-binding, check value)
    });

    // ── Settings toggles ──
    document.getElementById('toggleDOFOnly').addEventListener('change', function () {
        var fb = document.getElementById('dofToggleFeedback');
        if (this.checked) {
            fb.innerHTML = '<span class="badge bg-label-secondary">ยกเว้น %Yield (นอกรับรอง) ✅ — ผ่านอัตโนมัติ</span>';
        } else {
            fb.innerHTML = '<span class="badge bg-label-warning">ตรวจสอบ %Yield ทุกโรงงาน (รวมนอกรับรอง)</span>';
        }
    });
    document.getElementById('toggleSelfDecl').addEventListener('change', function () {
        var fb = document.getElementById('selfDeclToggleFeedback');
        if (this.checked) {
            fb.innerHTML = '<span class="badge bg-label-warning">ตรวจสอบ %Yield หนังสือรับรองตนเอง</span>';
        } else {
            fb.innerHTML = '<span class="badge bg-label-secondary">ยกเว้น %Yield (Self-Decl.) ✅ — ผ่านอัตโนมัติ</span>';
        }
    });

    // ── Non-DOF table search ──
    document.getElementById('nonDofSearch').addEventListener('input', function () {
        var kw = this.value.trim().toLowerCase();
        document.querySelectorAll('#nonDofTableBody tr').forEach(function (row) {
            var name = (row.dataset.name || '').toLowerCase();
            row.classList.toggle('d-none', kw && !name.includes(kw));
        });
    });

    // ── Dim non-DOF tab pane when DOF-only toggle is off ──
    document.getElementById('toggleDOFOnly').addEventListener('change', function () {
        document.getElementById('pane-nonDOF').style.opacity = this.checked ? '1' : '0.5';
    });

    // ─── Print Yield Form ───
    document.getElementById('btnPrintYield').addEventListener('click', function () {
        bootstrap.Modal.getInstance(document.getElementById('modalPrintYield')).hide();
        setTimeout(function () { window.print(); }, 300);
    });
    document.getElementById('btnDownloadPdf').addEventListener('click', function () {
        // TODO: generate and download PDF via server API
        alert('TODO: ดาวน์โหลด PDF — เชื่อมต่อ API สร้างเอกสาร PDF จริง');
    });

    // ─── Row-level action buttons ───
    var currentRowReqNo = '';

    document.querySelectorAll('.btn-row-approve').forEach(function (btn) {
        btn.addEventListener('click', function () {
            currentRowReqNo = this.dataset.reqno;
            document.getElementById('approveReqNoDisplay').textContent = currentRowReqNo;
            document.getElementById('rowApproveRemark').value = '';
            new bootstrap.Modal(document.getElementById('modalRowApprove')).show();
        });
    });

    document.querySelectorAll('.btn-row-suspend').forEach(function (btn) {
        btn.addEventListener('click', function () {
            currentRowReqNo = this.dataset.reqno;
            document.getElementById('suspendReqNoDisplay').textContent = currentRowReqNo;
            document.getElementById('suspendReason').value = '';
            document.getElementById('suspendReasonError').classList.add('d-none');
            new bootstrap.Modal(document.getElementById('modalRowSuspend')).show();
        });
    });

    document.querySelectorAll('.btn-row-cancel').forEach(function (btn) {
        btn.addEventListener('click', function () {
            currentRowReqNo = this.dataset.reqno;
            document.getElementById('cancelReqNoDisplay').textContent = currentRowReqNo;
            document.getElementById('cancelReason').value = '';
            document.getElementById('cancelReasonError').classList.add('d-none');
            new bootstrap.Modal(document.getElementById('modalRowCancel')).show();
        });
    });

    document.getElementById('btnConfirmRowApprove').addEventListener('click', function () {
        bootstrap.Modal.getInstance(document.getElementById('modalRowApprove')).hide();
        showImportToast('อนุมัติ ' + currentRowReqNo + ' เรียบร้อยแล้ว', 'success');
        var row = document.querySelector('tr[data-id="' + currentRowReqNo + '"]');
        if (row) {
            var badge = row.querySelector('td .badge.rounded-pill');
            if (badge) { badge.className = 'badge rounded-pill bg-label-success'; badge.textContent = 'อนุมัติแล้ว'; }
            row.querySelectorAll('.btn-row-approve, .btn-row-suspend, .btn-row-cancel').forEach(function (b) { b.style.display = 'none'; });
        }
    });

    document.getElementById('btnConfirmRowSuspend').addEventListener('click', function () {
        var reason = document.getElementById('suspendReason').value.trim();
        if (!reason) { document.getElementById('suspendReasonError').classList.remove('d-none'); return; }
        document.getElementById('suspendReasonError').classList.add('d-none');
        bootstrap.Modal.getInstance(document.getElementById('modalRowSuspend')).hide();
        showImportToast('ระงับ ' + currentRowReqNo + ' เรียบร้อยแล้ว', 'warning');
        var row = document.querySelector('tr[data-id="' + currentRowReqNo + '"]');
        if (row) {
            var badge = row.querySelector('td .badge.rounded-pill');
            if (badge) { badge.className = 'badge rounded-pill bg-label-warning'; badge.textContent = 'ระงับ 🚫'; }
            row.querySelectorAll('.btn-row-approve, .btn-row-suspend, .btn-row-cancel').forEach(function (b) { b.style.display = 'none'; });
        }
    });

    document.getElementById('btnConfirmRowCancel').addEventListener('click', function () {
        var reason = document.getElementById('cancelReason').value.trim();
        if (!reason) { document.getElementById('cancelReasonError').classList.remove('d-none'); return; }
        document.getElementById('cancelReasonError').classList.add('d-none');
        bootstrap.Modal.getInstance(document.getElementById('modalRowCancel')).hide();
        showImportToast('ยกเลิก ' + currentRowReqNo + ' เรียบร้อยแล้ว', 'danger');
        var row = document.querySelector('tr[data-id="' + currentRowReqNo + '"]');
        if (row) {
            var badge = row.querySelector('td .badge.rounded-pill');
            if (badge) { badge.className = 'badge rounded-pill bg-label-secondary'; badge.textContent = 'ยกเลิกแล้ว'; }
            row.querySelectorAll('.btn-row-approve, .btn-row-suspend, .btn-row-cancel').forEach(function (b) { b.style.display = 'none'; });
        }
    });
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) { new bootstrap.Tooltip(el); });
    }
});
</script>
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-1">
    <div>
        <h4 class="mb-0">อนุมัติ %Yield</h4>
        <p class="mb-0 text-muted">พิจารณาอนุมัติอัตราส่วนผลผลิต (%Yield) ที่สมาชิกยื่นขอ</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalImportYield">
        <i class="ri ri-upload-2-line me-1"></i> นำเข้าข้อมูล Template
    </button>
</div>

<!-- ==================== Modal: นำเข้าข้อมูล %Yield จาก Template ==================== -->
<div class="modal fade" id="modalImportYield" tabindex="-1" aria-labelledby="modalImportYieldLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold" id="modalImportYieldLabel">
                    <i class="ri ri-upload-2-line me-1 text-primary"></i> นำเข้าข้อมูล %Yield หลายรายการด้วย Template file
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- Step 1: ดาวน์โหลด Template -->
                <div class="alert alert-info d-flex align-items-center gap-3 py-2 mb-3">
                    <i class="ri ri-information-line fs-5 flex-shrink-0"></i>
                    <div class="small">
                        <strong>ขั้นที่ 1</strong> — ดาวน์โหลดไฟล์ Template กรอกข้อมูลตามตัวอย่างในไฟล์ จากนั้นบันทึกข้อมูลแล้วอัปโหลดไฟล์ในขั้นที่ 2
                    </div>
                    <button type="button" class="btn btn-sm btn-success ms-auto text-nowrap flex-shrink-0" id="btnDownloadTemplate">
                        <i class="ri ri-file-excel-line me-1"></i> ดาวน์โหลด Template (.xlsx)
                    </button>
                </div>

                <!-- Step 2: Upload -->
                <div class="mb-3">
