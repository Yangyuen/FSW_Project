@section PageScripts {
<script>
    $(document).ready(function () {
        // Flatpickr
        document.querySelectorAll('.flatpickr-date').forEach(function (el) {
            if (!el._flatpickr) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true, locale: { firstDayOfWeek: 1 } });
            }
        });

        // Tooltips
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // Toggle RMBS2
        $(document).on('click', '.toggle-rmbs2', function () {
            var target = $(this).data('target');
            var container = $('#rmbs2-container-' + target.replace('rmbs2-', ''));
            var icon = $(this).find('i');
            container.toggle();
            icon.toggleClass('ri-arrow-down-s-line ri-arrow-right-s-line');
        });

        $('#btnExpandAll').on('click', function () {
            $('.rmbs2-row').show();
            $('.toggle-rmbs2 i').removeClass('ri-arrow-right-s-line').addClass('ri-arrow-down-s-line');
        });

        $('#btnCollapseAll').on('click', function () {
            $('.rmbs2-row').hide();
            $('.toggle-rmbs2 i').removeClass('ri-arrow-down-s-line').addClass('ri-arrow-right-s-line');
        });

        // Approve / Reject buttons
        $('#btnApproveRequest').on('click', function () {
            if (confirm('ยืนยันการอนุมัติคำขอใบรับรองทดแทนนี้?')) {
                alert('บันทึกผลการอนุมัติเรียบร้อย');
            }
        });

        $('#btnRejectRequest').on('click', function () {
            if (confirm('ยืนยันการไม่อนุมัติคำขอใบรับรองทดแทนนี้?')) {
                alert('บันทึกผลการไม่อนุมัติเรียบร้อย');
            }
        });
    });
</script>
}
