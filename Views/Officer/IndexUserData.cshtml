                            <div class="col-12">
                                <label class="form-label fw-semibold mb-1">
                                    <i class="ri ri-history-line me-1 text-secondary"></i>ประวัติการเปลี่ยนแปลงสิทธิ์ล่าสุด
                                </label>
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered mb-0" style="font-size:0.72rem;">
                                        <thead class="table-light text-center">
                                            <tr>
                                                <th>วันที่</th>
                                                <th>รายการเปลี่ยนแปลง</th>
                                                <th>ผู้ดำเนินการ</th>
                                                <th>สถานะ</th>
                                            </tr>
                                        </thead>
                                        <tbody id="modalPermHistoryBody">
                                            <tr>
                                                <td>23/04/2569</td>
                                                <td>กำหนดบทบาท: เจ้าหน้าที่รับเรื่อง</td>
                                                <td>นายประสิทธิ์ วงค์ดี</td>
                                                <td class="text-center"><span class="badge bg-label-success">มีผล</span></td>
                                            </tr>
                                            <tr>
                                                <td>20/04/2569</td>
                                                <td>เปิดสิทธิ์การใช้งาน</td>
                                                <td>ระบบ (Auto)</td>
                                                <td class="text-center"><span class="badge bg-label-success">มีผล</span></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i>ปิด
                </button>
                <button type="button" class="btn btn-warning me-auto" id="btnTogglePermission">
                    <i class="ri ri-lock-unlock-line me-1"></i>ปิดสิทธิ์ชั่วคราว
                </button>
                <button type="button" class="btn btn-primary">
                    <i class="ri ri-save-line me-1"></i>บันทึกการแก้ไข
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: กำหนดสิทธิ์การมองเห็นข้อมูล (TOR 3.1(7)) -->
<div class="modal fade" id="dataAccessModal" tabindex="-1" aria-labelledby="dataAccessModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header text-white py-2">
                <h6 class="modal-title fw-semibold" id="dataAccessModalLabel">
                    กำหนดสิทธิ์การมองเห็นข้อมูล
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">

                <!-- ข้อมูลผู้ใช้ (header info strip) -->
                <div class="d-flex align-items-center gap-3 mb-3 p-3 bg-light rounded">
                    <div class="avatar avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;font-size:1rem;">
                        <i class="ri ri-user-3-line"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" id="scopeModalUserName">-</div>
                        <div class="small text-muted">
                            <span id="scopeModalUserId" class="me-2"></span>
                            <span>สังกัด: </span><span id="scopeModalAgency" class="text-primary fw-semibold"></span>
                        </div>
                    </div>
                </div>

                <!-- ส่วนที่ 1: ส่วนข้อมูลที่มองเห็นได้ -->
                <div class="card border mb-3">
                    <div class="card-header py-2" style="background:rgba(105,108,255,0.08)">
                        <h6 class="mb-0 fw-semibold text-primary">
                            <i class="ri ri-eye-line me-1"></i>ส่วนข้อมูลที่มองเห็นได้ในพื้นที่รับผิดชอบ
                        </h6>
                    </div>
                    <div class="card-body py-3">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input scope-data-checkbox" type="checkbox" value="cert" id="scopeCert" checked>
                                    <label class="form-check-label" for="scopeCert">
                                        <i class="ri ri-file-text-line me-1 text-success"></i>ข้อมูลใบรับรองในพื้นที่รับผิดชอบ
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input scope-data-checkbox" type="checkbox" value="rmbs" id="scopeRMBS" checked>
                                    <label class="form-check-label" for="scopeRMBS">
                                        <i class="ri ri-clipboard-line me-1 text-primary"></i>ข้อมูล RMBS1/RMBS2 ในพื้นที่รับผิดชอบ
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input scope-data-checkbox" type="checkbox" value="operator" id="scopeOperator" checked>
                                    <label class="form-check-label" for="scopeOperator">
                                        <i class="ri ri-store-2-line me-1 text-info"></i>ข้อมูลผู้ประกอบการในพื้นที่รับผิดชอบ
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input scope-data-checkbox" type="checkbox" value="dof" id="scopeDOF">
                                    <label class="form-check-label" for="scopeDOF">
                                        <i class="ri ri-list-check me-1 text-warning"></i>DOF List ในพื้นที่รับผิดชอบ
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input scope-data-checkbox" type="checkbox" value="trace" id="scopeTrace">
                                    <label class="form-check-label" for="scopeTrace">
                                        <i class="ri ri-route-line me-1 text-danger"></i>Traceability List ในพื้นที่รับผิดชอบ
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ส่วนที่ 2: ขอบเขตพื้นที่ -->
                <div class="card border mb-3">
                    <div class="card-header py-2" style="background:rgba(105,108,255,0.08)">
                        <h6 class="mb-0 fw-semibold text-primary">
                            <i class="ri ri-map-pin-2-line me-1"></i>ขอบเขตพื้นที่ที่มองเห็นได้
                        </h6>
                    </div>
                    <div class="card-body py-3">
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="scopeMode" id="scopeModeAgency" value="agency" checked>
                                    <label class="form-check-label" for="scopeModeAgency">
                                        <i class="ri ri-government-line me-1"></i>ตามที่มอบหมายจากหน่วยงาน (ค่าเริ่มต้น)
                                    </label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="scopeMode" id="scopeModeCustom" value="custom">
                                    <label class="form-check-label" for="scopeModeCustom">
                                        <i class="ri ri-settings-3-line me-1"></i>กำหนดเอง
                                    </label>
                                </div>
                            </div>
                            <div class="col-12 d-none" id="scopeCustomProvinceRow">
                                <label class="form-label fw-semibold">เลือกจังหวัดในขอบเขตที่มองเห็นได้</label>
                                <select id="scopeCustomProvinces" class="form-select" multiple size="6">
                                    <option>กรุงเทพมหานคร</option>
                                    <option>นนทบุรี</option>
                                    <option>ปทุมธานี</option>
                                    <option>สมุทรปราการ</option>
                                    <option>สมุทรสาคร</option>
                                    <option>สมุทรสงคราม</option>
                                    <option>สงขลา</option>
                                    <option>สตูล</option>
                                    <option>พัทลุง</option>
                                    <option>ระยอง</option>
                                    <option>ชลบุรี</option>
                                    <option>เพชรบุรี</option>
                                    <option>เชียงใหม่</option>
                                    <option>ขอนแก่น</option>
                                    <option>สุราษฎร์ธานี</option>
                                    <option>ปัตตานี</option>
                                    <option>ตราด</option>
                                    <option>พิษณุโลก</option>
                                </select>
                                <div class="form-text">กด Ctrl/Cmd ค้างเพื่อเลือกหลายจังหวัด</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ส่วนที่ 3: สิทธิ์ข้ามพื้นที่ (TOR 3.1(8)) -->
                <div class="card border mb-3">
                    <div class="card-header py-2" style="background:rgba(255,159,67,0.08)">
                        <div class="d-flex align-items-center justify-content-between">
                            <h6 class="mb-0 fw-semibold text-warning">
                                <i class="ri ri-exchange-2-line me-1"></i>สิทธิ์ข้ามพื้นที่ (Cross-Area Access)
                            </h6>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" role="switch" id="crossAgencyToggle">
                                <label class="form-check-label small" for="crossAgencyToggle">เปิดใช้งาน</label>
                            </div>
                        </div>
                    </div>
                    <div class="card-body py-3 d-none" id="crossAgencySection">
                        <div class="alert alert-warning border-0 py-2 mb-3" role="alert">
                            <i class="ri ri-error-warning-line me-1"></i>
                            สิทธิ์ข้ามพื้นที่ต้องได้รับอนุมัติจาก Admin ระดับ กตส. ก่อนมีผล
                        </div>
                        <div class="row g-2">
                            <div class="col-12">
                                <label class="form-label fw-semibold">หน่วยงานที่อนุญาตให้มองเห็นข้ามพื้นที่</label>
                                <div class="row g-2">
                                    @foreach (var agencyOpt in new[]{"กตส.","ศตส.เขต 1","ศตส.เขต 2","ศตส.เขต 3","ศตส.เขต 4","ศตส.เขต 5","ศตส.เขต 6"})
                                    {
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input cross-agency-checkbox" type="checkbox" value="@agencyOpt" id="cross_@agencyOpt.Replace(" ","_")">
                                                <label class="form-check-label" for="cross_@agencyOpt.Replace(" ","_")">@agencyOpt</label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">เหตุผล / บันทึกการร้องขอ</label>
                                <textarea class="form-control" id="crossAgencyReason" rows="2" placeholder="ระบุเหตุผลความจำเป็น..."></textarea>
                            </div>
                        </div>

                        <!-- TOR 3.1(8): สิทธิ์ตรวจสอบใบรับรองข้ามหน่วยงาน (ศตส. ดู กตส.) -->
                        <hr class="my-3">
                        <div>
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <label class="fw-semibold mb-0 small">
                                    <i class="ri ri-file-certificate-line me-1 text-primary"></i>
                                    สิทธิ์ตรวจสอบใบรับรองที่ออกโดย กตส. (สำหรับ ศตส. เท่านั้น)
                                </label>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" role="switch" id="certCrossAgencyToggle">
                                    <label class="form-check-label small" for="certCrossAgencyToggle">อนุญาต</label>
                                </div>
                            </div>
                            <div class="d-none" id="certCrossAgencySection">
                                <div class="row g-2 border rounded p-2 bg-light mb-2">
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="crossCertPS" checked>
                                            <label class="form-check-label small" for="crossCertPS">
                                                <i class="ri ri-file-text-line me-1 text-success"></i>ใบรับรอง PS (Health Certificate) กตส.
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="crossCertNMD" checked>
                                            <label class="form-check-label small" for="crossCertNMD">
                                                <i class="ri ri-file-list-3-line me-1 text-primary"></i>ใบรับรอง NMD กตส.
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="crossCertRMBS1">
                                            <label class="form-check-label small" for="crossCertRMBS1">
                                                <i class="ri ri-clipboard-line me-1 text-info"></i>ข้อมูล RMBS1 กตส.
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="crossCertRMBS2">
                                            <label class="form-check-label small" for="crossCertRMBS2">
                                                <i class="ri ri-clipboard-check-line me-1 text-warning"></i>ข้อมูล RMBS2 กตส.
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <div class="alert alert-info border-0 py-2 mb-0 small" role="alert">
                                    <i class="ri ri-information-line me-1"></i>
                                    สิทธิ์ตรวจสอบใบรับรองเป็นสิทธิ์อ่านอย่างเดียว (ไม่สามารถแก้ไข/ยกเลิกได้)
                                    ผู้อนุมัติคือ Admin ระดับ กตส. เท่านั้น
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ส่วนที่ 4: สิทธิ์จัดการฐานข้อมูล DOF List + Traceability List (TOR 3.1(10)) -->
                <div class="card border mb-0">
                    <div class="card-header py-2" style="background:rgba(102,192,62,0.08)">
                        <h6 class="mb-0 fw-semibold" style="color:#28a745;">
                            <i class="ri ri-database-2-line me-1"></i>สิทธิ์จัดการฐานข้อมูล (DOF List / Traceability List)
                        </h6>
                    </div>
                    <div class="card-body py-3">
                        <div class="alert alert-info border-0 py-2 mb-3 small">
                            <i class="ri ri-information-line me-1"></i>
                            สิทธิ์นี้อนุญาตให้เจ้าหน้าที่ เพิ่มเติม/แก้ไข/ระงับ/ยกเลิก ข้อมูลในพื้นที่รับผิดชอบ
                        </div>
                        <div class="row g-3">
                            <!-- DOF List -->
                            <div class="col-md-6">
                                <div class="card border-0 bg-light p-3">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <div class="fw-semibold small">
                                            <i class="ri ri-list-check me-1 text-warning"></i>DOF List
                                        </div>
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input" type="checkbox" role="switch" id="dofManageToggle">
                                            <label class="form-check-label small" for="dofManageToggle">จัดการได้</label>
                                        </div>
                                    </div>
                                    <div id="dofManageSection" class="d-none">
                                        <label class="form-label small fw-semibold">ขอบเขตพื้นที่ DOF List</label>
                                        <div class="form-check mb-1">
                                            <input class="form-check-input" type="radio" name="dofScope" id="dofScopeAgency" value="agency" checked>
                                            <label class="form-check-label small" for="dofScopeAgency">เฉพาะหน่วยงานสังกัด</label>
                                        </div>
                                        <div class="form-check mb-1">
                                            <input class="form-check-input" type="radio" name="dofScope" id="dofScopeAll" value="all">
                                            <label class="form-check-label small" for="dofScopeAll">ทุกพื้นที่ (เฉพาะ Admin)</label>
                                        </div>
                                        <div class="mt-2">
                                            <label class="form-label small fw-semibold">สิทธิ์การดำเนินการ</label>
                                            <div class="d-flex flex-wrap gap-2">
                                                <div class="form-check">
                                                    <input class="form-check-input dof-perm" type="checkbox" id="dofPermAdd" value="add" checked>
                                                    <label class="form-check-label small" for="dofPermAdd">เพิ่ม</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input dof-perm" type="checkbox" id="dofPermEdit" value="edit" checked>
                                                    <label class="form-check-label small" for="dofPermEdit">แก้ไข</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input dof-perm" type="checkbox" id="dofPermSuspend" value="suspend">
                                                    <label class="form-check-label small" for="dofPermSuspend">ระงับ</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input dof-perm" type="checkbox" id="dofPermCancel" value="cancel">
                                                    <label class="form-check-label small" for="dofPermCancel">ยกเลิก</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Traceability List -->
                            <div class="col-md-6">
                                <div class="card border-0 bg-light p-3">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <div class="fw-semibold small">
                                            <i class="ri ri-route-line me-1 text-danger"></i>Traceability List
                                        </div>
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input" type="checkbox" role="switch" id="traceManageToggle">
                                            <label class="form-check-label small" for="traceManageToggle">จัดการได้</label>
                                        </div>
                                    </div>
                                    <div id="traceManageSection" class="d-none">
                                        <label class="form-label small fw-semibold">ขอบเขตพื้นที่ Traceability</label>
                                        <div class="form-check mb-1">
                                            <input class="form-check-input" type="radio" name="traceScope" id="traceScopeAgency" value="agency" checked>
                                            <label class="form-check-label small" for="traceScopeAgency">เฉพาะหน่วยงานสังกัด</label>
                                        </div>
                                        <div class="form-check mb-1">
                                            <input class="form-check-input" type="radio" name="traceScope" id="traceScopeAll" value="all">
                                            <label class="form-check-label small" for="traceScopeAll">ทุกพื้นที่ (เฉพาะ Admin)</label>
                                        </div>
                                        <div class="mt-2">
                                            <label class="form-label small fw-semibold">สิทธิ์การดำเนินการ</label>
                                            <div class="d-flex flex-wrap gap-2">
                                                <div class="form-check">
                                                    <input class="form-check-input trace-perm" type="checkbox" id="tracePermAdd" value="add" checked>
                                                    <label class="form-check-label small" for="tracePermAdd">เพิ่ม</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input trace-perm" type="checkbox" id="tracePermEdit" value="edit" checked>
                                                    <label class="form-check-label small" for="tracePermEdit">แก้ไข</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input trace-perm" type="checkbox" id="tracePermSuspend" value="suspend">
                                                    <label class="form-check-label small" for="tracePermSuspend">ระงับ</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input trace-perm" type="checkbox" id="tracePermCancel" value="cancel">
                                                    <label class="form-check-label small" for="tracePermCancel">ยกเลิก</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i>ยกเลิก
                </button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">
                    <i class="ri ri-save-line me-1"></i>บันทึกสิทธิ์
                </button>
            </div>
        </div>
    </div>
</div>
