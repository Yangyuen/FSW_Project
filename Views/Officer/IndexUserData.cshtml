        new { RowNo=2, UserId="USR-0002", FullName="นายภาณุพงศ์ รัตน์ชัย", Email="phanu@oceanprime.co.th", Organization="บริษัท โอเชียน ไพร์ม เอ็กซ์พอร์ต จำกัด", Role="สมาชิก", LastLoginAt=new DateTime(2026,4,22,14,30,0), StatusText="ใช้งาน", StatusClass="bg-label-success" },
        new { RowNo=3, UserId="USR-0003", FullName="นางสาวสมหญิง ใจดี", Email="officer1@dof.go.th", Organization="กรมประมง", Role="เจ้าหน้าที่", LastLoginAt=new DateTime(2026,4,23,8,0,0), StatusText="ใช้งาน", StatusClass="bg-label-success" },
        new { RowNo=4, UserId="USR-0004", FullName="นายประสิทธิ์ วงค์ดี", Email="admin@dof.go.th", Organization="กรมประมง", Role="ผู้ดูแลระบบ", LastLoginAt=new DateTime(2026,4,23,7,45,0), StatusText="ใช้งาน", StatusClass="bg-label-success" },
        new { RowNo=5, UserId="USR-0005", FullName="นายธนกฤต วงศ์ดี", Email="thanakrit@siammarine.co.th", Organization="บริษัท สยาม มารีน ฟู้ดส์ จำกัด", Role="สมาชิก", LastLoginAt=new DateTime(2026,4,20,11,0,0), StatusText="ระงับ", StatusClass="bg-label-warning" },
        new { RowNo=6, UserId="USR-0006", FullName="นางสาวกนกพร สายชล", Email="kanokporn@oceanprime.co.th", Organization="บริษัท โอเชียน ไพร์ม เอ็กซ์พอร์ต จำกัด", Role="สมาชิก", LastLoginAt=new DateTime(2026,4,15,16,30,0), StatusText="ใช้งาน", StatusClass="bg-label-success" },
