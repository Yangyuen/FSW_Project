<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ค้นหาผู้ใช้งาน</h5>
            <p class="text-muted small mb-0">ค้นหาตามชื่อ อีเมล องค์กร บทบาท สังกัด หรือสถานะ</p>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3 col-lg-3">
                <label for="filterKeyword" class="form-label">ค้นหา</label>
                <input id="filterKeyword" type="text" class="form-control" placeholder="ชื่อผู้ใช้ / อีเมล / องค์กร" />
            </div>
            <div class="col-md-2 col-lg-2">
                <label for="filterRole" class="form-label">บทบาท</label>
                <select id="filterRole" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="สมาชิก">สมาชิก</option>
                    <option value="เจ้าหน้าที่">เจ้าหน้าที่</option>
                    <option value="ผู้ดูแลระบบ">ผู้ดูแลระบบ</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-3">
                <label for="filterAgency" class="form-label">สังกัดหน่วยงาน</label>
                <select id="filterAgency" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="กตส.">กตส. (กองตรวจสอบคุณภาพสินค้าประมง)</option>
                    <option value="ศตส.">ศตส. (ทุกเขต)</option>
                </select>
            </div>
            <div class="col-md-2 col-lg-2">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ใช้งาน">ใช้งาน</option>
                    <option value="ระงับ">ระงับ</option>
                </select>
            </div>
            <div class="col-md-2 col-lg-2">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearch" class="btn btn-outline-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnReset" class="btn btn-outline-secondary btn-square">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายชื่อผู้ใช้งาน</h5>
            <p class="text-muted small mb-0">แสดงข้อมูลผู้ใช้งานทั้งหมดในระบบ</p>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 user-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width:50px">#</th>
                    <th>รหัสผู้ใช้</th>
                    <th>ชื่อ-สกุล</th>
                    <th>อีเมล</th>
                    <th>องค์กร / สังกัด</th>
                    <th>บทบาท</th>
                    <th>บทบาทพิเศษ</th>
                    <th style="min-width:110px;">สิทธิ์ข้อมูล</th>
                    <th>เข้าใช้ล่าสุด</th>
                    <th>สถานะ</th>
                    <th style="width:80px"></th>
                </tr>
            </thead>
            <tbody id="userTableBody">
                @foreach (var u in users)
                {
                    <tr data-id="@u.UserId" data-role="@u.Role" data-status="@u.StatusText" data-agency="@u.Agency" data-search-text="@u.FullName.ToLower() @u.Email.ToLower() @u.Organization.ToLower()">
                        <td class="text-center text-muted">@u.RowNo</td>
                        <td><span class="fw-semibold text-primary">@u.UserId</span></td>
                        <td>@u.FullName</td>
                        <td>@u.Email</td>
                        <td>
                            @u.Organization
                            @if (!string.IsNullOrEmpty(u.Agency)) {
                                <br/><small class="text-muted">@u.Agency</small>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill bg-label-@(u.Role == "ผู้ดูแลระบบ" ? "danger" : u.Role == "เจ้าหน้าที่" ? "info" : "secondary")">@u.Role</span>
                        </td>
                        <td class="text-center">
                            @if (u.IsSigner) {<span class="badge bg-success me-1"><i class="ri ri-pen-nib-line"></i> ผู้ลงนาม</span>}
                            @if (u.IsApprover) {<span class="badge bg-primary"><i class="ri ri-checkbox-circle-line"></i> ผู้อนุมัติ</span>}
                            @if (!u.IsSigner && !u.IsApprover) {<span class="text-muted small">-</span>}
                        </td>
                        <td class="text-center">
                            @if (u.HasDataScope)
                            {
                                <span class="badge bg-label-success" style="font-size:0.67rem;">
                                    <i class="ri ri-eye-line me-1"></i>@u.DataScopeLabel
                                </span>
                            }
                            else if (!string.IsNullOrEmpty(u.Agency))
                            {
                                <span class="badge bg-label-warning" style="font-size:0.67rem;">
                                    <i class="ri ri-eye-off-line me-1"></i>ยังไม่กำหนด
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                            @if (u.HasCrossAgencyCertAccess)
                            {
                                <br/><span class="badge bg-label-primary mt-1" style="font-size:0.67rem;">
                                    <i class="ri ri-file-certificate-line me-1"></i>@u.CrossAgencyCertLabel
                                </span>
                            }
                            @if (u.CanManageDofList)
                            {
                                <br/><span class="badge bg-label-warning mt-1" style="font-size:0.67rem;">
                                    <i class="ri ri-list-check me-1"></i>@u.DofScopeLabel
                                </span>
                            }
                            @if (u.CanManageTraceList)
                            {
                                <br/><span class="badge bg-label-danger mt-1" style="font-size:0.67rem;">
                                    <i class="ri ri-route-line me-1"></i>@u.TraceScopeLabel
                                </span>
                            }
                        </td>
                        <td>@u.LastLoginAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center"><span class="badge rounded-pill @u.StatusClass">@u.StatusText</span></td>
                        <td class="text-center text-nowrap">
                            @if (!string.IsNullOrEmpty(u.Agency))
                            {
                                <button class="btn btn-icon btn-sm btn-outline-primary me-1 btn-assign-scope" data-user-id="@u.UserId" data-bs-toggle="tooltip" title="กำหนดสิทธิ์ข้อมูล">
                                    <i class="ri ri-shield-keyhole-line text-primary"></i>
                                </button>
                            }
                            <button class="btn btn-icon btn-sm btn-outline-info btn-view-user" data-user-id="@u.UserId" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                <i class="ri ri-eye-line text-info"></i>
                            </button>
                        </td>
                    </tr>
                }
                <tr id="userTableEmpty" class="d-none">
                    <td colspan="11" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- User Detail Modal -->
