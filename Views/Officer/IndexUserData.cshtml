@section PageScripts {
<script>
var userData = {
    "USR-0001": { userId:"USR-0001", fullName:"นางสาวปรียา ศรีสุข", email:"priya@siammarine.co.th", organization:"บริษัท สยาม มารีน ฟู้ดส์ จำกัด", role:"สมาชิก", agency:"", specificRoles:[], responsibleArea:[], isSigner:false, isApprover:false, crossAgencyCertAccess:false, status:"ใช้งาน" },
    "USR-0002": { userId:"USR-0002", fullName:"นายภาณุพงศ์ รัตน์ชัย", email:"phanu@oceanprime.co.th", organization:"บริษัท โอเชียน ไพร์ม เอ็กซ์พอร์ต จำกัด", role:"สมาชิก", agency:"", specificRoles:[], responsibleArea:[], isSigner:false, isApprover:false, crossAgencyCertAccess:false, status:"ใช้งาน" },
    "USR-0003": { userId:"USR-0003", fullName:"นางสาวสมหญิง ใจดี", email:"officer1@dof.go.th", organization:"กรมประมง — กตส.", role:"เจ้าหน้าที่", agency:"กตส.", specificRoles:["เจ้าหน้าที่รับเรื่อง","เจ้าหน้าที่พิจารณา"], responsibleArea:["กรุงเทพมหานคร","สมุทรปราการ"], isSigner:false, isApprover:false, crossAgencyCertAccess:false, canManageDofList:true, dofManageScope:"กตส.", canManageTraceList:false, traceManageScope:"", status:"ใช้งาน" },
    "USR-0004": { userId:"USR-0004", fullName:"นายประสิทธิ์ วงค์ดี", email:"admin@dof.go.th", organization:"กรมประมง — กตส.", role:"ผู้ดูแลระบบ", agency:"กตส.", specificRoles:["ผู้อนุมัติ RMBS1","ผู้ลงนามใบรับรอง"], responsibleArea:["กรุงเทพมหานคร","นนทบุรี","ปทุมธานี"], isSigner:true, isApprover:true, crossAgencyCertAccess:false, canManageDofList:true, dofManageScope:"ทุกพื้นที่", canManageTraceList:true, traceManageScope:"ทุกพื้นที่", status:"ใช้งาน" },
    "USR-0005": { userId:"USR-0005", fullName:"นายธนกฤต วงศ์ดี", email:"thanakrit@siammarine.co.th", organization:"บริษัท สยาม มารีน ฟู้ดส์ จำกัด", role:"สมาชิก", agency:"", specificRoles:[], responsibleArea:[], isSigner:false, isApprover:false, crossAgencyCertAccess:false, canManageDofList:false, dofManageScope:"", canManageTraceList:false, traceManageScope:"", status:"ระงับ" },
    "USR-0006": { userId:"USR-0006", fullName:"นางสาวกนกพร สายชล", email:"kanokporn@oceanprime.co.th", organization:"บริษัท โอเชียน ไพร์ม เอ็กซ์พอร์ต จำกัด", role:"สมาชิก", agency:"", specificRoles:[], responsibleArea:[], isSigner:false, isApprover:false, crossAgencyCertAccess:false, canManageDofList:false, dofManageScope:"", canManageTraceList:false, traceManageScope:"", status:"ใช้งาน" },
    "USR-0007": { userId:"USR-0007", fullName:"นายวิทยา ทองดี", email:"wittaya@dof.go.th", organization:"ศตส. เขต 3 (สงขลา)", role:"เจ้าหน้าที่", agency:"ศตส.เขต 3", specificRoles:["เจ้าหน้าที่รับเรื่อง","ผู้ตรวจสอบ Traceability","ผู้ลงนามใบรับรอง"], responsibleArea:["สงขลา","สตูล","พัทลุง"], isSigner:true, isApprover:false, crossAgencyCertAccess:true, certTypes:["PS","NMD","RMBS1"], canManageDofList:false, dofManageScope:"", canManageTraceList:true, traceManageScope:"ศตส.เขต 3", status:"ใช้งาน" },
    "USR-0008": { userId:"USR-0008", fullName:"นางสาวพิมพ์ใจ ชูศรี", email:"pimjai@dof.go.th", organization:"ศตส. เขต 5 (สมุทรสาคร)", role:"เจ้าหน้าที่", agency:"ศตส.เขต 5", specificRoles:["ผู้อนุมัติ RMBS1","เจ้าหน้าที่พิจารณา"], responsibleArea:["สมุทรสาคร","สมุทรสงคราม","เพชรบุรี"], isSigner:false, isApprover:true, crossAgencyCertAccess:true, certTypes:["PS","NMD","RMBS2"], canManageDofList:true, dofManageScope:"ศตส.เขต 5", canManageTraceList:true, traceManageScope:"ศตส.เขต 5", status:"ใช้งาน" }
};
document.addEventListener('DOMContentLoaded', function () {
    function filterRows() {
        var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var role = (document.getElementById('filterRole').value || '').trim();
        var agency = (document.getElementById('filterAgency').value || '').trim();
        var status = (document.getElementById('filterStatus').value || '').trim();
        var rows = document.querySelectorAll('#userTableBody tr[data-id]');
        var count = 0;
        rows.forEach(function (row) {
            var text = (row.dataset.searchText || '').toLowerCase();
            var rowRole = row.dataset.role || '';
            var rowAgency = row.dataset.agency || '';
            var rowStatus = row.dataset.status || '';
            var agencyMatch = !agency || (agency === 'ศตส.' ? rowAgency.startsWith('ศตส.') : rowAgency === agency);
            var show = (!keyword || text.includes(keyword)) && (!role || rowRole === role) && agencyMatch && (!status || rowStatus === status);
            row.classList.toggle('d-none', !show);
            if (show) count++;
        });
        document.getElementById('userTableEmpty').classList.toggle('d-none', count !== 0);
    }
    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function () {
        document.getElementById('filterKeyword').value = '';
        document.getElementById('filterRole').value = '';
        document.getElementById('filterAgency').value = '';
        document.getElementById('filterStatus').value = '';
        filterRows();
    });
    ['filterKeyword', 'filterRole', 'filterAgency', 'filterStatus'].forEach(function (id) {
        var el = document.getElementById(id);
        el.addEventListener('change', filterRows);
        if (el.tagName === 'INPUT') el.addEventListener('keydown', function (e) { if (e.key === 'Enter') filterRows(); });
    });
    // ---- กำหนดสิทธิ์ข้อมูล ----
    document.querySelectorAll('.btn-assign-scope').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var userId = this.dataset.userId;
            var u = userData[userId];
            if (!u) return;
            document.getElementById('scopeModalUserName').textContent = u.fullName;
            document.getElementById('scopeModalUserId').textContent = u.userId;
            document.getElementById('scopeModalAgency').textContent = u.agency || '(ไม่ระบุหน่วยงาน)';
            // pre-select scope mode to "agency"
            document.getElementById('scopeModeAgency').checked = true;
            document.getElementById('scopeCustomProvinceRow').classList.add('d-none');
            // pre-check all data-access checkboxes for officers with agency
            document.querySelectorAll('.scope-data-checkbox').forEach(function (cb) {
                cb.checked = !!u.agency;
            });
            // cross-agency: set based on user cert access data
            var hasCrossAgencyCert = !!(u.crossAgencyCertAccess);
            document.getElementById('crossAgencyToggle').checked = hasCrossAgencyCert;
            document.getElementById('crossAgencySection').classList.toggle('d-none', !hasCrossAgencyCert);
            // cert-specific toggle
            document.getElementById('certCrossAgencyToggle').checked = hasCrossAgencyCert;
            document.getElementById('certCrossAgencySection').classList.toggle('d-none', !hasCrossAgencyCert);
            // cert type checkboxes
            var certTypes = u.certTypes || [];
            document.getElementById('crossCertPS').checked = certTypes.includes('PS');
            document.getElementById('crossCertNMD').checked = certTypes.includes('NMD');
            document.getElementById('crossCertRMBS1').checked = certTypes.includes('RMBS1');
            document.getElementById('crossCertRMBS2').checked = certTypes.includes('RMBS2');
            // TOR 3.1(10): DOF / Trace manage toggles
            var hasDof = !!(u.canManageDofList);
            var hasTrace = !!(u.canManageTraceList);
            document.getElementById('dofManageToggle').checked = hasDof;
            document.getElementById('dofManageSection').classList.toggle('d-none', !hasDof);
            if (hasDof && u.dofManageScope === 'ทุกพื้นที่') document.getElementById('dofScopeAll').checked = true;
            else document.getElementById('dofScopeAgency').checked = true;
            document.getElementById('traceManageToggle').checked = hasTrace;
            document.getElementById('traceManageSection').classList.toggle('d-none', !hasTrace);
            if (hasTrace && u.traceManageScope === 'ทุกพื้นที่') document.getElementById('traceScopeAll').checked = true;
            else document.getElementById('traceScopeAgency').checked = true;
            new bootstrap.Modal(document.getElementById('dataAccessModal')).show();
        });
    });

    // scope mode toggle
    document.querySelectorAll('input[name="scopeMode"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            var show = this.value === 'custom';
            document.getElementById('scopeCustomProvinceRow').classList.toggle('d-none', !show);
        });
    });

    // cross-agency toggle
    document.getElementById('crossAgencyToggle').addEventListener('change', function () {
        document.getElementById('crossAgencySection').classList.toggle('d-none', !this.checked);
        // sync cert toggle
        document.getElementById('certCrossAgencyToggle').checked = this.checked;
        document.getElementById('certCrossAgencySection').classList.toggle('d-none', !this.checked);
    });

    // cert cross-agency toggle
    document.getElementById('certCrossAgencyToggle').addEventListener('change', function () {
        document.getElementById('certCrossAgencySection').classList.toggle('d-none', !this.checked);
        // ensure parent toggle also on
        if (this.checked) {
            document.getElementById('crossAgencyToggle').checked = true;
            document.getElementById('crossAgencySection').classList.remove('d-none');
        }
    });

    // TOR 3.1(10): DOF/Trace manage toggles
    document.getElementById('dofManageToggle').addEventListener('change', function () {
        document.getElementById('dofManageSection').classList.toggle('d-none', !this.checked);
    });
    document.getElementById('traceManageToggle').addEventListener('change', function () {
        document.getElementById('traceManageSection').classList.toggle('d-none', !this.checked);
    });

    document.querySelectorAll('.btn-view-user').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var userId = this.dataset.userId;
            var u = userData[userId];
            if (!u) return;
            document.getElementById('modalUserId').textContent = u.userId;
            document.getElementById('modalUserFullName').textContent = u.fullName;
            document.getElementById('modalUserEmail').textContent = u.email;
            document.getElementById('modalUserOrg').textContent = u.organization;
            document.getElementById('modalUserRole').textContent = u.role;
            document.getElementById('modalUserStatus').textContent = u.status;
            var agencySelect = document.getElementById('modalUserAgency');
            agencySelect.value = u.agency || '';
            document.querySelectorAll('.modal-role-checkbox').forEach(function (cb) {
                cb.checked = u.specificRoles.indexOf(cb.value) !== -1;
            });
            var areaEl = document.getElementById('modalResponsibleArea');
            areaEl.innerHTML = '';
            if (u.responsibleArea && u.responsibleArea.length > 0) {
                u.responsibleArea.forEach(function (area) {
                    var span = document.createElement('span');
                    span.className = 'badge bg-label-secondary me-1 mb-1';
                    span.textContent = area;
                    areaEl.appendChild(span);
                });
            } else {
                areaEl.textContent = '-';
            }
            document.getElementById('modalSignerBadge').classList.toggle('d-none', !u.isSigner);
            document.getElementById('modalApproverBadge').classList.toggle('d-none', !u.isApprover);
            // TOR 3.1(9): permissions section
            var hasAgency = !!u.agency;
            document.getElementById('permissionManageCard').classList.toggle('d-none', !hasAgency);
            if (hasAgency) {
                // status radio
                var statusVal = u.status || 'ใช้งาน';
                document.querySelectorAll('input[name="modalUserStatusRadio"]').forEach(function(r){ r.checked = (r.value === statusVal); });
                document.getElementById('modalPermStatusBadge').textContent = statusVal;
                document.getElementById('modalPermStatusBadge').className = 'badge small ' +
                    (statusVal === 'ใช้งาน' ? 'bg-label-success' : statusVal === 'ระงับ' ? 'bg-label-warning' : 'bg-label-danger');
                // role & scope agency
                document.getElementById('modalRoleAssign').value = u.role || 'สมาชิก';
                document.getElementById('modalScopeAgency').value = u.agency || '';
                // signer / approver toggles
                document.getElementById('modalIsSignerToggle').checked = !!u.isSigner;
                document.getElementById('modalIsApproverToggle').checked = !!u.isApprover;
                // toggle button label
                document.getElementById('btnTogglePermission').innerHTML = statusVal === 'ใช้งาน'
                    ? '<i class="ri ri-lock-line me-1"></i>ปิดสิทธิ์ชั่วคราว'
                    : '<i class="ri ri-lock-unlock-line me-1"></i>เปิดสิทธิ์';
            }
            new bootstrap.Modal(document.getElementById('userDetailModal')).show();
        });
    });
    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) { new bootstrap.Tooltip(el); });
    }
});
</script>
}

