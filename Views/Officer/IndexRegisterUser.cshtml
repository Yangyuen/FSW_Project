        new { RowNo=2, ReqNo="REG-2026-00102", FullName="นางสาววรรณพร ดีงาม", Email="wannaporn@bluefish.co.th", Organization="บริษัท บลู ฟิช เอ็กซ์พอร์ต จำกัด", RequestedRole="สมาชิก", RequestedAgency="", SubmittedAt=new DateTime(2026,4,22,14,15,0), StatusText="รอตรวจสอบ", StatusClass="bg-label-warning" },
        new { RowNo=3, ReqNo="REG-2026-00103", FullName="นายกิตติภัทร พงษ์ไพร", Email="kittipat@andaman2.co.th", Organization="บริษัท อันดามัน 2 โปรเซสซิ่ง จำกัด", RequestedRole="สมาชิก", RequestedAgency="", SubmittedAt=new DateTime(2026,4,23,9,0,0), StatusText="รอตรวจสอบ", StatusClass="bg-label-warning" },
        new { RowNo=4, ReqNo="REG-2026-00104", FullName="นายศุภชัย มือเย็น", Email="supachai@dof.go.th", Organization="กรมประมง — ศตส. เขต 4", RequestedRole="เจ้าหน้าที่", RequestedAgency="ศตส.เขต 4", SubmittedAt=new DateTime(2026,4,23,11,0,0), StatusText="รอตรวจสอบ", StatusClass="bg-label-warning" },
        new { RowNo=5, ReqNo="REG-2026-00099", FullName="นางสาวมณีรัตน์ สุขใจ", Email="maneerat@siammarine.co.th", Organization="บริษัท สยาม มารีน ฟู้ดส์ จำกัด", RequestedRole="สมาชิก", RequestedAgency="", SubmittedAt=new DateTime(2026,4,21,11,0,0), StatusText="อนุมัติแล้ว", StatusClass="bg-label-success" },
        new { RowNo=6, ReqNo="REG-2026-00098", FullName="นายอิทธิพล รักดี", Email="itthiphon@fake.co.th", Organization="ไม่ระบุ", RequestedRole="สมาชิก", RequestedAgency="", SubmittedAt=new DateTime(2026,4,20,8,30,0), StatusText="ปฏิเสธ", StatusClass="bg-label-danger" },
