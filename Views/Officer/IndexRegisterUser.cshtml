@section PageStyles {
<style>
    .reg-table-compact { font-size: 0.78rem; }
    .reg-table-compact th,
    .reg-table-compact td { padding: 0.45rem 0.5rem; vertical-align: middle; }
    .reg-table-compact .btn-icon { width: 1.65rem; height: 1.65rem; }
    .filter-action-buttons .btn-square {
        width: 48px; height: 48px; padding: 0;
        display: inline-flex; align-items: center; justify-content: center;
    }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    function filterRows() {
        var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var status = (document.getElementById('filterStatus').value || '').trim();
        var role = (document.getElementById('filterRole').value || '').trim();
        var rows = document.querySelectorAll('#regTableBody tr[data-id]');
        var count = 0;
        rows.forEach(function (row) {
            var text = (row.dataset.searchText || '').toLowerCase();
            var rowStatus = row.dataset.status || '';
            var rowRole = row.dataset.role || '';
            var show = (!keyword || text.includes(keyword)) && (!status || rowStatus === status) && (!role || rowRole === role);
            row.classList.toggle('d-none', !show);
            if (show) count++;
        });
        document.getElementById('regTableEmpty').classList.toggle('d-none', count !== 0);
    }
    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function () {
        document.getElementById('filterKeyword').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterRole').value = '';
        filterRows();
    });
    document.getElementById('filterKeyword').addEventListener('keydown', function (e) { if (e.key === 'Enter') filterRows(); });
    document.getElementById('filterStatus').addEventListener('change', filterRows);
    document.getElementById('filterRole').addEventListener('change', filterRows);

    // Approve button — open approval modal
    document.querySelectorAll('.btn-approve-reg').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var reqNo = this.dataset.reqNo;
            var fullName = this.dataset.fullName;
            var org = this.dataset.org;
            var reqRole = this.dataset.role;
            var reqAgency = this.dataset.agency || '';
            document.getElementById('approveModalReqNo').textContent = reqNo;
            document.getElementById('approveModalName').textContent = fullName;
            document.getElementById('approveModalOrg').textContent = org;
            // set role default from request
            document.getElementById('approveRoleAssign').value = (reqRole === 'เจ้าหน้าที่') ? 'เจ้าหน้าที่' : 'สมาชิก';
            document.getElementById('approveAgencyAssign').value = reqAgency;
            document.getElementById('approveOfficerSection').classList.toggle('d-none', reqRole !== 'เจ้าหน้าที่');
            document.getElementById('approveIsSignerToggle').checked = false;
            document.getElementById('approveIsApproverToggle').checked = false;
            document.querySelectorAll('.approve-specific-role').forEach(function(cb){ cb.checked = false; });
            document.getElementById('approveResponsibleArea').value = '';
            new bootstrap.Modal(document.getElementById('approveRegModal')).show();
        });
    });

    // Role select in approve modal toggles officer section
    document.getElementById('approveRoleAssign').addEventListener('change', function() {
        document.getElementById('approveOfficerSection').classList.toggle('d-none', this.value !== 'เจ้าหน้าที่');
    });

    // Reject button
    document.querySelectorAll('.btn-reject-reg').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById('rejectModalReqNo').textContent = this.dataset.reqNo;
            document.getElementById('rejectModalName').textContent = this.dataset.fullName;
            document.getElementById('rejectReason').value = '';
            new bootstrap.Modal(document.getElementById('rejectRegModal')).show();
        });
    });

    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) { new bootstrap.Tooltip(el); });
    }
});
</script>
}

@* ************** Content ************** *@
<h4 class="mb-1">ลงทะเบียนผู้ใช้งาน</h4>
<p class="mb-1">พิจารณาอนุมัติคำขอลงทะเบียนผู้ใช้งานระบบใบรับรองสัตว์น้ำ</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item"><a href="#" class="text-primary fw-semibold">เจ้าหน้าที่</a></li>
        <li class="breadcrumb-item active text-secondary">ลงทะเบียนผู้ใช้งาน</li>
    </ol>
</nav>

<!-- Summary Cards -->
