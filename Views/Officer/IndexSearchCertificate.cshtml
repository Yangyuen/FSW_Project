@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    // ── Flatpickr date range ──
    ['filterIssuedFrom', 'filterIssuedTo'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
    });

    // ── Tooltip ──
    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el) { new bootstrap.Tooltip(el); });
    }

    // ── Parse date dd/mm/yyyy ──
    function parseDate(val, endOfDay) {
        if (!val) return null;
        var p = val.split('/');
        if (p.length !== 3) return null;
        var d = new Date(parseInt(p[2]), parseInt(p[1]) - 1, parseInt(p[0]), endOfDay ? 23 : 0, endOfDay ? 59 : 0, endOfDay ? 59 : 0);
        return isNaN(d.getTime()) ? null : d;
    }

    // ── Filter ──
    function filterRows() {
        var keyword     = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var certType    = (document.getElementById('filterCertType').value || '').trim();
        var status      = (document.getElementById('filterStatus').value || '').trim();
        var country     = (document.getElementById('filterCountry').value || '').trim().toLowerCase();
        var fromDate    = parseDate(document.getElementById('filterIssuedFrom').value, false);
        var toDate      = parseDate(document.getElementById('filterIssuedTo').value, true);
        var rows        = document.querySelectorAll('#searchTableBody tr[data-cert-no]');
        var count       = 0;

        rows.forEach(function(row) {
            var text        = (row.dataset.searchText || '').toLowerCase();
            var rowType     = row.dataset.certType || '';
            var rowStatus   = row.dataset.status || '';
            var rowCountry  = (row.dataset.country || '').toLowerCase();
            var rowDate     = new Date(row.dataset.issuedDate || '');

            var keyOk     = !keyword  || text.includes(keyword);
            var typeOk    = !certType || rowType === certType;
            var statusOk  = !status   || rowStatus === status;
            var countryOk = !country  || rowCountry.includes(country);
            var dateOk    = (!fromDate && !toDate) ||
                            ((!fromDate || rowDate >= fromDate) && (!toDate || rowDate <= toDate));

            var show = keyOk && typeOk && statusOk && countryOk && dateOk;
            row.classList.toggle('d-none', !show);
            if (show) count++;
        });

        document.getElementById('searchTableEmpty').classList.toggle('d-none', count !== 0);
        document.getElementById('resultCount').textContent = count;
    }

    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function() {
        ['filterKeyword', 'filterIssuedFrom', 'filterIssuedTo'].forEach(function(id) {
            document.getElementById(id).value = '';
        });
        ['filterCertType', 'filterStatus', 'filterCountry'].forEach(function(id) {
            document.getElementById(id).value = '';
        });
        filterRows();
    });

    ['filterCertType', 'filterStatus', 'filterCountry'].forEach(function(id) {
        document.getElementById(id).addEventListener('change', filterRows);
    });
    document.getElementById('filterKeyword').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') filterRows();
    });
    ['filterIssuedFrom', 'filterIssuedTo'].forEach(function(id) {
        document.getElementById(id).addEventListener('change', filterRows);
    });
});
</script>
}

