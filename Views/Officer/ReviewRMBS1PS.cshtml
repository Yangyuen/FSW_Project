@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {

        var btnApprove = document.getElementById('btnApprove');
        var btnReject  = document.getElementById('btnReject');

        // ── อนุมัติ ──
        btnApprove.addEventListener('click', function () {
            new bootstrap.Modal(document.getElementById('modalConfirmApprove')).show();
        });

        document.getElementById('btnConfirmApprove').addEventListener('click', function () {
            // TODO: submit form or call API
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmApprove')).hide();
            showToast('อนุมัติเอกสารเรียบร้อยแล้ว', 'success');
        });

        // ── ไม่อนุมัติ ──
        btnReject.addEventListener('click', function () {
            var rejectEl = document.getElementById('rejectRemark');
            rejectEl.classList.remove('is-invalid');
            rejectEl.value = '';
            new bootstrap.Modal(document.getElementById('modalConfirmReject')).show();
        });

        document.getElementById('btnConfirmReject').addEventListener('click', function () {
            var rejectEl = document.getElementById('rejectRemark');
            if (!rejectEl.value.trim()) {
                rejectEl.classList.add('is-invalid');
                rejectEl.focus();
                return;
            }
            // TODO: submit form or call API
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmReject')).hide();
            showToast('ไม่อนุมัติเอกสารเรียบร้อยแล้ว', 'danger');
        });

        document.getElementById('rejectRemark').addEventListener('input', function () {
            if (this.value.trim()) this.classList.remove('is-invalid');
        });

        // ── Toast helper ──
        function showToast(msg, type) {
            var bg = type === 'success' ? 'bg-success' : type === 'danger' ? 'bg-danger' : type === 'warning' ? 'bg-warning' : 'bg-info';
            var icon = type === 'success' ? 'ri-checkbox-circle-line' : type === 'danger' ? 'ri-close-circle-line' : type === 'warning' ? 'ri-reply-line' : 'ri-information-line';
            var toastEl = document.createElement('div');
            toastEl.className = 'position-fixed bottom-0 end-0 p-3' ;
            toastEl.style.zIndex = 9999;
            toastEl.innerHTML =
                '<div class="toast show align-items-center text-white ' + bg + ' border-0" role="alert">' +
                '  <div class="d-flex">' +
                '    <div class="toast-body d-flex align-items-center gap-2">' +
                '      <i class="ri ' + icon + ' fs-5"></i> ' + msg +
                '    </div>' +
                '    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                '  </div>' +
                '</div>';
            document.body.appendChild(toastEl);
            setTimeout(function () { toastEl.remove(); }, 3500);
        }

    });
</script>
}
