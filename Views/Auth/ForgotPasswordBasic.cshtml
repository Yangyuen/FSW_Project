@{
  Layout = "_BlankLayout";
  ViewData["Title"] = "ลืมรหัสผ่าน — DPIM Portal";
}

@section PageStyles {
<link rel="stylesheet" href="~/vendor/css/pages/page-auth.css" />
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  html, body { height:100%; }
  .authentication-wrapper.authentication-cover { min-height:100vh; max-height:100vh; overflow:hidden; }
  .authentication-inner { height:100vh; }
  .dpim-banner-left { width:100%; height:100%; object-fit:cover; object-position:70% center; }
  .dpim-cover-left { position:relative; overflow:hidden; }
  .dpim-cover-left::after {
    content:""; position:absolute; inset:0;
    pointer-events:none;
  }
  .dpim-brand-logo { width:80px; height:80px; object-fit:contain; }
  .dpim-brand-divider { width:40px; height:3px; background:var(--dpim-green); border-radius:2px; margin:.5rem auto .65rem; }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; border-color:#1b3175; color:#fff; }
  .method-tab { border:none; background:none; padding:.55rem 1.25rem; border-radius:30px; font-size:.88rem; font-weight:500; color:#6c757d; cursor:pointer; transition:all .18s; }
  .method-tab.active { background:var(--dpim-blue); color:#fff; }
  .method-pane { display:none; }
  .method-pane.active { display:block; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.method-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.method-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.method-pane').forEach(p => p.classList.remove('active'));
      this.classList.add('active');
      document.getElementById(this.dataset.target).classList.add('active');
    });
  });

  document.getElementById('btnSendEmail')?.addEventListener('click', function (e) {
    e.preventDefault();
    var email = document.getElementById('fpEmail').value;
    if (!email) { document.getElementById('fpEmail').focus(); return; }
    alert('(Mock) ส่งลิงก์รีเซ็ตรหัสผ่านไปยัง ' + email + ' แล้ว กรุณาตรวจสอบอีเมล');
  });

  document.getElementById('btnSendSMS')?.addEventListener('click', function (e) {
    e.preventDefault();
    alert('(Mock) ส่ง OTP ทาง SMS ไปยังเบอร์ที่ลงทะเบียนไว้แล้ว');
  });
});
</script>
}

@* ============================================================ *@
<div class="authentication-wrapper authentication-cover">
  <a href="/" class="auth-cover-brand d-flex align-items-center gap-2">
    <img src="~/img/dpim-logo.png" alt="DPIM Logo" style="width:48px;height:48px;object-fit:contain;" />
    <span class="fw-semibold d-none d-sm-inline" style="color:var(--dpim-blue);">DPIM Portal</span>
  </a>

  <div class="authentication-inner row m-0">
    <!-- Left: Banner -->
    <div class="d-none d-lg-flex col-lg-7 col-xl-8 p-0 dpim-cover-left">
      <img src="~/img/dpim-banner.jpg" alt="Mining for the Community" class="dpim-banner-left" />
    </div>

    <!-- Right: Form -->
    <div class="d-flex col-12 col-lg-5 col-xl-4 align-items-center authentication-bg position-relative px-4 px-sm-5" style="overflow-y:auto;">
      <div class="w-100 mx-auto py-4" style="max-width:380px;">

        <div class="text-center mb-4">
          <img src="~/img/dpim-logo.png" alt="กพร." class="dpim-brand-logo mb-2" />
          <h5 class="fw-bold mb-0" style="color:var(--dpim-blue);">กรมอุตสาหกรรมพื้นฐานและการเหมืองแร่</h5>
          <div class="dpim-brand-divider"></div>
          <p class="text-muted mb-0" style="font-size:.78rem;">MINING FOR THE COMMUNITY</p>
        </div>

        <h6 class="fw-bold mb-1 text-center">ลืมรหัสผ่าน?</h6>
        <p class="text-muted text-center mb-4" style="font-size:.85rem;">เลือกวิธีรับรหัสเพื่อรีเซ็ตรหัสผ่านของท่าน</p>

        <!-- Method Tabs -->
        <div class="d-flex gap-2 mb-4 p-1" style="background:#f1f5fb;border-radius:30px;">
          <button class="method-tab active flex-fill" data-target="paneEmailFP">
            <i class="ri ri-mail-line me-1"></i>อีเมล
          </button>
          <button class="method-tab flex-fill" data-target="paneSMS">
            <i class="ri ri-smartphone-line me-1"></i>SMS OTP
          </button>
        </div>

        <!-- Email Pane -->
        <div id="paneEmailFP" class="method-pane active">
          <p class="text-muted mb-3" style="font-size:.83rem;">กรอกอีเมลที่ลงทะเบียนไว้ ระบบจะส่งลิงก์รีเซ็ตรหัสผ่านให้</p>
          <div class="form-floating form-floating-outline mb-4">
            <input type="email" class="form-control" id="fpEmail" placeholder="อีเมล" />
            <label for="fpEmail">อีเมล</label>
          </div>
          <button id="btnSendEmail" class="btn btn-dpim w-100 mb-3">
            <i class="ri ri-send-plane-line me-1"></i>ส่งลิงก์รีเซ็ตรหัสผ่าน
          </button>
        </div>

        <!-- SMS Pane -->
        <div id="paneSMS" class="method-pane">
          <p class="text-muted mb-3" style="font-size:.83rem;">ระบบจะส่ง OTP ทาง SMS ไปยังเบอร์โทรที่ลงทะเบียนไว้</p>
          <div class="alert mb-3 d-flex align-items-center gap-2" style="background:#e8f5e9;border:none;border-radius:8px;padding:.6rem .9rem;font-size:.82rem;">
            <i class="ri ri-smartphone-line" style="font-size:1.2rem;color:var(--dpim-green);"></i>
            <span>เบอร์โทร: <strong>06x-xxx-x890</strong></span>
          </div>
          <button id="btnSendSMS" class="btn btn-dpim w-100 mb-3">
            <i class="ri ri-message-2-line me-1"></i>ส่ง OTP ทาง SMS
          </button>
        </div>

        <div class="text-center">
          <a href="/Auth/LoginBasic" class="d-flex align-items-center justify-content-center gap-1" style="font-size:.85rem;color:var(--dpim-blue);">
            <i class="ri ri-arrow-left-line"></i>กลับหน้าเข้าสู่ระบบ
          </a>
        </div>

      </div>
    </div>
    <!-- /Right -->
  </div>
</div>
