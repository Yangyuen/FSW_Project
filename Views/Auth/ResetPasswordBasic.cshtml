@{
  Layout = "_BlankLayout";
  ViewData["Title"] = "ตั้งรหัสผ่านใหม่ — DPIM Portal";
}

@section PageStyles {
<link rel="stylesheet" href="~/vendor/css/pages/page-auth.css" />
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  html, body { height:100%; }
  .authentication-wrapper.authentication-cover { min-height:100vh; max-height:100vh; overflow:hidden; }
  .authentication-inner { height:100vh; }
  .dpim-banner-left { width:100%; height:100%; object-fit:cover; object-position:70% center; }
  .dpim-cover-left { position:relative; overflow:hidden; }
  .dpim-cover-left::after {
    content:""; position:absolute; inset:0;
    pointer-events:none;
  }
  .dpim-brand-logo { width:80px; height:80px; object-fit:contain; }
  .dpim-brand-divider { width:40px; height:3px; background:var(--dpim-green); border-radius:2px; margin:.5rem auto .65rem; }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; border-color:#1b3175; color:#fff; }
  /* Password strength bar */
  .strength-bar { height:5px; border-radius:3px; background:#e9ecef; margin-top:.5rem; }
  .strength-bar-fill { height:100%; border-radius:3px; transition:width .3s, background .3s; }
  .rule-item { display:flex; align-items:center; gap:.4rem; font-size:.78rem; color:#6c757d; }
  .rule-item.pass { color:var(--dpim-green); }
  .rule-item.pass i { color:var(--dpim-green); }
  .rule-item i { color:#adb5bd; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
  var pwInput = document.getElementById('newPassword');
  var pw2Input = document.getElementById('confirmPassword');
  var strengthFill = document.getElementById('strengthFill');
  var strengthLabel = document.getElementById('strengthLabel');
  var btnSet = document.getElementById('btnSetPassword');

  // Show/hide toggle
  document.querySelectorAll('.pw-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var inp = this.previousElementSibling.querySelector('input') || this.closest('.input-group').querySelector('input');
      inp.type = inp.type === 'password' ? 'text' : 'password';
      this.querySelector('i').classList.toggle('bx-show');
      this.querySelector('i').classList.toggle('bx-hide');
    });
  });

  // Strength checker
  var rules = {
    len: { el: document.getElementById('ruleLen'), fn: function (v) { return v.length >= 8; } },
    upper: { el: document.getElementById('ruleUpper'), fn: function (v) { return /[A-Z]/.test(v); } },
    num: { el: document.getElementById('ruleNum'), fn: function (v) { return /[0-9]/.test(v); } },
    sym: { el: document.getElementById('ruleSym'), fn: function (v) { return /[^A-Za-z0-9]/.test(v); } },
  };
  var colors = ['#dc3545', '#fd7e14', '#ffc107', '#41AD49'];
  var labels = ['อ่อนมาก', 'อ่อน', 'ปานกลาง', 'แข็งแกร่ง'];

  pwInput?.addEventListener('input', function () {
    var v = this.value;
    var score = Object.values(rules).filter(function (r) { return r.fn(v); }).length;
    Object.values(rules).forEach(function (r) {
      r.el?.classList.toggle('pass', r.fn(v));
      r.el?.querySelector('i')?.setAttribute('class', r.fn(v) ? 'ri ri-checkbox-circle-line' : 'ri ri-checkbox-blank-circle-line');
    });
    if (!v) { strengthFill.style.width = '0'; strengthLabel.textContent = ''; return; }
    strengthFill.style.width = (score * 25) + '%';
    strengthFill.style.background = colors[score - 1] || colors[0];
    strengthLabel.textContent = labels[score - 1] || labels[0];
    strengthLabel.style.color = colors[score - 1] || colors[0];
  });

  btnSet?.addEventListener('click', function (e) {
    e.preventDefault();
    if (!pwInput.value || pwInput.value !== pw2Input.value) {
      alert('รหัสผ่านไม่ตรงกัน กรุณาตรวจสอบอีกครั้ง'); return;
    }
    var score = Object.values(rules).filter(function (r) { return r.fn(pwInput.value); }).length;
    if (score < 3) { alert('รหัสผ่านต้องมีความปลอดภัยอย่างน้อยระดับ "ปานกลาง"'); return; }
    alert('(Mock) ตั้งรหัสผ่านใหม่สำเร็จ! กำลังนำไปยังหน้า Login...');
    window.location.href = '/Auth/LoginBasic';
  });
});
</script>
}

@* ============================================================ *@
<div class="authentication-wrapper authentication-cover">
  <a href="/" class="auth-cover-brand d-flex align-items-center gap-2">
    <img src="~/img/dpim-logo.png" alt="DPIM Logo" style="width:48px;height:48px;object-fit:contain;" />
    <span class="fw-semibold d-none d-sm-inline" style="color:var(--dpim-blue);">DPIM Portal</span>
  </a>

  <div class="authentication-inner row m-0">
    <!-- Left: Banner -->
    <div class="d-none d-lg-flex col-lg-7 col-xl-8 p-0 dpim-cover-left">
      <img src="~/img/dpim-banner.jpg" alt="Mining for the Community" class="dpim-banner-left" />
    </div>

    <!-- Right: Form -->
    <div class="d-flex col-12 col-lg-5 col-xl-4 align-items-center authentication-bg position-relative px-4 px-sm-5" style="overflow-y:auto;">
      <div class="w-100 mx-auto py-4" style="max-width:380px;">

        <div class="text-center mb-4">
          <img src="~/img/dpim-logo.png" alt="กพร." class="dpim-brand-logo mb-2" />
          <h5 class="fw-bold mb-0" style="color:var(--dpim-blue);">กรมอุตสาหกรรมพื้นฐานและการเหมืองแร่</h5>
          <div class="dpim-brand-divider"></div>
          <p class="text-muted mb-0" style="font-size:.78rem;">MINING FOR THE COMMUNITY</p>
        </div>

        <h6 class="fw-bold mb-1 text-center">ตั้งรหัสผ่านใหม่</h6>
        <p class="text-muted text-center mb-4" style="font-size:.85rem;">รหัสผ่านใหม่ต้องแตกต่างจากที่เคยใช้งาน</p>

        <!-- New Password -->
        <label class="form-label fw-semibold" style="font-size:.85rem;">รหัสผ่านใหม่ <span class="text-danger">*</span></label>
        <div class="input-group input-group-merge mb-1">
          <div class="form-floating form-floating-outline flex-grow-1">
            <input type="password" class="form-control" id="newPassword" placeholder="รหัสผ่านใหม่" />
            <label for="newPassword">รหัสผ่านใหม่</label>
          </div>
          <span class="input-group-text cursor-pointer pw-toggle">
            <i class="ri ri-eye-off-line"></i>
          </span>
        </div>
        <!-- Strength bar -->
        <div class="strength-bar mb-1"><div id="strengthFill" class="strength-bar-fill" style="width:0;"></div></div>
        <div class="d-flex justify-content-end mb-2"><span id="strengthLabel" style="font-size:.75rem;font-weight:600;"></span></div>

        <!-- Rules -->
        <div class="mb-3 p-2" style="background:#f8f9fa;border-radius:8px;">
          <div class="rule-item mb-1" id="ruleLen"><i class="ri ri-checkbox-blank-circle-line"></i>อย่างน้อย 8 ตัวอักษร</div>
          <div class="rule-item mb-1" id="ruleUpper"><i class="ri ri-checkbox-blank-circle-line"></i>มีอักษรพิมพ์ใหญ่ (A-Z)</div>
          <div class="rule-item mb-1" id="ruleNum"><i class="ri ri-checkbox-blank-circle-line"></i>มีตัวเลข (0-9)</div>
          <div class="rule-item" id="ruleSym"><i class="ri ri-checkbox-blank-circle-line"></i>มีอักขระพิเศษ (@@, #, !, เป็นต้น)</div>
        </div>

        <!-- Confirm Password -->
        <label class="form-label fw-semibold" style="font-size:.85rem;">ยืนยันรหัสผ่าน <span class="text-danger">*</span></label>
        <div class="input-group input-group-merge mb-4">
          <div class="form-floating form-floating-outline flex-grow-1">
            <input type="password" class="form-control" id="confirmPassword" placeholder="ยืนยันรหัสผ่าน" />
            <label for="confirmPassword">ยืนยันรหัสผ่าน</label>
          </div>
          <span class="input-group-text cursor-pointer pw-toggle">
            <i class="ri ri-eye-off-line"></i>
          </span>
        </div>

        <button id="btnSetPassword" class="btn btn-dpim w-100 mb-3">
          <i class="ri ri-lock-unlock-line me-1"></i>ตั้งรหัสผ่านใหม่
        </button>

        <div class="text-center">
          <a href="/Auth/LoginBasic" class="d-flex align-items-center justify-content-center gap-1" style="font-size:.85rem;color:var(--dpim-blue);">
            <i class="ri ri-arrow-left-line"></i>กลับหน้าเข้าสู่ระบบ
          </a>
        </div>

      </div>
    </div>
    <!-- /Right -->
  </div>
</div>
