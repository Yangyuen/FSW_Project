@{
  Layout = "_BlankLayout";
  ViewData["Title"] = "ลงทะเบียนสมาชิก — DPIM Portal";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
<link rel="stylesheet" href="~/vendor/libs/dropzone/dropzone.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/cleave-zen/cleave-zen.js"></script>
<script src="~/vendor/libs/select2/select2.js"></script>
<script src="~/vendor/libs/dropzone/dropzone.js"></script>
}

@section PageStyles {
<link rel="stylesheet" href="~/vendor/css/pages/page-auth.css" />
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  html, body { height:100%; margin:0; }
  .reg-wrapper { display:flex; min-height:100vh; flex-direction:column; background:var(--bs-body-bg); }

  /* Top bar */
  .reg-topbar {
    display:flex; align-items:center; gap:.75rem;
    padding:.85rem 1.5rem;
    background:var(--bs-card-bg);
    border-bottom:1px solid var(--bs-border-color);
    position:sticky; top:0; z-index:100;
  }

  /* Main area */
  .reg-main { display:flex; flex:1; overflow:hidden; }

  /* Left panel — vertical steps */
  .reg-steps-panel {
    width:260px; min-width:260px;
    background:var(--bs-card-bg);
    border-right:1px solid var(--bs-border-color);
    padding:1.5rem 1.25rem;
    overflow-y:auto;
  }
  @@media(max-width:767px){ .reg-steps-panel { display:none; } }

  .vstep-list { list-style:none; padding:0; margin:0; }
  .vstep-item { display:flex; gap:.9rem; position:relative; }
  .vstep-item:not(:last-child)::before {
    content:"";
    position:absolute;
    left:15px; top:32px;
    width:2px; bottom:-12px;
    background:var(--bs-border-color);
  }
  .vstep-item.active::before { background:var(--dpim-blue); }
  .vstep-item.done::before { background:var(--dpim-green); }

  .vstep-dot {
    width:32px; height:32px; min-width:32px; border-radius:50%;
    border:2px solid var(--bs-border-color);
    display:flex; align-items:center; justify-content:center;
    font-size:.8rem; font-weight:700; color:var(--bs-secondary-color);
    background:var(--bs-body-bg); z-index:1; margin-top:2px;
  }
  .vstep-item.active .vstep-dot {
    border-color:var(--dpim-blue); background:var(--dpim-blue); color:#fff;
  }
  .vstep-item.done .vstep-dot {
    border-color:var(--dpim-green); background:var(--dpim-green); color:#fff;
  }
  .vstep-info { padding-bottom:1.5rem; }
  .vstep-title { font-weight:600; font-size:.88rem; color:var(--bs-heading-color); }
  .vstep-sub { font-size:.78rem; color:var(--bs-secondary-color); }
  .vstep-item.active .vstep-title { color:var(--dpim-blue); }
  .vstep-item.done .vstep-title { color:var(--dpim-green); }

  /* Right: content */
  .reg-content-area {
    flex:1; overflow-y:auto;
    padding:2rem 2.5rem;
    display:flex; flex-direction:column; align-items:center;
  }
  @@media(max-width:767px){ .reg-content-area { padding:1.25rem; } }
  .reg-step-content { width:100%; max-width:680px; }
  .reg-step-content > .step-pane { display:none; }
  .reg-step-content > .step-pane.active { display:block; }

  /* Terms scroll box */
  .terms-box {
    height:340px; overflow-y:auto;
    border:1px solid var(--bs-border-color);
    border-radius:8px; padding:1.25rem 1.5rem;
    font-size:.875rem; line-height:1.8;
    background:var(--bs-body-bg);
  }
  .terms-box::-webkit-scrollbar { width:6px; }
  .terms-box::-webkit-scrollbar-thumb { background:var(--bs-border-color); border-radius:3px; }

  /* Dropzone */
  .dropzone-dpim {
    border:2px dashed var(--bs-border-color); border-radius:8px;
    padding:2rem; text-align:center; cursor:pointer;
    background:var(--bs-body-bg); transition:border-color .2s;
  }
  .dropzone-dpim:hover,.dropzone-dpim.dz-drag-hover { border-color:var(--bs-primary); }
  .dropzone-dpim .dz-message { margin:0; }
  .doc-hint { background:var(--bs-light); border-left:3px solid var(--bs-primary); padding:.75rem 1rem; border-radius:4px; font-size:.875rem; }

  /* step nav bottom */
  .step-nav { display:flex; justify-content:space-between; align-items:center; margin-top:1.75rem; padding-top:1.25rem; border-top:1px solid var(--bs-border-color); }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ---- State ---- */
  let currentStep = 0;
  const totalSteps = 5;

  const stepPanes  = document.querySelectorAll('.step-pane');
  const vstepItems = document.querySelectorAll('.vstep-item');

  function goTo(n) {
    if (n < 0 || n >= totalSteps) return;
    stepPanes.forEach((p, i)  => p.classList.toggle('active', i === n));
    vstepItems.forEach((el, i) => {
      el.classList.toggle('active', i === n);
      el.classList.toggle('done',   i < n);
    });
    currentStep = n;
    window.scrollTo(0, 0);
    document.querySelector('.reg-content-area')?.scrollTo(0, 0);
  }

  document.querySelectorAll('[data-step-next]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (currentStep === 0) {
        if (!document.getElementById('agreeTerms').checked) {
          document.getElementById('termsAlert').classList.remove('d-none');
          return;
        }
        document.getElementById('termsAlert').classList.add('d-none');
      }
      if (currentStep === 3) { updateReview(); }
      goTo(currentStep + 1);
    });
  });
  document.querySelectorAll('[data-step-prev]').forEach(btn => {
    btn.addEventListener('click', () => goTo(currentStep - 1));
  });

  /* ---- Terms scroll detection ---- */
  const termsBox = document.getElementById('termsBox');
  const scrollNote = document.getElementById('termsScrollNote');
  if (termsBox) {
    termsBox.addEventListener('scroll', function () {
      if (this.scrollTop + this.clientHeight >= this.scrollHeight - 20) {
        if (scrollNote) scrollNote.style.display = 'none';
      }
    });
  }

  /* ---- Member type ---- */
  const memberTypeSelect = document.getElementById('memberType');
  const prefixWrap = document.getElementById('prefixWrap');
  const docHintEl  = document.getElementById('docHint');
  const docHints = {
    'บุคคลธรรมดา': '<strong>เอกสารที่ต้องแนบ:</strong><ul class="mb-0 ps-3 mt-1"><li>สำเนาบัตรประชาชน</li><li>สำเนาทะเบียนบ้าน</li></ul>',
    'นิติบุคคล': '<strong>เอกสารที่ต้องแนบ:</strong><ul class="mb-0 ps-3 mt-1"><li>หนังสือรับรองบริษัท (ไม่เกิน 3 เดือน)</li><li>สำเนาบัตรประชาชนผู้มีอำนาจ</li><li>หนังสือมอบอำนาจ (ถ้ามี)</li></ul>',
    'วิสาหกิจชุมชน': '<strong>เอกสารที่ต้องแนบ:</strong><ul class="mb-0 ps-3 mt-1"><li>หนังสือรับรองวิสาหกิจ</li><li>สำเนาบัตรประชาชนประธาน</li></ul>'
  };
  function updateMemberType(val) {
    if (prefixWrap) prefixWrap.style.display = val === 'บุคคลธรรมดา' ? '' : 'none';
    if (docHintEl)  docHintEl.innerHTML = docHints[val] || '<span class="text-muted">กรุณาเลือกประเภทสมาชิกก่อน</span>';
  }
  if (memberTypeSelect) {
    memberTypeSelect.addEventListener('change', () => updateMemberType(memberTypeSelect.value));
    if (typeof $ !== 'undefined') {
      $(memberTypeSelect).on('select2:select', e => updateMemberType(e.params.data.text));
    }
  }

  /* ---- Duplicate ID check (mock) ---- */
  const idInput  = document.getElementById('idNumber');
  const idAlert  = document.getElementById('idDuplicateAlert');
  const MOCK_DUP = ['1234567890123'];
  if (idInput) {
    idInput.addEventListener('blur', function () {
      const v = this.value.replace(/\D/g, '');
      idAlert?.classList.toggle('d-none', !(v.length === 13 && MOCK_DUP.includes(v)));
    });
  }

  /* ---- Review summary ---- */
  function updateReview() {
    const g = id => (document.getElementById(id)?.value || '');
    const typeEl = document.getElementById('memberType');
    document.getElementById('rv-memberType').textContent = typeEl?.options[typeEl.selectedIndex]?.text || '—';
    const px = document.getElementById('prefix');
    const pxText = px ? (px.options[px.selectedIndex]?.text || '') : '';
    document.getElementById('rv-name').textContent = (pxText + ' ' + g('firstName') + ' ' + g('lastName')).trim() || '—';
    document.getElementById('rv-idNumber').textContent = g('idNumber') || '—';
    document.getElementById('rv-email').textContent    = g('email') || '—';
    document.getElementById('rv-phone').textContent    = g('phone') || '—';
  }

  /* ---- Submit (mock) ---- */
  document.getElementById('btnSubmitReg')?.addEventListener('click', () => goTo(4));

  /* ---- Copy ref ---- */
  document.getElementById('btnCopyRef')?.addEventListener('click', function () {
    navigator.clipboard?.writeText('REG-2569-00001');
    this.textContent = 'คัดลอกแล้ว!';
    setTimeout(() => { this.textContent = 'คัดลอก'; }, 2000);
  });

  /* ---- Select2 ---- */
  if (typeof $ !== 'undefined' && $.fn.select2) {
    $('#memberType, #prefix').select2({ dropdownParent: document.body });
  }

  /* ---- Dropzone ---- */
  if (typeof Dropzone !== 'undefined') {
    Dropzone.autoDiscover = false;
    new Dropzone('#dropzoneArea', {
      url: '#', maxFilesize: 5, acceptedFiles: '.pdf,.jpg,.jpeg,.png',
      dictDefaultMessage: '',
      autoProcessQueue: false
    });
  }

  goTo(0);
});
</script>
}

@* ============================================================ *@
<div class="reg-wrapper">

  <!-- Top bar -->
  <div class="reg-topbar">
    <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
      <img src="~/img/dpim-logo.png" alt="DPIM" style="width:36px;height:36px;object-fit:contain;" />
      <span class="fw-bold" style="color:var(--dpim-blue);font-size:.95rem;">DPIM Portal</span>
    </a>
    <span class="ms-3 text-muted" style="font-size:.85rem;">ลงทะเบียนสมาชิก — Mining Account</span>
    <a href="/Auth/RegisterChannel" class="btn btn-sm btn-outline-secondary ms-auto">
      <i class="ri ri-close-line"></i> ยกเลิก
    </a>
  </div>

  <div class="reg-main">

    <!-- ====== Left: Vertical Steps ====== -->
    <div class="reg-steps-panel">
      <p class="text-uppercase fw-semibold mb-3" style="font-size:.72rem;letter-spacing:.08em;color:var(--bs-secondary-color);">ขั้นตอนการลงทะเบียน</p>
      <ul class="vstep-list">
        <li class="vstep-item" data-vstep="0">
          <div class="vstep-dot">01</div>
          <div class="vstep-info">
            <div class="vstep-title">ข้อตกลงและเงื่อนไข</div>
            <div class="vstep-sub">อ่านและยอมรับข้อตกลง</div>
          </div>
        </li>
        <li class="vstep-item" data-vstep="1">
          <div class="vstep-dot">02</div>
          <div class="vstep-info">
            <div class="vstep-title">ข้อมูลพื้นฐาน</div>
            <div class="vstep-sub">กรอกข้อมูลสมาชิก</div>
          </div>
        </li>
        <li class="vstep-item" data-vstep="2">
          <div class="vstep-dot">03</div>
          <div class="vstep-info">
            <div class="vstep-title">แนบเอกสาร</div>
            <div class="vstep-sub">อัปโหลดเอกสารประกอบ</div>
          </div>
        </li>
        <li class="vstep-item" data-vstep="3">
          <div class="vstep-dot">04</div>
          <div class="vstep-info">
            <div class="vstep-title">ตรวจสอบ</div>
            <div class="vstep-sub">ทบทวนและยืนยัน</div>
          </div>
        </li>
        <li class="vstep-item" data-vstep="4">
          <div class="vstep-dot">05</div>
          <div class="vstep-info">
            <div class="vstep-title">สำเร็จ</div>
            <div class="vstep-sub">การลงทะเบียนเสร็จสิ้น</div>
          </div>
        </li>
      </ul>
    </div>
    <!-- /Left -->

    <!-- ====== Right: Content ====== -->
    <div class="reg-content-area">
      <div class="reg-step-content">

        <!-- header brand (mobile only banner) -->
        <div class="text-center mb-5 d-lg-none">
          <img src="~/img/dpim-logo.png" alt="กพร." style="width:56px;height:56px;object-fit:contain;" class="mb-2" />
          <h5 class="fw-bold mb-0">ลงทะเบียนสมาชิก</h5>
          <p class="text-muted small">กรมอุตสาหกรรมพื้นฐานและการเหมืองแร่ (กพร.)</p>
        </div>

        <!-- ===== STEP 0: ข้อตกลงและเงื่อนไข ===== -->
        <div class="step-pane" id="pane-0">
          <div class="mb-4">
            <h5 class="fw-bold mb-1"><i class="ri ri-file-text-line me-2 text-primary"></i>ข้อตกลงและเงื่อนไข</h5>
            <p class="text-muted mb-0" style="font-size:.87rem;">การขอรับชื่อผู้ใช้และรหัสผ่าน (Username &amp; Password) และการใช้บริการระบบลงทะเบียนผู้ใช้งานอิเล็กทรอนิกส์ (Mining Account) ของกรมอุตสาหกรรมพื้นฐานและการเหมืองแร่</p>
          </div>

          <div id="termsBox" class="terms-box mb-2">
            <p style="font-size:.83rem;color:var(--bs-secondary-color);">ข้าพเจ้าผู้สมัครขอรับชื่อผู้ใช้และรหัสผ่าน (Username &amp; Password) สำหรับการใช้งานระบบลงทะเบียนผู้ใช้งานอิเล็กทรอนิกส์ (Mining Account) โดยตกลงและยินยอมผูกพันและปฏิบัติตามข้อตกลงและเงื่อนไขดังต่อไปนี้ทุกประการ</p>
            <p><strong>ข้อ 1</strong> ข้อตกลงและเงื่อนไขนี้ใช้บังคับระหว่าง กรมอุตสาหกรรมพื้นฐานและการเหมืองแร่ ซึ่งต่อไปนี้จะเรียกว่า "กรม" กับผู้สมัครขอรับชื่อผู้ใช้และรหัสผ่าน (Username &amp; Password) เพื่อใช้บริการระบบลงทะเบียนผู้ใช้งานอิเล็กทรอนิกส์ (Mining Account) ซึ่งต่อไปนี้จะเรียกว่า "ผู้รับบริการ"</p>
            <p><strong>ข้อ 2</strong> ผู้รับบริการ จะต้องกรอกหรือระบุข้อมูลรายละเอียดต่าง ๆ ตามความเป็นจริงให้ครบถ้วน ทั้งนี้ เพื่อประโยชน์แก่ผู้รับบริการ และผู้รับบริการตกลงยินยอมให้ กรม ตรวจสอบความถูกต้องและเปิดเผยข้อมูลตามที่ได้ระบุไว้ หากตรวจพบว่าข้อมูลของผู้รับบริการไม่เป็นความจริง กรมอาจระงับหรือยกเลิกสิทธิการใช้งานของผู้รับบริการได้โดยไม่ต้องแจ้งให้ทราบล่วงหน้า และผู้รับบริการจะต้องรับผิดชอบในความเสียหายที่เกิดขึ้นจากการกรอกข้อมูลอันเป็นเท็จดังกล่าว</p>
            <p><strong>ข้อ 3</strong> เมื่อผู้รับบริการทำการกรอกข้อมูลรายละเอียดต่าง ๆ เรียบร้อยแล้ว ให้ผู้รับบริการดำเนินการยืนยันตัวผ่านช่องทางใดช่องทางหนึ่ง ได้แก่</p>
            <p><u>กรณีบุคคลธรรมดา</u></p>
            <ol>
              <li>ยืนยันตัวตนต่อหน้าเจ้าหน้าที่ด้วยตนเอง โดยแสดงบัตรประจำตัวประชาชนที่ยังไม่หมดอายุ</li>
              <li>ยืนยันตัวตนผ่านระบบอิเล็กทรอนิกส์ (Electronic Know Your Customer : e-KYC) โดยใช้บัตรประจำตัวประชาชน ประกอบกับการถ่ายภาพใบหน้าด้วยตัวเอง (Selfie)</li>
              <li>ยืนยันตัวตนโดยใช้ใบรับรองอิเล็กทรอนิกส์ที่ได้รับจากกรมออกใบรับรองอิเล็กทรอนิกส์ (Certification Authority : CA)</li>
              <li>มอบอำนาจให้บุคคลธรรมดาที่มีสัญชาติไทยเป็นผู้ดำเนินการยื่นเอกสารยืนยันตัวตนแทน โดยสั่งพิมพ์ (Print out) คำขอรับชื่อผู้ใช้และรหัสผ่าน เพื่อทำการลงลายมือชื่อผู้รับบริการ ผู้รับมอบอำนาจ และพยานอย่างน้อยหนึ่งคนแล้วนำไปยื่นต่อเจ้าหน้าที่พร้อมแนบเอกสารประกอบตามที่กำหนดไว้</li>
            </ol>
            <p>กรณีผู้รับบริการสมัครเป็นผู้แทน จะไม่สามารถยืนยันตัวตนผ่านช่องทางตาม (4) ได้</p>
            <p><u>กรณีนิติบุคคล</u></p>
            <ol>
              <li>ยืนยันตัวตนโดยใช้ใบรับรองอิเล็กทรอนิกส์ที่ได้รับจากกรมออกใบรับรองอิเล็กทรอนิกส์ (Certification Authority : CA)</li>
              <li>สั่งพิมพ์ (Print out) คำขอรับชื่อผู้ใช้และรหัสผ่าน เพื่อทำการลงลายมือชื่อ พร้อมแนบเอกสารดังนี้
                <ol type="a">
                  <li>หนังสือรับรองการจดทะเบียนนิติบุคคล (ออกให้ไม่เกิน 6 เดือน)</li>
                  <li>หนังสือบริคณห์สนธิ (ออกให้ไม่เกิน 6 เดือน)</li>
                  <li>บอจ.5 สำเนารายชื่อผู้ถือหุ้น (ออกให้ไม่เกิน 6 เดือน)</li>
                  <li>สำเนาบัตรประจำตัวประชาชนพร้อมเซ็นรับรองสำเนาถูกต้องของกรรมการผู้มีอำนาจลงนาม</li>
                  <li>หนังสือมอบอำนาจ และบัตรประจำตัวประชาชนของผู้รับมอบอำนาจ (ถ้ามี)</li>
                </ol>
              </li>
            </ol>
            <p>ทั้งนี้ เมื่อเจ้าหน้าที่ได้ตรวจสอบข้อมูลและอนุมัติแล้ว ระบบจะแจ้งให้ผู้รับบริการยืนยันการเปิดใช้งาน (Activate User) ทางอีเมล ภายใน 30 วันนับแต่วันที่ได้รับแจ้ง</p>
            <p><strong>ข้อ 4</strong> ผู้รับบริการต้องไม่นำชื่อผู้ใช้และรหัสผ่าน (Username &amp; Password) ไปใช้ในทางที่ขัดต่อกฎหมาย และความสงบเรียบร้อย หรือศีลธรรมอันดีของประชาชน</p>
            <p><strong>ข้อ 5</strong> ผู้รับบริการตกลงและเข้าใจดีว่า การสร้างลายมือชื่ออิเล็กทรอนิกส์ด้วยการใช้ชื่อผู้ใช้ (Username) จะต้องใช้คู่กับรหัสผ่าน (Password) ซึ่งผู้รับบริการเป็นผู้กำหนดขึ้นด้วยตนเอง และใช้ร่วมกับรหัสลับแบบใช้ครั้งเดียว (One Time Password : OTP)</p>
            <p><strong>ข้อ 6</strong> ผู้รับบริการต้องเก็บรักษาชื่อผู้ใช้และรหัสผ่าน (Username &amp; Password) ที่ได้รับไว้เป็นความลับ ในกรณีที่มีเหตุอันควรสงสัยว่าชื่อผู้ใช้และรหัสผ่านล่วงรู้ไปถึงบุคคลอื่น ผู้รับบริการมีหน้าที่ต้องดำเนินการตั้งรหัสผ่านใหม่โดยทันทีผ่านระบบ Mining Account</p>
            <p><strong>ข้อ 7</strong> ผู้รับบริการตกลงและยอมรับว่าการใช้ลายมือชื่ออิเล็กทรอนิกส์ที่เกิดจากการใช้ชื่อผู้ใช้และรหัสผ่านในระบบ Mining Account มีความผูกพันตามกฎหมายเสมือนเป็นการลงลายมือชื่อของผู้รับบริการในเอกสารทุกประการ</p>
            <p><strong>ข้อ 8</strong> ผู้รับบริการตกลงและยอมรับว่ากรมมีสิทธิที่จะแก้ไข เปลี่ยนแปลง หรือยกเลิกข้อตกลงและเงื่อนไขนี้ได้ตามที่กรมเห็นสมควร</p>
            <p><strong>ข้อ 9</strong> ผู้รับบริการต้องปฏิบัติตามข้อตกลงและเงื่อนไขของกรมโดยเคร่งครัด กรมมีสิทธิปฏิเสธและไม่ต้องรับผิดชอบในความเสียหายที่เกิดขึ้นจากเหตุสุดวิสัย</p>
            <p><strong>ข้อ 10</strong> ผู้ใดแอบอ้างหรือกระทำการอันเป็นการละเมิดสิทธิส่วนบุคคลโดยใช้ข้อมูลของผู้อื่นมาแอบอ้างในการสมัคร ถือเป็นความผิดและต้องได้รับโทษตามที่กฎหมายกำหนดไว้</p>
            <p><strong>ข้อ 11</strong> กรมอาจส่งข้อมูลหรือแจ้งข่าวประชาสัมพันธ์ผ่านช่องทางอีเมล หรือช่องทางอื่นใดให้แก่ผู้รับบริการได้ตามที่กรมเห็นสมควร</p>
            <p><strong>ข้อ 12</strong> กรมมีสิทธิระงับหรือยกเลิกการให้บริการกับผู้รับบริการได้ทันที ถ้าปรากฏว่าผู้รับบริการปฏิบัติผิดข้อตกลงและเงื่อนไขนี้แม้เพียงข้อใดข้อหนึ่ง</p>
            <p><strong>ข้อ 13</strong> การใช้ชื่อผู้ใช้และรหัสผ่านของผู้รับบริการที่เป็นผู้แทนซึ่งกระทำแทนห้างหุ้นส่วนและบริษัทจำกัด ถือว่าเป็นไปตามความประสงค์ของผู้ประกอบการ</p>
            <p><strong>ข้อ 14</strong> กรมมีสิทธิระงับหรือยกเลิกการให้บริการกับผู้รับบริการได้ทันที ถ้าปรากฏว่าผู้รับบริการปฏิบัติผิดข้อตกลงและเงื่อนไขนี้แม้เพียงข้อใดข้อหนึ่ง</p>
            <p><strong>ข้อ 15</strong> คำประกาศเกี่ยวกับความเป็นส่วนตัว (Privacy Notice) สำหรับผู้รับบริการตามพระราชบัญญัติแร่ พ.ศ. 2560 — <a href="#" class="text-primary">คลิกเพื่ออ่านเพิ่มเติม</a></p>
            <p><strong>ข้อ 16</strong> กรมมีการเก็บรวบรวมข้อมูลส่วนบุคคล เพื่อใช้ในการยืนยันตัวตน ได้แก่ ชื่อและชื่อสกุล / เลขบัตรประจำตัวประชาชน / ที่อยู่ / วันเดือนปีเกิด / ภาพใบหน้า</p>
            <p><strong>ข้อ 17</strong> กรมจะเก็บรักษาข้อมูลส่วนบุคคลของผู้รับบริการไว้ตราบเท่าที่จำเป็นตามสมควร เมื่อพ้นระยะเวลาดังกล่าวกรมจะลบ/ทำลายหรือทำให้ข้อมูลไม่สามารถระบุตัวตนได้ ทั้งนี้ หากผู้รับบริการประสงค์ยกเลิกข้อตกลง ต้องแจ้งเป็นลายลักษณ์อักษรล่วงหน้าไม่น้อยกว่า 3 วัน</p>
