    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ตัวกรองการค้นหา</h5>
            <p class="text-muted small mb-0">ค้นหารายการคำขอตามประเภทใบรับรองและช่วงวันที่ร่างคำขอ</p>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label for="filterCertificate" class="form-label">ใบรับรอง</label>
                <select id="filterCertificate" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="declaration">ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)</option>
                    <option value="processing">ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ส่งคำขอแล้ว">ส่งคำขอแล้ว</option>
                    <option value="ร่างคำขอ">ร่างคำขอ</option>
                </select>
            </div>
            <div class="col-md-12 col-lg-6">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label for="filterDraftDateFrom" class="form-label">วันที่ยื่นคำขอ</label>
                        <input type="text" id="filterDraftDateFrom" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-md-4">
                        <label for="filterDraftDateTo" class="form-label">ถึงวันที่</label>
                        <input type="text" id="filterDraftDateTo" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="filterDateExclude" />
                            <label class="form-check-label small" for="filterDateExclude">ไม่อยู่ในช่วง</label>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="d-flex gap-2 filter-action-buttons">
                            <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square" title="ค้นหา">
                                <i class="ri ri-search-line"></i>
                            </button>
                            <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square">
                                <i class="ri ri-refresh-line"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการติดตามสถานะคำขอใบรับรอง</h5>
            <p class="text-muted small mb-0">แสดงสถานะการตรวจสอบ อนุมัติ และลายมือชื่ออิเล็กทรอนิกส์ของคำขอทั้งหมด</p>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:250px;">เลขที่คำขอ</th>
                    <th style="width:70px;">เลขที่<br/>รับ</th>
                    <th style="min-width:155px;">Health Certificate<br/>Number</th>
                    <th style="width:90px;">HS Code</th>
                    <th style="min-width:210px;">ใบรับรอง</th>
                    <th style="min-width:200px;">ผู้ผลิตสินค้า</th>
                    <th style="min-width:120px;">ประเทศปลายทาง</th>
                    <th style="min-width:130px;">วันที่ยื่นคำขอ</th>
                    <th style="width:100px;"></th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    <tr data-certificate="@request.CertificateKey" data-status="@request.StatusText" data-draft-date="@request.DraftedAt.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td>
                            <a href="@request.DetailUrl" class="fw-semibold text-primary text-decoration-none">@request.RequestNumber</a>
                            <div class="mt-1 d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @request.StatusClass d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                        @if (request.StatusText == "ส่งคำขอแล้ว")
                                        {
                                            <i class="ri ri-send-plane-fill" style="font-size:0.6rem;"></i>
                                        }
                                        else if (request.StatusText == "ร่างคำขอ")
                                        {
                                            <i class="ri ri-draft-line" style="font-size:0.6rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="ri ri-checkbox-blank-circle-fill" style="font-size:0.6rem;"></i>
                                        }
                                    </span>
                                    <span><span class="fw-semibold">สถานะ:</span> @request.StatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    @if (request.SignatureStatusText == "ลงลายมือชื่อแล้ว")
                                    {
                                        <span class="badge rounded-circle bg-label-success d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                            <i class="ri ri-check-line" style="font-size:0.6rem;"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-circle bg-label-warning d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                            <i class="ri ri-time-line" style="font-size:0.6rem;"></i>
                                        </span>
                                    }
                                    <span><span class="fw-semibold">ลายมือชื่อ:</span> @request.SignatureStatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @request.WrittenByClass d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                        <i class="ri @request.WrittenByIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span><span class="fw-semibold">เขียนคำขอโดย:</span> @request.WrittenByText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @request.AutoProcessClass d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                        <i class="ri @request.AutoProcessIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span><span class="fw-semibold">จัดทำอัตโนมัติ:</span> @request.AutoProcessText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @request.PaymentClass d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                        <i class="ri @request.PaymentIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span><span class="fw-semibold">ชำระเงิน:</span> @request.PaymentText</span>
                                </div>
                            </div>
                        </td>
                        <td class="text-center text-muted">@request.ReceiveNo</td>
                        <td>@request.HealthCertificateNumber</td>
                        <td class="text-center">@request.HsCode</td>
                        <td>
                            <div>@request.CertificateName</div>
                        </td>
                        <td>
                            <div>@request.Establishment</div>
                            <div class="small text-muted">(@request.EstablishmentBranch)</div>
                        </td>
                        <td>
                            <div>@request.Country</div>
                            <div class="small text-muted">(@request.CountryCode)</div>
                        </td>
                        <td>
                            @request.DraftedAt.ToString("dd/MM/yyyy")<br/>
                            <span class="small text-muted">(@request.DraftedAt.ToString("HH:mm:ss"))</span>
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                <a href="@request.DetailUrl" class="btn btn-sm btn-icon btn-outline-info" title="รายละเอียดข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="รายละเอียดข้อมูล">
                                    <i class="ri ri-eye-line text-info"></i>
                                </a>
                                @if (request.AllowClone)
                                {
                                    <a href="@request.DetailUrl" class="btn btn-sm btn-icon btn-outline-secondary" title="บันทึกเป็นคำขอใหม่" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="บันทึกเป็นคำขอใหม่">
                                        <i class="ri ri-file-copy-line text-secondary"></i>
                                    </a>
                                }
                                @if (request.AllowEdit)
                                {
                                    <a href="@request.DetailUrl" class="btn btn-sm btn-icon btn-outline-warning" title="แก้ไขคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="แก้ไขคำขอ">
                                        <i class="ri ri-pencil-line text-warning"></i>
                                    </a>
                                }
                                @if (request.AllowCancel)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-dark" title="ยกเลิกคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ยกเลิกคำขอ">
                                        <i class="ri ri-close-circle-line text-dark"></i>
                                    </button>
                                }
                                @if (request.AllowSubmit)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success" title="ส่งคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ส่งคำขอ">
                                        <i class="ri ri-send-plane-line text-success"></i>
                                    </button>
                                }
                                @if (request.AllowDelete)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" title="ลบคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ลบคำขอ">
                                        <i class="ri ri-delete-bin-line text-danger"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="9" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>