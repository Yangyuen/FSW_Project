                    <div class="col-12">
                        <label class="form-label small">แนบไฟล์เอกสาร</label>
                        <input type="file" id="ev_file" class="form-control form-control-sm"
                            accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                        <div class="form-text text-muted text-small">รองรับ PDF, JPG, PNG, DOC (ขนาดไม่เกิน 10 MB)</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i> ยกเลิก
                </button>
                <button type="button" class="btn btn-primary" id="btnConfirmAddEvidence">
                    <i class="ri ri-save-line me-1"></i> บันทึก
                </button>
            </div>
        </div>
    </div>
</div>
<!-- /Modal 6 -->

@section PageScripts {
<script>
    // TOR 1.7(24): ดึงข้อมูลน้ำหนักจากด่านตรวจประมง → auto-fill ตาราง RMBS2/P2
    function fetchWeightFromInspection() {
        // mockup: น้ำหนักที่ผ่านตรวจปล่อย = 18,450.000 กก. แจกตาม RMBS2/P2
        var autoFillData = [
            { id: '1', weight: 9.8000,  original: 10.0000 },
            { id: '2', weight: 8.2000,  original: 8.5000 },
            { id: '3', weight: 14.9500, original: 15.2500 }
        ];
        autoFillData.forEach(function(row) {
            var el = document.getElementById('weightNew' + row.id);
            if (el) {
                el.value = row.weight.toFixed(4);
                checkWeightLimit(el, row.original);
            }
        });
        // แสดง banner ยืนยันการดึงข้อมูล
        var banner = document.getElementById('bannerWeightAutoFill');
        if (banner) { banner.classList.remove('d-none'); }
        var timeEl = document.getElementById('bannerWeightFillTime');
        if (timeEl) {
            var now = new Date();
            var hours = String(now.getHours()).padStart(2, '0');
            var mins  = String(now.getMinutes()).padStart(2, '0');
            timeEl.textContent = '29/04/2569 เวลา ' + hours + ':' + mins + ' น.';
        }
        // เปลี่ยนปุ่มเป็น disabled + แสดงว่าอัปเดตแล้ว
        var btn = document.getElementById('btnFetchInspWeight');
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<i class="ri ri-check-line me-1"></i>อัปเดตแล้ว ✅';
            btn.classList.replace('btn-info', 'btn-success');
        }
    }

    // TOR 1.7(24): บันทึกการปรับปรุงน้ำหนัก (mockup toast notification)
    function saveWeightAdjustment() {
        var invalid = document.querySelectorAll('#accordionWeightAdjust .bg-label-danger');
        if (invalid.length > 0) {
            alert('⚠️ ยังมีรายการน้ำหนักที่เกินกำหนด กรุณาแก้ไขก่อนบันทึก');
            return;
        }
        alert('✅ บันทึกการปรับปรุงน้ำหนักเรียบร้อยแล้ว\nระบบจะอัปเดตโควตาและออกใบรับรองอัตโนมัติ');
    }

    // TOR 1.7(24): ตรวจสอบน้ำหนักที่ปรับปรุงใหม่ต้องไม่เกินปริมาณที่ขอส่งออกครั้งแรก
    function checkWeightLimit(inputEl, originalWeight) {
        var newVal = parseFloat(inputEl.value);
        var rowNum = inputEl.id.replace('weightNew', '');
        var statusEl = document.getElementById('weightStatus' + rowNum);
        if (!statusEl) { return; }
        if (isNaN(newVal) || newVal <= originalWeight) {
            statusEl.innerHTML = '<span class="badge bg-label-success">✅ ไม่เกินปริมาณที่ขอส่งออกครั้งแรก</span>';
        } else {
            statusEl.innerHTML = '<span class="badge bg-label-danger">❌ เกินกำหนด (เกิน ' + (newVal - originalWeight).toFixed(4) + ' กก.)</span>';
        }
    }

    $(document).ready(function() {
        // ── Select2 ──
        $('.select2').select2({ width: '100%' });

        // ── Flatpickr ──
        function initFlatpickr(el) {
            if (el && !el._flatpickr) {
                flatpickr(el, {
                    dateFormat: 'd/m/Y',
                    allowInput: true,
                    appendTo: document.body,
                    onReady: function(selectedDates, dateStr, instance) {
                        instance.calendarContainer.style.zIndex = '9999';
                    }
                });
            }
        }
        document.querySelectorAll('.flatpickr-date').forEach(function(el) { initFlatpickr(el); });

        $('#modalAddRMBS2').on('shown.bs.modal', function() {
            $(this).find('.flatpickr-date').each(function() { initFlatpickr(this); });
            initFlatpickr(document.getElementById('searchRmbs2Date'));
        });

        // ── Reindex RMBS2 rows inside a sub-table ──
        function reindexRmbs2(tableId) {
            $('#' + tableId + ' tbody tr').each(function(i) {
                $(this).find('td:first').text(i + 1);
            });
        }

        // ── Modal 1 (RMBS1): คลิก row → toggle checkbox ──
        $(document).on('click', '.rmbs1-result-row', function(e) {
            if ($(e.target).is('input[type=checkbox]')) return;
            var $cb = $(this).find('input[name=rmbs1Select]');
            $cb.prop('checked', !$cb.prop('checked'));
            $(this).toggleClass('table-active', $cb.prop('checked'));
        });
        $(document).on('change', 'input[name=rmbs1Select]', function() {
            $(this).closest('tr').toggleClass('table-active', $(this).prop('checked'));
        });
        $('#m1CheckAll').on('change', function() {
            var checked = $(this).prop('checked');
            $('input[name=rmbs1Select]').prop('checked', checked);
            $('#rmbs1ResultTbody .rmbs1-result-row').toggleClass('table-active', checked);
        });
        $('#btnSelectRmbs1').on('click', function() {
            if ($('input[name=rmbs1Select]:checked').length === 0) { alert('กรุณาเลือกรายการก่อน'); return; }
            bootstrap.Modal.getInstance(document.getElementById('modalSearchRMBS1')).hide();
        });

        // ── Tab 2: Inline RMBS1 panel (Button 6) ──
        $(document).on('click', '.btn-toggle-rmbs1-panel', function() {
            var goodsId = $(this).data('goods-id');
            var $panel = $('#rmbs1-panel-' + goodsId);
            if ($panel.hasClass('d-none')) {
                $panel.removeClass('d-none');
                $(this).removeClass('btn-outline-success').addClass('btn-success');
            } else {
                $panel.addClass('d-none');
                $(this).removeClass('btn-success').addClass('btn-outline-success');
            }
        });
        $(document).on('click', '.btn-close-rmbs1-panel', function() {
            var goodsId = $(this).data('goods-id');
            $('#rmbs1-panel-' + goodsId).addClass('d-none');
            $('[data-goods-id="' + goodsId + '"].btn-toggle-rmbs1-panel')
                .removeClass('btn-success').addClass('btn-outline-success');
        });
        $(document).on('click', '.btn-remove-ref-doc', function() {
            $(this).closest('tr').remove();
        });

        // ── เพิ่มผลิตภัณฑ์ (RMBS2) — เปิด Modal แล้ว reset กลับ Step 1 ──
        var _rmbs2Target = '';
        var _rmbs2NwUnit = 0;
        $(document).on('click', '.btn-add-rmbs2', function() {
            _rmbs2Target = 'rmbs2-' + $(this).data('parent-id');
            var parentRmbs = $(this).data('parent-rmbs');
            $('#rmbs2ParentLabel').text('RMBS1: ' + parentRmbs);
            // Reset to Step 1
            $('#rmbs2StepSearch').removeClass('d-none');
            $('#rmbs2StepDetail').addClass('d-none');
            $('#rmbs2FooterSearch').removeClass('d-none');
            $('#rmbs2FooterDetail').addClass('d-none');
            $('input[name=rmbs2Select]').prop('checked', false);
            $('.rmbs2-search-row').removeClass('table-active');
            $('#searchRmbs2Code, #searchRmbs2Name, #searchRmbs2Date').val('');
            $('#d2_exported, #d2_nw').val('');
            $('#d2_qty_product').val('');
            new bootstrap.Modal(document.getElementById('modalAddRMBS2')).show();
        });

        // ── คลิก RMBS2 result row ──
        $(document).on('click', '.rmbs2-search-row', function() {
            $('.rmbs2-search-row').removeClass('table-active');
            $(this).addClass('table-active');
            $(this).find('input[type=radio]').prop('checked', true);
        });

        // ── เลือกรายการ RMBS2 → Step 2 ──
        $('#btnSelectRmbs2').on('click', function() {
            var $sel = $('input[name=rmbs2Select]:checked').closest('tr');
            if ($sel.length === 0) { alert('กรุณาเลือกรายการก่อน'); return; }
            _rmbs2NwUnit = parseFloat($sel.data('nw-unit')) || 0;
            $('#d2_date').text($sel.data('date'));
            $('#d2_line').text($sel.data('line'));
            $('#d2_code').text($sel.data('code'));
            $('#d2_name').text($sel.data('name'));
            $('#d2_produced').text($sel.data('produced'));
            $('#d2_yield').text($sel.data('yield'));
            $('#d2_remaining').text($sel.data('remaining'));
            $('#d2_exported, #d2_nw').val('');
            $('#d2_qty_product').val('');
            $('#rmbs2StepSearch').addClass('d-none');
            $('#rmbs2StepDetail').removeClass('d-none');
            $('#rmbs2FooterSearch').addClass('d-none');
            $('#rmbs2FooterDetail').removeClass('d-none');
        });

        // ── ย้อนกลับ Step 1 ──
        $('#btnBackToRmbs2Search').on('click', function() {
            $('#rmbs2StepDetail').addClass('d-none');
            $('#rmbs2StepSearch').removeClass('d-none');
            $('#rmbs2FooterDetail').addClass('d-none');
            $('#rmbs2FooterSearch').removeClass('d-none');
        });

        // ── Auto-calc ปริมาณที่ส่งออกตามบรรจุภัณฑ์ = จำนวนบรรจุ × N.W. ต่อหน่วย ──
        $(document).on('input', '#d2_exported', function() {
            var qty = parseFloat($(this).val()) || 0;
            var qtyProduct = qty * _rmbs2NwUnit;
            $('#d2_qty_product').val(qtyProduct > 0 ? qtyProduct.toLocaleString('th-TH', { minimumFractionDigits: 3 }) : '');
        });

        // ── บันทึก RMBS2 ──
        $('#btnConfirmAddRMBS2').on('click', function() {
            var exported = parseFloat($('#d2_exported').val()) || 0;
            var nw       = parseFloat($('#d2_nw').val()) || 0;
            if (exported <= 0 || nw <= 0) {
                alert('กรุณากรอกจำนวนบรรจุภัณฑ์และน้ำหนักสุทธิให้ถูกต้อง');
                return;
            }
            var fmt = function(v) {
                var n = parseFloat(v) || 0;
                return n.toLocaleString('th-TH', { minimumFractionDigits: 3 });
            };
            var qtyProduct = exported * _rmbs2NwUnit;
            var $tbody = $('#' + _rmbs2Target + ' tbody');
            $tbody.find('tr.text-muted').remove();
            var rowNum = $tbody.find('tr').length + 1;
            var $row = $(`<tr
                data-date="${$('#d2_date').text()}"
                data-line="${$('#d2_line').text()}"
                data-code="${$('#d2_code').text()}"
                data-name="${$('#d2_name').text()}"
                data-produced="${$('#d2_produced').text()}"
                data-nw-unit="${_rmbs2NwUnit}">
                <td class="text-center text-muted small">${rowNum}</td>
                <td>${$('#d2_date').text()}</td>
                <td>${$('#d2_line').text()}</td>
                <td>${$('#d2_code').text()}</td>
                <td>${$('#d2_name').text()}</td>
                <td class="text-end">${$('#d2_produced').text()}</td>
                <td class="text-end">${fmt(exported)}</td>
                <td class="text-end">${fmt(qtyProduct)}</td>
                <td class="text-end">${fmt(nw)}</td>
                <td class="text-center">
                    <div class="d-flex gap-1 justify-content-center">
                        <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-edit-rmbs2" title="แก้ไข">
                            <i class="ri ri-pencil-line text-warning"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-remove-rmbs2" title="ลบรายการ">
                            <i class="ri ri-delete-bin-line text-danger"></i>
                        </button>
                    </div>
                </td>
            </tr>`);
            $tbody.append($row);
            bootstrap.Modal.getInstance(document.getElementById('modalAddRMBS2')).hide();
        });

        // ── แก้ไขผลิตภัณฑ์ RMBS2 ──
        var _editRmbs2Row = null;
        $(document).on('click', '.btn-edit-rmbs2', function() {
            _editRmbs2Row = $(this).closest('tr');
            var $row = _editRmbs2Row;
            $('#er2_date').text($row.data('date'));
            $('#er2_line').text($row.data('line'));
            $('#er2_code').text($row.data('code'));
            $('#er2_name').text($row.data('name'));
            $('#er2_produced').text($row.data('produced'));
            var expVal = parseFloat($row.find('td:nth-child(7)').text().replace(/,/g, '')) || '';
            var nwVal  = parseFloat($row.find('td:nth-child(9)').text().replace(/,/g, '')) || '';
            $('#er2_exported').val(expVal);
            $('#er2_nw').val(nwVal);
            var nwUnit = parseFloat($row.data('nw-unit')) || 0;
            var qp = (parseFloat(expVal) || 0) * nwUnit;
            $('#er2_qty_product').val(qp > 0 ? qp.toLocaleString('th-TH', { minimumFractionDigits: 3 }) : '');
            new bootstrap.Modal(document.getElementById('modalEditRMBS2')).show();
            setTimeout(function() { $('#er2_exported').select(); }, 300);
        });

        $(document).on('input', '#er2_exported', function() {
            if (!_editRmbs2Row) return;
            var qty = parseFloat($(this).val()) || 0;
            var nwUnit = parseFloat(_editRmbs2Row.data('nw-unit')) || 0;
            var qp = qty * nwUnit;
            $('#er2_qty_product').val(qp > 0 ? qp.toLocaleString('th-TH', { minimumFractionDigits: 3 }) : '');
        });

        $('#btnSaveEditRMBS2').on('click', function() {
            var exported = parseFloat($('#er2_exported').val()) || 0;
            var nw = parseFloat($('#er2_nw').val()) || 0;
            if (exported <= 0 || nw <= 0) { alert('กรุณากรอกจำนวนบรรจุภัณฑ์และน้ำหนักสุทธิ์ให้ถูกต้อง'); return; }
            var nwUnit = parseFloat(_editRmbs2Row.data('nw-unit')) || 0;
            var qtyProduct = exported * nwUnit;
            var fmt = function(v) { return (parseFloat(v) || 0).toLocaleString('th-TH', { minimumFractionDigits: 3 }); };
            _editRmbs2Row.find('td:nth-child(7)').text(fmt(exported));
            _editRmbs2Row.find('td:nth-child(8)').text(fmt(qtyProduct));
            _editRmbs2Row.find('td:nth-child(9)').text(fmt(nw));
            bootstrap.Modal.getInstance(document.getElementById('modalEditRMBS2')).hide();
        });

        // ── ลบ RMBS2 row ──
        $(document).on('click', '.btn-remove-rmbs2', function() {
            var $tbody = $(this).closest('tbody');
            var tableId = $(this).closest('table').attr('id');
            $(this).closest('tr').remove();
            reindexRmbs2(tableId);
            if ($tbody.find('tr').length === 0) {
                $tbody.append('<tr class="text-center text-muted"><td colspan="10" class="py-2 small fst-italic">ยังไม่มีรายการ — กด "เพิ่มผลิตภัณฑ์"</td></tr>');
            }
        });

        // ── Tab 3: Evidence ──
        function reindexEvidence() {
            $('#evidenceTbody tr').each(function(i) {
                $(this).find('td:first').text(i + 1);
            });
        }

        // init flatpickr on Modal 6
        $('#modalAddEvidence').on('shown.bs.modal', function() {
            initFlatpickr(document.getElementById('ev_issue_date'));
            initFlatpickr(document.getElementById('ev_expire_date'));
            // reset fields
            $('#ev_name, #ev_docno, #ev_issuer, #ev_issue_date, #ev_expire_date').val('');
            $('#ev_source, #ev_doctype, #ev_docself, #ev_docowner').val('');
            $('#ev_file').val('');
        });

        // Icon-line maps สำหรับ 4 ฟิลด์
        var _evSourceMap  = {
            'inside':          { cls: 'bg-label-warning',   icon: 'ri-file-list-line',    lbl: 'สายในระบบ [FSW]' },
            'outside':         { cls: 'bg-label-success',   icon: 'ri-file-check-line',   lbl: 'ภายนอกระบบ [FSW]' }
        };
        var _evDoctypeMap = {
            'backend':         { cls: 'bg-label-primary',   icon: 'ri-government-line',   lbl: 'Backend' },
            'backend-dof':     { cls: 'bg-label-info',      icon: 'ri-building-line',     lbl: 'Backend DOF' }
        };
        var _evDocselfMap = {
            'original':        { cls: 'bg-label-danger',    icon: 'ri-file-warning-line', lbl: 'ต้นฉบับ' },
            'copy':            { cls: 'bg-label-secondary', icon: 'ri-file-copy-line',    lbl: 'สำเนา' },
            'certified-copy':  { cls: 'bg-label-warning',   icon: 'ri-file-add-line',     lbl: 'สำเนาล้างสำเนา' }
        };
        var _evDocownerMap = {
            'applicant':       { cls: 'bg-label-danger',    icon: 'ri-user-line',         lbl: 'ของผู้ร้องขอ' },
            'authorized':      { cls: 'bg-label-primary',   icon: 'ri-shield-check-line', lbl: 'ของผู้รับมอบอำนาจ' }
        };
        function evBadgeHtml(map, val, fieldLabel) {
            if (!val || !map[val]) return '';
            var m = map[val];
            return '<div class="small text-muted d-flex align-items-center gap-1 mb-1"><span class="badge ' + m.cls + ' rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;"><i class="ri ' + m.icon + '" style="font-size:0.65rem;"></i></span><span class="fw-semibold">' + fieldLabel + ' :</span> ' + m.lbl + '</div>';
        }

        $('#btnConfirmAddEvidence').on('click', function() {
            var name = $.trim($('#ev_name').val());
            if (!name) { alert('กรุณากรอกชื่อหลักฐานประกอบ'); return; }
            var sourceVal = $('#ev_source').val() || '';
            if (!sourceVal) { alert('กรุณาเลือกแหล่งที่มา'); return; }
            var doctypeVal  = $('#ev_doctype').val() || '';
            var docselfVal  = $('#ev_docself').val() || '';
            var docownerVal = $('#ev_docowner').val() || '';
            var docno    = $('#ev_docno').val() || '—';
            var issuer   = $('#ev_issuer').val() || '—';
            var issuedt  = $('#ev_issue_date').val() || '—';
            var expdt    = $('#ev_expire_date').val() || '—';
            var fileName = '';
            var fileEl   = document.getElementById('ev_file');
            if (fileEl && fileEl.files && fileEl.files.length > 0) {
                fileName = fileEl.files[0].name;
            }
            var metaBadges = evBadgeHtml(_evSourceMap, sourceVal, 'แหล่งที่มา')
                           + evBadgeHtml(_evDoctypeMap, doctypeVal, 'ประเภทเอกสาร')
                           + evBadgeHtml(_evDocselfMap, docselfVal, 'ตัวเอกสาร')
                           + evBadgeHtml(_evDocownerMap, docownerVal, 'เจ้าของเอกสาร');
            var rowNum = $('#evidenceTbody tr').length + 1;
            var $row = $(`<tr>
                <td class="text-center text-muted small">${rowNum}</td>
                <td>
                    <div class="fw-semibold text-primary">${name}</div>
                    ${metaBadges ? `<div class="mt-1">${metaBadges}</div>` : ''}
                    ${fileName ? `<div class="text-muted small mt-1"><i class="ri ri-attachment-2 me-1"></i>${fileName}</div>` : ''}
                </td>
                <td>${docno}</td>
                <td>${issuedt}</td>
                <td>${expdt}</td>
                <td>${issuer}</td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-remove-evidence" title="ลบรายการ">
                        <i class="ri ri-delete-bin-line"></i>
                    </button>
                </td>
            </tr>`);
            $('#evidenceTbody').append($row);
            bootstrap.Modal.getInstance(document.getElementById('modalAddEvidence')).hide();
        });

        $(document).on('click', '.btn-remove-evidence', function() {
            $(this).closest('tr').remove();
            reindexEvidence();
        });
    });

    @* TOR 1.11(16): ส่งผลการพิจารณาให้ด่านตรวจประมง *@
    function confirmSendToInspection() {
        var modal = new bootstrap.Modal(document.getElementById('modalSendToInspection'));
        modal.show();
    }
    function doSendToInspection() {
        bootstrap.Modal.getInstance(document.getElementById('modalSendToInspection')).hide();
        var badge = document.getElementById('badgeInspSendStatus');
        if (badge) {
            badge.className = 'badge bg-label-success';
            badge.innerHTML = '<i class="ri ri-checkbox-circle-line me-1"></i>ส่งผลให้ด่านตรวจแล้ว ✅';
        }
        setTimeout(function() {
            alert('[mockup] ส่งผลการพิจารณาอนุมัติคืนน้ำหนักให้ด่านตรวจประมงท่าเรือกรุงเทพ สำเร็จ\nเลขที่: APPR-2569-0401 | วันที่: 28/04/2569');
        }, 300);
    }

    @* TOR 1.11(14): ส่งข้อมูลเศษเหลือไประบบปลาป่น *@
    var _scrapGoodsId = null;
    function confirmSendScrap(goodsId) {
        _scrapGoodsId = goodsId;
        var modal = new bootstrap.Modal(document.getElementById('modalSendScrap'));
        modal.show();
    }
    function doSendScrap() {
        bootstrap.Modal.getInstance(document.getElementById('modalSendScrap')).hide();
        if (_scrapGoodsId) {
            var badge = document.getElementById('badgeScrapSent-' + _scrapGoodsId);
            if (badge) badge.classList.remove('d-none');
            setTimeout(function() {
                alert('[mockup] ส่งข้อมูลเศษเหลือไประบบ ScrapTrading สำเร็จ\nรายการ: หัวปลา 125.50 กก. + กระดูกปลา 48.20 กก.\nสามารถดูรายละเอียดได้ที่ระบบหนังสือรับรองปลาป่น');
            }, 300);
        }
    }

    @* TOR 1.11(9): สร้างใบรับรองใหม่รวม RMBS2 สินค้าส่งคืน + ปกติ *@
    function confirmNewCertFromReturned() {
        var modal = new bootstrap.Modal(document.getElementById('modalNewCertFromReturned'));
        modal.show();
    }

    @* TOR 1.11(8): สำเนา RMBS2/P2 จากใบรับรองเดิม *@
    var _cloneGoodsId = null;
    function confirmCloneRMBS2(goodsId, rmbs2No, batchCode) {
        _cloneGoodsId = goodsId;
        document.getElementById('cloneSourceLabel').textContent = rmbs2No + ' (' + batchCode + ')';
        var modal = new bootstrap.Modal(document.getElementById('modalCloneRMBS2'));
        modal.show();
    }
    function doCloneRMBS2() {
        bootstrap.Modal.getInstance(document.getElementById('modalCloneRMBS2')).hide();
        if (_cloneGoodsId) {
            var badge = document.getElementById('badgeCloneRmbs-' + _cloneGoodsId);
            if (badge) badge.classList.remove('d-none');
            setTimeout(function() {
                alert('[mockup] สำเนา RMBS2/P2 สำเร็จ — ระบบสร้าง RMBS2 สินค้าส่งคืนใหม่เรียบร้อยแล้ว ข้อมูลต้นฉบับไม่ถูกแก้ไข');
            }, 300);
        }
    }

    @* TOR 1.11(6): toggle ref-doc tab RMBS vs P *@
    function switchRefDocTab(tab) {
        var isRmbs = tab === 'rmbs';
        document.getElementById('panelRefDocRmbs').classList.toggle('d-none', !isRmbs);
        document.getElementById('panelRefDocP').classList.toggle('d-none', isRmbs);
        document.getElementById('btnTabRmbs').className = isRmbs
            ? 'btn btn-sm btn-primary active' : 'btn btn-sm btn-outline-secondary';
        document.getElementById('btnTabP').className = isRmbs
            ? 'btn btn-sm btn-outline-secondary' : 'btn btn-sm btn-primary active';
    }

    @* TOR 1.11(6): toggle ปริมาณที่ขอคืน — ทั้งหมด=readonly, บางส่วน=editable *@
    function toggleReturnQty(sel) {
        var input = sel.closest('tr').querySelector('input[type="number"]');
        if (!input) return;
        if (sel.value === 'ทั้งหมด') {
            input.readOnly = true;
            input.classList.add('bg-light');
        } else {
            input.readOnly = false;
            input.classList.remove('bg-light');
            input.focus();
        }
    }

    @* TOR 1.11(5): branching logic วัตถุประสงค์ 3 กรณี *@
    function onReturnPurposeChange(value) {
        document.getElementById('sectionPurposeDestroy').classList.add('d-none');
        document.getElementById('sectionPurposeExport').classList.add('d-none');
        document.getElementById('sectionPurposeDomestic').classList.add('d-none');
        if (value === 'ทำลาย') {
            document.getElementById('sectionPurposeDestroy').classList.remove('d-none');
        } else if (value === 'ส่งออก') {
            document.getElementById('sectionPurposeExport').classList.remove('d-none');
        } else if (value === 'จำหน่ายในประเทศ') {
            document.getElementById('sectionPurposeDomestic').classList.remove('d-none');
        }
    }
</script>
}