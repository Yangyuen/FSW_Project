            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterIssuedDateTo" class="form-label">วันที่ออกใบรับรอง (ถึง)</label>
                <input type="text" id="filterIssuedDateTo" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            @* Row 2 *@
            <div class="col-md-4 col-lg-3">
                <label for="filterEstablishment" class="form-label">ชื่อสถานประกอบการ</label>
                <input type="text" id="filterEstablishment" class="form-control" placeholder="ชื่อสถานประกอบการ" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterApprovalNo" class="form-label">หมายเลขรับรองโรงงาน</label>
                <input type="text" id="filterApprovalNo" class="form-control" placeholder="เช่น AP-74110-001" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterProduct" class="form-label">ชื่อสินค้า</label>
                <input type="text" id="filterProduct" class="form-control" placeholder="ชื่อสินค้า / HS Code" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterCountry" class="form-label">ประเทศปลายทาง</label>
                <input type="text" id="filterCountry" class="form-control" placeholder="เช่น ญี่ปุ่น / JAPAN" />
            </div>
            @* Row 3 *@
            <div class="col-md-4 col-lg-3">
                <label for="filterHCNo" class="form-label">เลขที่ใบรับรองสุขอนามัย</label>
                <input type="text" id="filterHCNo" class="form-control" placeholder="เช่น HC821B211414" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterHCIssuedDateFrom" class="form-label">วันที่ออกใบรับรองสุขอนามัย (ตั้งแต่)</label>
                <input type="text" id="filterHCIssuedDateFrom" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterHCIssuedDateTo" class="form-label">วันที่ออกใบรับรองสุขอนามัย (ถึง)</label>
                <input type="text" id="filterHCIssuedDateTo" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ส่งคำขอแล้ว">ส่งคำขอแล้ว</option>
                    <option value="ร่างคำขอ">ร่างคำขอ</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterInspectionStatus" class="form-label">สถานะด่านตรวจ</label>
                <select id="filterInspectionStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="sent">ส่งด่านตรวจแล้ว</option>
                    <option value="not-sent">ยังไม่ส่ง</option>
                </select>
            </div>
            @* TOR 1.10(3): สถานะการยกเลิก *@
            <div class="col-md-4 col-lg-3">
                <label for="filterCancelStatus" class="form-label">สถานะการยกเลิก</label>
                <select id="filterCancelStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="true">ยกเลิกแล้ว 🚫</option>
                    <option value="false">ยังไม่ถูกยกเลิก</option>
                </select>
            </div>
            @* Action buttons *@
            <div class="col-12">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square" title="ล้างการค้นหา">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
@{
    var cancelledCertNos = new[] { "AC821B2171102", "AC821B2171201" };
}
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการใบรับรอง</h5>
            <p class="text-muted small mb-0">แสดงรายการใบรับรองการแปรรูปสัตว์นํ้า (PS) และใบรับรองไม่แปรรูปสัตว์นํ้า (Declaration)</p>
        </div>
        <!-- TOR 1.7(34): Export Excel -->
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-success btn-sm"
                onclick="alert('Export Excel รายการใบรับรอง PS/NMD (mockup)\n\nรายการที่ export:\n- เลขที่ใบรับรอง\n- ชื่อสถานประกอบการ\n- เลขที่อนุมัติ\n- สินค้า / HS Code\n- ประเทศปลายทาง\n- วันที่ออกใบรับรอง\n- สถานะ')">
                <i class="ri ri-file-excel-2-line me-1"></i> Export Excel
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:220px;">Doc No. / สถานะ</th>
                    <th style="min-width:160px;">Plant / รับรองโรงงาน</th>
                    <th style="width:70px;">TH No.</th>
                    <th style="width:90px;">HS Code</th>
                    <th style="min-width:140px;">HC No.</th>
                    <th style="min-width:120px;">วันที่ออก HC</th>
                    <th style="min-width:160px;">Product Name</th>
                    <th style="min-width:120px;">Country</th>
                    <th style="min-width:120px;">วันที่ออกใบรับรอง</th>
                    <th style="min-width:130px;">สถานะด่านตรวจ</th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    var inspSent = request.StatusText == "ส่งคำขอแล้ว";
                    var inspSentValue = inspSent ? "true" : "false";
                    var isCancelledCert = cancelledCertNos.Contains(request.HealthCertificateNumber);
                    <tr data-certificate="@request.CertificateKey"
                        data-status="@request.StatusText"
                        data-draft-date="@request.DraftedAt.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-cert-no="@request.HealthCertificateNumber"
                        data-issued-date="@request.IssuedDate.ToString("yyyy-MM-dd")"
                        data-establishment="@request.Establishment"
                        data-approval-no="@request.ApprovalNo"
                        data-product="@request.FisheryProducts"
                        data-country="@request.Country"
                        data-hc-no="@request.HealthCertificateNumber"
                        data-hc-issued-date="@request.HCIssuedDate.ToString("yyyy-MM-dd")"
                        data-inspection-sent="@inspSentValue"
                        data-is-cancelled="@isCancelledCert.ToString().ToLower()">
                        <td>
                            <a href="@(request.CertificateKey == "processing" ? Url.Action("CreateManageCertificatePS", "PSDeclaration") : Url.Action("CreateManageCertificateNoPS", "PSDeclaration"))" class="fw-semibold text-primary text-decoration-none d-block mb-1">@request.RequestNumber</a>
                            <div class="d-flex flex-column gap-1">
                                <!-- ประเภท -->
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle bg-label-info d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                        @if (request.CertificateKey == "declaration")
                                        {
                                            <i class="ri ri-file-text-line" style="font-size:0.6rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="ri ri-file-chart-line" style="font-size:0.6rem;"></i>
                                        }
                                    </span>
                                    <span><span class="fw-semibold">ประเภท:</span> @request.CertificateName</span>
                                </div>
                                <!-- สถานะ -->
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @request.StatusClass d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                        @if (request.StatusText == "ส่งคำขอแล้ว")
                                        {
                                            <i class="ri ri-checkbox-circle-fill" style="font-size:0.6rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="ri ri-draft-line" style="font-size:0.6rem;"></i>
                                        }
                                    </span>
                                    <span><span class="fw-semibold">สถานะ:</span> @request.StatusText</span>
                                </div>
                                @* TOR 1.10(3): badge ยกเลิกแล้ว *@
                                @if (isCancelledCert)
                                {
                                    <div class="d-flex align-items-center gap-1 small mt-1">
                                        <span class="badge bg-label-danger">
                                            <i class="ri ri-forbid-2-line me-1"></i>ยกเลิกแล้ว 🚫
                                        </span>
                                    </div>
                                }
                                <!-- ลายมือชื่อ -->
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    @if (request.SignatureStatusText == "ลงลายมือชื่อแล้ว")
                                    {
                                        <span class="badge rounded-circle bg-label-success d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                            <i class="ri ri-pen-nib-line" style="font-size:0.6rem;"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-circle bg-label-warning d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                            <i class="ri ri-pen-nib-line" style="font-size:0.6rem;"></i>
                                        </span>
                                    }
                                    <span><span class="fw-semibold">ลายมือชื่อ:</span> @request.SignatureStatusText</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="fw-semibold">@request.Establishment</div>
                            <div class="small text-muted">@request.ApprovalNo</div>
                        </td>
                        <td class="text-center text-muted">@request.ReceiveNo</td>
                        <td class="text-center">@request.HsCode</td>
                        <td class="small">
                            <div>@request.HealthCertificateNumber</div>
                        </td>
                        <td class="text-center small text-nowrap text-muted">
                            @request.HCIssuedDate.ToString("dd/MM/yyyy")
                        </td>
                        <td class="small">@request.FisheryProducts</td>
                        <td class="small">
                            <div>@request.Country</div>
                            <div class="small text-muted">(@request.CountryCode)</div>
                        </td>
                        <td class="text-center small text-nowrap text-muted">
                            @request.IssuedDate.ToString("dd/MM/yyyy")
                        </td>
                        <td class="text-center">
                            @* TOR 1.10(12): สถานะด่านตรวจ + link ดูการตรวจปล่อย *@
                            @if (isCancelledCert)
                            {
                                <span class="badge bg-label-danger small">
                                    <i class="ri ri-forbid-line me-1"></i>ถูกยกเลิก 🚫
                                </span>
                            }
                            else if (inspSent)
                            {
                                <div class="d-flex flex-column align-items-center gap-1">
                                    <span class="badge bg-success small">
                                        <i class="ri ri-checkbox-circle-line me-1"></i>ส่งด่านตรวจแล้ว ✅
                                    </span>
                                    <a href="@Url.Action("IndexApproveReturnWeight", "PSDeclaration")"
                                       class="btn btn-xs btn-outline-success py-0 px-1" style="font-size:0.7rem;"
                                       data-bs-toggle="tooltip" title="ดูรายการตรวจปล่อยที่เชื่อมโยง">
                                        <i class="ri ri-eye-line me-1"></i>ดูการตรวจปล่อย
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-items-center gap-1">
                                    <span class="badge bg-label-secondary small">ยังไม่ส่ง</span>
                                    <button type="button" class="btn btn-xs btn-outline-primary py-0 px-1" style="font-size:0.7rem;"
                                        onclick="alert('ส่งข้อมูลใบรับรอง @request.RequestNumber ไปด่านตรวจ (mockup)')">
                                        <i class="ri ri-send-plane-line me-1"></i>ส่งไปด่านตรวจ
                                    </button>
                                </div>
                            }
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="10" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>