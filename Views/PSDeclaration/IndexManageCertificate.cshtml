@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Init flatpickr for all date filter inputs (TOR 1.7(28))
        document.querySelectorAll('.flatpickr-date').forEach(function(el) {
            flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) {
                return null;
            }

            var parts = value.split('/');
            if (parts.length !== 3) {
                return null;
            }

            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            var hours = endOfDay ? 23 : 0;
            var minutes = endOfDay ? 59 : 0;
            var seconds = endOfDay ? 59 : 0;
            var parsed = new Date(year, month, day, hours, minutes, seconds);

            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function filterRows() {
            var certificate  = (document.getElementById('filterCertificate').value || '').trim();
            var certNo       = (document.getElementById('filterCertNo').value || '').trim().toLowerCase();
            var issuedFrom   = parseDateInput(document.getElementById('filterIssuedDateFrom').value, false);
            var issuedTo     = parseDateInput(document.getElementById('filterIssuedDateTo').value, true);
            var estab        = (document.getElementById('filterEstablishment').value || '').trim().toLowerCase();
            var approvalNo   = (document.getElementById('filterApprovalNo').value || '').trim().toLowerCase();
            var product      = (document.getElementById('filterProduct').value || '').trim().toLowerCase();
            var country      = (document.getElementById('filterCountry').value || '').trim().toLowerCase();
            var hcNo         = (document.getElementById('filterHCNo').value || '').trim().toLowerCase();
            var hcIssuedFrom = parseDateInput(document.getElementById('filterHCIssuedDateFrom').value, false);
            var hcIssuedTo   = parseDateInput(document.getElementById('filterHCIssuedDateTo').value, true);
            var status       = (document.getElementById('filterStatus').value || '').trim();
            var inspStatus   = (document.getElementById('filterInspectionStatus').value || '').trim();
            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var certTypeMatch   = !certificate  || (row.dataset.certificate || '') === certificate;
                var certNoMatch     = !certNo       || (row.dataset.certNo || '').toLowerCase().includes(certNo);
                var estabMatch      = !estab        || (row.dataset.establishment || '').toLowerCase().includes(estab);
                var approvalMatch   = !approvalNo   || (row.dataset.approvalNo || '').toLowerCase().includes(approvalNo);
                var productMatch    = !product      || (row.dataset.product || '').toLowerCase().includes(product);
                var countryMatch    = !country      || (row.dataset.country || '').toLowerCase().includes(country);
                var hcNoMatch       = !hcNo         || (row.dataset.hcNo || '').toLowerCase().includes(hcNo);
                var statusMatch     = !status       || (row.dataset.status || '') === status;
                var inspMatch       = !inspStatus   || (row.dataset.inspectionSent || '') === inspStatus;
                // TOR 1.10(3): filter สถานะการยกเลิก
                var cancelStatus = (document.getElementById('filterCancelStatus').value || '').trim();
                var cancelMatch  = !cancelStatus || (row.dataset.isCancelled || 'false') === cancelStatus;

                var rowIssued   = new Date(row.dataset.issuedDate || '');
                var rowHCIssued = new Date(row.dataset.hcIssuedDate || '');
                var issuedMatch   = (!issuedFrom   && !issuedTo)   || ((!issuedFrom   || rowIssued   >= issuedFrom)   && (!issuedTo   || rowIssued   <= issuedTo));
                var hcIssuedMatch = (!hcIssuedFrom && !hcIssuedTo) || ((!hcIssuedFrom || rowHCIssued >= hcIssuedFrom) && (!hcIssuedTo  || rowHCIssued <= hcIssuedTo));

                var isVisible = certTypeMatch && certNoMatch && estabMatch && approvalMatch && productMatch && countryMatch && hcNoMatch && statusMatch && inspMatch && issuedMatch && hcIssuedMatch && cancelMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) { visibleCount += 1; }
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
        ['filterCertificate','filterStatus','filterInspectionStatus','filterCancelStatus','filterCertNo','filterEstablishment','filterApprovalNo',
         'filterProduct','filterCountry','filterHCNo',
         'filterIssuedDateFrom','filterIssuedDateTo','filterHCIssuedDateFrom','filterHCIssuedDateTo'
        ].forEach(function(id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.addEventListener('change', filterRows);
            el.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });
        document.getElementById('btnResetRequests').addEventListener('click', function () {
            ['filterCertNo','filterEstablishment','filterApprovalNo','filterProduct','filterCountry',
             'filterHCNo','filterIssuedDateFrom','filterIssuedDateTo','filterHCIssuedDateFrom','filterHCIssuedDateTo'
            ].forEach(function(id) { var el = document.getElementById(id); if (el) el.value = ''; });
            document.getElementById('filterCertificate').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterInspectionStatus').value = '';
            document.getElementById('filterCancelStatus').value = '';
            filterRows();
        });
    });
</script>
}

@* ************** Content ************** *@
<h4 class="mb-1">ใบรับรองฯ</h4>
