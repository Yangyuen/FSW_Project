<!-- ==================== Modal: เพิ่มหลักฐานประกอบ ==================== -->
<div class="modal fade" id="modalAddEvidence" tabindex="-1" aria-labelledby="modalAddEvidenceLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalAddEvidenceLabel">
                     เพิ่มหลักฐานประกอบ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="ev_doctype" class="form-label">ประเภทเอกสาร <span class="text-danger">●</span></label>
                        <select id="ev_doctype" class="form-select" required>
                            <option value="">-- เลือกประเภทเอกสาร --</option>
                            <option value="police_report">ใบแจ้งความ</option>
                            <option value="loss_certificate">หนังสือรับรองการสูญหาย</option>
                            <option value="damage_photo">รูปภาพเอกสารชำรุด</option>
                            <option value="statutory_declaration">คำให้การ/คำสาบาน</option>
                            <option value="other">อื่นๆ</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="ev_date" class="form-label">วันที่เอกสาร</label>
                        <input type="text" id="ev_date" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-12">
                        <label for="ev_description" class="form-label">ชื่อเอกสาร / คำอธิบาย <span class="text-danger">●</span></label>
                        <input type="text" id="ev_description" class="form-control"
                            placeholder="ระบุชื่อหรือคำอธิบายเอกสาร" required />
                    </div>
                    <div class="col-12">
                        <label for="ev_file" class="form-label">ไฟล์แนบ</label>
                        <input type="file" id="ev_file" class="form-control"
                            accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                        <div class="form-text">รองรับ PDF, JPG, PNG, DOC, DOCX ขนาดไม่เกิน 10 MB</div>
                    </div>
                    <div class="col-12">
                        <label for="ev_remark" class="form-label">หมายเหตุ</label>
                        <textarea id="ev_remark" class="form-control" rows="3" placeholder="หมายเหตุเพิ่มเติม (ถ้ามี)"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i> ยกเลิก
                </button>
                <button type="button" class="btn btn-primary" id="btnConfirmAddEvidence">
                    <i class="ri ri-check-line me-1"></i> เพิ่มหลักฐาน
                </button>
            </div>
        </div>
    </div>
</div>
<!-- /Modal Evidence -->

@section PageScripts {
<script>
    $(document).ready(function () {
        // Select2
        $('.select2').select2({ width: '100%' });

        // Flatpickr
        function initFlatpickr(el) {
            if (el && !el._flatpickr) {
                flatpickr(el, {
                    dateFormat: 'd/m/Y',
                    allowInput: true,
                    locale: { firstDayOfWeek: 1 }
                });
            }
        }
        document.querySelectorAll('.flatpickr-date').forEach(function (el) { initFlatpickr(el); });

        $('#modalAddEvidence').on('shown.bs.modal', function () {
            $(this).find('.flatpickr-date').each(function () { initFlatpickr(this); });
            $('#ev_doctype').val('').trigger('change');
            $('#ev_date').val('');
            $('#ev_description').val('');
            $('#ev_file').val('');
            $('#ev_remark').val('');
        });

        // Tooltips
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // Evidence row index
        function reindexEvidence() {
            $('#evidenceTbody tr:not(#evidenceTableEmpty)').each(function (i) {
                $(this).find('td:first').text(i + 1);
            });
        }

        // Add evidence
        $('#btnConfirmAddEvidence').on('click', function () {
            var doctype = $('#ev_doctype').val();
            var doctypeText = $('#ev_doctype option:selected').text();
            var desc = $('#ev_description').val().trim();
            var evDate = $('#ev_date').val().trim();
            var fileName = '';
            if ($('#ev_file')[0].files.length > 0) {
                fileName = $('#ev_file')[0].files[0].name;
            }

            if (!doctype || !desc) {
                alert('กรุณากรอกข้อมูลที่จำเป็นให้ครบถ้วน');
                return;
            }

            var rowCount = $('#evidenceTbody tr:not(#evidenceTableEmpty)').length + 1;
            var fileHtml = fileName
                ? '<span class="badge bg-label-secondary"><i class="ri ri-file-line me-1"></i>' + fileName + '</span>'
                : '<span class="text-muted small">-</span>';

            var $row = $('<tr>' +
                '<td class="text-center text-muted">' + rowCount + '</td>' +
                '<td><span class="badge bg-label-danger">' + doctypeText + '</span></td>' +
                '<td>' + desc + '</td>' +
                '<td class="text-center">' + (evDate || '-') + '</td>' +
                '<td class="text-center">' + fileHtml + '</td>' +
                '<td class="text-center">' +
                '<button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-remove-evidence" title="ลบ">' +
                '<i class="ri ri-delete-bin-line text-danger"></i></button>' +
                '</td></tr>');

            $('#evidenceTbody').append($row);
            bootstrap.Modal.getInstance(document.getElementById('modalAddEvidence')).hide();
        });

        // Remove evidence
        $(document).on('click', '.btn-remove-evidence', function () {
            $(this).closest('tr').remove();
            reindexEvidence();
        });
    });
</script>
}
