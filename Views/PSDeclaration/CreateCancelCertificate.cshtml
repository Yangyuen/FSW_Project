                                                                        <i class="ri ri-eraser-line me-1"></i>ล้าง
                                                                    </button>
                                                                    <button type="button" class="btn btn-outline-primary btn-sm"
                                                                            onclick="alert('[mockup] บันทึกลายเซ็น')">
                                                                        <i class="ri ri-check-line me-1"></i>ใช้ลายเซ็นนี้
                                                                    </button>
                                                                </div>
                                                            </div>
                                                            <!-- Divider -->
                                                            <div class="d-flex align-items-center text-muted small" style="padding-top:40px;">— หรือ —</div>
                                                            <!-- Upload image -->
                                                            <div>
                                                                <div class="small text-muted mb-1">Upload ภาพลายเซ็น</div>
                                                                <label class="btn btn-outline-success btn-sm mb-1" style="cursor:pointer;">
                                                                    <i class="ri ri-upload-2-line me-1"></i>เลือกไฟล์
                                                                    <input type="file" accept="image/*" class="d-none" />
                                                                </label>
                                                                <div class="small text-muted">JPG / PNG ไม่เกิน 2 MB</div>
                                                            </div>
                                                        </div>
                                                        <div class="mt-2">
                                                            <span class="badge bg-label-danger">
                                                                <i class="ri ri-close-circle-line me-1"></i>ยังไม่ได้ลงนาม
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
