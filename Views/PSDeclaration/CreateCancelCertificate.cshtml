                                <!-- ===== Accordion: รายละเอียดคำขอยกเลิก ===== -->
                                <div class="accordion accordion-custom-button mb-4" id="accordionCancelDetail">
                                    <div class="accordion-item active">
                                        <h2 class="accordion-header" id="headingCancelDetail">
                                            <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                                data-bs-target="#collapseCancelDetail" aria-expanded="true"
                                                aria-controls="collapseCancelDetail">
                                                <i class="icon-base ri ri-file-list-line me-2"></i>
                                                รายละเอียดคำขอยกเลิกใบรับรอง
                                            </button>
                                        </h2>
                                        <div id="collapseCancelDetail" class="accordion-collapse collapse show"
                                            aria-labelledby="headingCancelDetail">
                                            <div class="accordion-body p-0">

                                                <!-- TOR 1.10(3)(9): Timeline ติดตามสถานะ -->
                                                <div class="p-4 border-bottom">
                                                    <div class="d-flex align-items-center mb-3">
