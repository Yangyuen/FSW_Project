@{
    ViewData["Title"] = "สร้างคำขอยกเลิกใบรับรอง";

    // TOR 1.10(1): mockup — มีการตรวจปล่อยอยู่ (แสดง alert)
    bool hasInspection = true;
}

<h4 class="mb-1">สร้างคำขอยกเลิกใบรับรอง</h4>
<p class="mb-1">สร้างคำร้องขอยกเลิกใบรับรองการแปรรูปสัตว์น้ำและใบรับรองที่เกี่ยวข้อง</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "PSDeclaration")" class="text-primary fw-semibold">ขอใบรับรอง PS/Declaration</a>
        </li>
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexCancelCertificate", "PSDeclaration")" class="text-primary fw-semibold">ขอยกเลิกใบรับรอง</a>
        </li>
        <li class="breadcrumb-item active text-secondary">สร้างคำขอยกเลิก</li>
    </ol>
</nav>

<div class="row">
    <div class="col-12">

        <!-- ==================== TOR 1.10(1): Alert กรณีมีการตรวจปล่อยอยู่แล้ว ==================== -->
        @if (hasInspection)
        {
            <div class="alert alert-warning d-flex align-items-start gap-3 mb-4" role="alert" id="alertInspectionExistsCancel">
                <i class="ri ri-error-warning-line fs-4 flex-shrink-0 mt-1 text-warning"></i>
                <div class="flex-grow-1">
                    <div class="fw-semibold mb-1">⚠️ ใบรับรองนี้มีการตรวจปล่อยจากด่านตรวจประมงอยู่แล้ว</div>
                    <div class="small mb-2">
                        กรุณาลบ/ยกเลิกการตรวจปล่อยออกจากด่านตรวจประมงก่อน จึงจะสามารถดำเนินการยกเลิกใบรับรองได้
                        <br />ใบรับรอง <strong>AC821B2171001</strong> มีการตรวจปล่อยที่ด่าน: <span class="fw-semibold text-danger">ด่านท่าเรือแหลมฉบัง</span>
                        &mdash; วันที่ตรวจ: 22/04/2569
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="@Url.Action("IndexApproveReturnWeight", "PSDeclaration")"
                           class="btn btn-sm btn-warning">
                            <i class="ri ri-arrow-right-line me-1"></i>ไปยังหน้าตรวจปล่อย
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                onclick="document.getElementById('alertInspectionExistsCancel').style.display='none';">
                            <i class="ri ri-close-line me-1"></i>ปิดการแจ้งเตือน (ดำเนินการต่อ)
                        </button>
                    </div>
                </div>
            </div>
        }

        <form action="#" method="post" id="cancelCertForm">
            <div class="row">
                <div class="col-12">

                    <!-- ==================== Tabs ==================== -->
                    <div class="nav-align-top nav-tabs-shadow mb-4">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button type="button" class="nav-link waves-effect active" id="tab-detail-tab"
                                        data-bs-toggle="tab" data-bs-target="#tab-detail"
                                        role="tab" aria-controls="tab-detail" aria-selected="true">
                                    <i class="ri ri-file-info-line me-1"></i>รายละเอียดคำขอ
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button type="button" class="nav-link waves-effect" id="tab-evidence-tab"
                                        data-bs-toggle="tab" data-bs-target="#tab-evidence"
                                        role="tab" aria-controls="tab-evidence" aria-selected="false" tabindex="-1">
                                    <i class="ri ri-attachment-2 me-1"></i>หลักฐานประกอบ
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button type="button" class="nav-link waves-effect" id="tab-history-tab"
                                        data-bs-toggle="tab" data-bs-target="#tab-history"
                                        role="tab" aria-controls="tab-history" aria-selected="false" tabindex="-1">
                                    <i class="ri ri-time-line me-1"></i>ประวัติการดำเนินการ
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content">

                            <!-- ==================== TAB 1: รายละเอียดคำขอ ==================== -->
