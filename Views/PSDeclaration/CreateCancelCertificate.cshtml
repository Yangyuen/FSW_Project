                                <!-- ===== Accordion: Health Certificate & การปลดล็อก (TOR 1.10(10)) ===== -->
                                <div class="accordion accordion-custom-button mb-4" id="accordionHcUnlock">
                                    <div class="accordion-item border">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button collapsed fw-semibold" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#collapseHcUnlock"
                                                aria-expanded="false" aria-controls="collapseHcUnlock">
                                                <i class="ri ri-shield-check-line me-2 text-info"></i>
                                                ใบรับรองสุขอนามัยที่อ้างอิง (Health Certificate)
                                                <span class="badge bg-label-info ms-2 small">จะถูกปลดล็อกหลังอนุมัติยกเลิก</span>
                                            </button>
                                        </h2>
                                        <div id="collapseHcUnlock" class="accordion-collapse collapse" id="cancelHcUnlockCard">
                                            <div class="accordion-body">
                                                <div class="alert alert-success small py-2 mb-3">
                                                    <i class="ri ri-lock-unlock-line me-1"></i>
                                                    การยกเลิกใบรับรองฉบับนี้จะ<strong>ปลดล็อก HC</strong> ที่อ้างอิงอยู่
                                                    — สามารถนำไปใช้กับใบรับรองอื่นได้หลังจากเจ้าหน้าที่<strong>อนุมัติยกเลิก</strong>
                                                </div>
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-bordered align-middle mb-0 small">
                                                        <thead class="table-light text-center">
                                                            <tr>
                                                                <th style="min-width:180px;">เลขที่ Health Certificate</th>
                                                                <th style="min-width:180px;">ใบรับรองที่อ้างถึงปัจจุบัน</th>
