                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label small">เลขที่ใบรับรอง</label>
                                                            <input type="text" class="form-control bg-light"
                                                                   value="AC821B2171001" readonly />
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label small">ชื่อสถานประกอบการ</label>
                                                            <input type="text" class="form-control bg-light"
                                                                   value="Alpha Office Automation Co., Ltd. (สาขา 00001)" readonly />
                                                        </div>
                                                        <div class="col-md-3">
                                                            <label class="form-label small">หมายเลขรับรองโรงงาน</label>
                                                            <input type="text" class="form-control bg-light"
                                                                   value="AP-74110-001" readonly />
                                                        </div>
                                                        <div class="col-md-3">
                                                            <label class="form-label small">วันที่ออกใบรับรอง</label>
                                                            <input type="text" class="form-control bg-light"
                                                                   value="15/02/2569" readonly />
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label small">ชื่อสินค้า</label>
                                                            <input type="text" class="form-control bg-light"
                                                                   value="CANNED TUNA IN BRINE / ปลาทูน่ากระป๋อง" readonly />
                                                        </div>
                                                        <div class="col-md-3">
                                                            <label class="form-label small">ประเทศปลายทาง</label>
                                                            <input type="text" class="form-control bg-light"
                                                                   value="สหภาพยุโรป (EU)" readonly />
                                                        </div>
                                                        <div class="col-md-3">
                                                            <label class="form-label small">น้ำหนักรวม (กก.)</label>
                                                            <input type="text" class="form-control bg-light"
                                                                   value="6,882 กก." readonly />
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- TOR 1.10(4): เหตุผลการยกเลิก -->
                                                <div class="p-4 border-bottom">
                                                    <div class="d-flex align-items-center mb-3">
                                                        <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                            <i class="ri ri-question-answer-line fs-5"></i>
                                                        </span>
                                                        <h6 class="mb-0 fw-semibold">เหตุผลการยกเลิก <span class="text-danger ms-1">*</span></h6>
                                                    </div>
                                                    <div class="row g-3">
                                                        <div class="col-md-6">
                                                            <label class="form-label small">ประเภทเหตุผล <span class="text-danger">*</span></label>
                                                            <div class="d-flex flex-column gap-2">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="radio"
                                                                           name="cancellationReason" id="reasonWithdraw"
                                                                           value="withdraw" onchange="toggleCancelReasonDetail()" />
                                                                    <label class="form-check-label" for="reasonWithdraw">ขอถอนคำขอ</label>
                                                                </div>
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="radio"
                                                                           name="cancellationReason" id="reasonDataError"
                                                                           value="data_error" onchange="toggleCancelReasonDetail()" />
                                                                    <label class="form-check-label" for="reasonDataError">ข้อมูลผิดพลาด</label>
                                                                </div>
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="radio"
                                                                           name="cancellationReason" id="reasonNoExport"
                                                                           value="no_export" onchange="toggleCancelReasonDetail()" />
                                                                    <label class="form-check-label" for="reasonNoExport">สินค้าไม่ได้ส่งออก</label>
                                                                </div>
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="radio"
                                                                           name="cancellationReason" id="reasonWrongType"
                                                                           value="wrong_type" onchange="toggleCancelReasonDetail()" />
                                                                    <label class="form-check-label" for="reasonWrongType">ใช้ใบรับรองผิดประเภท</label>
                                                                </div>
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="radio"
                                                                           name="cancellationReason" id="reasonOther"
                                                                           value="other" onchange="toggleCancelReasonDetail()" />
                                                                    <label class="form-check-label" for="reasonOther">อื่นๆ (ระบุ)</label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label small" for="cancelReasonDetail">รายละเอียดเพิ่มเติม</label>
                                                            <textarea class="form-control" id="cancelReasonDetail"
                                                                      name="cancelReasonDetail" rows="6"
                                                                      placeholder="ระบุรายละเอียดเพิ่มเติม..."></textarea>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- ลายเซ็นอิเล็กทรอนิกส์ -->
                                                <div class="p-4" id="eSignatureCancelCard">
                                                    <div class="d-flex align-items-center mb-3">
                                                        <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                            <i class="ri ri-pen-nib-line fs-5"></i>
                                                        </span>
                                                        <h6 class="mb-0 fw-semibold">ลายเซ็นอิเล็กทรอนิกส์ผู้ประกอบการ</h6>
                                                    </div>
                                                    <div class="card border p-3" style="background:#fafafa;">
                                                        <div class="d-flex align-items-start gap-3 flex-wrap">
