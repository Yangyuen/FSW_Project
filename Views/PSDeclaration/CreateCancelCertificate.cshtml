                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr>
                                                                <td class="fw-semibold">HC-TH-2569-00847</td>
                                                                <td>AC821B2171001 (ฉบับนี้)</td>
                                                                <td class="text-center">
                                                                    <span class="badge bg-label-danger small">
                                                                        <i class="ri ri-lock-2-line me-1"></i>ถูกล็อค
