                                                        <div class="d-flex flex-column align-items-center text-center" style="min-width:120px;">
                                                            <div class="rounded-circle d-flex align-items-center justify-content-center mb-1 bg-primary text-white"
                                                                 style="width:2.2rem;height:2.2rem;">
                                                                <i class="ri ri-file-add-line fs-6"></i>
                                                            </div>
                                                            <div class="small fw-semibold text-primary">สร้างคำขอ</div>
                                                            <div class="text-muted" style="font-size:0.7rem;">22/04/2569 10:20</div>
                                                            <span class="badge bg-label-primary mt-1" style="font-size:0.65rem;">เสร็จสิ้น</span>
                                                        </div>
                                                        <div class="flex-grow-1 border-top border-primary border-2 mx-1" style="min-width:30px;"></div>
                                                        <!-- Step 2: ส่งคำขอ -->
                                                        <div class="d-flex flex-column align-items-center text-center" style="min-width:120px;">
                                                            <div class="rounded-circle d-flex align-items-center justify-content-center mb-1 bg-primary text-white"
                                                                 style="width:2.2rem;height:2.2rem;">
                                                                <i class="ri ri-send-plane-line fs-6"></i>
                                                            </div>
                                                            <div class="small fw-semibold text-primary">ส่งคำขอ</div>
                                                            <div class="text-muted" style="font-size:0.7rem;">22/04/2569 10:45</div>
                                                            <span class="badge bg-label-primary mt-1" style="font-size:0.65rem;">เสร็จสิ้น</span>
                                                        </div>
                                                        <div class="flex-grow-1 border-top border-primary border-2 mx-1" style="min-width:30px;"></div>
                                                        <!-- Step 3: รับคำขอ -->
                                                        <div class="d-flex flex-column align-items-center text-center" style="min-width:120px;">
                                                            <div class="rounded-circle d-flex align-items-center justify-content-center mb-1 bg-warning text-dark"
                                                                 style="width:2.2rem;height:2.2rem;">
                                                                <i class="ri ri-inbox-archive-line fs-6"></i>
                                                            </div>
                                                            <div class="small fw-semibold text-warning">รับคำขอ</div>
                                                            <div class="text-muted" style="font-size:0.7rem;">23/04/2569 09:15</div>
                                                            <span class="badge bg-label-warning mt-1" style="font-size:0.65rem;">กำลังดำเนินการ</span>
                                                        </div>
                                                        <div class="flex-grow-1 border-top border-secondary border-2 mx-1" style="min-width:30px; opacity:0.35;"></div>
                                                        <!-- Step 4: อนุมัติ / ไม่อนุมัติ -->
                                                        <div class="d-flex flex-column align-items-center text-center" style="min-width:120px;">
                                                            <div class="rounded-circle d-flex align-items-center justify-content-center mb-1 bg-secondary text-white"
                                                                 style="width:2.2rem;height:2.2rem; opacity:0.45;">
                                                                <i class="ri ri-checkbox-circle-line fs-6"></i>
                                                            </div>
                                                            <div class="small fw-semibold text-muted">อนุมัติ / ไม่อนุมัติ</div>
                                                            <div class="text-muted" style="font-size:0.7rem;">รอดำเนินการ</div>
                                                            <span class="badge bg-label-secondary mt-1" style="font-size:0.65rem;">รอดำเนินการ</span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- ข้อมูลใบรับรองที่จะยกเลิก (readonly) -->
                                                <div class="p-4 border-bottom">
                                                    <div class="d-flex align-items-center mb-3">
                                                        <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                            <i class="ri ri-file-info-line fs-5"></i>
                                                        </span>
                                                        <h6 class="mb-0 fw-semibold">ข้อมูลใบรับรองที่ขอยกเลิก</h6>
                                                        <span class="badge bg-label-secondary ms-2 small">อ่านอย่างเดียว</span>
                                                    </div>
                                                    <div class="row g-3">
                                                        <div class="col-md-6">
                                                            <label class="form-label small">ประเภทใบรับรอง</label>
                                                            <input type="text" class="form-control bg-light"
