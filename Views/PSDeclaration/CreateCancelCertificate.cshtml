@section PageScripts {
<script>
    // TOR 1.10(5): เพิ่มหลักฐานประกอบ
    var _cancelEvidenceRowCount = 3; // เริ่มจากแถวที่ 3 (มีอยู่แล้ว 3 แถว)

    function saveCancelEvidence() {
        var docName  = (document.getElementById('cevDocName').value  || '').trim();
        var docType  = document.getElementById('cevDocType').value;
        var docDate  = (document.getElementById('cevDocDate').value  || '').trim();
        var fileEl   = document.getElementById('cevFile');
        var fileName = fileEl.files.length > 0 ? fileEl.files[0].name : '';
        var alertEl  = document.getElementById('cevValidationAlert');
        var msgEl    = document.getElementById('cevValidationMsg');

        // Validate
        if (!docName || !docType || !fileName) {
            msgEl.textContent = 'กรุณากรอกชื่อเอกสาร เลือกประเภทเอกสาร และแนบไฟล์';
            alertEl.classList.remove('d-none');
            return;
        }
        alertEl.classList.add('d-none');

        // Determine badge color from file extension
        var ext = fileName.split('.').pop().toUpperCase();
        var badgeClass = ext === 'PDF' ? 'bg-label-danger'
                       : (ext === 'JPG' || ext === 'JPEG' || ext === 'PNG') ? 'bg-label-info'
                       : 'bg-label-secondary';

        var today = docDate || new Date().toLocaleDateString('th-TH', { day: '2-digit', month: '2-digit', year: 'numeric' });
        _cancelEvidenceRowCount++;

        var tbody = document.querySelector('#cancelEvidenceTable tbody');
        var tr = document.createElement('tr');
        tr.innerHTML = `
            <td class="text-center">${_cancelEvidenceRowCount}</td>
            <td>${docName}</td>
            <td class="text-center"><span class="badge ${badgeClass} small">${ext}</span></td>
            <td class="small text-muted">${fileName}</td>
            <td class="text-center small">${today}</td>
            <td class="text-center">
                <button type="button" class="btn btn-xs btn-outline-primary p-0 px-1 me-1"
                        onclick="alert('[mockup] ดาวน์โหลดไฟล์')" title="ดาวน์โหลด">
                    <i class="ri ri-download-line"></i>
                </button>
                <button type="button" class="btn btn-xs btn-outline-danger p-0 px-1"
                        onclick="deleteCancelEvidenceRow(this)" title="ลบ">
                    <i class="ri ri-delete-bin-line"></i>
                </button>
            </td>`;
        tbody.appendChild(tr);

        // Reset form & close modal
        document.getElementById('cevDocName').value = '';
        document.getElementById('cevDocType').value = '';
        document.getElementById('cevDocDate').value = '';
        fileEl.value = '';
        bootstrap.Modal.getInstance(document.getElementById('modalAddCancelEvidence')).hide();

        // Renumber rows
        renumberCancelEvidenceRows();
    }

    function deleteCancelEvidenceRow(btn) {
        btn.closest('tr').remove();
        renumberCancelEvidenceRows();
    }

    function renumberCancelEvidenceRows() {
        document.querySelectorAll('#cancelEvidenceTable tbody tr').forEach(function(tr, i) {
            tr.cells[0].textContent = i + 1;
        });
        _cancelEvidenceRowCount = document.querySelectorAll('#cancelEvidenceTable tbody tr').length;
    }

    // Init flatpickr for modal date field
    document.getElementById('modalAddCancelEvidence').addEventListener('shown.bs.modal', function() {
        var el = document.getElementById('cevDocDate');
        if (el && !el._flatpickr && typeof flatpickr !== 'undefined') {
            flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
        }
        document.getElementById('cevValidationAlert').classList.add('d-none');
    });
        const other = document.getElementById('reasonOther');
        const detail = document.getElementById('cancelReasonDetail');
        if (other && other.checked) {
            detail.placeholder = 'ระบุเหตุผลการยกเลิกโดยละเอียด...';
        } else {
            detail.placeholder = 'ระบุรายละเอียดเพิ่มเติม (ถ้ามี)...';
        }
    }

    // Canvas e-signature
    (function () {
        const canvas = document.getElementById('cancelSignatureCanvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let drawing = false;

        function getPos(e) {
            const rect = canvas.getBoundingClientRect();
            const src = e.touches ? e.touches[0] : e;
            return { x: src.clientX - rect.left, y: src.clientY - rect.top };
        }

        canvas.addEventListener('mousedown', e => { drawing = true; const p = getPos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); });
        canvas.addEventListener('mousemove', e => { if (!drawing) return; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.strokeStyle = '#1a1a2e'; ctx.lineWidth = 1.5; ctx.stroke(); });
        canvas.addEventListener('mouseup', () => drawing = false);
        canvas.addEventListener('mouseleave', () => drawing = false);
        canvas.addEventListener('touchstart', e => { e.preventDefault(); drawing = true; const p = getPos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); });
        canvas.addEventListener('touchmove', e => { e.preventDefault(); if (!drawing) return; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.strokeStyle = '#1a1a2e'; ctx.lineWidth = 1.5; ctx.stroke(); });
        canvas.addEventListener('touchend', () => drawing = false);
    })();

    function clearCancelSignature() {
        const canvas = document.getElementById('cancelSignatureCanvas');
        if (canvas) canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
    }

    // Init tooltips
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        new bootstrap.Tooltip(el);
    });

    // TOR 1.10(2): ยืนยันส่งคำขอ → ปิด modal ยืนยัน → เปิด modal ผลลัพธ์
    function confirmCancelSubmit() {
        const confirmModal = bootstrap.Modal.getInstance(document.getElementById('modalConfirmCancel'));
        if (confirmModal) confirmModal.hide();
        setTimeout(function () {
            const resultModal = new bootstrap.Modal(document.getElementById('modalAutoCancelResult'));
            resultModal.show();
        }, 400);
    }
</script>
}
