        <div data-i18n="จัดการองค์กร">จัดการองค์กร</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Admin/DofList" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="DofList" class="menu-link">
        <i class="menu-icon icon-base ri ri-list-check-2"></i>
        <div data-i18n="ทะเบียน DOF">ทะเบียน DOF</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Admin/TraceabilityList" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="TraceabilityList" class="menu-link">
        <i class="menu-icon icon-base ri ri-search-eye-line"></i>
        <div data-i18n="รายชื่อ Traceability">รายชื่อ Traceability</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Admin/NotificationReason" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="NotificationReason" class="menu-link">
        <i class="menu-icon icon-base ri ri-notification-3-line"></i>
        <div data-i18n="มาตรการสุขอนามัย">มาตรการสุขอนามัย</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Admin/IssueReason" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="IssueReason" class="menu-link">
        <i class="menu-icon icon-base ri ri-file-paper-2-line"></i>
        <div data-i18n="ออกใบรับรอง PS/NMD">ออกใบรับรอง PS/NMD</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Admin/Reports" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="Reports" class="menu-link">
        <i class="menu-icon icon-base ri ri-bar-chart-box-line"></i>
        <div data-i18n="รายงาน">รายงาน</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Admin/CertificateTemplate" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="CertificateTemplate" class="menu-link">
