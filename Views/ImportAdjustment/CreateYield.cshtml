@section PageScripts {
<script>
var APPROVED_YIELD = 40.00;

function calcYieldDiff() {
    var requested = parseFloat(document.getElementById('requestedYield').value) || 0;
    var tolerance = parseFloat(document.getElementById('yieldTolerance').value) || 0;
    var diff = requested - APPROVED_YIELD;
    var diffEl = document.getElementById('yieldDiff');
    var noteEl = document.getElementById('yieldDiffNote');
    diffEl.value = (diff >= 0 ? '+' : '') + diff.toFixed(2);
    if (diff > 0) {
        diffEl.style.color = '#28a745';
        noteEl.innerHTML = '<span class="text-success">เพิ่มขึ้น ' + Math.abs(diff).toFixed(2) + '%</span>';
    } else if (diff < 0) {
        diffEl.style.color = '#dc3545';
        noteEl.innerHTML = '<span class="text-danger">ลดลง ' + Math.abs(diff).toFixed(2) + '%</span>';
    } else {
        diffEl.style.color = '';
        noteEl.innerHTML = '<span class="text-muted">เท่ากัน</span>';
    }
    // Tolerance check
    var warnEl = document.getElementById('alertToleranceWarn');
    var okEl   = document.getElementById('alertToleranceOk');
    var msgEl  = document.getElementById('alertToleranceMsg');
    var okMsgEl = document.getElementById('alertToleranceOkMsg');
    if (requested > 0 && tolerance >= 0) {
        var absDiff = Math.abs(diff);
        var lowerBound = (APPROVED_YIELD - tolerance).toFixed(2);
        var upperBound = (APPROVED_YIELD + tolerance).toFixed(2);
        if (absDiff > tolerance) {
            warnEl.style.display = '';
            okEl.style.display = 'none';
            msgEl.textContent = ' ผลต่าง ' + (diff >= 0 ? '+' : '') + diff.toFixed(2) + '% เกิน ±' + tolerance.toFixed(1) + '% (ช่วงที่ยอมรับ: ' + lowerBound + '% – ' + upperBound + '%)';
        } else {
            warnEl.style.display = 'none';
            okEl.style.display = '';
            okMsgEl.textContent = ' ผลต่าง ' + (diff >= 0 ? '+' : '') + diff.toFixed(2) + '% อยู่ในช่วง ±' + tolerance.toFixed(1) + '%';
        }
    } else {
        warnEl.style.display = 'none';
        okEl.style.display = 'none';
    }
}

function onYieldTypeChange(val) {
    var refField = document.getElementById('fieldImportRef');
    var note = document.getElementById('yieldTypeNote');
    if (val === 'import') {
        refField.style.display = '';
        note.textContent = 'วัตถุดิบที่ผ่านการพิจารณาแล้วของสถานประกอบการที่อยู่ในการรับรอง';
    } else if (val === 'ps') {
        refField.style.display = 'none';
        note.textContent = 'ผลิตภัณฑ์แปรรูปเบื้องต้น (Prior Season / PS)';
    } else if (val === 'nmd') {
        refField.style.display = 'none';
        note.textContent = 'ผลิตภัณฑ์สำเร็จรูป (NMD) สำหรับจำหน่ายภายในประเทศ';
    } else {
        refField.style.display = '';
        note.textContent = '';
    }
}

function handleEvidenceUpload(input) {
    if (!input.files || !input.files.length) return;
    var tbody = document.getElementById('evidenceTbody');
    var count = tbody.querySelectorAll('tr').length;
    Array.from(input.files).forEach(function (file) {
        count++;
        var ext = file.name.split('.').pop().toLowerCase();
        var icon = ['pdf'].includes(ext)
            ? '<i class="ri ri-file-pdf-line text-danger me-1"></i>'
            : (['xlsx','xls'].includes(ext)
                ? '<i class="ri ri-file-excel-2-line text-success me-1"></i>'
                : '<i class="ri ri-file-line text-muted me-1"></i>');
        var tr = '<tr><td class="text-center text-muted">' + count + '</td>' +
            '<td>' + icon + '<a href="#" onclick="alert(\'ดูไฟล์ (mockup)\'); return false;" class="text-primary">' + file.name + '</a></td>' +
            '<td>—</td>' +
            '<td class="text-muted">วันนี้</td>' +
            '<td class="text-center"><button type="button" class="btn btn-sm btn-icon btn-outline-danger" onclick="this.closest(\'tr\').remove(); alert(\'ลบไฟล์ (mockup)\')"><i class="ri ri-delete-bin-line"></i></button></td></tr>';
        tbody.insertAdjacentHTML('beforeend', tr);
    });
    input.value = '';
}

$(document).ready(function () {
    calcYieldDiff();
});

function printYieldForm() {
    var formHtml = document.getElementById('yieldFormA4').outerHTML;
    var printWin = window.open('', '_blank', 'width=900,height=750');
    printWin.document.write(
        '<!DOCTYPE html><html><head><meta charset="utf-8"><title>\u0e41\u0e1a\u0e1a\u0e1f\u0e2d\u0e23\u0e4c\u0e21\u0e01\u0e32\u0e23\u0e41\u0e08\u0e49\u0e07 %\u0e1c\u0e25\u0e1c\u0e25\u0e34\u0e15</title>' +
        '<style>' +
        'body{margin:0;padding:0;background:#f0f0f0;font-family:Sarabun,sans-serif;}' +
        '@@media print{body{background:#fff;}@@page{size:A4;margin:0;}.no-print{display:none!important;}}' +
        '</style></head><body>' +
        '<div class="no-print" style="text-align:center;padding:12px;background:#fff;border-bottom:1px solid #ddd;">' +
        '<button onclick="window.print()" style="padding:8px 24px;background:#003366;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:14px;">\u2399 \u0e2a\u0e31\u0e48\u0e07\u0e1e\u0e34\u0e21\u0e1e\u0e4c</button>' +
        '&nbsp;&nbsp;<button onclick="window.close()" style="padding:8px 20px;background:#888;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:14px;">\u2715 \u0e1b\u0e34\u0e14</button>' +
        '</div>' + formHtml + '</body></html>'
    );
    printWin.document.close();
    printWin.focus();
}
</script>
}
