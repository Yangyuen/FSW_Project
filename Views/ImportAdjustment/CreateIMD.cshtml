                            <input type="number" id="d2_nw" class="form-control form-control-sm text-end"
                                placeholder="0.000" step="0.001" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted"># ปริมาณที่ส่งออกตามบรรจุภัณฑ์ (กก.) <span class="text-primary">●</span></label>
                            <input type="text" id="d2_qty_product" class="form-control form-control-sm text-end bg-light"
                                readonly placeholder="0.000" />
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <!-- Footer Step 1 -->
                <div id="rmbs2FooterSearch" class="d-flex gap-2 w-100 justify-content-end">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="ri ri-close-line me-1"></i> ยกเลิก
                    </button>
                    <button type="button" class="btn btn-primary" id="btnSelectRmbs2">
                        <i class="ri ri-check-line me-1"></i> เลือกรายการ
                    </button>
                </div>
                <!-- Footer Step 2 -->
                <div id="rmbs2FooterDetail" class="d-none d-flex gap-2 w-100 justify-content-end">
                    <button type="button" class="btn btn-secondary" id="btnBackToRmbs2Search">
                        <i class="ri ri-arrow-left-line me-1"></i> ย้อนกลับ
                    </button>
                    <button type="button" class="btn btn-primary" id="btnConfirmAddRMBS2">
                        <i class="ri ri-save-line me-1"></i> บันทึก
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
