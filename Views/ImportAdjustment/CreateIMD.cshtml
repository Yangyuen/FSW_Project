@{
ViewData["Title"] = "คำขอใบรับรองการแปรรูปสัตว์น้ำ";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/select2/select2.js"></script>
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}


@* ************** Content ************** *@
<h4 class="mb-1">สร้างคำขออนุมัติปริมาณ (IMD)</h4>
<p class="mb-1">สร้างคำขออนุมัติปริมาณตั้งต้นวัตถุดิบสัตว์นํ้านำเข้า (IMD)</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexIMD", "ImportAdjustment")" class="text-primary fw-semibold">ขออนุมัติปริมาณ (จับคู่ IMD)</a>
        </li>
        <li class="breadcrumb-item active text-secondary">สร้างคำขออนุมัติปริมาณ (IMD)</li>
    </ol>
</nav>

<div class="row">
    <div class="col-12">

        <!-- ===== Tabs ===== -->
        <form method="post" action="#">
        <div class="nav-align-top nav-tabs-shadow mb-4">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-detail" aria-controls="tab-detail" aria-selected="true">
                        <i class="ri ri-file-list-2-line me-1"></i> รายละเอียดคำขอ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-evidence" aria-controls="tab-evidence" aria-selected="false">
                        <i class="ri ri-folder-open-line me-1"></i> หลักฐานประกอบ
                    </button>
                </li>
            </ul>
            <div class="tab-content">

                <!-- ==================== TAB 1: รายละเอียดคำขอ ==================== -->
                <div id="tab-detail" class="tab-pane fade show active">
                    <!-- ===== Accordion: ข้อมูล IMD และการจับคู่ ===== -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionIMD">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingIMD">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseIMDContent" aria-expanded="true"
                                    aria-controls="collapseIMDContent">
                                    <i class="icon-base ri ri-links-line me-2"></i>
                                    ข้อมูล IMD และการจับคู่เอกสาร
                                </button>
                            </h2>
                            <div id="collapseIMDContent" class="accordion-collapse collapse show"
                                aria-labelledby="headingIMD">
                                <div class="accordion-body p-0">

                                    <!-- ── รายละเอียด ── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-information-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">รายละเอียด</h6>
                                        </div>
                                        <div class="row g-3">
                                            <!-- ผู้ประกอบการ -->
                                            <div class="col-12">
                                                <label class="form-label small">ผู้ประกอบการ <span class="text-danger">●</span></label>
                                                <input type="text" id="imdOperator" class="form-control bg-light"
                                                        placeholder="ชื่อผู้ประกอบการ"
                                                        value="บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด" readonly />
                                            </div>
                                            <!-- เลขที่ IMD + วันที่ IMD -->
                                            <div class="col-md-6">
                                                <label class="form-label small">เลขที่หนังสือกำกับการจำหน่าย (IMD) <span class="text-danger">●</span></label>
                                                <input type="text" id="imdNo" class="form-control bg-light"
                                                        placeholder="เลขที่ IMD" value="23501201316100081" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">วันที่ออกเอกสารหนังสือกำกับการจำหน่าย (IMD)</label>
                                                <input type="text" id="imdDate" class="form-control bg-light flatpickr-date"
                                                    placeholder="วว/ดด/ปปปป" value="10/07/2561" readonly />
                                            </div>
                                            <!-- หน่วยงาน -->
                                            <div class="col-md-6">
                                                <label class="form-label small">หน่วยงานพิจารณาข้อมูลต้นทางผลิต</label>
                                                <input type="text" id="imdSourceUnit" class="form-control bg-light"
                                                    placeholder="หน่วยงาน" value="ด่านตรวจสัตว์น้ำจังหวัดตราด" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">หน่วยงานพิจารณาออกเลขที่ RMBS1 <span class="text-danger">●</span></label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="imdRmbs1Unit" class="select2 form-select" required>
                                                        <option value="">-- เลือก --</option>
                                                        <option value="1" selected>กองตรวจสอบคุณภาพสินค้าประมง</option>
                                                    </select>
                                                    <label for="imdRmbs1Unit">หน่วยงาน</label>
                                                </div>
                                            </div>
                                            <!-- เอกสารที่นำมาดำเนินการจับคู่ -->
                                            <div class="col-12">
                                                <label class="form-label small d-block">เอกสารที่นำมาดำเนินการจับคู่ <span class="text-danger">●</span></label>
                                                <div class="d-flex flex-wrap gap-4">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="imdDocType"
                                                            id="imdDocCC" value="CC" checked />
                                                        <label class="form-check-label" for="imdDocCC">Catch Certificate</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="imdDocType"
                                                            id="imdDocSCC" value="SCC" />
                                                        <label class="form-check-label" for="imdDocSCC">Simplified Catch Certificate</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="imdDocType"
                                                            id="imdDocOther" value="Other" />
                                                        <label class="form-check-label" for="imdDocOther">Other Document</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- Checkbox มาภายหลัง -->
                                            <div class="col-12">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="imdDocLate" />
                                                    <label class="form-check-label" for="imdDocLate">
                                                        Catch Certificate/Simplified Catch Certificate มาภายหลัง
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ── ข้อมูลตรวจสอบการจับคู่ IMD ── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-ship-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ข้อมูลตรวจสอบการจับคู่ IMD</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อเรือจับ (Fishing Vessel) <span class="text-danger">●</span></label>
                                                <input type="text" id="imdFishingVessel" class="form-control bg-light"
                                                    value="MALVA 888" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ธงสัญชาติของเรือ <span class="text-danger">●</span></label>
                                                <input type="text" id="imdVesselFlag" class="form-control bg-light"
                                                    value="ปาปัวนิวกินี (PAPUA NEW GUINEA)" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อเครื่องมือที่ใช้จับ <span class="text-danger">●</span></label>
                                                <input type="text" id="imdGearType" class="form-control bg-light"
                                                    value="อวนล้อมจับ (Purse seine)" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อประเทศที่นำมาบรรจุ <span class="text-danger">●</span></label>
                                                <input type="text" id="imdPackagingCountry" class="form-control bg-light"
                                                    value="เวียดนาม (VIET NAM)" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ช่วงเวลาทำการประมง (วันที่เริ่ม) <span class="text-danger">●</span></label>
                                                <input type="text" id="imdFishingStart" class="form-control bg-light"
                                                    value="1 พฤษภาคม 2561" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ช่วงเวลาทำการประมง (วันที่สิ้นสุด)</label>
                                                <input type="text" id="imdFishingEnd" class="form-control bg-light"
                                                    value="10 กรกฎาคม 2561" readonly />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small">ข้อมูลสัตว์น้ำ <span class="text-danger">●</span></label>
                                                <div class="input-group" style="height:48px;">
                                                    <input type="text" id="imdSpeciesData" class="form-control bg-light h-100"
                                                        value="0303.49.00 000/KGM [F020076S03030001/KGM]=ปลาโอดำ ทั้งตัว แช่แข็ง" readonly />
                                                    <button type="button" class="btn btn-outline-danger h-100" id="btnCancelPairing">
                                                        <i class="ri ri-close-circle-line me-1"></i> ยกเลิกการจับคู่
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ── ข้อมูลตรวจสอบการจับคู่ CC/SCC/Other Document ── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-file-text-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ข้อมูลตรวจสอบการจับคู่ CC/SCC/Other Document</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small">Ref. System Document No.</label>
                                                <input type="text" id="ccRefDocNo" class="form-control bg-light"
                                                    value="S20180710SEA FANTASY XVI00032" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Reference Date</label>
                                                <input type="text" id="ccRefDate" class="form-control bg-light"
                                                    value="10 กรกฎาคม 2561" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Catch Certificate Number</label>
                                                <input type="text" id="ccNumber" class="form-control"
                                                    placeholder="Catch Certificate Number" value="CC1879-T145501" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Validation date</label>
                                                <input type="text" id="ccValidDate" class="form-control flatpickr-date"
                                                    placeholder="วว/ดด/ปปปป" value="10/07/2561" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ประเทศของหน่วยงานที่รับรอง</label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="ccCertCountry" class="select2 form-select">
                                                        <option value="">-- เลือก --</option>
                                                        <option value="FR" selected>ฝรั่งเศส (FRANCE)</option>
                                                        <option value="US">สหรัฐอเมริกา</option>
                                                        <option value="JP">ญี่ปุ่น</option>
                                                    </select>
                                                    <label for="ccCertCountry">ประเทศ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อหน่วยงานที่รับรอง</label>
                                                <input type="text" id="ccCertAgency" class="form-control"
                                                    placeholder="ชื่อหน่วยงาน"
                                                    value="Guadeloupe (Directorate of the sea Guadeloupe)" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อเรือจับ (Fishing Vessel)</label>
                                                <input type="text" id="ccVessel" class="form-control bg-light"
                                                    value="MALVA 888" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ธงสัญชาติของเรือ</label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="ccVesselFlag" class="select2 form-select">
                                                        <option value="">-- เลือก --</option>
                                                        <option value="PG" selected>ปาปัวนิวกินี (PAPUA NEW GUINEA)</option>
                                                    </select>
                                                    <label for="ccVesselFlag">ธงสัญชาติ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">หมายเรียกขาน (Call Sign)</label>
                                                <input type="text" id="ccCallSign" class="form-control"
                                                    placeholder="Call Sign" value="COSMO88" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">หมายเลขไอเอ็มโอ (IMO)</label>
                                                <input type="text" id="ccImo" class="form-control"
                                                    placeholder="IMO Number" value="88-112" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อเครื่องมือที่ใช้จับ</label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="ccGearType" class="select2 form-select">
                                                        <option value="">-- เลือก --</option>
                                                        <option value="PS" selected>อวนล้อมจับ (Purse seine)</option>
                                                    </select>
                                                    <label for="ccGearType">เครื่องมือ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">สถานที่จับ/แหล่งทำประมง</label>
                                                <div class="row g-2">
                                                    <div class="col-6">
                                                        <div class="form-floating form-floating-outline">
                                                            <select id="ccFishingArea1" class="select2 form-select">
                                                                <option value="">-- เลือก --</option>
                                                                <option value="PG" selected>ปาปัวนิวกินี (PAPUA NEW GUINEA)</option>
                                                            </select>
                                                            <label for="ccFishingArea1">ประเทศ</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-6">
                                                        <div class="form-floating form-floating-outline">
                                                            <select id="ccFishingArea2" class="select2 form-select">
                                                                <option value="">-- เลือก --</option>
                                                                <option value="71" selected>Area 71 (Pacific, Western Central)</option>
                                                            </select>
                                                            <label for="ccFishingArea2">พื้นที่</label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ช่วงเวลาทำการประมง (วันที่เริ่ม)</label>
                                                <input type="text" id="ccFishingStart" class="form-control flatpickr-date"
                                                    placeholder="วว/ดด/ปปปป" value="01/05/2561" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ช่วงเวลาทำการประมง (วันที่สิ้นสุด)</label>
                                                <input type="text" id="ccFishingEnd" class="form-control flatpickr-date"
                                                    placeholder="วว/ดด/ปปปป" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อกัปตัน/ผู้บังคับการเรือ</label>
                                                <input type="text" id="ccCaptain" class="form-control"
                                                    placeholder="ชื่อกัปตัน" value="MR.MASHIMURA" />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small">Catch description (สำหรับแสดงในหนังสือรับรอง)</label>
                                                <div class="input-group">
                                                    <input type="text" id="ccCatchDesc" class="form-control"
                                                        placeholder="Catch description" value="CC1879-T145501 CC&lt;AW" />
                                                    <button type="button" class="btn btn-outline-secondary" title="จัดรูปแบบตัวเอียง">
                                                        <i class="ri ri-italic"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ── ข้อมูลน้ำหนักสินค้า ── -->
                                    <div class="p-4">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-scales-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ข้อมูลน้ำหนักสินค้า</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label small">รูปแบบการจัดสรร CC/SCC</label>
                                                <input type="text" id="ccAllocType" class="form-control bg-light"
                                                    value="Average (เฉลี่ย)" readonly />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">วันที่เริ่มรับสัตว์น้ำเข้าโรงงาน</label>
                                                <input type="text" id="ccRecvStart" class="form-control flatpickr-date"
                                                    placeholder="วว/ดด/ปปปป" value="10/07/2561" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">วันที่สิ้นสุดการรับสัตว์น้ำเข้าโรงงาน</label>
                                                <input type="text" id="ccRecvEnd" class="form-control flatpickr-date"
                                                    placeholder="วว/ดด/ปปปป" value="10/07/2561" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ปริมาณสัตว์น้ำทั้งหมดที่รับจับ (กก.)</label>
                                                <div class="input-group">
                                                    <input type="text" id="ccTotalQty" class="form-control bg-light"
                                                        value="60,000.000" readonly />
                                                    <span class="input-group-text">KGM = กิโลกรัม</span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ปริมาณสัตว์น้ำที่กำรงานนับรับ (กก.)</label>
                                                <div class="input-group">
                                                    <input type="text" id="ccApprovedQty" class="form-control"
                                                        value="60000" />
                                                    <span class="input-group-text">KGM = กิโลกรัม</span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ปริมาณสัตว์น้ำที่ระบุใน Catch Certificate</label>
                                                <div class="input-group">
                                                    <input type="text" id="ccCertQty" class="form-control"
                                                        value="60000" />
                                                    <span class="input-group-text">KGM = กิโลกรัม</span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">โควตาสัตว์น้ำที่กำรงานนับรับ (กก.)</label>
                                                <div class="input-group">
                                                    <input type="text" id="ccQuota" class="form-control"
                                                        value="60,000.000" />
                                                    <span class="input-group-text">KGM = กิโลกรัม</span>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="alert alert-danger py-2 mb-0" role="alert">
                                                    <i class="ri ri-information-line me-1"></i>
                                                    โควตาสัตว์น้ำนี้เป็นโควตาประมาณการณ์ โควตาจริงจะได้รับหลังจากเจ้าหน้าที่อนุมัติและตรวจสอบกับข้อมูลปริมาณสัตว์น้ำที่ระบุใน Catch Certificate เรียบร้อยแล้ว
