                note: 'รองรับการพิมพ์ฉลากส่งออกตามมาตรฐาน EU และ US',
                products: [
                    { name: 'ซองบรรจุปลาทูน่า', hsCode: '3923.29', market: 'US / EU', status: 'ใช้งาน' },
                    { name: 'ฉลากสินค้าส่งออก', hsCode: '4821.10', market: 'US / AU', status: 'ใช้งาน' }
                ],
