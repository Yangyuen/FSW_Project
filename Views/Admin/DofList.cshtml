    .dof-table-compact td {
        padding: 0.45rem 0.5rem;
        vertical-align: middle;
        line-height: 1.3;
        white-space: normal;
        word-break: break-word;
    }

    .dof-table-compact thead th {
        white-space: normal;
        word-break: keep-all;
        overflow-wrap: normal;
    }

    .dof-table-compact .badge {
        font-size: 0.68rem;
    }

