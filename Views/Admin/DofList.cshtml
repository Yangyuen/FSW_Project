                    <option value="">ทั้งหมด</option>
                    <option value="ชลบุรี">ชลบุรี</option>
                    <option value="ภูเก็ต">ภูเก็ต</option>
                    <option value="ระนอง">ระนอง</option>
                    <option value="สงขลา">สงขลา</option>
                    <option value="สมุทรปราการ">สมุทรปราการ</option>
                    <option value="สมุทรสาคร">สมุทรสาคร</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="รับรองแล้ว">รับรองแล้ว</option>
                    <option value="ใกล้หมดอายุ">ใกล้หมดอายุ</option>
                    <option value="ระงับชั่วคราว">ระงับชั่วคราว</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-3">
                <label for="filterAudit" class="form-label">ผลการตรวจ</label>
                <select id="filterAudit" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ผ่าน">ผ่าน</option>
                    <option value="ผ่านแบบมีข้อสังเกต">ผ่านแบบมีข้อสังเกต</option>
                    <option value="รอตรวจซ้ำ">รอตรวจซ้ำ</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearchDof" class="btn btn-outline-primary btn-square" title="ค้นหา"><i class="ri ri-search-line"></i></button>
                    <button type="button" id="btnResetDof" class="btn btn-outline-secondary btn-square" title="ล้างค่า"><i class="ri ri-refresh-line"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการโรงงานที่ผ่านการรับรอง</h5>
            <p class="text-muted small mb-0">แสดงเลขทะเบียน DOF ขอบเขตการรับรอง ตลาดส่งออก และสถานะการรับรองสุขอนามัย</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#dofFactoryDetailModal">
                <i class="ri ri-add-line me-1"></i> เพิ่มข้อมูล
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 dof-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width:56px;">#</th>
                    <th>เลขทะเบียน DOF</th>
                    <th>โรงงาน</th>
                    <th>Establishment No.</th>
                    <th>จังหวัด</th>
                    <th>ขอบเขตการรับรอง</th>
                    <th>ตลาดส่งออก</th>
                    <th>หมดอายุ</th>
                    <th>ผลการตรวจ</th>
                    <th>สถานะ</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="dofTableBody">
                @foreach (var factory in dofFactories)
                {
                    <tr data-dof-number="@factory.DofNumber"
                        data-factory-code="@factory.FactoryCode"
                        data-factory-name="@factory.FactoryName"
                        data-establishment-no="@factory.EstablishmentNo"
                        data-province="@factory.Province"
                        data-scope="@factory.ApprovalScope"
                        data-audit="@factory.AuditResult"
                        data-status="@factory.StatusText"
                        data-status-class="@factory.StatusClass"
                        data-search-text="@($"{factory.DofNumber} {factory.FactoryName} {factory.EstablishmentNo} {factory.Province}")">
                        <td class="text-center text-muted">@factory.RowNo</td>
                        <td class="fw-semibold text-primary">@factory.DofNumber</td>
                        <td>
                            <div class="fw-semibold">@factory.FactoryName</div>
                            <div class="text-muted small">@factory.FactoryCode</div>
                        </td>
                        <td class="text-center">@factory.EstablishmentNo</td>
                        <td>@factory.Province</td>
                        <td>@factory.ApprovalScope</td>
                        <td class="text-center">@factory.ExportMarkets ตลาด</td>
                        <td class="text-center">@factory.ExpireDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">@factory.AuditResult</td>
                        <td class="text-center"><span class="badge rounded-pill @factory.StatusClass">@factory.StatusText</span></td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-view-dof" data-dof-number="@factory.DofNumber" title="รายละเอียดข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-eye-line text-info"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-edit-dof" data-dof-number="@factory.DofNumber" title="แก้ไขข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-pencil-line text-warning"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="พิมพ์ทะเบียน" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-printer-line text-secondary"></i></button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="dofTableEmpty" class="d-none">
                    <td colspan="11" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="dofFactoryDetailModal" tabindex="-1" aria-labelledby="dofFactoryDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="dofFactoryDetailModalLabel">
                    <i class="ri ri-shield-star-line me-2"></i><span id="factoryModalTitle">รายละเอียดทะเบียน DOF</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="nav-align-top nav-tabs-shadow">
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item">
                            <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-dof-detail" aria-selected="true"><i class="ri ri-file-list-2-line me-1"></i> ข้อมูลรับรอง</button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-dof-product" aria-selected="false"><i class="ri ri-box-3-line me-1"></i> สินค้าที่รับรอง</button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-dof-audit" aria-selected="false"><i class="ri ri-survey-line me-1"></i> ประวัติการตรวจ</button>
                        </li>
                    </ul>
                    <div class="tab-content">
                        <div id="tab-dof-detail" class="tab-pane fade show active">
                            <div class="accordion accordion-custom-button" id="dofAccordion">
                                <div class="accordion-item active">
                                    <h2 class="accordion-header" id="headingDofGeneral">
                                        <button type="button" class="accordion-button" data-bs-toggle="collapse" data-bs-target="#collapseDofGeneral" aria-expanded="true"><i class="icon-base ri ri-information-line me-2"></i> ข้อมูลทั่วไป</button>
                                    </h2>
                                    <div id="collapseDofGeneral" class="accordion-collapse collapse show">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">เลขทะเบียน DOF</span><span class="value" id="detailDofNumber">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">รหัสโรงงาน</span><span class="value" id="detailFactoryCode">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">สถานะ</span><span class="value" id="detailStatus">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">Establishment No.</span><span class="value" id="detailEstablishmentNo">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">จังหวัด</span><span class="value" id="detailProvince">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">ผลการตรวจล่าสุด</span><span class="value" id="detailAuditResult">-</span></div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item active">
                                    <h2 class="accordion-header" id="headingDofRegistration">
                                        <button type="button" class="accordion-button" data-bs-toggle="collapse" data-bs-target="#collapseDofRegistration" aria-expanded="true"><i class="icon-base ri ri-file-shield-2-line me-2"></i> ขอบเขตและการติดต่อ</button>
                                    </h2>
                                    <div id="collapseDofRegistration" class="accordion-collapse collapse show">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-6"><div class="detail-kv"><span class="label">ขอบเขตการรับรอง</span><span class="value" id="detailApprovalScope">-</span></div></div>
                                                <div class="col-md-3"><div class="detail-kv"><span class="label">วันที่รับรอง</span><span class="value" id="detailCertDate">-</span></div></div>
                                                <div class="col-md-3"><div class="detail-kv"><span class="label">ตรวจครั้งถัดไป</span><span class="value" id="detailNextAuditDate">-</span></div></div>
                                                <div class="col-md-6"><div class="detail-kv"><span class="label">ที่อยู่</span><span class="value" id="detailAddress">-</span></div></div>
                                                <div class="col-md-3"><div class="detail-kv"><span class="label">โทรศัพท์</span><span class="value" id="detailPhone">-</span></div></div>
                                                <div class="col-md-3"><div class="detail-kv"><span class="label">อีเมล</span><span class="value" id="detailEmail">-</span></div></div>
                                                <div class="col-12"><div class="detail-kv"><span class="label">หมายเหตุ</span><span class="value" id="detailNote">-</span></div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="tab-dof-product" class="tab-pane fade">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-0 dof-table-compact">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width:56px;">#</th>
                                            <th>รายการสินค้า</th>
                                            <th>HS Code</th>
                                            <th>ตลาด</th>
                                            <th>สถานะ</th>
                                        </tr>
                                    </thead>
                                    <tbody id="productTableBody"></tbody>
                                </table>
                            </div>
                        </div>
                        <div id="tab-dof-audit" class="tab-pane fade">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-0 dof-table-compact">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width:56px;">#</th>
                                            <th>วันที่ตรวจ</th>
                                            <th>ผลการตรวจ</th>
                                            <th>หน่วยตรวจ</th>
                                            <th>หมายเหตุ</th>
                                        </tr>
                                    </thead>
                                    <tbody id="auditTableBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class="ri ri-close-line me-1"></i> ปิด</button>
                <button type="button" class="btn btn-primary"><i class="ri ri-save-line me-1"></i> บันทึกข้อมูล</button>
            </div>
        </div>
    </div>
</div>