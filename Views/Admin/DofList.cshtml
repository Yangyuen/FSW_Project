<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการโรงงานที่ผ่านการรับรอง</h5>
            <p class="text-muted small mb-0">แสดงเลขทะเบียน DOF ขอบเขตการรับรอง ตลาดส่งออก และสถานะการรับรองสุขอนามัย</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="dropdown">
                <button type="button" class="btn btn-outline-success btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ri ri-file-excel-2-line me-1"></i>Export Excel
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item btn-export-dof" href="#" data-export-type="all"><i class="ri ri-list-check me-1"></i>Export ทั้งหมด</a></li>
                    <li><a class="dropdown-item btn-export-dof" href="#" data-export-type="filtered"><i class="ri ri-filter-3-line me-1"></i>Export เฉพาะที่กรอง</a></li>
                    <li><a class="dropdown-item btn-export-dof" href="#" data-export-type="selected"><i class="ri ri-checkbox-multiple-line me-1"></i>Export เฉพาะที่เลือก</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item btn-export-dof" href="#" data-export-type="summary"><i class="ri ri-bar-chart-2-line me-1"></i>Export สรุปรายปี</a></li>
                </ul>
            </div>
            <button type="button" class="btn btn-outline-purple btn-sm" id="btnImportDof" data-bs-toggle="modal" data-bs-target="#dofImportModal">
                <i class="ri ri-upload-cloud-2-line me-1"></i>นำเข้าข้อมูล
            </button>
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#dofFactoryDetailModal">
                <i class="ri ri-add-line me-1"></i> เพิ่มข้อมูล
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 dof-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width:40px;" class="text-center"><input type="checkbox" id="dofSelectAll" class="form-check-input"></th>
                    <th style="width:56px;">#</th>
                    <th>เลขทะเบียน DOF</th>
                    <th>โรงงาน</th>
                    <th>Establishment No.</th>
                    <th>จังหวัด</th>
                    <th>ขอบเขตการรับรอง</th>
                    <th>ตลาดส่งออก</th>
                    <th>หมดอายุ</th>
                    <th>ผลการตรวจ</th>
                    <th>สถานะ</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="dofTableBody">
                @foreach (var factory in dofFactories)
                {
                    <tr data-dof-number="@factory.DofNumber"
                        data-factory-code="@factory.FactoryCode"
                        data-factory-name="@factory.FactoryName"
                        data-factory-name-en="@factory.FactoryNameEN"
                        data-tax-id="@factory.TaxId"
                        data-branch-code="@factory.BranchCode"
                        data-establishment-no="@factory.EstablishmentNo"
                        data-approval-number="@factory.ApprovalNumber"
                        data-province="@factory.Province"
                        data-scope="@factory.ApprovalScope"
                        data-audit="@factory.AuditResult"
                        data-status="@factory.StatusText"
                        data-status-class="@factory.StatusClass"
                        data-export-countries="@factory.ExportCountries"
                        data-search-text="@($"{factory.DofNumber} {factory.FactoryName} {factory.FactoryNameEN} {factory.TaxId} {factory.EstablishmentNo} {factory.Province}")">
                        <td class="text-center"><input type="checkbox" class="form-check-input dof-row-check" data-dof-number="@factory.DofNumber"></td>
                        <td class="text-center text-muted">@factory.RowNo</td>
                        <td class="fw-semibold text-primary">@factory.DofNumber</td>
                        <td>
                            <div class="fw-semibold">@factory.FactoryName</div>
                            <div class="text-muted small fst-italic">@factory.FactoryNameEN</div>
                            <div class="text-muted small">@factory.FactoryCode</div>
                        </td>
                        <td class="text-center">@factory.EstablishmentNo</td>
                        <td>@factory.Province</td>
                        <td>@factory.ApprovalScope</td>
                        <td class="text-center">
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                @foreach (var chip in factory.ExportCountries.Split(','))
                                {
                                    <span class="badge bg-label-primary" style="font-size:0.65rem;">@chip.Trim()</span>
                                }
                            </div>
                        </td>
                        <td class="text-center">@factory.ExpireDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">@factory.AuditResult</td>
                        <td class="text-center"><span class="badge rounded-pill @factory.StatusClass">@factory.StatusText</span></td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-view-dof" data-dof-number="@factory.DofNumber" title="รายละเอียดข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-eye-line text-info"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-edit-dof" data-dof-number="@factory.DofNumber" title="แก้ไขข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-pencil-line text-warning"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-suspend-dof" data-dof-number="@factory.DofNumber" title="ระงับชั่วคราว" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-forbid-2-line" style="color:#ff9f43;"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-cancel-dof" data-dof-number="@factory.DofNumber" title="ยกเลิกการรับรอง" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-close-circle-line text-danger"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="พิมพ์ทะเบียน" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-printer-line text-secondary"></i></button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="dofTableEmpty" class="d-none">
                    <td colspan="12" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div><!-- /main table card -->
</div><!-- /tab-pane: รายการโรงงาน -->

