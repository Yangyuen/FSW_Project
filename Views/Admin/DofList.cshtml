<!-- Modal: ระงับโรงงานชั่วคราว -->
<div class="modal fade" id="dofSuspendModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-warning"><i class="ri ri-forbid-2-line me-2"></i>ระงับโรงงานชั่วคราว</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">คุณต้องการ <strong class="text-warning">ระงับชั่วคราว</strong> โรงงาน:</p>
                <div class="alert alert-warning py-2 fw-semibold mb-3" id="suspendFactoryName">-</div>
                <input type="hidden" id="suspendDofNumberHidden">
                <div class="mb-3">
                    <label class="form-label fw-semibold">วันที่ระงับ <span class="text-danger">*</span></label>
                    <input type="date" class="form-control" id="suspendDate" value="2026-04-27">
                </div>
                <div class="mb-0">
                    <label class="form-label fw-semibold">เหตุผลการระงับ <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="suspendReason" rows="3" placeholder="ระบุเหตุผลการระงับ..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-warning" id="btnConfirmSuspend" data-bs-dismiss="modal"><i class="ri ri-forbid-2-line me-1"></i>ยืนยันระงับ</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: ยกเลิกการรับรอง -->
<div class="modal fade" id="dofCancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger"><i class="ri ri-close-circle-line me-2"></i>ยกเลิกการรับรอง</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">คุณต้องการ <strong class="text-danger">ยกเลิกการรับรอง</strong> โรงงาน:</p>
                <div class="alert alert-danger py-2 fw-semibold mb-3" id="cancelFactoryName">-</div>
                <input type="hidden" id="cancelDofNumberHidden">
                <div class="mb-3">
                    <label class="form-label fw-semibold">วันที่ยกเลิก <span class="text-danger">*</span></label>
                    <input type="date" class="form-control" id="cancelDate" value="2026-04-27">
                </div>
                <div class="mb-0">
                    <label class="form-label fw-semibold">เหตุผลการยกเลิก <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="cancelReason" rows="3" placeholder="ระบุเหตุผลการยกเลิกการรับรอง..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-danger" id="btnConfirmCancel" data-bs-dismiss="modal"><i class="ri ri-close-circle-line me-1"></i>ยืนยันยกเลิก</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: นำเข้าข้อมูล DOF List (4-step wizard) -->
<div class="modal fade" id="dofImportModal" tabindex="-1" aria-labelledby="dofImportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="dofImportModalLabel"><i class="ri ri-upload-cloud-2-line me-2 text-purple"></i>นำเข้าข้อมูล DOF List</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Step indicator -->
                <div class="d-flex align-items-center justify-content-center gap-0 mb-4" id="importStepIndicator">
                    <div class="import-step active" data-step="1"><span class="step-num">1</span><span class="step-label">ดาวน์โหลด Template</span></div>
                    <div class="import-step-divider"></div>
                    <div class="import-step" data-step="2"><span class="step-num">2</span><span class="step-label">อัปโหลดไฟล์</span></div>
                    <div class="import-step-divider"></div>
                    <div class="import-step" data-step="3"><span class="step-num">3</span><span class="step-label">ตรวจสอบข้อมูล</span></div>
                    <div class="import-step-divider"></div>
                    <div class="import-step" data-step="4"><span class="step-num">4</span><span class="step-label">ยืนยันนำเข้า</span></div>
                </div>

                <!-- Step 1: Download template -->
                <div id="importStep1" class="import-step-content">
                    <h6 class="fw-semibold mb-3"><i class="ri ri-download-cloud-line me-1 text-primary"></i>Step 1 — ดาวน์โหลด Template</h6>
                    <p class="text-muted small mb-3">ดาวน์โหลดไฟล์ Template (.xlsx) แล้วกรอกข้อมูลโรงงานตามคอลัมน์ที่กำหนด ก่อนนำเข้าระบบ</p>
                    <button type="button" class="btn btn-outline-primary mb-4" id="btnDownloadTemplate">
                        <i class="ri ri-download-line me-1"></i>ดาวน์โหลด Template (.xlsx)
                    </button>
                    <div class="card bg-light">
                        <div class="card-header py-2"><span class="fw-semibold small">คอลัมน์ใน Template</span></div>
                        <div class="card-body py-3">
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var col in new[] { "DofNumber", "FactoryName(TH)", "FactoryName(EN)", "TaxId", "BranchCode", "EstablishmentNo", "ApprovalNo", "Province", "Address(TH)", "Address(EN)", "Phone", "Fax", "ApprovalScope", "ExportCountries", "ExpireDate", "Status" })
                                {
                                    <span class="badge bg-label-primary font-monospace">@col</span>
                                }
                            </div>
                            <p class="text-muted small mt-2 mb-0"><i class="ri ri-information-line me-1"></i>ExportCountries: คั่นด้วยเครื่องหมาย <code>|</code> เช่น <code>EU|JP|US</code> &nbsp;|&nbsp; ExpireDate: รูปแบบ <code>DD/MM/YYYY</code></p>
                        </div>
                    </div>
                </div>

                <!-- Step 2: Upload file -->
                <div id="importStep2" class="import-step-content d-none">
                    <h6 class="fw-semibold mb-3"><i class="ri ri-file-upload-line me-1 text-primary"></i>Step 2 — อัปโหลดไฟล์</h6>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">เลือกไฟล์ (.xlsx หรือ .csv) <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="importFileInput" accept=".xlsx,.csv">
                        <div class="form-text text-muted">ขนาดไฟล์สูงสุด 5 MB | รองรับ .xlsx และ .csv เท่านั้น</div>
                    </div>
                    <div id="importFileInfo" class="alert alert-info d-none py-2 small">
                        <i class="ri ri-file-excel-2-line me-1"></i><span id="importFileName">-</span> &nbsp;|&nbsp; <span id="importFileSize">-</span>
                    </div>
                    <div id="importFileError" class="alert alert-danger d-none py-2 small"></div>
                </div>

                <!-- Step 3: Preview / validate -->
                <div id="importStep3" class="import-step-content d-none">
                    <h6 class="fw-semibold mb-3"><i class="ri ri-table-line me-1 text-primary"></i>Step 3 — ตรวจสอบข้อมูล</h6>
                    <div class="d-flex gap-3 mb-3">
                        <span class="badge bg-label-success px-3 py-2 fs-6" id="importOkCount">ผ่าน 3 รายการ</span>
                        <span class="badge bg-label-danger px-3 py-2 fs-6" id="importErrCount">มีข้อผิดพลาด 1 รายการ</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle mb-0 dof-table-compact">
                            <thead class="text-center table-light">
                                <tr>
                                    <th>#</th>
                                    <th>DofNumber</th>
                                    <th>ชื่อโรงงาน (TH)</th>
                                    <th>TaxId</th>
                                    <th>EstablishmentNo</th>
                                    <th>จังหวัด</th>
                                    <th>สถานะตรวจสอบ</th>
                                </tr>
                            </thead>
                            <tbody id="importPreviewBody">
                                <tr class="table-success">
                                    <td class="text-center">1</td>
                                    <td class="font-monospace">DOF-FAC-01001</td>
                                    <td>บริษัท สยาม ซีฟู้ด จำกัด</td>
                                    <td class="font-monospace">0105558099901</td>
                                    <td>EST-TH-1701</td>
                                    <td>สงขลา</td>
                                    <td><span class="badge bg-success"><i class="ri ri-check-line me-1"></i>ผ่าน</span></td>
                                </tr>
                                <tr class="table-success">
                                    <td class="text-center">2</td>
                                    <td class="font-monospace">DOF-FAC-01002</td>
                                    <td>บริษัท ภูเก็ต ฟิช โปรเซสซิ่ง จำกัด</td>
                                    <td class="font-monospace">0835558099902</td>
                                    <td>EST-TH-1702</td>
                                    <td>ภูเก็ต</td>
                                    <td><span class="badge bg-success"><i class="ri ri-check-line me-1"></i>ผ่าน</span></td>
                                </tr>
                                <tr class="table-danger">
                                    <td class="text-center">3</td>
                                    <td class="font-monospace">DOF-FAC-01003</td>
                                    <td>บริษัท ชลบุรี มารีน จำกัด</td>
                                    <td class="font-monospace text-danger fw-bold">020555</td>
                                    <td>EST-TH-1703</td>
                                    <td>ชลบุรี</td>
                                    <td><span class="badge bg-danger"><i class="ri ri-error-warning-line me-1"></i>TaxId ไม่ครบ 13 หลัก</span></td>
                                </tr>
                                <tr class="table-success">
                                    <td class="text-center">4</td>
                                    <td class="font-monospace">DOF-FAC-01004</td>
                                    <td>บริษัท ระนอง โคลด์เชน จำกัด</td>
                                    <td class="font-monospace">0605558099904</td>
                                    <td>EST-TH-1704</td>
                                    <td>ระนอง</td>
                                    <td><span class="badge bg-success"><i class="ri ri-check-line me-1"></i>ผ่าน</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-muted small mt-2 mb-0"><i class="ri ri-information-line me-1"></i>แถวสีแดงจะถูกข้ามในการนำเข้า โปรดแก้ไขไฟล์แล้วอัปโหลดใหม่ หรือดำเนินการต่อเฉพาะแถวที่ผ่าน</p>
                </div>

                <!-- Step 4: Confirm / progress -->
                <div id="importStep4" class="import-step-content d-none">
                    <h6 class="fw-semibold mb-3"><i class="ri ri-check-double-line me-1 text-primary"></i>Step 4 — ยืนยันนำเข้า</h6>
                    <div class="alert alert-warning py-2 small mb-3">
                        <i class="ri ri-error-warning-line me-1"></i>ระบบจะนำเข้า <strong>3 รายการที่ผ่านการตรวจสอบ</strong> และข้าม 1 รายการที่มีข้อผิดพลาด
                    </div>
                    <div id="importProgressArea" class="d-none mb-3">
                        <label class="form-label small fw-semibold">กำลังนำเข้าข้อมูล...</label>
                        <div class="progress" style="height:18px;">
                            <div id="importProgressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-purple" style="width:0%"></div>
                        </div>
                    </div>
                    <div id="importSuccessMsg" class="alert alert-success d-none py-2">
                        <i class="ri ri-checkbox-circle-line me-1"></i><strong>นำเข้าสำเร็จ 3 รายการ</strong> — ข้อมูลได้รับการบันทึกลงในระบบแล้ว
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" id="btnImportPrev"><i class="ri ri-arrow-left-line me-1"></i>ย้อนกลับ</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                    <button type="button" class="btn btn-purple" id="btnImportNext"><i class="ri ri-arrow-right-line me-1"></i>ถัดไป</button>
                </div>
            </div>
        </div>
    </div>
</div>
