    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label for="filterKeyword" class="form-label">คำค้นหา</label>
                <input type="text" id="filterKeyword" class="form-control" placeholder="เลข DOF, ชื่อโรงงาน, Establishment No." />
