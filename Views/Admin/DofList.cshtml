@section PageStyles {
<style>
    .dof-table-compact {
        font-size: 0.78rem;
    }

    .dof-table-compact th,
    .dof-table-compact td {
        padding: 0.45rem 0.5rem;
        vertical-align: middle;
        line-height: 1.3;
        white-space: normal;
        word-break: break-word;
    }

    .dof-table-compact thead th {
        white-space: normal;
        word-break: keep-all;
        overflow-wrap: normal;
    }

    .dof-table-compact .badge {
        font-size: 0.68rem;
    }

    .dof-table-compact .btn.btn-sm {
        --bs-btn-padding-y: 0.14rem;
        --bs-btn-padding-x: 0.3rem;
    }

    .dof-table-compact .btn-icon {
        width: 1.65rem;
        height: 1.65rem;
    }

    .filter-action-buttons .btn-square {
        width: 48px;
        height: 48px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .detail-kv {
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        background: var(--bs-paper-bg);
        padding: 0.85rem 1rem;
        height: 100%;
    }

    .detail-kv .label {
        display: block;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        margin-bottom: 0.25rem;
    }

    .detail-kv .value {
        font-weight: 600;
        color: var(--bs-heading-color);
    }

    /* --- Import wizard --- */
    .import-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        min-width: 110px;
    }
    .import-step .step-num {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--bs-secondary-bg);
        border: 2px solid var(--bs-border-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--bs-secondary-color);
    }
    .import-step .step-label {
        font-size: 0.72rem;
        color: var(--bs-secondary-color);
        text-align: center;
        white-space: nowrap;
    }
    .import-step.active .step-num {
        background: #7367f0;
        border-color: #7367f0;
        color: #fff;
    }
    .import-step.active .step-label {
        color: #7367f0;
        font-weight: 600;
    }
    .import-step.done .step-num {
        background: #28a745;
        border-color: #28a745;
        color: #fff;
    }
    .import-step-divider {
        flex: 1;
        height: 2px;
        background: var(--bs-border-color);
        margin-top: -16px;
        min-width: 24px;
    }
    .btn-purple { background-color: #7367f0; border-color: #7367f0; color: #fff; }
    .btn-purple:hover { background-color: #5e50ee; border-color: #5e50ee; color: #fff; }
    .text-purple { color: #7367f0 !important; }
    .bg-purple { background-color: #7367f0 !important; }
</style>
}

