                    { date: '05/01/2566', fromStatus: '-', toStatus: 'รับรองแล้ว', reason: 'ผ่านการตรวจประเมินรับรองครั้งแรก', officer: 'กองรับรองมาตรฐาน' }
                ],
                exportCountries: [
                    { country: 'สหภาพยุโรป', countryEN: 'European Union', iso: 'EU', group: 'EU', startDate: '15/01/2566', endDate: '05/01/2570', status: 'ใช้งาน' },
                    { country: 'ญี่ปุ่น', countryEN: 'Japan', iso: 'JP', group: 'เอเชียตะวันออก', startDate: '15/01/2566', endDate: '05/01/2570', status: 'ใช้งาน' },
                    { country: 'สหรัฐอเมริกา', countryEN: 'United States', iso: 'US', group: 'อเมริกา', startDate: '01/06/2566', endDate: '31/05/2569', status: 'ใช้งาน' },
                    { country: 'แคนาดา', countryEN: 'Canada', iso: 'CA', group: 'อเมริกา', startDate: '01/06/2566', endDate: '31/05/2569', status: 'ใช้งาน' },
                    { country: 'อาเซียน', countryEN: 'ASEAN', iso: '-', group: 'อาเซียน', startDate: '01/09/2566', endDate: '31/08/2569', status: 'ใช้งาน' }
                ]
            }
        };

        function filterRows() {
            var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
            var province = (document.getElementById('filterProvince').value || '').trim();
            var status = (document.getElementById('filterStatus').value || '').trim();
            var audit = (document.getElementById('filterAudit').value || '').trim();
            var market = (document.getElementById('filterMarket').value || '').trim();
            var rows = document.querySelectorAll('#dofTableBody tr[data-dof-number]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var text = (row.dataset.searchText || '').toLowerCase();
                var rowProvince = row.dataset.province || '';
                var rowStatus = row.dataset.status || '';
                var rowAudit = row.dataset.audit || '';
                var rowMarkets = row.dataset.exportCountries || '';
                var keywordMatch = !keyword || text.includes(keyword);
                var provinceMatch = !province || rowProvince === province;
                var statusMatch = !status || rowStatus === status;
                var auditMatch = !audit || rowAudit === audit;
                var marketMatch = !market || rowMarkets.split(',').some(function (m) { return m.trim() === market; });
                var isVisible = keywordMatch && provinceMatch && statusMatch && auditMatch && marketMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('dofTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        function renderRows(items, columns, emptyMessage) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="' + columns + '" class="text-center text-muted py-3">' + emptyMessage + '</td></tr>';
            }

            if (columns === 5) {
                return items.map(function (item, index) {
                    return '<tr>' +
                        '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                        '<td>' + item.name + '</td>' +
                        '<td class="text-center">' + item.hsCode + '</td>' +
                        '<td>' + item.market + '</td>' +
                        '<td class="text-center"><span class="badge rounded-pill ' + (item.status === 'ใช้งาน' ? 'bg-label-success' : item.status === 'เฝ้าระวัง' ? 'bg-label-warning' : 'bg-label-danger') + '">' + item.status + '</span></td>' +
                        '</tr>';
                }).join('');
            }

            return items.map(function (item, index) {
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.date + '</td>' +
                    '<td><span class="badge rounded-pill ' + (item.result === 'ผ่าน' ? 'bg-label-success' : item.result === 'ผ่านแบบมีข้อสังเกต' ? 'bg-label-warning' : 'bg-label-danger') + '">' + item.result + '</span></td>' +
                    '<td>' + item.officer + '</td>' +
                    '<td>' + item.remark + '</td>' +
                    '</tr>';
            }).join('');
        }

        function renderStatusLogRows(items) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="6" class="text-center text-muted py-3">ไม่พบประวัติการเปลี่ยนสถานะ</td></tr>';
            }
            return items.map(function (item, index) {
                var fromHtml = item.fromStatus === '-' ? '<span class="text-muted">—</span>' :
                    '<span class="badge rounded-pill bg-label-secondary">' + item.fromStatus + '</span>';
                var toClass = item.toStatus === 'รับรองแล้ว' ? 'bg-label-success' :
                    item.toStatus === 'ระงับชั่วคราว' ? 'bg-label-danger' :
                    item.toStatus === 'ยกเลิกแล้ว' ? 'bg-label-secondary' :
                    item.toStatus === 'ใกล้หมดอายุ' ? 'bg-label-warning' : 'bg-label-info';
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.date + '</td>' +
                    '<td>' + fromHtml + '</td>' +
                    '<td><span class="badge rounded-pill ' + toClass + '">' + item.toStatus + '</span></td>' +
                    '<td>' + item.reason + '</td>' +
                    '<td>' + item.officer + '</td>' +
                    '</tr>';
            }).join('');
        }

        function renderExportCountriesRows(items) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="8" class="text-center text-muted py-3">ไม่พบข้อมูลประเทศปลายทาง</td></tr>';
            }
            return items.map(function (item, index) {
                var statusClass = item.status === 'ใช้งาน' ? 'bg-label-success' : 'bg-label-danger';
                var groupClass = item.group === 'EU' ? 'bg-label-primary' :
                    item.group === 'เอเชียตะวันออก' ? 'bg-label-warning' :
                    item.group === 'อเมริกา' ? 'bg-label-success' :
                    item.group === 'อาเซียน' ? 'bg-label-info' : 'bg-label-secondary';
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.country + '</td>' +
                    '<td class="fst-italic">' + item.countryEN + '</td>' +
                    '<td class="text-center font-monospace">' + item.iso + '</td>' +
                    '<td><span class="badge rounded-pill ' + groupClass + '">' + item.group + '</span></td>' +
                    '<td>' + item.startDate + '</td>' +
                    '<td>' + item.endDate + '</td>' +
                    '<td class="text-center"><span class="badge rounded-pill ' + statusClass + '">' + item.status + '</span></td>' +
                    '</tr>';
            }).join('');
        }

        function openFactoryDetail(dofNumber) {
            var detail = detailsMap[dofNumber];
            var row = document.querySelector('#dofTableBody tr[data-dof-number="' + dofNumber + '"]');
            if (!detail || !row) {
                return;
            }

            document.getElementById('factoryModalTitle').textContent = row.dataset.factoryName;
            document.getElementById('detailDofNumber').textContent = dofNumber;
            document.getElementById('detailFactoryCode').textContent = row.dataset.factoryCode;
            document.getElementById('detailFactoryNameTH').textContent = row.dataset.factoryName;
            document.getElementById('detailFactoryNameEN').textContent = row.dataset.factoryNameEn || '-';
            document.getElementById('detailTaxId').textContent = row.dataset.taxId || '-';
            var branchRaw = row.dataset.branchCode || '';
            document.getElementById('detailBranchCode').textContent = branchRaw ? branchRaw + (branchRaw === '00000' ? ' (สำนักงานใหญ่)' : ' (สาขาที่ ' + parseInt(branchRaw, 10) + ')') : '-';
            document.getElementById('detailEstablishmentNo').textContent = row.dataset.establishmentNo;
            document.getElementById('detailApprovalNumber').textContent = row.dataset.approvalNumber || '-';
            document.getElementById('detailProvince').textContent = row.dataset.province;
            document.getElementById('detailStatus').innerHTML = '<span class="badge rounded-pill ' + row.dataset.statusClass + '">' + row.dataset.status + '</span>';
            document.getElementById('detailApprovalScope').textContent = row.dataset.scope;
            document.getElementById('detailAuditResult').textContent = row.dataset.audit;
            document.getElementById('detailCertDate').textContent = detail.certDate;
            document.getElementById('detailNextAuditDate').textContent = detail.nextAuditDate;
            document.getElementById('detailPhone').textContent = detail.phone;
            document.getElementById('detailFax').textContent = detail.fax || '-';
            document.getElementById('detailEmail').textContent = detail.email;
            document.getElementById('detailAddress').textContent = detail.address;
            document.getElementById('detailAddressEN').textContent = detail.addressEN || '-';
            document.getElementById('detailNote').textContent = detail.note;
            document.getElementById('productTableBody').innerHTML = renderRows(detail.products, 5, 'ไม่พบรายการสินค้า');
            document.getElementById('auditTableBody').innerHTML = renderRows(detail.audits, 5, 'ไม่พบประวัติการตรวจประเมิน');
            document.getElementById('statusLogTableBody').innerHTML = renderStatusLogRows(detail.statusLogs);
            document.getElementById('exportCountriesTableBody').innerHTML = renderExportCountriesRows(detail.exportCountries);

            new bootstrap.Modal(document.getElementById('dofFactoryDetailModal')).show();
        }

        document.getElementById('btnSearchDof').addEventListener('click', filterRows);
        document.getElementById('btnResetDof').addEventListener('click', function () {
            document.getElementById('filterKeyword').value = '';
            document.getElementById('filterProvince').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterAudit').value = '';
            document.getElementById('filterMarket').value = '';
            filterRows();
        });

        document.querySelectorAll('#filterKeyword, #filterProvince, #filterStatus, #filterAudit, #filterMarket').forEach(function (element) {
            element.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    filterRows();
                }
            });
            element.addEventListener('change', filterRows);
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        document.querySelectorAll('.btn-view-dof, .btn-edit-dof').forEach(function (button) {
            button.addEventListener('click', function () {
                openFactoryDetail(this.dataset.dofNumber);
            });
        });

        document.querySelectorAll('.btn-suspend-dof').forEach(function (button) {
            button.addEventListener('click', function () {
                var row = document.querySelector('#dofTableBody tr[data-dof-number="' + this.dataset.dofNumber + '"]');
                document.getElementById('suspendFactoryName').textContent = row ? row.dataset.factoryName : this.dataset.dofNumber;
                document.getElementById('suspendDofNumberHidden').value = this.dataset.dofNumber;
                new bootstrap.Modal(document.getElementById('dofSuspendModal')).show();
            });
        });

        document.querySelectorAll('.btn-cancel-dof').forEach(function (button) {
            button.addEventListener('click', function () {
                var row = document.querySelector('#dofTableBody tr[data-dof-number="' + this.dataset.dofNumber + '"]');
                document.getElementById('cancelFactoryName').textContent = row ? row.dataset.factoryName : this.dataset.dofNumber;
                document.getElementById('cancelDofNumberHidden').value = this.dataset.dofNumber;
                new bootstrap.Modal(document.getElementById('dofCancelModal')).show();
            });
        });

        document.getElementById('btnConfirmSuspend').addEventListener('click', function () {
            showDofToast('ระงับชั่วคราว: ' + document.getElementById('suspendFactoryName').textContent + ' เรียบร้อยแล้ว', 'warning');
        });

        document.getElementById('btnConfirmCancel').addEventListener('click', function () {
            showDofToast('ยกเลิกการรับรอง: ' + document.getElementById('cancelFactoryName').textContent + ' เรียบร้อยแล้ว', 'danger');
        });

        document.querySelectorAll('.btn-export-dof').forEach(function (item) {
            item.addEventListener('click', function (e) {
                e.preventDefault();
                var exportType = this.dataset.exportType || 'all';
                var allRows = document.querySelectorAll('#dofTableBody tr[data-dof-number]');
                var filteredRows = document.querySelectorAll('#dofTableBody tr[data-dof-number]:not(.d-none)');
                var selectedRows = document.querySelectorAll('#dofTableBody .dof-row-check:checked');
                var count, label;

                if (exportType === 'selected') {
                    count = selectedRows.length;
                    label = 'เฉพาะที่เลือก';
                    if (count === 0) {
                        showDofToast('กรุณาเลือกรายการที่ต้องการ Export ก่อน', 'warning');
                        return;
                    }
                } else if (exportType === 'filtered') {
                    count = filteredRows.length;
                    label = 'เฉพาะที่กรอง';
                } else if (exportType === 'summary') {
                    count = 1;
                    label = 'สรุปรายปี';
                } else {
                    count = allRows.length;
                    label = 'ทั้งหมด';
                }

                showDofToast('กำลัง Export Excel (' + label + ')...', 'info');
                var self = this;
                setTimeout(function () {
                    if (exportType === 'summary') {
                        showDofToast('Export Excel สรุปรายปี สำเร็จ', 'success');
                    } else {
                        showDofToast('Export Excel สำเร็จ ' + count + ' รายการ (' + label + ')', 'success');
                    }
                }, 800);
            });
        });

        /* Select-all checkbox */
        document.getElementById('dofSelectAll').addEventListener('change', function () {
            var checked = this.checked;
            document.querySelectorAll('#dofTableBody tr[data-dof-number]:not(.d-none) .dof-row-check').forEach(function (cb) {
                cb.checked = checked;
            });
        });

        function showDofToast(message, type) {
            var toastEl = document.getElementById('dofActionToast');
            toastEl.className = 'toast align-items-center text-bg-' + type + ' border-0';
            document.getElementById('dofActionToastMsg').textContent = message;
            new bootstrap.Toast(toastEl).show();
        }
    });

    /* --- Import wizard JS --- */
    document.addEventListener('DOMContentLoaded', function () {
        var currentStep = 1;
        var totalSteps = 4;

        function setStep(step) {
            currentStep = step;
            for (var i = 1; i <= totalSteps; i++) {
                var el = document.getElementById('importStep' + i);
                if (el) el.classList.toggle('d-none', i !== step);
            }
            document.querySelectorAll('#importStepIndicator .import-step').forEach(function (el) {
                var s = parseInt(el.dataset.step, 10);
                el.classList.toggle('active', s === step);
                el.classList.toggle('done', s < step);
            });
            var prevBtn = document.getElementById('btnImportPrev');
            var nextBtn = document.getElementById('btnImportNext');
            prevBtn.classList.toggle('d-none', step === 1);
            if (step === totalSteps) {
                nextBtn.innerHTML = '<i class="ri ri-check-line me-1"></i>ยืนยันนำเข้า';
            } else {
                nextBtn.innerHTML = '<i class="ri ri-arrow-right-line me-1"></i>ถัดไป';
            }
        }

        document.getElementById('dofImportModal').addEventListener('show.bs.modal', function () {
            setStep(1);
            document.getElementById('importProgressArea').classList.add('d-none');
            document.getElementById('importSuccessMsg').classList.add('d-none');
            document.getElementById('importProgressBar').style.width = '0%';
            document.getElementById('importFileInfo').classList.add('d-none');
            document.getElementById('importFileError').classList.add('d-none');
            var fi = document.getElementById('importFileInput');
            if (fi) fi.value = '';
            var nb = document.getElementById('btnImportNext');
            nb.disabled = false;
            nb.onclick = null;
            nb.innerHTML = '<i class="ri ri-arrow-right-line me-1"></i>ถัดไป';
        });

        document.getElementById('btnImportNext').addEventListener('click', function () {
            if (currentStep === 2) {
                var fi = document.getElementById('importFileInput');
                var errEl = document.getElementById('importFileError');
                errEl.classList.add('d-none');
                if (!fi.files || fi.files.length === 0) {
                    errEl.textContent = 'กรุณาเลือกไฟล์ก่อนดำเนินการต่อ';
                    errEl.classList.remove('d-none');
                    return;
                }
                var f = fi.files[0];
                if (f.size > 5 * 1024 * 1024) {
                    errEl.textContent = 'ไฟล์มีขนาดเกิน 5 MB กรุณาเลือกไฟล์ใหม่';
                    errEl.classList.remove('d-none');
                    return;
                }
                var ext = f.name.split('.').pop().toLowerCase();
                if (ext !== 'xlsx' && ext !== 'csv') {
                    errEl.textContent = 'รองรับเฉพาะไฟล์ .xlsx และ .csv เท่านั้น';
                    errEl.classList.remove('d-none');
                    return;
                }
            }
            if (currentStep === totalSteps) {
                var progressArea = document.getElementById('importProgressArea');
                var progressBar = document.getElementById('importProgressBar');
                var successMsg = document.getElementById('importSuccessMsg');
                var nextBtn = document.getElementById('btnImportNext');
                progressArea.classList.remove('d-none');
                successMsg.classList.add('d-none');
                nextBtn.disabled = true;
                var pct = 0;
                var iv = setInterval(function () {
                    pct += 20;
                    progressBar.style.width = pct + '%';
                    if (pct >= 100) {
                        clearInterval(iv);
                        progressArea.classList.add('d-none');
                        successMsg.classList.remove('d-none');
                        nextBtn.disabled = false;
                        nextBtn.innerHTML = '<i class="ri ri-close-line me-1"></i>ปิด';
                        nextBtn.onclick = function () {
                            bootstrap.Modal.getInstance(document.getElementById('dofImportModal')).hide();
                        };
                    }
                }, 250);
                return;
            }
            setStep(currentStep + 1);
        });

        document.getElementById('btnImportPrev').addEventListener('click', function () {
            if (currentStep > 1) setStep(currentStep - 1);
        });

        document.getElementById('btnDownloadTemplate').addEventListener('click', function () {
            showDofToast('ดาวน์โหลด Template DOF_Import_Template.xlsx เรียบร้อยแล้ว', 'success');
        });

        document.getElementById('importFileInput').addEventListener('change', function () {
            var errEl = document.getElementById('importFileError');
            var infoEl = document.getElementById('importFileInfo');
            errEl.classList.add('d-none');
            if (this.files && this.files.length > 0) {
                var f = this.files[0];
                var sizeKB = (f.size / 1024).toFixed(1);
                document.getElementById('importFileName').textContent = f.name;
                document.getElementById('importFileSize').textContent = sizeKB + ' KB';
                infoEl.classList.remove('d-none');
            } else {
                infoEl.classList.add('d-none');
            }
        });
    });
</script>
}

