                inspectionConfig: {
                    sampleFrequency: 'ทุก lot',
                    samplePercent: 100,
                    alertDays: 14,
                    alertUnit: 'วัน',
                    alertOnStatusChange: true,
                    alertOnReviewDue: true,
                    alertOnFactoryIssue: true,
                    affectedFactories: [
                        { code: 'DOF-FAC-00128', name: 'สยามมารีนฟูดส์ จำกัด', nameEN: 'Siam Marine Foods Co., Ltd.', province: 'สมุทรสาคร', market: 'EU,JP,US,CN', status: 'รับรองแล้ว', statusClass: 'bg-label-success' },
                        { code: 'DOF-FAC-00449', name: 'กัลฟแคทช์โปรเซสซิ่ง จำกัด', nameEN: 'Gulf Catch Processing Co., Ltd.', province: 'ชลบุรี', market: 'EU,JP,US,CN,KR,AU', status: 'รับรองแล้ว', statusClass: 'bg-label-success' },
                        { code: 'DOF-FAC-00818', name: 'ซาวเทิร์นเพลาจิก จำกัด', nameEN: 'Southern Pelagic Co., Ltd.', province: 'ภูเก็ต', market: 'EU,CN', status: 'ระงับชั่วคราว', statusClass: 'bg-label-warning' }
                    ]
                }
            }
        };

        function filterRows() {
            var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
            var region = (document.getElementById('filterRegion').value || '').trim();
            var status = (document.getElementById('filterStatus').value || '').trim();
            var risk = (document.getElementById('filterRisk').value || '').trim();
            var rows = document.querySelectorAll('#measureTableBody tr[data-measure-code]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowText = (row.dataset.searchText || '').toLowerCase();
                var rowRegion = row.dataset.region || '';
                var rowStatus = row.dataset.status || '';
                var rowRisk = row.dataset.risk || '';
                var keywordMatch = !keyword || rowText.includes(keyword);
                var regionMatch = !region || rowRegion === region;
                var statusMatch = !status || rowStatus === status;
                var riskMatch = !risk || rowRisk === risk;
                var isVisible = keywordMatch && regionMatch && statusMatch && riskMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('measureTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        function renderRequirementRows(items, emptyMessage) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="5" class="text-center text-muted py-3">' + emptyMessage + '</td></tr>';
            }

            return items.map(function (item, index) {
                var severityClass = item.severity === 'สูง' ? 'bg-label-danger' : item.severity === 'กลาง' ? 'bg-label-warning' : 'bg-label-success';
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.item + '</td>' +
                    '<td>' + item.criteria + '</td>' +
                    '<td class="text-center">' + item.frequency + '</td>' +
                    '<td class="text-center"><span class="badge rounded-pill ' + severityClass + '">' + item.severity + '</span></td>' +
                    '</tr>';
            }).join('');
        }

        function renderDocumentRows(items, emptyMessage) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="5" class="text-center text-muted py-3">' + emptyMessage + '</td></tr>';
            }

            return items.map(function (item, index) {
                var statusClass = item.status === 'ใช้งาน' ? 'bg-label-success' : item.status === 'รอทบทวน' ? 'bg-label-warning' : 'bg-label-danger';
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.name + '</td>' +
                    '<td class="text-center">' + item.version + '</td>' +
                    '<td class="text-center">' + item.publishDate + '</td>' +
                    '<td class="text-center"><span class="badge rounded-pill ' + statusClass + '">' + item.status + '</span></td>' +
                    '</tr>';
            }).join('');
        }

        function renderStatusLogRows(items) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="6" class="text-center text-muted py-3">ไม่พบประวัติการเปลี่ยนสถานะ</td></tr>';
            }
            return items.map(function (item, index) {
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td class="text-center small">' + item.date + '</td>' +
                    '<td class="text-center"><span class="badge rounded-pill ' + item.oldStatusClass + '">' + item.oldStatus + '</span></td>' +
                    '<td class="text-center"><span class="badge rounded-pill ' + item.newStatusClass + '">' + item.newStatus + '</span></td>' +
                    '<td>' + item.reason + '</td>' +
                    '<td>' + item.operator + '</td>' +
                    '</tr>';
            }).join('');
        }

        function openMeasureDetail(measureCode) {
            var detail = detailsMap[measureCode];
            var row = document.querySelector('#measureTableBody tr[data-measure-code="' + measureCode + '"]');
            if (!detail || !row) {
                return;
            }

            document.getElementById('measureModalTitle').textContent = row.dataset.measureName;
            document.getElementById('detailMeasureCode').textContent = measureCode;
            document.getElementById('detailCountry').textContent = row.dataset.country;
            document.getElementById('detailRegion').textContent = row.dataset.region;
            document.getElementById('detailProductScope').textContent = row.dataset.productScope;
            document.getElementById('detailOwnerUnit').textContent = row.dataset.ownerUnit;
            document.getElementById('detailRisk').textContent = row.dataset.risk;
            document.getElementById('detailStatus').innerHTML = '<span class="badge rounded-pill ' + row.dataset.statusClass + '">' + row.dataset.status + '</span>';
            document.getElementById('detailEffectiveDate').textContent = row.dataset.effectiveDate;
            document.getElementById('detailReviewDueDate').textContent = row.dataset.reviewDueDate;
            document.getElementById('detailObjective').textContent = detail.objective;
            document.getElementById('detailAuthority').textContent = detail.authority;
            document.getElementById('detailContact').textContent = detail.contact;
            document.getElementById('detailUpdateDate').textContent = detail.updateDate;
            document.getElementById('detailNote').textContent = detail.note;
            document.getElementById('requirementTableBody').innerHTML = renderRequirementRows(detail.requirements, 'ไม่พบข้อกำหนดหลัก');
            document.getElementById('documentTableBody').innerHTML = renderDocumentRows(detail.documents, 'ไม่พบเอกสารอ้างอิง');
            document.getElementById('statusLogTableBody').innerHTML = renderStatusLogRows(detail.statusLogs);
            populateInspectionConfig(measureCode, detail, row);

            new bootstrap.Modal(document.getElementById('measureDetailModal')).show();
        }

        document.getElementById('btnSearchMeasures').addEventListener('click', filterRows);
        document.getElementById('btnResetMeasures').addEventListener('click', function () {
            document.getElementById('filterKeyword').value = '';
            document.getElementById('filterRegion').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterRisk').value = '';
            filterRows();
        });

        document.querySelectorAll('#filterKeyword, #filterRegion, #filterStatus, #filterRisk').forEach(function (element) {
            element.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    filterRows();
                }
            });
            element.addEventListener('change', filterRows);
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        document.querySelectorAll('.btn-view-measure, .btn-edit-measure').forEach(function (button) {
            button.addEventListener('click', function () {
                openMeasureDetail(this.dataset.measureCode);
            });
        });

        document.querySelectorAll('.btn-suspend-measure').forEach(function (button) {
            button.addEventListener('click', function () {
                var code = this.dataset.measureCode;
                var name = this.dataset.measureName;
                var country = this.dataset.countryName;
                document.getElementById('suspendMeasureCode').textContent = code;
                document.getElementById('suspendMeasureName').textContent = name + ' (' + country + ')';
                document.getElementById('suspendReason').value = '';
                document.getElementById('suspendReason').classList.remove('is-invalid');
                document.getElementById('suspendEffectiveDate').value = '';
                new bootstrap.Modal(document.getElementById('measureSuspendModal')).show();
            });
        });

        document.querySelectorAll('.btn-cancel-measure').forEach(function (button) {
            button.addEventListener('click', function () {
                var code = this.dataset.measureCode;
                var name = this.dataset.measureName;
                document.getElementById('cancelMeasureCode').textContent = code;
                document.getElementById('cancelMeasureName').textContent = name;
                document.getElementById('cancelReason').value = '';
                document.getElementById('cancelReason').classList.remove('is-invalid');
                document.getElementById('cancelDate').value = '';
                new bootstrap.Modal(document.getElementById('measureCancelModal')).show();
            });
        });

        document.getElementById('btnConfirmSuspend').addEventListener('click', function () {
            var reason = document.getElementById('suspendReason').value.trim();
            if (!reason) {
                document.getElementById('suspendReason').classList.add('is-invalid');
                return;
            }
            document.getElementById('suspendReason').classList.remove('is-invalid');
            bootstrap.Modal.getInstance(document.getElementById('measureSuspendModal')).hide();
            showMeasureToast('warning', 'ระงับมาตรการ ' + document.getElementById('suspendMeasureCode').textContent + ' เรียบร้อยแล้ว');
        });

        document.getElementById('btnConfirmCancel').addEventListener('click', function () {
            var reason = document.getElementById('cancelReason').value.trim();
            if (!reason) {
                document.getElementById('cancelReason').classList.add('is-invalid');
                return;
            }
            document.getElementById('cancelReason').classList.remove('is-invalid');
            bootstrap.Modal.getInstance(document.getElementById('measureCancelModal')).hide();
            showMeasureToast('danger', 'ยกเลิกมาตรการ ' + document.getElementById('cancelMeasureCode').textContent + ' เรียบร้อยแล้ว');
        });

        function showMeasureToast(type, message) {
            var toastEl = document.getElementById('measureActionToast');
            toastEl.className = 'toast align-items-center text-white border-0 bg-' + type;
            document.getElementById('measureToastMessage').textContent = message;
            new bootstrap.Toast(toastEl, { delay: 3500 }).show();
        }

        function renderAffectedFactoriesRows(factories, riskLevel) {
            if (!factories || factories.length === 0) {
                return '<tr><td colspan="6" class="text-center text-muted py-3">ไม่พบโรงงานที่ได้รับผลกระทบ</td></tr>';
            }
            return factories.map(function (f, i) {
                var markets = f.market.split(',').map(function (m) {
                    return '<span class="badge bg-label-primary me-1" style="font-size:0.65rem;">' + m.trim() + '</span>';
                }).join('');
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (i + 1) + '</td>' +
                    '<td class="fw-semibold font-monospace small">' + f.code + '</td>' +
                    '<td><div class="fw-semibold">' + f.name + '</div><div class="text-muted small fst-italic">' + f.nameEN + '</div></td>' +
                    '<td class="text-center small">' + f.province + '</td>' +
                    '<td>' + markets + '</td>' +
                    '<td class="text-center"><span class="badge rounded-pill ' + f.statusClass + '">' + f.status + '</span></td>' +
                    '</tr>';
            }).join('');
        }

        function populateInspectionConfig(measureCode, detail, row) {
            var cfg = detail.inspectionConfig;
            if (!cfg) { return; }

            // accordion 1: ความถี่
            var freqSel = document.getElementById('configSampleFrequency');
            for (var i = 0; i < freqSel.options.length; i++) {
                if (freqSel.options[i].value === cfg.sampleFrequency) { freqSel.selectedIndex = i; break; }
            }
            document.getElementById('configSamplePercent').value = cfg.samplePercent;

            // accordion 2: แจ้งเตือน
            document.getElementById('configAlertDays').value = cfg.alertDays;
            var unitSel = document.getElementById('configAlertUnit');
            for (var j = 0; j < unitSel.options.length; j++) {
                if (unitSel.options[j].value === cfg.alertUnit) { unitSel.selectedIndex = j; break; }
            }
            document.getElementById('chkAlertStatusChange').checked = cfg.alertOnStatusChange;
            document.getElementById('chkAlertReviewDue').checked = cfg.alertOnReviewDue;
            document.getElementById('chkAlertFactoryIssue').checked = cfg.alertOnFactoryIssue;

            // example toast label
            document.getElementById('configAlertExampleCode').textContent = measureCode;
            document.getElementById('configAlertExampleDays').textContent = cfg.alertDays + ' ' + cfg.alertUnit + ' (วันที่ทบทวน: ' + row.dataset.reviewDueDate + ')';

            // accordion 3: โรงงาน
            var riskLevel = row.dataset.risk;
            var factories = cfg.affectedFactories || [];
            var n = factories.length;
            var badgeClass = riskLevel === 'สูง' ? 'bg-danger' : riskLevel === 'กลาง' ? 'bg-warning' : 'bg-success';
            document.getElementById('configFactoryBadge').innerHTML =
                '<span class="badge ' + badgeClass + ' rounded-pill px-3 py-2" style="font-size:0.8rem;">' +
                '<i class="ri ri-building-line me-1"></i>มาตรการนี้ส่งผลกระทบ ' + n + ' โรงงาน</span>' +
                (riskLevel === 'สูง' ? ' <span class="badge bg-label-danger ms-1">ความเสี่ยงสูง — ต้องตรวจสอบทุก lot</span>' : '');
            document.getElementById('configFactoryTableBody').innerHTML = renderAffectedFactoriesRows(factories, riskLevel);
        }

        // wire "บันทึกตั้งค่า"
        document.getElementById('btnSaveInspConfig').addEventListener('click', function () {
            var measureCode = document.getElementById('detailMeasureCode').textContent;
            showMeasureToast('success', 'บันทึกตั้งค่าการตรวจสอบ ' + measureCode + ' เรียบร้อยแล้ว');
        });

        // Export Excel handlers
        document.querySelectorAll('.btn-export-measure').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var type = this.dataset.exportType;
                var allRows = document.querySelectorAll('#measureTableBody tr[data-measure-code]');
                var filteredRows = Array.from(allRows).filter(function (r) { return !r.classList.contains('d-none'); });
                var highRiskRows = Array.from(allRows).filter(function (r) { return r.dataset.risk === 'สูง'; });

                var label, count;
                if (type === 'all') {
                    label = 'ทั้งหมด (ทุกฟิลด์)';
                    count = allRows.length;
                } else if (type === 'filtered') {
                    label = 'เฉพาะรายการที่กรอง';
                    count = filteredRows.length;
                } else if (type === 'region') {
                    label = 'สรุปตามภูมิภาค';
                    count = null;
                } else if (type === 'highrisk') {
                    label = 'เฉพาะมาตรการความเสี่ยงสูง';
                    count = highRiskRows.length;
                }

                var infoMsg = count !== null
                    ? 'กำลัง Export Excel ' + label + '... (' + count + ' รายการ)'
                    : 'กำลัง Export Excel ' + label + '...';
                showMeasureToast('info', infoMsg);

                setTimeout(function () {
                    var successMsg = count !== null
                        ? 'Export Excel สำเร็จ ' + count + ' รายการ (' + label + ')'
                        : 'Export Excel ' + label + ' สำเร็จ';
                    showMeasureToast('success', successMsg);
                }, 900);
            });
        });
    });
</script>
}

