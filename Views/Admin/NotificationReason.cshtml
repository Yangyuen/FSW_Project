            </div>
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addMeasureModal">
                <i class="ri ri-add-line me-1"></i> เพิ่มมาตรการ
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 measure-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width:56px;">#</th>
                    <th>ประเทศ</th>
                    <th>รหัสมาตรการ</th>
                    <th>ชื่อมาตรการ</th>
                    <th>ขอบเขตสินค้า</th>
                    <th>มีผลใช้</th>
                    <th>ทบทวนถัดไป</th>
                    <th>เสี่ยง</th>
                    <th>สถานะ</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="measureTableBody">
                @foreach (var measure in sanitaryMeasures)
                {
                    <tr data-measure-code="@measure.MeasureCode"
                        data-country="@measure.CountryName"
                        data-region="@measure.Region"
                        data-measure-name="@measure.MeasureName"
                        data-product-scope="@measure.ProductScope"
                        data-owner-unit="@measure.OwnerUnit"
                        data-risk="@measure.RiskLevel"
                        data-status="@measure.StatusText"
                        data-status-class="@measure.StatusClass"
                        data-effective-date="@measure.EffectiveDate.ToString("dd/MM/yyyy")"
                        data-review-due-date="@measure.ReviewDueDate.ToString("dd/MM/yyyy")"
                        data-search-text="@($"{measure.CountryCode} {measure.CountryName} {measure.MeasureCode} {measure.MeasureName} {measure.ProductScope} {measure.Region}")">
                        <td class="text-center text-muted">@measure.RowNo</td>
                        <td>
                            <div class="fw-semibold">@measure.CountryName</div>
                            <div class="text-muted small">@measure.CountryCode</div>
                        </td>
                        <td class="fw-semibold text-primary">@measure.MeasureCode</td>
                        <td>@measure.MeasureName</td>
                        <td>@measure.ProductScope</td>
                        <td class="text-center">@measure.EffectiveDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">@measure.ReviewDueDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <span class="badge rounded-pill @(measure.RiskLevel == "สูง" ? "bg-label-danger" : measure.RiskLevel == "กลาง" ? "bg-label-warning" : "bg-label-success")">@measure.RiskLevel</span>
                        </td>
                        <td class="text-center"><span class="badge rounded-pill @measure.StatusClass">@measure.StatusText</span></td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-view-measure" data-measure-code="@measure.MeasureCode" title="รายละเอียดข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-eye-line text-info"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-edit-measure" data-measure-code="@measure.MeasureCode" title="แก้ไขข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-pencil-line text-warning"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="ประวัติการเปลี่ยนแปลง" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-history-line text-secondary"></i></button>
                                @if (measure.StatusText != "พักใช้ชั่วคราว" && measure.StatusText != "ยกเลิก")
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-suspend-measure" style="color:#ff9f43;border:1px solid #ff9f43;" data-measure-code="@measure.MeasureCode" data-measure-name="@measure.MeasureName" data-country-name="@measure.CountryName" title="ระงับมาตรการ" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-forbid-2-line"></i></button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-cancel-measure" data-measure-code="@measure.MeasureCode" data-measure-name="@measure.MeasureName" title="ยกเลิกมาตรการ" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-close-circle-line text-danger"></i></button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="measureTableEmpty" class="d-none">
                    <td colspan="10" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

