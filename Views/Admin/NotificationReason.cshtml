        font-size: 0.78rem;
    }

    .measure-table-compact th,
    .measure-table-compact td {
        padding: 0.45rem 0.5rem;
        vertical-align: middle;
        line-height: 1.3;
        white-space: normal;
        word-break: break-word;
    }

    .measure-table-compact thead th {
        white-space: normal;
        word-break: keep-all;
        overflow-wrap: normal;
    }

    .measure-table-compact .badge {
        font-size: 0.68rem;
    }

    .measure-table-compact .btn.btn-sm {
        --bs-btn-padding-y: 0.14rem;
        --bs-btn-padding-x: 0.3rem;
    }

    .measure-table-compact .btn-icon {
        width: 1.65rem;
        height: 1.65rem;
    }

    .filter-action-buttons .btn-square {
        width: 48px;
        height: 48px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .detail-kv {
        border: 1px solid var(--bs-border-color);
