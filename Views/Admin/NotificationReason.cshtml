{{- modal: ระงับมาตรการ -}}
<div class="modal fade" id="measureSuspendModal" tabindex="-1" aria-labelledby="measureSuspendModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="measureSuspendModalLabel" style="color:#ff9f43;"><i class="ri ri-forbid-2-line me-2"></i>ระงับมาตรการ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1 text-muted small">รหัสมาตรการ</p>
                <p class="fw-bold mb-1" id="suspendMeasureCode"></p>
                <p class="mb-3 small text-secondary" id="suspendMeasureName"></p>
                <div class="mb-3">
                    <label class="form-label">วันที่มีผล</label>
                    <input type="date" id="suspendEffectiveDate" class="form-control" />
                </div>
                <div class="mb-1">
                    <label class="form-label">เหตุผลการระงับ <span class="text-danger">*</span></label>
                    <textarea id="suspendReason" class="form-control" rows="3" placeholder="ระบุเหตุผลการระงับมาตรการ (required)"></textarea>
                    <div class="invalid-feedback">กรุณาระบุเหตุผล</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmSuspend" class="btn text-white fw-semibold" style="background:#ff9f43;border-color:#ff9f43;"><i class="ri ri-forbid-2-line me-1"></i>ยืนยันระงับมาตรการ</button>
            </div>
        </div>
    </div>
</div>

{{- modal: ยกเลิกมาตรการ -}}
<div class="modal fade" id="measureCancelModal" tabindex="-1" aria-labelledby="measureCancelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger" id="measureCancelModalLabel"><i class="ri ri-close-circle-line me-2"></i>ยกเลิกมาตรการ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger d-flex gap-2 align-items-start py-2 mb-3">
                    <i class="ri ri-alert-line mt-1"></i>
                    <span class="small">การยกเลิกมาตรการจะมีผลถาวร และบันทึกลงในประวัติการดำเนินการ</span>
                </div>
                <p class="mb-1 text-muted small">รหัสมาตรการ</p>
                <p class="fw-bold mb-1" id="cancelMeasureCode"></p>
                <p class="mb-3 small text-secondary" id="cancelMeasureName"></p>
                <div class="mb-3">
                    <label class="form-label">วันที่ยกเลิก</label>
                    <input type="date" id="cancelDate" class="form-control" />
                </div>
                <div class="mb-1">
                    <label class="form-label">เหตุผลการยกเลิก <span class="text-danger">*</span></label>
                    <textarea id="cancelReason" class="form-control" rows="3" placeholder="ระบุเหตุผลการยกเลิกมาตรการ (required)"></textarea>
                    <div class="invalid-feedback">กรุณาระบุเหตุผล</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmCancel" class="btn btn-danger"><i class="ri ri-close-circle-line me-1"></i>ยืนยันยกเลิกมาตรการ</button>
            </div>
        </div>
    </div>
</div>

