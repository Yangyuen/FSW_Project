                            <span class="fw-semibold" id="detailAnnPublish">-</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="detail-kv-mini">
                            <small class="text-muted d-block">วันหมดอายุ</small>
                            <span class="fw-semibold" id="detailAnnExpire">-</span>
                        </div>
                    </div>
                    <div class="col-md-4">
