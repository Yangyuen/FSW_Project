@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {

        // ---- Filter ----
        function filterRows() {
            var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
            var typeFilter = (document.getElementById('filterType').value || '').trim();
            var targetFilter = (document.getElementById('filterTarget').value || '').trim();
            var statusFilter = (document.getElementById('filterStatus').value || '').trim();

            var rows = document.querySelectorAll('#announceTableBody tr[data-ann-id]');
            var visible = 0;
            rows.forEach(function (row) {
                var title = (row.dataset.title || '').toLowerCase();
                var type = (row.dataset.type || '');
                var target = (row.dataset.target || '');
                var status = (row.dataset.status || '');

                var match =
                    (!keyword || title.includes(keyword)) &&
                    (!typeFilter || type === typeFilter) &&
                    (!targetFilter || target === targetFilter) &&
                    (!statusFilter || status === statusFilter);

                row.classList.toggle('d-none', !match);
                if (match) visible++;
            });
            document.getElementById('announceTableEmpty').classList.toggle('d-none', visible !== 0);
            document.getElementById('visibleCount').textContent = visible;
        }

        document.getElementById('btnSearch').addEventListener('click', filterRows);
        document.getElementById('btnReset').addEventListener('click', function () {
            document.getElementById('filterKeyword').value = '';
            document.getElementById('filterType').value = '';
            document.getElementById('filterTarget').value = '';
            document.getElementById('filterStatus').value = '';
            filterRows();
        });
        document.getElementById('filterKeyword').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
        });
        ['filterType', 'filterTarget', 'filterStatus'].forEach(function (id) {
            document.getElementById(id).addEventListener('change', filterRows);
        });

        // ---- Open detail ----
        document.querySelectorAll('.btn-view-ann, .btn-edit-ann').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var id = this.dataset.annId;
                var row = document.querySelector('#announceTableBody tr[data-ann-id="' + id + '"]');
                if (!row) return;
                document.getElementById('annModalTitle').textContent = row.dataset.title;
                document.getElementById('detailAnnId').textContent = id;
                document.getElementById('detailAnnType').innerHTML = '<span class="badge ' + row.dataset.typeClass + '"><i class="ri ' + row.dataset.typeIcon + ' me-1"></i>' + row.dataset.type + '</span>';
                document.getElementById('detailAnnTarget').textContent = row.dataset.target;
                document.getElementById('detailAnnPublish').textContent = row.dataset.publishDate;
                document.getElementById('detailAnnExpire').textContent = row.dataset.expireDate;
                document.getElementById('detailAnnStatus').innerHTML = '<span class="badge ' + row.dataset.statusClass + '">' + row.dataset.status + '</span>';
                document.getElementById('detailAnnCreatedBy').textContent = row.dataset.createdBy;
                new bootstrap.Modal(document.getElementById('annDetailModal')).show();
            });
        });

        // ---- Add Link (in create/edit modal) ----
        var linkCount = 0;
        document.getElementById('btnAddLink').addEventListener('click', function () {
            linkCount++;
            var item = document.createElement('div');
            item.className = 'link-list-item';
            item.innerHTML =
                '<i class="ri ri-links-line text-primary"></i>' +
                '<input type="url" class="form-control form-control-sm" placeholder="https://..." style="flex:1;">' +
                '<input type="text" class="form-control form-control-sm ms-1" placeholder="ชื่อลิงก์" style="width:140px;">' +
                '<button type="button" class="btn btn-icon btn-xs btn-outline-danger btn-remove ms-1"><i class="ri ri-close-line"></i></button>';
            item.querySelector('.btn-remove').addEventListener('click', function () { item.remove(); });
            document.getElementById('linkListContainer').appendChild(item);
        });

        // ---- Add File (in create/edit modal) ----
        document.getElementById('btnAddFile').addEventListener('click', function () {
            var item = document.createElement('div');
            item.className = 'file-list-item';
            var fileInput = document.createElement('input');
            fileInput.type = 'file';
            fileInput.accept = '.pdf,.doc,.docx,.xls,.xlsx,.zip';
            fileInput.style.display = 'none';
            fileInput.addEventListener('change', function () {
                if (fileInput.files.length > 0) {
                    var file = fileInput.files[0];
                    if (file.size > 10 * 1024 * 1024) {
                        alert('ขนาดไฟล์เกิน 10 MB กรุณาเลือกไฟล์ใหม่');
                        return;
                    }
                    label.textContent = file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB)';
                }
            });
            var label = document.createElement('span');
            label.className = 'flex-grow-1 text-muted small';
            label.textContent = 'ยังไม่ได้เลือกไฟล์';
            var selectBtn = document.createElement('button');
            selectBtn.type = 'button';
            selectBtn.className = 'btn btn-xs btn-outline-primary';
            selectBtn.innerHTML = '<i class="ri ri-upload-2-line me-1"></i> เลือกไฟล์';
            selectBtn.addEventListener('click', function () { fileInput.click(); });
            var removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'btn btn-icon btn-xs btn-outline-danger btn-remove ms-1';
            removeBtn.innerHTML = '<i class="ri ri-close-line"></i>';
            removeBtn.addEventListener('click', function () { item.remove(); });
            item.appendChild(document.createElement('i')).className = 'ri ri-file-line text-success';
            item.appendChild(fileInput);
            item.appendChild(label);
            item.appendChild(selectBtn);
            item.appendChild(removeBtn);
            document.getElementById('fileListContainer').appendChild(item);
        });

        // ---- Schedule date toggle ----
        document.querySelectorAll('input[name="publishMode"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                var show = this.value === 'schedule';
                document.getElementById('schedulePublishDateRow').classList.toggle('d-none', !show);
            });
        });

        // ---- Preview modal ----
        document.getElementById('btnPreview').addEventListener('click', function () {
            var title = (document.getElementById('annTitle').value || '').trim() || '(ยังไม่ได้ระบุหัวข้อ)';
            var content = (document.getElementById('annContent').value || '').trim() || '(ยังไม่มีเนื้อหา)';
            var type = document.getElementById('annType').options[document.getElementById('annType').selectedIndex].text;
            document.getElementById('previewTitle').textContent = title;
            document.getElementById('previewType').textContent = type;
            document.getElementById('previewContent').textContent = content;
            var lnkCount = document.getElementById('linkListContainer').children.length;
            var fileCount = document.getElementById('fileListContainer').children.length;
            document.getElementById('previewAttachInfo').textContent =
                'ลิงก์: ' + lnkCount + ' รายการ  |  ไฟล์: ' + fileCount + ' รายการ';
            new bootstrap.Modal(document.getElementById('previewModal')).show();
        });
    });
</script>
}

