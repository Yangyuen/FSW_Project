</div>

<!-- Table Card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการข่าวประชาสัมพันธ์</h5>
            <p class="text-muted small mb-0">แสดง <span id="visibleCount">@totalCount</span> รายการ</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addAnnouncementModal">
                <i class="ri ri-megaphone-line me-1"></i> เพิ่มข่าว
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 announce-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width:44px;">#</th>
                    <th class="announce-title-col">หัวข้อข่าว</th>
                    <th style="min-width:100px;">ประเภท</th>
                    <th style="min-width:100px;">กลุ่มเป้าหมาย</th>
                    <th style="min-width:110px;">วันเผยแพร่</th>
                    <th style="min-width:110px;">วันหมดอายุ</th>
                    <th style="min-width:70px;">ไฟล์/ลิงก์</th>
                    <th style="min-width:100px;">สถานะ</th>
                    <th style="width:7rem;">การดำเนินการ</th>
                </tr>
            </thead>
            <tbody id="announceTableBody">
                @foreach (var ann in announcements)
                {
                    <tr data-ann-id="@ann.AnnouncementId"
                        data-title="@ann.Title"
                        data-type="@ann.TypeText"
                        data-type-class="@ann.TypeClass"
                        data-type-icon="@ann.TypeIcon"
                        data-target="@ann.Target"
                        data-publish-date="@ann.PublishDate.ToString("dd/MM/yyyy")"
                        data-expire-date="@ann.ExpireDate.ToString("dd/MM/yyyy")"
                        data-status="@ann.StatusText"
                        data-status-class="@ann.StatusClass"
                        data-created-by="@ann.CreatedBy">
                        <td class="text-center text-muted">@ann.RowNo</td>
                        <td class="announce-title-col">
                            @if (ann.PinTop)
                            {
                                <span class="badge bg-label-danger pin-badge me-1"><i class="ri ri-pushpin-line"></i> ปักหมุด</span>
                            }
                            <span class="fw-semibold small d-block">@ann.Title</span>
                            <small class="text-muted">@ann.AnnouncementId</small>
                        </td>
                        <td class="text-center">
                            <span class="badge @ann.TypeClass">
                                <i class="ri @ann.TypeIcon me-1"></i>@ann.TypeText
                            </span>
                        </td>
                        <td class="text-center">
                            @if (ann.Target == "ทุกคน")
                            {
                                <span class="badge bg-label-primary">ทุกคน</span>
                            }
                            else if (ann.Target == "ผู้ประกอบการ")
                            {
                                <span class="badge bg-label-info">ผู้ประกอบการ</span>
                            }
                            else
                            {
                                <span class="badge bg-label-warning">เจ้าหน้าที่</span>
                            }
                        </td>
                        <td class="text-center">@ann.PublishDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center @(ann.StatusText == "หมดอายุ" ? "text-danger" : "")">
                            @ann.ExpireDate.ToString("dd/MM/yyyy")
                            @if (ann.StatusText == "หมดอายุ")
                            {
                                <i class="ri ri-error-warning-line" title="หมดอายุแล้ว"></i>
                            }
                        </td>
                        <td class="text-center">
                            @if (ann.AttachmentCount > 0)
                            {
                                <span class="badge bg-label-success me-1"><i class="ri ri-file-line me-1"></i>@ann.AttachmentCount</span>
                            }
                            @if (ann.LinkCount > 0)
                            {
                                <span class="badge bg-label-info"><i class="ri ri-links-line me-1"></i>@ann.LinkCount</span>
                            }
                            @if (ann.AttachmentCount == 0 && ann.LinkCount == 0)
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill @ann.StatusClass">@ann.StatusText</span>
                        </td>
                        <td class="text-center text-nowrap">
                            <button class="btn btn-icon btn-sm btn-outline-primary me-1 btn-view-ann" data-ann-id="@ann.AnnouncementId" title="ดูรายละเอียด">
                                <i class="ri ri-eye-line"></i>
                            </button>
                            <button class="btn btn-icon btn-sm btn-outline-warning me-1 btn-edit-ann" data-ann-id="@ann.AnnouncementId" title="แก้ไข">
                                <i class="ri ri-pencil-line"></i>
                            </button>
                            <button class="btn btn-icon btn-sm btn-outline-danger" title="ลบ">
                                <i class="ri ri-delete-bin-line"></i>
                            </button>
                        </td>
                    </tr>
                }
                <tr id="announceTableEmpty" class="d-none">
                    <td colspan="9" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ===== Modal: เพิ่ม/แก้ไขข่าวประชาสัมพันธ์ ===== -->
<div class="modal fade" id="addAnnouncementModal" tabindex="-1" aria-labelledby="addAnnouncementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addAnnouncementModalLabel">
                    เพิ่ม/แก้ไขข่าวประชาสัมพันธ์
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <!-- Left column -->
                    <div class="col-lg-8">
                        <!-- Basic info -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">หัวข้อข่าว <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="annTitle" placeholder="กรอกหัวข้อข่าว เช่น ประกาศ: แนวทางปฏิบัติ...">
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">ประเภทข่าว <span class="text-danger">*</span></label>
                                <select class="form-select" id="annType">
                                    <option value="">-- เลือกประเภท --</option>
                                    <option value="news">ข่าวสาร</option>
                                    <option value="announce">ประกาศ</option>
                                    <option value="warning">คำเตือน</option>
                                    <option value="update">อัปเดตระบบ</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">กลุ่มเป้าหมาย <span class="text-danger">*</span></label>
                                <div class="d-flex flex-wrap gap-3 mt-1">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="targetOperator" value="ผู้ประกอบการ">
                                        <label class="form-check-label" for="targetOperator">ผู้ประกอบการ</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="targetOfficer" value="เจ้าหน้าที่">
                                        <label class="form-check-label" for="targetOfficer">เจ้าหน้าที่</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="targetAll" value="ทุกคน">
                                        <label class="form-check-label" for="targetAll">ทุกคน</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Content -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">เนื้อหาข่าว <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="annContent" rows="6"
                                placeholder="กรอกเนื้อหาข่าวประชาสัมพันธ์ รองรับรูปแบบข้อความธรรมดา (plain text)&#10;&#10;เช่น กรมประมงขอประกาศว่า..."></textarea>
                            <div class="form-text">รองรับข้อความธรรมดา (plain text) ขนาดสูงสุด 5,000 ตัวอักษร</div>
                        </div>
                        <!-- Attachments -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label fw-semibold mb-0">
                                    <i class="ri ri-links-line me-1 text-primary"></i>แนบลิงก์
                                </label>
                                <button type="button" class="btn btn-xs btn-outline-primary" id="btnAddLink">
                                    <i class="ri ri-add-line me-1"></i> + เพิ่มลิงก์
                                </button>
                            </div>
                            <div id="linkListContainer">
                                <!-- Dynamic link items -->
                                <div class="link-list-item">
                                    <i class="ri ri-links-line text-primary"></i>
                                    <input type="url" class="form-control form-control-sm" placeholder="https://..." style="flex:1;" value="https://www.fisheries.go.th/news/2569">
                                    <input type="text" class="form-control form-control-sm ms-1" placeholder="ชื่อลิงก์" style="width:160px;" value="ข่าวบนเว็บไซต์กรมประมง">
                                    <button type="button" class="btn btn-icon btn-xs btn-outline-danger btn-remove ms-1"><i class="ri ri-close-line"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label fw-semibold mb-0">
                                    <i class="ri ri-attachment-2 me-1 text-success"></i>แนบไฟล์
                                    <span class="text-muted fw-normal small">(PDF / DOC / XLSX / ZIP, สูงสุด 10 MB ต่อไฟล์)</span>
                                </label>
                                <button type="button" class="btn btn-xs btn-outline-success" id="btnAddFile">
                                    <i class="ri ri-upload-2-line me-1"></i> + แนบไฟล์
                                </button>
                            </div>
                            <div id="fileListContainer">
                                <!-- Dynamic file items -->
                                <div class="file-list-item">
                                    <i class="ri ri-file-pdf-line text-danger"></i>
                                    <span class="flex-grow-1 small">ประกาศกรมประมง_2569.pdf (245 KB)</span>
                                    <span class="badge bg-label-secondary ms-1">PDF</span>
                                    <button type="button" class="btn btn-icon btn-xs btn-outline-danger btn-remove ms-1"><i class="ri ri-close-line"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Right column: settings -->
                    <div class="col-lg-4">
                        <div class="card border-0 p-3 h-100">
                            <h6 class="fw-semibold mb-3"><i class="ri ri-settings-3-line me-1"></i>ตั้งค่าการเผยแพร่</h6>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">วันที่เผยแพร่ <span class="text-danger">*</span></label>
                                <input type="text" class="form-control form-control-sm flatpickr-date" id="annPublishDate" placeholder="วว/ดด/ปปปป">
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">วันหมดอายุ</label>
                                <input type="text" class="form-control form-control-sm flatpickr-date" id="annExpireDate" placeholder="วว/ดด/ปปปป">
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">สถานะการเผยแพร่ <span class="text-danger">*</span></label>
                                <div class="d-flex flex-column gap-2 mt-1">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="publishMode" id="modeDraft" value="draft" checked>
                                        <label class="form-check-label small" for="modeDraft">
                                            ฉบับร่าง (บันทึกเท่านั้น)
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="publishMode" id="modeNow" value="now">
                                        <label class="form-check-label small" for="modeNow">
                                            เผยแพร่ทันที
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="publishMode" id="modeSchedule" value="schedule">
                                        <label class="form-check-label small" for="modeSchedule">
                                            กำหนดเวลาเผยแพร่
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3 d-none" id="schedulePublishDateRow">
                                <label class="form-label fw-semibold small">วันและเวลาที่กำหนดเผยแพร่ <span class="text-danger">*</span></label>
                                <input type="text" class="form-control form-control-sm" id="annScheduleDate" placeholder="วว/ดด/ปปปป ชช:นน">
                            </div>
                            <hr class="my-3">
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="annPinTop">
                                    <label class="form-check-label small fw-semibold" for="annPinTop">
                                        ปักหมุดข้างบน
                                    </label>
                                </div>
                                <div class="form-text small mt-1">ข่าวจะแสดงที่ด้านบนสุดของรายการเสมอ</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">หมายเหตุภายใน</label>
                                <textarea class="form-control form-control-sm" rows="3" placeholder="บันทึกภายในสำหรับ Admin เท่านั้น (ไม่แสดงต่อผู้ใช้)"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i> ยกเลิก
                </button>
                <button type="button" class="btn btn-outline-info" id="btnPreview">
                    <i class="ri ri-eye-line me-1"></i> ตัวอย่างการแสดงผล
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-save-line me-1"></i> บันทึกฉบับร่าง
                </button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">
                    <i class="ri ri-broadcast-line me-1"></i> เผยแพร่
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ===== Modal: รายละเอียดข่าว ===== -->
<div class="modal fade" id="annDetailModal" tabindex="-1" aria-labelledby="annDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="annDetailModalLabel">
                    <span id="annModalTitle">รายละเอียดข่าว</span>
