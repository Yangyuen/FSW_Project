            <div class="col-md-3 col-lg-2">
                <label for="filterType" class="form-label">ประเภท</label>
                <select id="filterType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ข่าวสาร">ข่าวสาร</option>
                    <option value="ประกาศ">ประกาศ</option>
                    <option value="คำเตือน">คำเตือน</option>
                    <option value="อัปเดตระบบ">อัปเดตระบบ</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterTarget" class="form-label">กลุ่มเป้าหมาย</label>
                <select id="filterTarget" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ทุกคน">ทุกคน</option>
                    <option value="ผู้ประกอบการ">ผู้ประกอบการ</option>
                    <option value="เจ้าหน้าที่">เจ้าหน้าที่</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="เผยแพร่แล้ว">เผยแพร่แล้ว</option>
                    <option value="หมดอายุ">หมดอายุ</option>
                    <option value="ฉบับร่าง">ฉบับร่าง</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearch" class="btn btn-outline-primary btn-square" title="ค้นหา"><i class="ri ri-search-line"></i></button>
                    <button type="button" id="btnReset" class="btn btn-outline-secondary btn-square" title="ล้างค่า"><i class="ri ri-refresh-line"></i></button>
                </div>
            </div>
