                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="detail-kv-mini">
                            <small class="text-muted d-block">ประเภท</small>
                            <span id="detailAnnType">-</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="detail-kv-mini">
                            <small class="text-muted d-block">กลุ่มเป้าหมาย</small>
                            <span class="fw-semibold" id="detailAnnTarget">-</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="detail-kv-mini">
