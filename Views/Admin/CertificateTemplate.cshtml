@{
    ViewData["Title"] = "กำหนดรูปแบบใบรับรอง";

    var templates = new[]
    {
        new
        {
            Id = 1,
            TemplateName = "Declaration – สหภาพยุโรป (มาตรฐาน)",
            CertificateType = "declaration",
            CertificateTypeName = "ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)",
            TargetGroup = "สหภาพยุโรป (EU)",
            Countries = new[] { "ฝรั่งเศส", "เยอรมนี", "อิตาลี", "สเปน", "เนเธอร์แลนด์" },
            HsCodePattern = "0301–0308",
            Version = "v2.4",
            IsActive = true,
            UpdatedAt = new DateTime(2026, 3, 10),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "เจ้าหน้าที่จัดทำ"
        },
        new
        {
            Id = 2,
            TemplateName = "Declaration – ญี่ปุ่น",
            CertificateType = "declaration",
            CertificateTypeName = "ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)",
            TargetGroup = "ญี่ปุ่น",
            Countries = new[] { "ญี่ปุ่น" },
            HsCodePattern = "0303, 0304",
            Version = "v1.8",
            IsActive = true,
            UpdatedAt = new DateTime(2026, 2, 28),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "อัตโนมัติหลังรับคำขอ"
        },
        new
        {
            Id = 3,
            TemplateName = "Declaration – สหรัฐอเมริกา",
            CertificateType = "declaration",
            CertificateTypeName = "ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)",
            TargetGroup = "อเมริกาเหนือ",
            Countries = new[] { "สหรัฐอเมริกา", "แคนาดา" },
            HsCodePattern = "0301–0308",
            Version = "v3.1",
            IsActive = true,
            UpdatedAt = new DateTime(2026, 4, 1),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "อัตโนมัติทั้งกระบวนการ"
        },
        new
        {
            Id = 4,
            TemplateName = "Declaration – เกาหลีใต้",
            CertificateType = "declaration",
            CertificateTypeName = "ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)",
            TargetGroup = "เกาหลีใต้",
            Countries = new[] { "เกาหลีใต้" },
            HsCodePattern = "0303, 0304",
            Version = "v1.2",
            IsActive = false,
            UpdatedAt = new DateTime(2025, 11, 15),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "เจ้าหน้าที่จัดทำ"
        },
        new
        {
            Id = 5,
            TemplateName = "Declaration – ออสเตรเลีย",
            CertificateType = "declaration",
            CertificateTypeName = "ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)",
            TargetGroup = "โอเชียเนีย",
            Countries = new[] { "ออสเตรเลีย" },
            HsCodePattern = "0301–0308",
            Version = "v1.5",
            IsActive = true,
            UpdatedAt = new DateTime(2026, 1, 20),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "อัตโนมัติหลังการตรวจปล่อย"
        },
        new
        {
            Id = 6,
            TemplateName = "Processing Statement – สหภาพยุโรป (มาตรฐาน)",
            CertificateType = "processing",
            CertificateTypeName = "ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)",
            TargetGroup = "สหภาพยุโรป (EU)",
            Countries = new[] { "ฝรั่งเศส", "เยอรมนี", "อิตาลี", "สเปน", "เนเธอร์แลนด์" },
            HsCodePattern = "1604, 1605",
            Version = "v2.0",
            IsActive = true,
            UpdatedAt = new DateTime(2026, 3, 15),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "เจ้าหน้าที่จัดทำ"
        },
        new
        {
            Id = 7,
            TemplateName = "Processing Statement – สหรัฐอเมริกา",
            CertificateType = "processing",
            CertificateTypeName = "ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)",
            TargetGroup = "อเมริกาเหนือ",
            Countries = new[] { "สหรัฐอเมริกา", "แคนาดา" },
            HsCodePattern = "1604, 1605",
            Version = "v2.3",
            IsActive = true,
            UpdatedAt = new DateTime(2026, 4, 5),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "อัตโนมัติหลังรับคำขอ"
        },
        new
        {
            Id = 8,
            TemplateName = "Processing Statement – อาร์เจนตินา",
            CertificateType = "processing",
            CertificateTypeName = "ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)",
            TargetGroup = "อเมริกาใต้",
            Countries = new[] { "อาร์เจนตินา", "บราซิล" },
            HsCodePattern = "1604, 1605",
            Version = "v1.0",
            IsActive = false,
            UpdatedAt = new DateTime(2025, 9, 30),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "เจ้าหน้าที่จัดทำ"
        },
        new
        {
            Id = 9,
            TemplateName = "Processing Statement – ญี่ปุ่น",
            CertificateType = "processing",
            CertificateTypeName = "ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)",
            TargetGroup = "ญี่ปุ่น",
            Countries = new[] { "ญี่ปุ่น" },
            HsCodePattern = "1604, 6014",
            Version = "v1.6",
            IsActive = true,
            UpdatedAt = new DateTime(2026, 2, 10),
            UpdatedBy = "ผู้ดูแลระบบ",
            ProductionMode = "อัตโนมัติทั้งกระบวนการ"
        },
    };

    var totalCount       = templates.Length;
    var activeCount      = templates.Count(t => t.IsActive);
    var declarationCount = templates.Count(t => t.CertificateType == "declaration");
    var processingCount  = templates.Count(t => t.CertificateType == "processing");
}

@section PageStyles {
<style>
    .template-table-compact {
        font-size: 0.8rem;
    }
    .template-table-compact th,
    .template-table-compact td {
        padding: 0.5rem 0.6rem;
        vertical-align: middle;
        line-height: 1.4;
    }
    .template-table-compact .badge {
        font-size: 0.68rem;
    }
    .template-table-compact .btn.btn-sm {
        --bs-btn-padding-y: 0.14rem;
        --bs-btn-padding-x: 0.3rem;
    }
    .template-table-compact .btn-icon {
        width: 1.65rem;
        height: 1.65rem;
    }
    .filter-action-buttons .btn-square {
        width: 48px;
        height: 48px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .country-tags .badge {
        font-size: 0.65rem;
    }
    .version-badge {
        font-family: monospace;
        font-size: 0.72rem;
    }
    /* Field builder (modal) */
    #fieldBuilderList .field-item {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        padding: 0.55rem 0.75rem;
        cursor: grab;
    }
    #fieldBuilderList .field-item:active { cursor: grabbing; }
    #fieldBuilderList .field-item .field-drag-handle {
        color: #adb5bd;
        cursor: grab;
    }
    .field-section-header {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #6c757d;
        font-weight: 600;
    }
    .edit-history-table {
        font-size: 0.79rem;
    }
    .edit-history-table th,
    .edit-history-table td {
        padding: 0.45rem 0.6rem;
        vertical-align: middle;
    }
    .restriction-table {
        font-size: 0.79rem;
    }
    .restriction-table th,
    .restriction-table td {
        padding: 0.45rem 0.6rem;
        vertical-align: middle;
    }
</style>
}

@* ************** Content ************** *@
<h4 class="mb-1">กำหนดรูปแบบใบรับรอง</h4>
<p class="mb-1">กำหนดและจัดการรูปแบบการจัดทำใบรับรองสำหรับแต่ละประเภทและประเทศปลายทาง</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="#" class="text-primary fw-semibold">ผู้ดูแลระบบ</a>
        </li>
        <li class="breadcrumb-item active text-secondary">กำหนดรูปแบบใบรับรอง</li>
    </ol>
</nav>

<!-- Summary Cards -->
<div class="row mb-6 g-6">
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@totalCount</h5>
                        <small>รูปแบบทั้งหมด</small>
                    </div>
                    <span class="badge bg-label-primary rounded-circle p-2">
                        <i class="icon-base ri ri-file-text-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@activeCount</h5>
                        <small>รูปแบบที่ใช้งานอยู่</small>
                    </div>
                    <span class="badge bg-label-success rounded-circle p-2">
                        <i class="icon-base ri ri-checkbox-circle-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@declarationCount</h5>
                        <small>Declaration</small>
                    </div>
                    <span class="badge bg-label-info rounded-circle p-2">
                        <i class="icon-base ri ri-leaf-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@processingCount</h5>
                        <small>Processing Statement</small>
                    </div>
                    <span class="badge bg-label-warning rounded-circle p-2">
                        <i class="icon-base ri ri-settings-3-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ค้นหารูปแบบใบรับรอง</h5>
            <p class="text-muted small mb-0">กรองตามประเภทใบรับรอง กลุ่มประเทศ และสถานะการใช้งาน</p>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label for="filterType" class="form-label">ประเภทใบรับรอง</label>
                <select id="filterType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="declaration">ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)</option>
                    <option value="processing">ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterCountry" class="form-label">กลุ่มประเทศ / ประเทศปลายทาง</label>
                <input type="text" id="filterCountry" class="form-control" placeholder="เช่น EU, ญี่ปุ่น, สหรัฐอเมริกา" />
            </div>
            <div class="col-md-2 col-lg-3">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="active">ใช้งานอยู่</option>
                    <option value="inactive">ปิดใช้งาน</option>
                </select>
            </div>
            <div class="col-md-2 col-lg-3">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearchTemplates" class="btn btn-outline-primary btn-square" title="ค้นหา" data-bs-toggle="tooltip" data-bs-placement="top">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnResetTemplates" class="btn btn-outline-secondary btn-square" title="ล้างเงื่อนไข" data-bs-toggle="tooltip" data-bs-placement="top">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Table Card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการรูปแบบใบรับรอง</h5>
            <p class="text-muted small mb-0">จัดการรูปแบบ เนื้อหา และเงื่อนไขการออกใบรับรองแต่ละประเภท</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalAddTemplate">
                <i class="ri ri-add-line me-1"></i> เพิ่มรูปแบบ
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 template-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width:50px;">#</th>
                    <th>ชื่อรูปแบบ</th>
                    <th>ประเภทใบรับรอง</th>
                    <th>กลุ่มประเทศ / ประเทศ</th>
                    <th>HS Code</th>
                    <th>เวอร์ชัน</th>
                    <th>อัปเดตล่าสุด</th>
                    <th>สถานะ</th>
                    <th style="width:175px;"></th>
                </tr>
            </thead>
            <tbody id="templateTableBody">
                @foreach (var t in templates)
                {
                    <tr data-type="@t.CertificateType"
                        data-id="@t.Id"
                        data-country="@string.Join(" ", t.Countries).ToLower()"
                        data-status="@(t.IsActive ? "active" : "inactive")">
                        <td class="text-center text-muted">@t.Id</td>
                        <td>
                            <div class="fw-semibold">
                                @t.TemplateName
                                @if (t.Id == 1 || t.Id == 6)
                                {
                                    <span class="badge ms-1" style="background-color:#ff9f43;color:#fff;font-size:0.65rem;">มีข้อจำกัด: @(t.Id == 1 ? 2 : 1) โรงงาน ⚠️</span>
                                }
                            </div>
                            <small class="text-muted">แก้ไขโดย @t.UpdatedBy</small>
                            <div class="mt-1">
                                @if (t.ProductionMode == "อัตโนมัติหลังการตรวจปล่อย")
                                {
                                    <span class="badge" style="background-color:rgba(115,103,240,0.16);color:#7367f0;font-size:0.62rem;">⚙ @t.ProductionMode</span>
                                }
                                else if (t.ProductionMode == "อัตโนมัติทั้งกระบวนการ")
                                {
                                    <span class="badge bg-label-success" style="font-size:0.62rem;">⚙ @t.ProductionMode</span>
                                }
                                else if (t.ProductionMode == "อัตโนมัติหลังรับคำขอ")
                                {
                                    <span class="badge bg-label-info" style="font-size:0.62rem;">⚙ @t.ProductionMode</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-warning" style="font-size:0.62rem;">⚙ @t.ProductionMode</span>
                                }
                            </div>
                            <div class="mt-1" id="effectiveBadge-@t.Id"></div>
                        </td>
                        <td>
                            @if (t.CertificateType == "declaration")
                            {
                                <span class="badge bg-label-info">Declaration</span>
                            }
                            else
                            {
                                <span class="badge bg-label-warning">Processing</span>
                            }
                        </td>
                        <td>
                            <div class="fw-semibold mb-1">@t.TargetGroup</div>
                            <div class="country-tags d-flex flex-wrap gap-1">
                                @foreach (var c in t.Countries.Take(3))
                                {
                                    <span class="badge bg-label-secondary">@c</span>
                                }
                                @if (t.Countries.Length > 3)
                                {
                                    <span class="badge bg-label-secondary">+@(t.Countries.Length - 3)</span>
                                }
                            </div>
                        </td>
                        <td class="text-center"><code class="version-badge">@t.HsCodePattern</code></td>
                        <td class="text-center">
                            <span class="badge bg-label-primary version-badge">@t.Version</span>
                        </td>
                        <td class="text-center">@t.UpdatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @if (t.IsActive)
                            {
                                <span class="badge rounded-pill bg-label-success">ใช้งานอยู่</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-label-secondary">ปิดใช้งาน</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info"
                                    title="ดูตัวอย่าง" data-bs-toggle="modal" data-bs-target="#modalPreview"
                                    data-id="@t.Id" data-name="@t.TemplateName"
                                    aria-label="ดูตัวอย่าง">
                                    <i class="ri ri-eye-line text-info"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning"
                                    title="แก้ไขรูปแบบ" data-bs-toggle="modal" data-bs-target="#modalEditTemplate"
                                    data-id="@t.Id" data-name="@t.TemplateName"
                                    aria-label="แก้ไขรูปแบบ">
                                    <i class="ri ri-pencil-line text-warning"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-primary"
                                    title="กำหนดช่องข้อมูล" data-bs-toggle="modal" data-bs-target="#modalFieldBuilder"
                                    data-id="@t.Id" data-name="@t.TemplateName"
                                    aria-label="กำหนดช่องข้อมูล">
                                    <i class="ri ri-layout-column-line text-primary"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary btn-set-prod-mode"
                                    title="กำหนดรูปแบบการจัดทำ" data-bs-toggle="modal" data-bs-target="#modalSetProductionMode"
                                    data-id="@t.Id" data-name="@t.TemplateName"
                                    aria-label="กำหนดรูปแบบการจัดทำ">
                                    <i class="ri ri-settings-4-line" style="color:#7367f0;"></i>
                                </button>
                                @if (t.IsActive)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-dark"
                                        title="ปิดใช้งาน" aria-label="ปิดใช้งาน">
                                        <i class="ri ri-toggle-line text-dark"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success"
                                        title="เปิดใช้งาน" aria-label="เปิดใช้งาน">
                                        <i class="ri ri-toggle-fill text-success"></i>
                                    </button>
                                }
                                <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-manage-restriction"
                                    title="จัดการข้อจำกัด" aria-label="จัดการข้อจำกัด"
                                    data-id="@t.Id" data-name="@t.TemplateName">
                                    <i class="ri ri-shield-star-line"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-danger"
                                    title="ลบรูปแบบ" aria-label="ลบรูปแบบ">
                                    <i class="ri ri-delete-bin-line text-danger"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="templateTableEmpty" class="d-none">
                    <td colspan="9" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>


<!-- ==================== Modal: เพิ่มรูปแบบใบรับรอง ==================== -->
<div class="modal fade" id="modalAddTemplate" tabindex="-1" aria-labelledby="modalAddTemplateLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalAddTemplateLabel">
                    เพิ่มรูปแบบใบรับรอง
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
