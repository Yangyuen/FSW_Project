<!-- ==================== Modal: กำหนดช่องข้อมูล (Field Builder) ==================== -->
<div class="modal fade" id="modalFieldBuilder" tabindex="-1" aria-labelledby="modalFieldBuilderLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalFieldBuilderLabel">
                    กำหนดช่องข้อมูลในใบรับรอง
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="alert alert-primary m-3 py-2 d-flex align-items-center gap-2">
                    <i class="ri ri-information-line"></i>
                    <span>รูปแบบ: <strong id="fieldBuilderTemplateName">Declaration – สหภาพยุโรป (มาตรฐาน)</strong></span>
                </div>
                <div class="row g-0">
                    <!-- Left: Available fields -->
                    <div class="col-md-4 border-end p-3">
                        <p class="field-section-header mb-2">ช่องข้อมูลที่พร้อมใช้งาน</p>
                        <div class="input-group input-group-sm mb-3">
                            <span class="input-group-text"><i class="ri ri-search-line"></i></span>
                            <input type="text" class="form-control" placeholder="ค้นหาช่องข้อมูล..." />
                        </div>
                        <div class="d-flex flex-column gap-2" id="availableFieldList">
                            @{
                                var availableFields = new[]
                                {
                                    new { Icon = "ri-hashtag", Label = "เลขที่ใบรับรอง (HC Number)", Type = "text", Tag = "header" },
                                    new { Icon = "ri-calendar-line", Label = "วันที่ออกเอกสาร", Type = "date", Tag = "header" },
                                    new { Icon = "ri-building-2-line", Label = "ชื่อผู้ส่งออก", Type = "text", Tag = "exporter" },
                                    new { Icon = "ri-map-pin-line", Label = "ที่อยู่ผู้ส่งออก", Type = "text", Tag = "exporter" },
                                    new { Icon = "ri-ship-line", Label = "เรือบรรทุก / ยานพาหนะ", Type = "text", Tag = "transport" },
                                    new { Icon = "ri-anchor-line", Label = "ท่าเรือต้นทาง", Type = "text", Tag = "transport" },
                                    new { Icon = "ri-flag-line", Label = "ท่าเรือปลายทาง", Type = "text", Tag = "transport" },
                                    new { Icon = "ri-fish-line", Label = "ชนิดสัตว์น้ำ (Species)", Type = "text", Tag = "product" },
                                    new { Icon = "ri-weight-line", Label = "น้ำหนักสุทธิ์ (Net Weight)", Type = "number", Tag = "product" },
                                    new { Icon = "ri-barcode-line", Label = "HS Code", Type = "text", Tag = "product" },
                                    new { Icon = "ri-user-star-line", Label = "ลายมือชื่อผู้รับรอง", Type = "signature", Tag = "footer" },
                                    new { Icon = "ri-seal-line", Label = "ตราประทับหน่วยงาน", Type = "image", Tag = "footer" },
                                };
                                var tagColorMap = new Dictionary<string, string> {
                                    { "header", "bg-label-primary" },
                                    { "exporter", "bg-label-info" },
                                    { "transport", "bg-label-warning" },
                                    { "product", "bg-label-success" },
                                    { "footer", "bg-label-secondary" },
                                };
                                foreach (var f in availableFields)
                                {
                                    var tagColor = tagColorMap.ContainsKey(f.Tag) ? tagColorMap[f.Tag] : "bg-label-secondary";
                                    <div class="field-item d-flex align-items-center gap-2">
                                        <i class="ri @f.Icon text-muted"></i>
                                        <span class="flex-grow-1 small">@f.Label</span>
                                        <span class="badge @tagColor" style="font-size:0.6rem;">@f.Tag</span>
                                        <button type="button" class="btn btn-xs btn-icon btn-outline-primary" title="เพิ่ม" style="width:1.3rem;height:1.3rem;">
                                            <i class="ri ri-add-line" style="font-size:0.7rem;"></i>
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                    <!-- Right: Selected fields / layout -->
                    <div class="col-md-8 p-3">
                        <p class="field-section-header mb-2">ช่องข้อมูลในใบรับรอง (ลำดับการแสดงผล)</p>
                        <div class="d-flex flex-column gap-2" id="fieldBuilderList">
                            @{
                                var selectedFields = new[]
                                {
                                    new { No = 1, Label = "เลขที่ใบรับรอง (HC Number)", Type = "text", Required = true, Section = "ส่วนหัว", SectionColor = "bg-label-primary" },
                                    new { No = 2, Label = "วันที่ออกเอกสาร", Type = "date", Required = true, Section = "ส่วนหัว", SectionColor = "bg-label-primary" },
                                    new { No = 3, Label = "ชื่อผู้ส่งออก", Type = "text", Required = true, Section = "ข้อมูลผู้ส่งออก", SectionColor = "bg-label-info" },
                                    new { No = 4, Label = "ที่อยู่ผู้ส่งออก", Type = "text", Required = false, Section = "ข้อมูลผู้ส่งออก", SectionColor = "bg-label-info" },
                                    new { No = 5, Label = "เรือบรรทุก / ยานพาหนะ", Type = "text", Required = true, Section = "ข้อมูลการขนส่ง", SectionColor = "bg-label-warning" },
                                    new { No = 6, Label = "ท่าเรือปลายทาง", Type = "text", Required = true, Section = "ข้อมูลการขนส่ง", SectionColor = "bg-label-warning" },
                                    new { No = 7, Label = "ชนิดสัตว์น้ำ (Species)", Type = "text", Required = true, Section = "ข้อมูลผลิตภัณฑ์", SectionColor = "bg-label-success" },
                                    new { No = 8, Label = "HS Code", Type = "text", Required = true, Section = "ข้อมูลผลิตภัณฑ์", SectionColor = "bg-label-success" },
                                    new { No = 9, Label = "น้ำหนักสุทธิ์ (Net Weight)", Type = "number", Required = true, Section = "ข้อมูลผลิตภัณฑ์", SectionColor = "bg-label-success" },
                                    new { No = 10, Label = "ลายมือชื่อผู้รับรอง", Type = "signature", Required = true, Section = "ส่วนท้าย", SectionColor = "bg-label-secondary" },
                                };
                                foreach (var sf in selectedFields)
                                {
                                    <div class="field-item d-flex align-items-center gap-2">
                                        <i class="ri ri-draggable field-drag-handle"></i>
                                        <span class="text-muted small" style="min-width:1.4rem;">@sf.No.</span>
                                        <span class="flex-grow-1 small fw-semibold">@sf.Label</span>
                                        <span class="badge @sf.SectionColor" style="font-size:0.6rem;">@sf.Section</span>
                                        <span class="badge bg-label-dark" style="font-size:0.6rem;">@sf.Type</span>
                                        @if (sf.Required)
                                        {
                                            <span class="badge bg-label-danger" style="font-size:0.6rem;">required</span>
                                        }
                                        @if (sf.Type == "signature")
                                        {
                                            <button type="button" class="btn btn-xs btn-outline-warning" title="ตั้งค่าลายมือชื่อ"
                                                id="btnSigConfig" aria-expanded="true" aria-controls="sigConfigPanel"
                                                style="font-size:0.65rem;padding:1px 5px;">
                                                <i class="ri ri-pen-nib-line me-1"></i>ตั้งค่า
                                            </button>
                                        }
                                        <button type="button" class="btn btn-xs btn-icon btn-outline-danger" title="ลบออก" style="width:1.3rem;height:1.3rem;">
                                            <i class="ri ri-close-line" style="font-size:0.7rem;"></i>
                                        </button>
                                    </div>
                                    @if (sf.Type == "signature")
                                    {
                                        <!-- Sub-panel: ตั้งค่าลายมือชื่อ -->
                                        <div id="sigConfigPanel" class="border rounded p-3 ms-4 mt-1" style="background:#fefce8;border-color:#f59e0b!important;">
                                            <div class="d-flex align-items-center gap-2 mb-3">
                                                <i class="ri ri-pen-nib-line text-warning"></i>
                                                <span class="fw-semibold small">ตั้งค่าลายมือชื่ออิเล็กทรอนิกส์</span>
