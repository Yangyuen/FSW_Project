            if (!fromVal) { previewDiv.classList.add('d-none'); return; }
            var fromDisplay = isoToThaiDisplay(fromVal);
            var toDisplay   = toVal ? isoToThaiDisplay(toVal) : 'ไม่มีกำหนดสิ้นสุด';
            previewText.textContent = 'รูปแบบนี้ใช้งานได้ตั้งแต่ ' + fromDisplay + ' ถึง ' + toDisplay;
            previewDiv.classList.remove('d-none');
        }

        // Render history table
        function renderProdModeHistory(id) {
            var history = prodModeHistoryMap[id] || [];
            var tbody = document.getElementById('setModeHistoryTableBody');
            var activeEntry = history.find(function (h) { return h.active; });

            // Update "ใช้งานอยู่ตั้งแต่" badge
            var currentBadge = document.getElementById('setModeHistoryCurrentBadge');
            if (activeEntry) {
                currentBadge.innerHTML = '<i class="ri ri-checkbox-circle-line me-1"></i>ใช้งานอยู่ตั้งแต่ ' + activeEntry.from;
                currentBadge.classList.remove('d-none');
            } else {
                currentBadge.classList.add('d-none');
            }

            if (!history.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">ยังไม่มีประวัติการกำหนดรูปแบบ</td></tr>';
                return;
            }
            tbody.innerHTML = history.map(function (h, i) {
                var modeBadge;
                if (h.mode === 'อัตโนมัติหลังการตรวจปล่อย') {
                    modeBadge = '<span class="badge" style="background-color:rgba(115,103,240,0.16);color:#7367f0;font-size:0.7rem;">' + h.mode + '</span>';
                } else if (h.mode === 'อัตโนมัติทั้งกระบวนการ') {
                    modeBadge = '<span class="badge bg-label-success" style="font-size:0.7rem;">' + h.mode + '</span>';
                } else if (h.mode === 'อัตโนมัติหลังรับคำขอ') {
                    modeBadge = '<span class="badge bg-label-info" style="font-size:0.7rem;">' + h.mode + '</span>';
                } else {
                    modeBadge = '<span class="badge bg-label-warning" style="font-size:0.7rem;">' + h.mode + '</span>';
                }
                var statusBadge = h.active
                    ? '<span class="badge bg-success rounded-pill"><i class="ri ri-checkbox-circle-line me-1"></i>มีผล</span>'
                    : '<span class="badge bg-label-secondary rounded-pill">หมดอายุ</span>';
                var dateRange = h.from + (h.to && h.to !== '—' ? ' — ' + h.to : ' — ปัจจุบัน');
                return '<tr' + (h.active ? ' class="table-success"' : '') + '>' +
                    '<td class="text-center text-muted">' + (i + 1) + '</td>' +
                    '<td class="text-nowrap"><small>' + dateRange + '</small></td>' +
                    '<td>' + modeBadge + '</td>' +
                    '<td class="text-nowrap"><small>' + h.setBy + '</small></td>' +
                    '<td><small class="text-muted">' + (h.note || '—') + '</small></td>' +
                    '<td class="text-center">' + statusBadge + '</td>' +
                    '</tr>';
            }).join('');
        }

        document.getElementById('modalSetProductionMode').addEventListener('show.bs.modal', function (e) {
            var btn  = e.relatedTarget;
            var id   = btn ? parseInt(btn.dataset.id || '1') : 1;
            var name = btn ? (btn.dataset.name || '') : '';
            currentModeTemplateId   = id;
            currentModeTemplateName = name;

            document.getElementById('setModeTemplateName').textContent = name;

            // Reset to first tab
            var configTabBtn = document.getElementById('setModeTab-config-tab');
            if (configTabBtn) { new bootstrap.Tab(configTabBtn).show(); }

            // Reset form
            document.querySelectorAll('input[name="setMode_radio"]').forEach(function (r) { r.checked = false; });
            document.getElementById('setMode_officerSection').classList.add('d-none');
            document.getElementById('setMode_effectiveFrom').value = '';
            document.getElementById('setMode_effectiveTo').value   = '';
            document.getElementById('setMode_note').value          = '';
            document.getElementById('setMode_effectiveFrom').classList.remove('is-invalid');
            document.getElementById('setMode_datePreview').classList.add('d-none');

            // Pre-fill from mockup data
            var data = productionModeData[id];
            if (data) {
                var radio = document.querySelector('input[name="setMode_radio"][value="' + data.mode + '"]');
                if (radio) {
                    radio.checked = true;
                    if (data.mode === 'เจ้าหน้าที่จัดทำ') {
                        document.getElementById('setMode_officerSection').classList.remove('d-none');
                        if (data.officer) { document.getElementById('setMode_officer').value = data.officer; }
                    }
                }
                document.getElementById('setMode_effectiveFrom').value = buddhistToIso(data.from);
                document.getElementById('setMode_effectiveTo').value   = buddhistToIso(data.to);
                document.getElementById('setMode_note').value          = data.note || '';
                updateDatePreview();
            }

            // Populate history table
            renderProdModeHistory(id);
        });

        // Date change → update preview
        document.getElementById('setMode_effectiveFrom').addEventListener('change', updateDatePreview);
        document.getElementById('setMode_effectiveTo').addEventListener('change', updateDatePreview);

        // Show/hide officer section on radio change
        document.querySelectorAll('input[name="setMode_radio"]').forEach(function (r) {
            r.addEventListener('change', function () {
                document.getElementById('setMode_officerSection').classList.toggle('d-none', this.value !== 'เจ้าหน้าที่จัดทำ');
            });
        });

        // Save
        document.getElementById('btnSaveProductionMode').addEventListener('click', function () {
            var selected = document.querySelector('input[name="setMode_radio"]:checked');
            var from     = document.getElementById('setMode_effectiveFrom').value;
            if (!selected) {
                showTemplateToast('warning', 'กรุณาเลือกรูปแบบการจัดทำ');
                return;
            }
            if (!from) {
                document.getElementById('setMode_effectiveFrom').classList.add('is-invalid');
                return;
            }
            document.getElementById('setMode_effectiveFrom').classList.remove('is-invalid');
            bootstrap.Modal.getInstance(document.getElementById('modalSetProductionMode')).hide();
            showTemplateToast('success', '"' + currentModeTemplateName + '" กำหนดรูปแบบการจัดทำเป็น "' + selected.value + '" เรียบร้อยแล้ว');
        });

        // Cancel mode → open confirm modal
        document.getElementById('btnCancelProductionMode').addEventListener('click', function () {
            document.getElementById('confirmCancelModeName').textContent = currentModeTemplateName;
            var setModeModal = bootstrap.Modal.getInstance(document.getElementById('modalSetProductionMode'));
            document.getElementById('modalSetProductionMode').addEventListener('hidden.bs.modal', function () {
                bootstrap.Modal.getOrCreateInstance(document.getElementById('modalConfirmCancelMode')).show();
            }, { once: true });
            if (setModeModal) { setModeModal.hide(); }
        });

        // Confirm cancel mode
        document.getElementById('btnConfirmCancelMode').addEventListener('click', function () {
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmCancelMode')).hide();
            showTemplateToast('warning', '"' + currentModeTemplateName + '" ยกเลิกรูปแบบการจัดทำแล้ว — กรุณากำหนดรูปแบบใหม่');
        });
        // ─────────────────────────────────────────────────────────────────────────
    });
</script>
}