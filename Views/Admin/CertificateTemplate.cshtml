@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {

        // ── Toast helper ──
        function showTemplateToast(type, message) {
            var toastEl = document.getElementById('templateActionToast');
            var body    = document.getElementById('templateToastBody');
            toastEl.className = 'toast align-items-center border-0 text-white';
            if (type === 'success') { toastEl.classList.add('bg-success'); }
            else if (type === 'warning') { toastEl.classList.add('bg-warning'); }
            else if (type === 'danger')  { toastEl.classList.add('bg-danger');  }
            else { toastEl.classList.add('bg-secondary'); }
            body.textContent = message;
            bootstrap.Toast.getOrCreateInstance(toastEl, { delay: 4000 }).show();
        }

        // ── Tooltips ──
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // ── Filter logic ──
        function filterRows() {
            var type    = (document.getElementById('filterType').value || '').trim();
            var country = (document.getElementById('filterCountry').value || '').trim().toLowerCase();
            var status  = (document.getElementById('filterStatus').value || '').trim();
            var rows    = document.querySelectorAll('#templateTableBody tr[data-type]');
            var visible = 0;

            rows.forEach(function (row) {
                var typeMatch    = !type    || row.dataset.type    === type;
                var countryMatch = !country || row.dataset.country.includes(country);
                var statusMatch  = !status  || row.dataset.status  === status;
                var show = typeMatch && countryMatch && statusMatch;
                row.classList.toggle('d-none', !show);
                if (show) { visible++; }
            });

            document.getElementById('templateTableEmpty').classList.toggle('d-none', visible !== 0);
        }

        document.getElementById('btnSearchTemplates').addEventListener('click', filterRows);
        document.getElementById('filterType').addEventListener('change', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);
        document.getElementById('filterCountry').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { filterRows(); }
        });

        document.getElementById('btnResetTemplates').addEventListener('click', function () {
            document.getElementById('filterType').value    = '';
            document.getElementById('filterCountry').value = '';
            document.getElementById('filterStatus').value  = '';
            filterRows();
