            // Convert Buddhist ISO date (already Buddhist year) to display string
            function isoToDisplayDate(iso) {
                var parts = iso.split('-');
                if (parts.length !== 3) { return iso; }
                return parts[2] + '/' + parts[1] + '/' + parts[0];
            }
            el.innerHTML = '<span class="badge bg-label-success" style="font-size:0.6rem;">' +
                '<i class="ri ri-checkbox-circle-line me-1"></i>ใช้งานอยู่ตั้งแต่ ' + isoToDisplayDate(d.from) + '</span>';
        });

        // Helper: ISO Gregorian → Buddhist Thai display
        function isoToThaiDisplay(iso) {
            if (!iso) { return ''; }
            var parts = iso.split('-');
            if (parts.length !== 3) { return iso; }
            var buddhistYear = parseInt(parts[0]) + 543;
            return parts[2] + '/' + parts[1] + '/' + buddhistYear;
        }
        // Helper: Buddhist ISO → Gregorian ISO
        function buddhistToIso(d) {
            if (!d) { return ''; }
            var parts = d.split('-');
            if (parts.length !== 3) { return d; }
            return (parseInt(parts[0]) - 543) + '-' + parts[1] + '-' + parts[2];
        }

