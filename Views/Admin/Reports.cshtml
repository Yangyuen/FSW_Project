        }).join('');
    }

    // Collect active search condition chips
    function buildFilterChips() {
        var chips = [];
        var speciesEl = document.getElementById('srchSpecies');
        if (speciesEl && speciesEl.value) { chips.push('ชนิด: ' + speciesEl.options[speciesEl.selectedIndex].text); }
        var qtyMin = (document.getElementById('srchQtyMin').value || '').trim();
        var qtyMax = (document.getElementById('srchQtyMax').value || '').trim();
        if (qtyMin || qtyMax) { chips.push('ปริมาณ: ' + (qtyMin || '0') + '–' + (qtyMax || '∞') + ' kg'); }
        var sourceEl = document.getElementById('srchSource');
        if (sourceEl && sourceEl.value) { chips.push('แหล่งที่มา: ' + sourceEl.options[sourceEl.selectedIndex].text); }
        var opEl = document.getElementById('srchOperator');
        if (opEl && opEl.value) { chips.push('โรงงาน: ' + opEl.options[opEl.selectedIndex].text.substring(0, 28) + '...'); }
        var agEl = document.getElementById('srchAgency');
        if (agEl && agEl.value) { chips.push('หน่วยงาน: ' + agEl.options[agEl.selectedIndex].text); }
        var dFrom = (document.getElementById('srchDateFrom').value || '').trim();
        var dTo   = (document.getElementById('srchDateTo').value   || '').trim();
        if (dFrom || dTo) { chips.push('วันที่: ' + (dFrom || '-') + ' ถึง ' + (dTo || '-')); }
        return chips;
    }

    function openViewer(rc) {
        var d = viewerDataMap[rc];
        if (!d) { showRptToast('warning', 'ไม่พบข้อมูลตัวอย่างสำหรับรายงานนี้'); return; }
        document.getElementById('viewerTitle').textContent = d.title;
        document.getElementById('viewerSummary').textContent = d.summary;
        renderViewerTable(d.columns, d.rows);
        // Bar chart (ST-007: %Yield, ST-012: country export)
        var chartSection = document.getElementById('viewerChartSection');
        var chartTitleEl = document.getElementById('viewerChartTitle');
        var chartLegendEl = document.getElementById('viewerChartLegend');
        if (d.chartType === 'country' && d.chartData) {
            var maxIn = Math.max.apply(null, d.chartData.map(function(i){ return i.rawIn; }));
            var barsHtml = d.chartData.map(function(item) {
                var pctIn  = Math.round(item.rawIn  / maxIn * 100);
                var pctOut = Math.round(item.rawOut / maxIn * 100);
                var inLabel  = (item.rawIn  / 1000).toFixed(0) + ',000 kg';
                var outLabel = (item.rawOut / 1000).toFixed(0) + ',000 kg';
                return '<div class="mb-3">' +
                    '<div class="d-flex justify-content-between mb-1"><span class="small fw-semibold">' + item.label + '</span>' +
                    '<span class="small text-muted fw-bold">' + inLabel + '</span></div>' +
                    '<div class="d-flex gap-1 align-items-center mb-1">' +
                    '<span class="small text-muted" style="width:120px;">วัตถุดิบนำเข้า</span>' +
                    '<div class="progress flex-grow-1" style="height:14px;"><div class="progress-bar" style="width:' + pctIn + '%;background:#696cff;">' + pctIn + '%</div></div>' +
                    '</div>' +
                    '<div class="d-flex gap-1 align-items-center">' +
                    '<span class="small text-muted" style="width:120px;">สุทธิส่งออก</span>' +
                    '<div class="progress flex-grow-1" style="height:14px;"><div class="progress-bar" style="width:' + pctOut + '%;background:#71dd37;">' + outLabel + '</div></div>' +
                    '</div></div>';
            }).join('');
            document.getElementById('viewerChartBars').innerHTML = barsHtml;
            if (chartTitleEl) chartTitleEl.textContent = 'กราฟสรุปประเทศที่ส่งออกมากที่สุด 5 อันดับ (เรียงตามน้ำหนักวัตถุดิบ)';
            if (chartLegendEl) chartLegendEl.innerHTML = '<span class="badge me-1" style="background:#696cff;">&nbsp;&nbsp;&nbsp;</span><span class="small me-3">น้ำหนักวัตถุดิบนำเข้า</span>' +
                '<span class="badge me-1" style="background:#71dd37;">&nbsp;&nbsp;&nbsp;</span><span class="small">น้ำหนักสุทธิสินค้าส่งออก</span>';
            chartSection.classList.remove('d-none');
        } else if (d.chartType === 'waste' && d.chartData) {
            var barsHtml = d.chartData.map(function(item) {
                var pct = item.wastePct;
                return '<div class="mb-3">' +
                    '<div class="d-flex justify-content-between mb-1"><span class="small fw-semibold">' + item.label + '</span>' +
                    '<span class="small fw-bold" style="color:#ffab00;">' + pct.toFixed(1) + '%</span></div>' +
                    '<div class="d-flex gap-1 align-items-center">' +
                    '<span class="small text-muted" style="width:130px;">%เศษเหลือ</span>' +
                    '<div class="progress flex-grow-1" style="height:18px;"><div class="progress-bar" style="width:' + pct + '%;background:#ffab00;">' + pct.toFixed(1) + '%</div></div>' +
                    '</div></div>';
            }).join('');
            document.getElementById('viewerChartBars').innerHTML = barsHtml;
            if (chartTitleEl) chartTitleEl.textContent = 'กราฟสัดส่วน %เศษเหลือจากกระบวนการผลิต แยกตามชนิดสัตว์น้ำ';
            if (chartLegendEl) chartLegendEl.innerHTML = '<span class="badge me-1" style="background:#ffab00;">&nbsp;&nbsp;&nbsp;</span><span class="small">%เศษเหลือ (วัตถุดิบรับเข้า − สินค้าสำเร็จรูป)</span>';
            chartSection.classList.remove('d-none');
        } else if (d.chartData) {
            var barsHtml = d.chartData.map(function(item) {
                var diff = item.req - item.approved;
                var diffLabel = diff > 0 ? '−' + diff + '%' : (diff < 0 ? '+' + Math.abs(diff) + '%' : '0%');
                var diffCls = diff > 0 ? 'text-danger' : (diff < 0 ? 'text-success' : 'text-muted');
                return '<div class="mb-3">' +
                    '<div class="d-flex justify-content-between mb-1"><span class="small fw-semibold">' + item.label + '</span>' +
                    '<span class="small ' + diffCls + ' fw-bold">' + diffLabel + '</span></div>' +
                    '<div class="d-flex gap-1 align-items-center mb-1">' +
                    '<span class="small text-muted" style="width:90px;">ที่ขอ</span>' +
                    '<div class="progress flex-grow-1" style="height:14px;"><div class="progress-bar" style="width:' + item.req + '%;background:#696cff;">' + item.req + '%</div></div>' +
                    '</div>' +
                    '<div class="d-flex gap-1 align-items-center">' +
                    '<span class="small text-muted" style="width:90px;">อนุมัติ</span>' +
                    '<div class="progress flex-grow-1" style="height:14px;"><div class="progress-bar" style="width:' + item.approved + '%;background:#71dd37;">' + item.approved + '%</div></div>' +
                    '</div></div>';
            }).join('');
            document.getElementById('viewerChartBars').innerHTML = barsHtml;
            if (chartTitleEl) chartTitleEl.textContent = 'กราฟเปรียบเทียบ %Yield ที่ขอ vs ที่อนุมัติ';
            if (chartLegendEl) chartLegendEl.innerHTML = '<span class="badge me-1" style="background:#696cff;">&nbsp;&nbsp;&nbsp;</span><span class="small me-3">%Yield ที่ขอ</span>' +
                '<span class="badge me-1" style="background:#71dd37;">&nbsp;&nbsp;&nbsp;</span><span class="small">%Yield ที่อนุมัติ</span>';
            chartSection.classList.remove('d-none');
        } else {
            chartSection.classList.add('d-none');
        }
        var chips = buildFilterChips();
        var filterDiv = document.getElementById('viewerFilterSummary');
        if (chips.length > 0) {
            filterDiv.innerHTML = '<span class="text-muted small me-1">เงื่อนไข:</span>' +
                chips.map(function(c) { return '<span class="badge bg-label-primary srch-chip">' + c + '</span>'; }).join('');
        } else {
            filterDiv.innerHTML = '<span class="text-muted small me-1">เงื่อนไข:</span><span class="badge bg-label-secondary srch-chip">ทั้งหมด (ไม่ระบุเงื่อนไข)</span>';
        }
        bootstrap.Modal.getOrCreateInstance(document.getElementById('rptViewerModal')).show();
    }

    function resetSearchCond() {
        ['srchSpecies','srchSource','srchOperator','srchAgency'].forEach(function(id) {
            var el = document.getElementById(id); if (el) { el.selectedIndex = 0; }
        });
        ['srchQtyMin','srchQtyMax'].forEach(function(id) {
            var el = document.getElementById(id); if (el) { el.value = ''; }
        });
        ['srchDateFrom','srchDateTo'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el && el._flatpickr) { el._flatpickr.clear(); } else if (el) { el.value = ''; }
        });
    }

