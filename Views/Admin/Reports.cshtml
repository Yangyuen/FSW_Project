                                <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-rpt-detail" data-rc="@r.ReportCode" title="รายละเอียด" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-eye-line text-info"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-rpt-detail" data-rc="@r.ReportCode" title="แก้ไข" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-pencil-line text-warning"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="รีเฟรช" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-refresh-line text-secondary"></i></button>
