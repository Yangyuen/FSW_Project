    // Render viewer table
    function renderViewerTable(cols, rows) {
        var thead = document.getElementById('viewerTableHead');
        var tbody = document.getElementById('viewerTableBody');
        thead.innerHTML = '<tr>' + cols.map(function(c) { return '<th class="text-nowrap">' + c + '</th>'; }).join('') + '</tr>';
        tbody.innerHTML = rows.map(function(row) {
