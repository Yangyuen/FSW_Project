@section PageStyles {
<style>
    .trace-table-compact {
        font-size: 0.78rem;
    }

    .trace-table-compact th,
    .trace-table-compact td {
        padding: 0.45rem 0.5rem;
        vertical-align: middle;
        line-height: 1.3;
        white-space: normal;
        word-break: break-word;
    }

    .trace-table-compact thead th {
        white-space: normal;
        word-break: keep-all;
        overflow-wrap: normal;
    }

    .trace-table-compact .badge {
        font-size: 0.68rem;
    }

    .trace-table-compact .btn.btn-sm {
        --bs-btn-padding-y: 0.14rem;
        --bs-btn-padding-x: 0.3rem;
    }

    .trace-table-compact .btn-icon {
        width: 1.65rem;
        height: 1.65rem;
    }

    .filter-action-buttons .btn-square {
        width: 48px;
        height: 48px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .detail-kv {
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        background: var(--bs-paper-bg);
        padding: 0.85rem 1rem;
        height: 100%;
    }

    .detail-kv .label {
        display: block;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        margin-bottom: 0.25rem;
    }

    .detail-kv .value {
        font-weight: 600;
        color: var(--bs-heading-color);
    }
</style>
}

