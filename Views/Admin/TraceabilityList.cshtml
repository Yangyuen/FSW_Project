        width: 48px;
        height: 48px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .detail-kv {
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        background: var(--bs-paper-bg);
