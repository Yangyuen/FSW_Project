        function filterRows() {
            var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
            var province = (document.getElementById('filterProvince').value || '').trim();
            var status = (document.getElementById('filterStatus').value || '').trim();
            var risk = (document.getElementById('filterRisk').value || '').trim();
            var rows = document.querySelectorAll('#traceTableBody tr[data-trace-code]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowText = (row.dataset.searchText || '').toLowerCase();
                var rowProvince = row.dataset.province || '';
                var rowStatus = row.dataset.status || '';
                var rowRisk = row.dataset.risk || '';
                var keywordMatch = !keyword || rowText.includes(keyword);
                var provinceMatch = !province || rowProvince === province;
                var statusMatch = !status || rowStatus === status;
                var riskMatch = !risk || rowRisk === risk;
                var isVisible = keywordMatch && provinceMatch && statusMatch && riskMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('traceTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        function renderRows(items, columns, emptyMessage, rowType) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="' + columns + '" class="text-center text-muted py-3">' + emptyMessage + '</td></tr>';
            }

            if (rowType === 'chain') {
                return items.map(function (item, index) {
                    var statusClass = item.status === 'ครบถ้วน' ? 'bg-label-success' : item.status === 'บางส่วน' ? 'bg-label-warning' : 'bg-label-danger';
                    return '<tr>' +
                        '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                        '<td>' + item.name + '</td>' +
                        '<td>' + item.document + '</td>' +
                        '<td class="text-center"><span class="badge rounded-pill ' + statusClass + '">' + item.status + '</span></td>' +
                        '<td>' + item.owner + '</td>' +
                        '</tr>';
                }).join('');
            }

            return items.map(function (item, index) {
                var resultClass = item.result === 'ผ่าน' ? 'bg-label-success' : item.result === 'ผ่านแบบมีข้อสังเกต' ? 'bg-label-warning' : 'bg-label-danger';
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.date + '</td>' +
                    '<td class="text-center"><span class="badge rounded-pill ' + resultClass + '">' + item.result + '</span></td>' +
                    '<td>' + item.officer + '</td>' +
                    '<td>' + item.remark + '</td>' +
                    '</tr>';
            }).join('');
        }

        function renderStatusLogRows(items) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="6" class="text-center text-muted py-3">ไม่พบประวัติการเปลี่ยนสถานะ</td></tr>';
            }
            return items.map(function (item, index) {
                var fromHtml = item.fromStatus === '-' ? '<span class="text-muted">—</span>' :
                    '<span class="badge rounded-pill bg-label-secondary">' + item.fromStatus + '</span>';
                var toClass = item.toStatus === 'ผ่านการตรวจสอบ' ? 'bg-label-success' :
                    item.toStatus === 'ผ่านแบบมีข้อสังเกต' ? 'bg-label-warning' :
                    item.toStatus === 'ระงับชั่วคราว' ? 'bg-label-danger' :
                    item.toStatus === 'ยกเลิกแล้ว' ? 'bg-label-secondary' :
                    item.toStatus === 'รอตรวจซ้ำ' ? 'bg-label-info' : 'bg-label-secondary';
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.date + '</td>' +
                    '<td>' + fromHtml + '</td>' +
                    '<td><span class="badge rounded-pill ' + toClass + '">' + item.toStatus + '</span></td>' +
                    '<td>' + item.reason + '</td>' +
                    '<td>' + item.officer + '</td>' +
                    '</tr>';
            }).join('');
        }

        function openTraceDetail(traceCode) {
            var detail = detailsMap[traceCode];
            var row = document.querySelector('#traceTableBody tr[data-trace-code="' + traceCode + '"]');
            if (!detail || !row) {
                return;
            }

            document.getElementById('traceModalTitle').textContent = row.dataset.factoryName;
            document.getElementById('detailTraceCode').textContent = traceCode;
            document.getElementById('detailFactoryCode').textContent = row.dataset.factoryCode;
            document.getElementById('detailFactoryNameTH').textContent = row.dataset.factoryName;
            document.getElementById('detailFactoryNameEN').textContent = row.dataset.factoryNameEn;
            var branchCode = row.dataset.branchCode || '00000';
            var branchLabel = branchCode === '00000' ? branchCode + ' (สำนักงานใหญ่)' : branchCode + ' (สาขา ' + parseInt(branchCode, 10) + ')';
            document.getElementById('detailTaxId').textContent = row.dataset.taxId;
            document.getElementById('detailBranchCode').textContent = branchLabel;
            document.getElementById('detailEstablishmentNo').textContent = row.dataset.establishmentNo;
            document.getElementById('detailApprovalNumber').textContent = row.dataset.approvalNumber;
            var dofRef = row.dataset.dofRefNumber || '-';
            document.getElementById('detailDofRefNumber').innerHTML = dofRef !== '-'
                ? '<a href="/Admin/DofList" class="text-primary fw-semibold">' + dofRef + '</a>'
                : '-';
            document.getElementById('detailProvince').textContent = row.dataset.province;
            document.getElementById('detailProductGroup').textContent = row.dataset.productGroup;
            document.getElementById('detailTraceLevel').textContent = row.dataset.traceLevel;
            document.getElementById('detailSupplierCount').textContent = row.dataset.supplierCount + ' ราย';
            document.getElementById('detailRisk').textContent = row.dataset.risk;
            document.getElementById('detailStatus').innerHTML = '<span class="badge rounded-pill ' + row.dataset.statusClass + '">' + row.dataset.status + '</span>';
            document.getElementById('detailRegisterDate').textContent = detail.registerDate;
            document.getElementById('detailNextReviewDate').textContent = detail.nextReviewDate;
            document.getElementById('detailPhone').textContent = detail.phone;
            document.getElementById('detailFax').textContent = detail.fax;
            document.getElementById('detailEmail').textContent = detail.email;
            document.getElementById('detailAddress').textContent = detail.address;
            document.getElementById('detailAddressEN').textContent = detail.addressEN;
            document.getElementById('detailNote').textContent = detail.note;
            document.getElementById('chainTableBody').innerHTML = renderRows(detail.chainSteps, 5, 'ไม่พบข้อมูลขั้นตอน traceability', 'chain');
            document.getElementById('auditTableBody').innerHTML = renderRows(detail.audits, 5, 'ไม่พบประวัติการตรวจ', 'audit');
            document.getElementById('statusLogTableBody').innerHTML = renderStatusLogRows(detail.statusLogs);

            new bootstrap.Modal(document.getElementById('traceDetailModal')).show();
        }

        document.getElementById('btnSearchTrace').addEventListener('click', filterRows);
        document.getElementById('btnResetTrace').addEventListener('click', function () {
            document.getElementById('filterKeyword').value = '';
            document.getElementById('filterProvince').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterRisk').value = '';
            filterRows();
        });

        document.querySelectorAll('#filterKeyword, #filterProvince, #filterStatus, #filterRisk').forEach(function (element) {
            element.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    filterRows();
                }
            });
            element.addEventListener('change', filterRows);
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        document.querySelectorAll('.btn-view-trace, .btn-edit-trace').forEach(function (button) {
            button.addEventListener('click', function () {
                openTraceDetail(this.dataset.traceCode);
            });
        });

        document.querySelectorAll('.btn-suspend-trace').forEach(function (button) {
            button.addEventListener('click', function () {
                document.getElementById('suspendTraceFactoryName').textContent = this.dataset.factoryName;
                document.getElementById('suspendTraceCodeHidden').value = this.dataset.traceCode;
                document.getElementById('suspendTraceDate').value = '2026-04-27';
                document.getElementById('suspendTraceReason').value = '';
                new bootstrap.Modal(document.getElementById('traceSuspendModal')).show();
            });
        });

        document.querySelectorAll('.btn-cancel-trace').forEach(function (button) {
            button.addEventListener('click', function () {
                document.getElementById('cancelTraceFactoryName').textContent = this.dataset.factoryName;
                document.getElementById('cancelTraceCodeHidden').value = this.dataset.traceCode;
                document.getElementById('cancelTraceDate').value = '2026-04-27';
                document.getElementById('cancelTraceReason').value = '';
                new bootstrap.Modal(document.getElementById('traceCancelModal')).show();
            });
        });

        function doTraceExport(label, count) {
            var toast = document.getElementById('traceActionToast');
            var toastBody = document.getElementById('traceToastBody');
            toast.className = 'toast align-items-center bg-label-info border-0';
            toastBody.textContent = 'กำลัง Export Excel (' + label + ')...';
            new bootstrap.Toast(toast, { delay: 900 }).show();
            setTimeout(function () {
                toast.className = 'toast align-items-center bg-label-success border-0';
                if (label === 'สรุปตามระดับ Traceability') {
                    toastBody.textContent = 'Export Excel สรุประดับ Traceability สำเร็จ';
                } else {
                    toastBody.textContent = 'Export Excel สำเร็จ ' + count + ' รายการ (' + label + ')';
                }
                new bootstrap.Toast(toast, { delay: 2500 }).show();
            }, 950);
        }

        document.querySelectorAll('.btn-export-trace').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                var exportType = this.dataset.exportType;
                var allRows = document.querySelectorAll('#traceTableBody tr[data-trace-code]');
                var visibleRows = Array.from(allRows).filter(function (r) { return !r.classList.contains('d-none'); });
                var checkedRows = document.querySelectorAll('#traceTableBody .trace-row-check:checked');
                if (exportType === 'all') {
                    doTraceExport('ทั้งหมด', allRows.length);
                } else if (exportType === 'filtered') {
                    doTraceExport('เฉพาะที่กรอง', visibleRows.length);
                } else if (exportType === 'selected') {
                    if (checkedRows.length === 0) {
                        var toast = document.getElementById('traceActionToast');
                        var toastBody = document.getElementById('traceToastBody');
                        toast.className = 'toast align-items-center bg-label-warning border-0';
                        toastBody.textContent = 'กรุณาเลือกรายการก่อน Export';
                        new bootstrap.Toast(toast, { delay: 2500 }).show();
                        return;
                    }
                    doTraceExport('เฉพาะที่เลือก', checkedRows.length);
                } else if (exportType === 'summary') {
                    doTraceExport('สรุปตามระดับ Traceability', 0);
                }
            });
        });

        document.getElementById('traceSelectAll').addEventListener('change', function () {
            document.querySelectorAll('#traceTableBody .trace-row-check').forEach(function (c) {
                c.checked = document.getElementById('traceSelectAll').checked;
            });
        });
    });

    /* --- Import wizard JS --- */
    document.addEventListener('DOMContentLoaded', function () {
        var traceImportStep = 1;
        var traceTotalSteps = 4;

        function setTraceImportStep(step) {
            traceImportStep = step;
            for (var i = 1; i <= traceTotalSteps; i++) {
                var el = document.getElementById('traceImportStep' + i);
                if (el) el.classList.toggle('d-none', i !== step);
            }
            document.querySelectorAll('#traceImportStepIndicator .import-step').forEach(function (el) {
                var s = parseInt(el.dataset.step, 10);
                el.classList.toggle('active', s === step);
                el.classList.toggle('done', s < step);
            });
            var prevBtn = document.getElementById('btnTraceImportPrev');
            var nextBtn = document.getElementById('btnTraceImportNext');
            prevBtn.classList.toggle('d-none', step === 1);
            if (step === traceTotalSteps) {
                nextBtn.innerHTML = '<i class="ri ri-check-line me-1"></i>ยืนยันนำเข้า';
            } else {
                nextBtn.innerHTML = '<i class="ri ri-arrow-right-line me-1"></i>ถัดไป';
            }
        }

        var traceImportModal = document.getElementById('traceImportModal');
        if (traceImportModal) {
            traceImportModal.addEventListener('show.bs.modal', function () {
                setTraceImportStep(1);
                document.getElementById('traceImportProgressArea').classList.add('d-none');
                document.getElementById('traceImportSuccessMsg').classList.add('d-none');
                document.getElementById('traceImportProgressBar').style.width = '0%';
                document.getElementById('traceImportFileInfo').classList.add('d-none');
                document.getElementById('traceImportFileError').classList.add('d-none');
                var fi = document.getElementById('traceImportFileInput');
                if (fi) fi.value = '';
                var nb = document.getElementById('btnTraceImportNext');
                nb.disabled = false;
                nb.onclick = null;
                nb.innerHTML = '<i class="ri ri-arrow-right-line me-1"></i>ถัดไป';
            });
        }

        var nextBtn = document.getElementById('btnTraceImportNext');
        if (nextBtn) {
            nextBtn.addEventListener('click', function () {
                if (traceImportStep === 2) {
                    var fi = document.getElementById('traceImportFileInput');
                    var errEl = document.getElementById('traceImportFileError');
                    errEl.classList.add('d-none');
                    if (!fi.files || fi.files.length === 0) {
                        errEl.textContent = 'กรุณาเลือกไฟล์ก่อนดำเนินการต่อ';
                        errEl.classList.remove('d-none');
                        return;
                    }
                    var f = fi.files[0];
                    if (f.size > 5 * 1024 * 1024) {
                        errEl.textContent = 'ไฟล์มีขนาดเกิน 5 MB กรุณาเลือกไฟล์ใหม่';
                        errEl.classList.remove('d-none');
                        return;
                    }
                    var ext = f.name.split('.').pop().toLowerCase();
                    if (ext !== 'xlsx' && ext !== 'csv') {
                        errEl.textContent = 'รองรับเฉพาะไฟล์ .xlsx และ .csv เท่านั้น';
                        errEl.classList.remove('d-none');
                        return;
                    }
                }
                if (traceImportStep === traceTotalSteps) {
                    var progressArea = document.getElementById('traceImportProgressArea');
                    var progressBar = document.getElementById('traceImportProgressBar');
                    var successMsg = document.getElementById('traceImportSuccessMsg');
                    progressArea.classList.remove('d-none');
                    successMsg.classList.add('d-none');
                    nextBtn.disabled = true;
                    var pct = 0;
                    var iv = setInterval(function () {
                        pct += 20;
                        progressBar.style.width = pct + '%';
                        if (pct >= 100) {
                            clearInterval(iv);
                            progressArea.classList.add('d-none');
                            successMsg.classList.remove('d-none');
                            nextBtn.disabled = false;
                            nextBtn.innerHTML = '<i class="ri ri-close-line me-1"></i>ปิด';
                            nextBtn.onclick = function () {
                                bootstrap.Modal.getInstance(document.getElementById('traceImportModal')).hide();
                            };
                        }
                    }, 250);
                    return;
                }
                setTraceImportStep(traceImportStep + 1);
            });
        }

        var prevBtn2 = document.getElementById('btnTraceImportPrev');
        if (prevBtn2) {
            prevBtn2.addEventListener('click', function () {
                if (traceImportStep > 1) setTraceImportStep(traceImportStep - 1);
            });
        }

        var dlBtn = document.getElementById('btnTraceDownloadTemplate');
        if (dlBtn) {
            dlBtn.addEventListener('click', function () {
                var toastEl = document.getElementById('traceActionToast');
                var toastBody = document.getElementById('traceToastBody');
                toastBody.textContent = 'ดาวน์โหลด Trace_Import_Template.xlsx เรียบร้อยแล้ว';
                toastEl.className = 'toast align-items-center bg-label-success border-0';
                new bootstrap.Toast(toastEl, { delay: 2500 }).show();
            });
        }

        var fileInput = document.getElementById('traceImportFileInput');
        if (fileInput) {
            fileInput.addEventListener('change', function () {
                var errEl = document.getElementById('traceImportFileError');
                var infoEl = document.getElementById('traceImportFileInfo');
                errEl.classList.add('d-none');
                if (this.files && this.files.length > 0) {
                    var f = this.files[0];
                    var sizeKB = (f.size / 1024).toFixed(1);
                    document.getElementById('traceImportFileName').textContent = f.name;
                    document.getElementById('traceImportFileSize').textContent = sizeKB + ' KB';
                    infoEl.classList.remove('d-none');
                } else {
                    infoEl.classList.add('d-none');
                }
            });
        }
    });

    /* --- Copy from DOF List wizard JS --- */
    document.addEventListener('DOMContentLoaded', function () {
        var dofCopyStep = 1;
        var dofCopyTotalSteps = 4;

        function setDofCopyStep(step) {
            dofCopyStep = step;
            for (var i = 1; i <= dofCopyTotalSteps; i++) {
                var el = document.getElementById('dofCopyStep' + i);
                if (el) el.classList.toggle('d-none', i !== step);
            }
            document.querySelectorAll('#dofCopyStepIndicator .import-step').forEach(function (el) {
                var s = parseInt(el.dataset.step, 10);
                el.classList.toggle('active', s === step);
                el.classList.toggle('done', s < step);
            });
            var prevBtn = document.getElementById('btnDofCopyPrev');
            var nextBtn = document.getElementById('btnDofCopyNext');
            prevBtn.classList.toggle('d-none', step === 1);
            if (step === dofCopyTotalSteps) {
                nextBtn.innerHTML = '<i class="ri ri-check-line me-1"></i>ยืนยันสำเนา';
            } else {
                nextBtn.innerHTML = '<i class="ri ri-arrow-right-line me-1"></i>ถัดไป';
            }
        }

        var dofCopyModal = document.getElementById('traceCopyFromDofModal');
        if (dofCopyModal) {
            dofCopyModal.addEventListener('show.bs.modal', function () {
                setDofCopyStep(1);
                document.getElementById('dofCopyProgressArea').classList.add('d-none');
                document.getElementById('dofCopySuccessMsg').classList.add('d-none');
                document.getElementById('dofCopyProgressBar').style.width = '0%';
                var nb = document.getElementById('btnDofCopyNext');
                nb.disabled = false;
                nb.onclick = null;
                nb.innerHTML = '<i class="ri ri-arrow-right-line me-1"></i>ถัดไป';
            });
        }

        var dofCopyNext = document.getElementById('btnDofCopyNext');
        if (dofCopyNext) {
            dofCopyNext.addEventListener('click', function () {
                if (dofCopyStep === 1) {
                    var checked = document.querySelectorAll('#dofCopySelectTable .dof-copy-check:checked');
                    if (checked.length === 0) {
                        alert('กรุณาเลือกอย่างน้อย 1 โรงงานก่อนดำเนินการต่อ');
                        return;
                    }
                }
                if (dofCopyStep === dofCopyTotalSteps) {
                    var progressArea = document.getElementById('dofCopyProgressArea');
                    var progressBar = document.getElementById('dofCopyProgressBar');
                    var successMsg = document.getElementById('dofCopySuccessMsg');
                    progressArea.classList.remove('d-none');
                    successMsg.classList.add('d-none');
                    dofCopyNext.disabled = true;
                    var pct = 0;
                    var iv = setInterval(function () {
                        pct += 25;
                        progressBar.style.width = pct + '%';
                        if (pct >= 100) {
                            clearInterval(iv);
                            progressArea.classList.add('d-none');
                            successMsg.classList.remove('d-none');
                            dofCopyNext.disabled = false;
                            dofCopyNext.innerHTML = '<i class="ri ri-close-line me-1"></i>ปิด';
                            dofCopyNext.onclick = function () {
                                bootstrap.Modal.getInstance(document.getElementById('traceCopyFromDofModal')).hide();
                            };
                        }
                    }, 300);
                    return;
                }
                setDofCopyStep(dofCopyStep + 1);
            });
        }

        var dofCopyPrev = document.getElementById('btnDofCopyPrev');
        if (dofCopyPrev) {
            dofCopyPrev.addEventListener('click', function () {
                if (dofCopyStep > 1) setDofCopyStep(dofCopyStep - 1);
            });
        }

        document.querySelectorAll('#dofCopySelectTable .dof-select-all').forEach(function (cb) {
            cb.addEventListener('change', function () {
                document.querySelectorAll('#dofCopySelectTable .dof-copy-check:not(:disabled)').forEach(function (c) {
                    c.checked = cb.checked;
                });
            });
        });
    });
</script>
}

