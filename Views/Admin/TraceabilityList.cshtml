            <div class="col-md-3 col-lg-2">
                <label for="filterProvince" class="form-label">จังหวัด</label>
                <select id="filterProvince" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ชลบุรี">ชลบุรี</option>
                    <option value="ภูเก็ต">ภูเก็ต</option>
                    <option value="ระนอง">ระนอง</option>
                    <option value="สงขลา">สงขลา</option>
                    <option value="สมุทรปราการ">สมุทรปราการ</option>
                    <option value="สมุทรสาคร">สมุทรสาคร</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-3">
                <label for="filterStatus" class="form-label">สถานะการตรวจ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ผ่านการตรวจสอบ">ผ่านการตรวจสอบ</option>
                    <option value="ผ่านแบบมีข้อสังเกต">ผ่านแบบมีข้อสังเกต</option>
                    <option value="รอตรวจซ้ำ">รอตรวจซ้ำ</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterRisk" class="form-label">ระดับความเสี่ยง</label>
                <select id="filterRisk" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ต่ำ">ต่ำ</option>
                    <option value="กลาง">กลาง</option>
                    <option value="สูง">สูง</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearchTrace" class="btn btn-outline-primary btn-square" title="ค้นหา"><i class="ri ri-search-line"></i></button>
                    <button type="button" id="btnResetTrace" class="btn btn-outline-secondary btn-square" title="ล้างค่า"><i class="ri ri-refresh-line"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการโรงงาน Traceability</h5>
            <p class="text-muted small mb-0">แสดงระดับ traceability กลุ่มสินค้า จำนวนผู้ส่งมอบ และผลการตรวจล่าสุด</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#traceDetailModal">
                <i class="ri ri-add-line me-1"></i> เพิ่มข้อมูล
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 trace-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width:56px;">#</th>
                    <th>รหัส Traceability</th>
                    <th>โรงงาน</th>
                    <th>จังหวัด</th>
                    <th>ระดับ Traceability</th>
                    <th>กลุ่มสินค้า</th>
                    <th>ผู้ส่งมอบ</th>
                    <th>ตรวจล่าสุด</th>
                    <th>ความเสี่ยง</th>
                    <th>สถานะ</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="traceTableBody">
                @foreach (var factory in traceabilityFactories)
                {
                    <tr data-trace-code="@factory.TraceCode"
                        data-factory-code="@factory.FactoryCode"
                        data-factory-name="@factory.FactoryName"
                        data-province="@factory.Province"
                        data-product-group="@factory.ProductGroup"
                        data-trace-level="@factory.TraceLevel"
                        data-supplier-count="@factory.SupplierCount"
                        data-risk="@factory.RiskLevel"
                        data-status="@factory.StatusText"
                        data-status-class="@factory.StatusClass"
                        data-search-text="@($"{factory.TraceCode} {factory.FactoryName} {factory.FactoryCode} {factory.ProductGroup} {factory.Province}")">
                        <td class="text-center text-muted">@factory.RowNo</td>
                        <td class="fw-semibold text-primary">@factory.TraceCode</td>
                        <td>
                            <div class="fw-semibold">@factory.FactoryName</div>
                            <div class="text-muted small">@factory.FactoryCode</div>
                        </td>
                        <td>@factory.Province</td>
                        <td>@factory.TraceLevel</td>
                        <td>@factory.ProductGroup</td>
                        <td class="text-center">@factory.SupplierCount ราย</td>
                        <td class="text-center">@factory.LastAuditDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <span class="badge rounded-pill @(factory.RiskLevel == "ต่ำ" ? "bg-label-success" : factory.RiskLevel == "กลาง" ? "bg-label-warning" : "bg-label-danger")">@factory.RiskLevel</span>
                        </td>
                        <td class="text-center"><span class="badge rounded-pill @factory.StatusClass">@factory.StatusText</span></td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-view-trace" data-trace-code="@factory.TraceCode" title="รายละเอียดข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-eye-line text-info"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-edit-trace" data-trace-code="@factory.TraceCode" title="แก้ไขข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-pencil-line text-warning"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="ดูเส้นทางข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-route-line text-secondary"></i></button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="traceTableEmpty" class="d-none">
                    <td colspan="11" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="traceDetailModal" tabindex="-1" aria-labelledby="traceDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="traceDetailModalLabel">
                    <i class="ri ri-links-box-line me-2"></i><span id="traceModalTitle">รายละเอียด Traceability</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="nav-align-top nav-tabs-shadow">
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item"><button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-trace-detail" aria-selected="true"><i class="ri ri-file-list-2-line me-1"></i> ข้อมูลหลัก</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-trace-chain" aria-selected="false"><i class="ri ri-git-branch-line me-1"></i> ขั้นตอนเชื่อมโยง</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-trace-audit" aria-selected="false"><i class="ri ri-survey-line me-1"></i> ประวัติการตรวจ</button></li>
                    </ul>
                    <div class="tab-content">
                        <div id="tab-trace-detail" class="tab-pane fade show active">
                            <div class="accordion accordion-custom-button" id="traceAccordion">
                                <div class="accordion-item active">
                                    <h2 class="accordion-header" id="headingTraceGeneral">
                                        <button type="button" class="accordion-button" data-bs-toggle="collapse" data-bs-target="#collapseTraceGeneral" aria-expanded="true"><i class="icon-base ri ri-information-line me-2"></i> ข้อมูลทั่วไป</button>
                                    </h2>
                                    <div id="collapseTraceGeneral" class="accordion-collapse collapse show">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">รหัส Traceability</span><span class="value" id="detailTraceCode">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">รหัสโรงงาน</span><span class="value" id="detailFactoryCode">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">สถานะ</span><span class="value" id="detailStatus">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">จังหวัด</span><span class="value" id="detailProvince">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">กลุ่มสินค้า</span><span class="value" id="detailProductGroup">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">ระดับความเสี่ยง</span><span class="value" id="detailRisk">-</span></div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item active">
                                    <h2 class="accordion-header" id="headingTraceRegistration">
                                        <button type="button" class="accordion-button" data-bs-toggle="collapse" data-bs-target="#collapseTraceRegistration" aria-expanded="true"><i class="icon-base ri ri-file-shield-2-line me-2"></i> ระดับการเชื่อมโยงและการติดต่อ</button>
                                    </h2>
                                    <div id="collapseTraceRegistration" class="accordion-collapse collapse show">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">ระดับ Traceability</span><span class="value" id="detailTraceLevel">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">จำนวนผู้ส่งมอบ</span><span class="value" id="detailSupplierCount">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">วันที่ลงทะเบียน</span><span class="value" id="detailRegisterDate">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">ทบทวนครั้งถัดไป</span><span class="value" id="detailNextReviewDate">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">โทรศัพท์</span><span class="value" id="detailPhone">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">อีเมล</span><span class="value" id="detailEmail">-</span></div></div>
                                                <div class="col-md-6"><div class="detail-kv"><span class="label">ที่อยู่</span><span class="value" id="detailAddress">-</span></div></div>
                                                <div class="col-md-6"><div class="detail-kv"><span class="label">หมายเหตุ</span><span class="value" id="detailNote">-</span></div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="tab-trace-chain" class="tab-pane fade">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-0 trace-table-compact">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width:56px;">#</th>
                                            <th>ขั้นตอน</th>
                                            <th>เอกสารอ้างอิง</th>
                                            <th>สถานะข้อมูล</th>
                                            <th>ผู้รับผิดชอบ</th>
                                        </tr>
                                    </thead>
                                    <tbody id="chainTableBody"></tbody>
                                </table>
                            </div>
                        </div>
                        <div id="tab-trace-audit" class="tab-pane fade">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-0 trace-table-compact">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width:56px;">#</th>
                                            <th>วันที่ตรวจ</th>
                                            <th>ผลการตรวจ</th>
                                            <th>หน่วยตรวจ</th>
                                            <th>หมายเหตุ</th>
                                        </tr>
                                    </thead>
                                    <tbody id="auditTableBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class="ri ri-close-line me-1"></i> ปิด</button>
                <button type="button" class="btn btn-primary"><i class="ri ri-save-line me-1"></i> บันทึกข้อมูล</button>
            </div>
        </div>
    </div>
</div>