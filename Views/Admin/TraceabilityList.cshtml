        };

        function filterRows() {
            var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
            var province = (document.getElementById('filterProvince').value || '').trim();
            var status = (document.getElementById('filterStatus').value || '').trim();
            var risk = (document.getElementById('filterRisk').value || '').trim();
            var rows = document.querySelectorAll('#traceTableBody tr[data-trace-code]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowText = (row.dataset.searchText || '').toLowerCase();
                var rowProvince = row.dataset.province || '';
                var rowStatus = row.dataset.status || '';
                var rowRisk = row.dataset.risk || '';
                var keywordMatch = !keyword || rowText.includes(keyword);
                var provinceMatch = !province || rowProvince === province;
                var statusMatch = !status || rowStatus === status;
                var riskMatch = !risk || rowRisk === risk;
                var isVisible = keywordMatch && provinceMatch && statusMatch && riskMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('traceTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        function renderRows(items, columns, emptyMessage, rowType) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="' + columns + '" class="text-center text-muted py-3">' + emptyMessage + '</td></tr>';
            }

            if (rowType === 'chain') {
                return items.map(function (item, index) {
                    var statusClass = item.status === 'ครบถ้วน' ? 'bg-label-success' : item.status === 'บางส่วน' ? 'bg-label-warning' : 'bg-label-danger';
                    return '<tr>' +
                        '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                        '<td>' + item.name + '</td>' +
                        '<td>' + item.document + '</td>' +
                        '<td class="text-center"><span class="badge rounded-pill ' + statusClass + '">' + item.status + '</span></td>' +
                        '<td>' + item.owner + '</td>' +
                        '</tr>';
                }).join('');
            }

            return items.map(function (item, index) {
                var resultClass = item.result === 'ผ่าน' ? 'bg-label-success' : item.result === 'ผ่านแบบมีข้อสังเกต' ? 'bg-label-warning' : 'bg-label-danger';
                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.date + '</td>' +
                    '<td class="text-center"><span class="badge rounded-pill ' + resultClass + '">' + item.result + '</span></td>' +
                    '<td>' + item.officer + '</td>' +
                    '<td>' + item.remark + '</td>' +
                    '</tr>';
            }).join('');
        }

        function openTraceDetail(traceCode) {
            var detail = detailsMap[traceCode];
            var row = document.querySelector('#traceTableBody tr[data-trace-code="' + traceCode + '"]');
            if (!detail || !row) {
                return;
            }

            document.getElementById('traceModalTitle').textContent = row.dataset.factoryName;
            document.getElementById('detailTraceCode').textContent = traceCode;
            document.getElementById('detailFactoryCode').textContent = row.dataset.factoryCode;
            document.getElementById('detailProvince').textContent = row.dataset.province;
            document.getElementById('detailProductGroup').textContent = row.dataset.productGroup;
            document.getElementById('detailTraceLevel').textContent = row.dataset.traceLevel;
            document.getElementById('detailSupplierCount').textContent = row.dataset.supplierCount + ' ราย';
            document.getElementById('detailRisk').textContent = row.dataset.risk;
            document.getElementById('detailStatus').innerHTML = '<span class="badge rounded-pill ' + row.dataset.statusClass + '">' + row.dataset.status + '</span>';
            document.getElementById('detailRegisterDate').textContent = detail.registerDate;
            document.getElementById('detailNextReviewDate').textContent = detail.nextReviewDate;
            document.getElementById('detailPhone').textContent = detail.phone;
            document.getElementById('detailEmail').textContent = detail.email;
            document.getElementById('detailAddress').textContent = detail.address;
            document.getElementById('detailNote').textContent = detail.note;
            document.getElementById('chainTableBody').innerHTML = renderRows(detail.chainSteps, 5, 'ไม่พบข้อมูลขั้นตอน traceability', 'chain');
            document.getElementById('auditTableBody').innerHTML = renderRows(detail.audits, 5, 'ไม่พบประวัติการตรวจ', 'audit');

            new bootstrap.Modal(document.getElementById('traceDetailModal')).show();
        }

        document.getElementById('btnSearchTrace').addEventListener('click', filterRows);
        document.getElementById('btnResetTrace').addEventListener('click', function () {
            document.getElementById('filterKeyword').value = '';
            document.getElementById('filterProvince').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterRisk').value = '';
            filterRows();
        });

        document.querySelectorAll('#filterKeyword, #filterProvince, #filterStatus, #filterRisk').forEach(function (element) {
            element.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    filterRows();
                }
            });
            element.addEventListener('change', filterRows);
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        document.querySelectorAll('.btn-view-trace, .btn-edit-trace').forEach(function (button) {
            button.addEventListener('click', function () {
                openTraceDetail(this.dataset.traceCode);
            });
        });
    });
</script>
