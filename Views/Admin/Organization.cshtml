@section PageStyles {
<style>
    .organization-table-compact {
        font-size: 0.78rem;
    }

    .organization-table-compact th,
    .organization-table-compact td {
        padding: 0.45rem 0.5rem;
        vertical-align: middle;
        line-height: 1.3;
        white-space: normal;
        word-break: break-word;
    }

    .organization-table-compact thead th {
        white-space: normal;
        word-break: keep-all;
        overflow-wrap: normal;
    }

    .organization-table-compact .badge {
        font-size: 0.68rem;
    }

    .organization-table-compact .btn.btn-sm {
        --bs-btn-padding-y: 0.14rem;
        --bs-btn-padding-x: 0.3rem;
    }

    .organization-table-compact .btn-icon {
        width: 1.65rem;
        height: 1.65rem;
    }

    .btn-square {
        width: 48px !important;
        height: 48px !important;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .detail-kv {
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        background: var(--bs-paper-bg);
        padding: 0.85rem 1rem;
        height: 100%;
    }

    .detail-kv .label {
        display: block;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        margin-bottom: 0.25rem;
    }

    .detail-kv .value {
        font-weight: 600;
        color: var(--bs-heading-color);
    }

    .role-chips .badge {
        font-size: 0.68rem;
        font-weight: 500;
    }

    .gov-tab-nav .nav-link {
        font-size: 0.82rem;
        padding: 0.45rem 0.9rem;
    }

    .province-chips span {
        font-size: 0.68rem;
    }
</style>
}

