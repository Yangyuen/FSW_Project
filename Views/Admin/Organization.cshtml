            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ค้นหาองค์กร</h5>
            <p class="text-muted small mb-0">ค้นหาจากชื่อองค์กร ประเภท จังหวัด และสถานะการใช้งาน</p>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label for="filterKeyword" class="form-label">คำค้นหา</label>
                <input type="text" id="filterKeyword" class="form-control" placeholder="ชื่อองค์กร, รหัสองค์กร, เลขผู้เสียภาษี" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterType" class="form-label">ประเภทองค์กร</label>
                <select id="filterType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="โรงงานแปรรูป">โรงงานแปรรูป</option>
                    <option value="ผู้ส่งออก">ผู้ส่งออก</option>
                    <option value="แพปลา/ท่าเทียบเรือ">แพปลา/ท่าเทียบเรือ</option>
                    <option value="คลังห้องเย็น">คลังห้องเย็น</option>
                    <option value="ผู้ให้บริการโลจิสติกส์">ผู้ให้บริการโลจิสติกส์</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label for="filterProvince" class="form-label">จังหวัด</label>
                <select id="filterProvince" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="กรุงเทพมหานคร">กรุงเทพมหานคร</option>
                    <option value="ชลบุรี">ชลบุรี</option>
                    <option value="ภูเก็ต">ภูเก็ต</option>
                    <option value="ระนอง">ระนอง</option>
                    <option value="สงขลา">สงขลา</option>
                    <option value="สมุทรสาคร">สมุทรสาคร</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ใช้งาน">ใช้งาน</option>
                    <option value="ระงับชั่วคราว">ระงับชั่วคราว</option>
                    <option value="ยกเลิก">ยกเลิก</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearchOrganizations" class="btn btn-outline-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnResetOrganizations" class="btn btn-outline-secondary btn-square" title="ล้างค่า">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการองค์กร</h5>
            <p class="text-muted small mb-0">แสดงข้อมูลรหัสองค์กร ประเภท สถานะการใช้งาน และการเข้าถึงข้อมูลรายละเอียด</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#organizationDetailModal">
                <i class="ri ri-add-line me-1"></i> เพิ่มองค์กร
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 organization-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width: 56px;">#</th>
                    <th>รหัสองค์กร</th>
                    <th>ชื่อองค์กร</th>
                    <th>ประเภท</th>
                    <th>เลขผู้เสียภาษี</th>
                    <th>จังหวัด</th>
                    <th>สาขา</th>
                    <th>ผู้ติดต่อ</th>
                    <th>สถานะ</th>
                    <th>อัปเดตล่าสุด</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="organizationTableBody">
                @foreach (var organization in organizations)
                {
                    <tr data-code="@organization.OrganizationCode"
                        data-name="@organization.OrganizationName"
                        data-type="@organization.OrganizationType"
                        data-tax-id="@organization.TaxId"
                        data-province="@organization.Province"
                        data-status="@organization.StatusText"
                        data-status-class="@organization.StatusClass"
                        data-search-text="@($"{organization.OrganizationCode} {organization.OrganizationName} {organization.TaxId} {organization.Province}")">
                        <td class="text-center text-muted">@organization.RowNo</td>
                        <td class="fw-semibold text-primary">@organization.OrganizationCode</td>
                        <td>
                            <div class="fw-semibold">@organization.OrganizationName</div>
                            <div class="text-muted small">ข้อมูลตัวอย่างสำหรับ mockup หน้าผู้ดูแลระบบ</div>
                        </td>
                        <td>@organization.OrganizationType</td>
                        <td class="text-center">@organization.TaxId</td>
                        <td>@organization.Province</td>
                        <td class="text-center">@organization.BranchCount</td>
                        <td class="text-center">@organization.ContactCount</td>
                        <td class="text-center">
                            <span class="badge rounded-pill @organization.StatusClass">@organization.StatusText</span>
                        </td>
                        <td class="text-center">@organization.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-view-org" data-code="@organization.OrganizationCode" title="รายละเอียดข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="รายละเอียดข้อมูล">
                                    <i class="ri ri-eye-line text-info"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-edit-org" data-code="@organization.OrganizationCode" title="แก้ไของค์กร" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="แก้ไของค์กร">
                                    <i class="ri ri-pencil-line text-warning"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="จัดการสิทธิ์" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="จัดการสิทธิ์">
                                    <i class="ri ri-shield-user-line text-secondary"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="organizationTableEmpty" class="d-none">
                    <td colspan="11" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="organizationDetailModal" tabindex="-1" aria-labelledby="organizationDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="organizationDetailModalLabel">
                    <i class="ri ri-building-line me-2"></i><span id="orgModalTitle">รายละเอียดองค์กร</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="nav-align-top nav-tabs-shadow">
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item">
                            <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-org-detail" aria-selected="true">
                                <i class="ri ri-file-list-2-line me-1"></i> ข้อมูลองค์กร
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-org-branch" aria-selected="false">
                                <i class="ri ri-git-branch-line me-1"></i> สาขา
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-org-contact" aria-selected="false">
                                <i class="ri ri-contacts-book-3-line me-1"></i> ผู้ติดต่อ
                            </button>
                        </li>
                    </ul>
                    <div class="tab-content">
                        <div id="tab-org-detail" class="tab-pane fade show active">
                            <div class="accordion accordion-custom-button" id="organizationAccordion">
                                <div class="accordion-item active">
                                    <h2 class="accordion-header" id="headingGeneral">
                                        <button type="button" class="accordion-button" data-bs-toggle="collapse" data-bs-target="#collapseGeneral" aria-expanded="true" aria-controls="collapseGeneral">
                                            <i class="icon-base ri ri-information-line me-2"></i>
                                            ข้อมูลทั่วไป
                                        </button>
                                    </h2>
                                    <div id="collapseGeneral" class="accordion-collapse collapse show" aria-labelledby="headingGeneral">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">รหัสองค์กร</span><span class="value" id="detailCode">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">ประเภทองค์กร</span><span class="value" id="detailType">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">สถานะ</span><span class="value" id="detailStatus">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">เลขผู้เสียภาษี</span><span class="value" id="detailTaxId">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">จังหวัด</span><span class="value" id="detailProvince">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">วันที่ขึ้นทะเบียน</span><span class="value" id="detailRegisteredDate">-</span></div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item active">
                                    <h2 class="accordion-header" id="headingRegistration">
                                        <button type="button" class="accordion-button" data-bs-toggle="collapse" data-bs-target="#collapseRegistration" aria-expanded="true" aria-controls="collapseRegistration">
                                            <i class="icon-base ri ri-file-shield-2-line me-2"></i>
                                            การขึ้นทะเบียนและการติดต่อ
                                        </button>
                                    </h2>
                                    <div id="collapseRegistration" class="accordion-collapse collapse show" aria-labelledby="headingRegistration">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">เลขทะเบียน DOF</span><span class="value" id="detailDofNumber">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">เลขใบอนุญาต</span><span class="value" id="detailLicenseNumber">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="label">โทรศัพท์</span><span class="value" id="detailPhone">-</span></div></div>
                                                <div class="col-md-6"><div class="detail-kv"><span class="label">อีเมล</span><span class="value" id="detailEmail">-</span></div></div>
                                                <div class="col-md-6"><div class="detail-kv"><span class="label">ที่อยู่</span><span class="value" id="detailAddress">-</span></div></div>
                                                <div class="col-12"><div class="detail-kv"><span class="label">หมายเหตุสถานะ</span><span class="value" id="detailStatusNote">-</span></div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="tab-org-branch" class="tab-pane fade">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-0 organization-table-compact">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width: 56px;">#</th>
                                            <th>สาขา</th>
                                            <th>จังหวัด</th>
                                            <th>สถานะ</th>
                                        </tr>
                                    </thead>
                                    <tbody id="branchTableBody"></tbody>
                                </table>
                            </div>
                        </div>
                        <div id="tab-org-contact" class="tab-pane fade">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-0 organization-table-compact">
                                    <thead class="text-center">
                                        <tr>
                                            <th style="width: 56px;">#</th>
                                            <th>ชื่อผู้ติดต่อ</th>
                                            <th>บทบาท</th>
                                            <th>โทรศัพท์</th>
                                            <th>อีเมล</th>
                                        </tr>
                                    </thead>
                                    <tbody id="contactTableBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i> ปิด
                </button>
                <button type="button" class="btn btn-primary">
                    <i class="ri ri-save-line me-1"></i> บันทึกข้อมูล
                </button>
            </div>
        </div>
    </div>
</div>