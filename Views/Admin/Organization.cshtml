        function filterRows() {
            var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
            var type = (document.getElementById('filterType').value || '').trim();
            var province = (document.getElementById('filterProvince').value || '').trim();
            var status = (document.getElementById('filterStatus').value || '').trim();
            var rows = document.querySelectorAll('#organizationTableBody tr[data-code]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowText = (row.dataset.searchText || '').toLowerCase();
                var rowType = row.dataset.type || '';
                var rowProvince = row.dataset.province || '';
                var rowStatus = row.dataset.status || '';
                var keywordMatch = !keyword || rowText.includes(keyword);
                var typeMatch = !type || rowType === type;
                var provinceMatch = !province || rowProvince === province;
                var statusMatch = !status || rowStatus === status;
                var isVisible = keywordMatch && typeMatch && provinceMatch && statusMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('organizationTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        function renderSimpleRows(items, emptyMessage, columns) {
            if (!items || items.length === 0) {
                return '<tr><td colspan="' + columns + '" class="text-center text-muted py-3">' + emptyMessage + '</td></tr>';
            }

            return items.map(function (item, index) {
                if (columns === 4) {
                    return '<tr>' +
                        '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                        '<td>' + item.name + '<div class="text-muted small">' + item.code + '</div></td>' +
                        '<td>' + item.province + '</td>' +
                        '<td class="text-center"><span class="badge rounded-pill ' + (item.status === 'ใช้งาน' ? 'bg-label-success' : item.status === 'ระงับชั่วคราว' ? 'bg-label-warning' : 'bg-label-danger') + '">' + item.status + '</span></td>' +
                        '</tr>';
                }

                return '<tr>' +
                    '<td class="text-center text-muted small">' + (index + 1) + '</td>' +
                    '<td>' + item.name + '</td>' +
                    '<td>' + item.role + '</td>' +
                    '<td>' + item.phone + '</td>' +
                    '<td>' + item.email + '</td>' +
                    '</tr>';
            }).join('');
        }

        function openOrganizationDetail(code) {
            var detail = detailsMap[code];
            if (!detail) {
                return;
            }

            var trigger = document.querySelector('[data-code="' + code + '"] .btn-view-org') || document.querySelector('[data-code="' + code + '"] .btn-edit-org');
            var row = trigger ? trigger.closest('tr') : null;
            if (!row) {
                return;
            }

            document.getElementById('orgModalTitle').textContent = row.dataset.name;
            document.getElementById('detailCode').textContent = code;
            document.getElementById('detailType').textContent = row.dataset.type;
            document.getElementById('detailTaxId').textContent = row.dataset.taxId;
            document.getElementById('detailProvince').textContent = row.dataset.province;
            document.getElementById('detailStatus').innerHTML = '<span class="badge rounded-pill ' + row.dataset.statusClass + '">' + row.dataset.status + '</span>';
            document.getElementById('detailRegisteredDate').textContent = detail.registeredDate;
            document.getElementById('detailDofNumber').textContent = detail.dofNumber;
            document.getElementById('detailLicenseNumber').textContent = detail.licenseNumber;
            document.getElementById('detailAddress').textContent = detail.address;
            document.getElementById('detailEmail').textContent = detail.email;
            document.getElementById('detailPhone').textContent = detail.phone;
            document.getElementById('detailStatusNote').textContent = detail.statusNote;
            document.getElementById('branchTableBody').innerHTML = renderSimpleRows(detail.branches, 'ไม่พบข้อมูลสาขา', 4);
            document.getElementById('contactTableBody').innerHTML = renderSimpleRows(detail.contacts, 'ไม่พบข้อมูลผู้ติดต่อ', 5);

            new bootstrap.Modal(document.getElementById('organizationDetailModal')).show();
        }

        document.getElementById('btnSearchOrganizations').addEventListener('click', filterRows);
        document.getElementById('btnResetOrganizations').addEventListener('click', function () {
            document.getElementById('filterKeyword').value = '';
            document.getElementById('filterType').value = '';
            document.getElementById('filterProvince').value = '';
            document.getElementById('filterStatus').value = '';
            filterRows();
        });

        document.querySelectorAll('#filterKeyword, #filterType, #filterProvince, #filterStatus').forEach(function (element) {
            element.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    filterRows();
                }
            });
            element.addEventListener('change', filterRows);
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        document.querySelectorAll('.btn-view-org, .btn-edit-org').forEach(function (button) {
            button.addEventListener('click', function () {
                openOrganizationDetail(this.dataset.code);
            });
        });
